<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Ufp.General.ABEWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Ufp.General"
                        xmlns:maskedInput="clr-namespace:Telerik.Windows.Controls.MaskedInput;assembly=Telerik.Windows.Controls.Input"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli anagrafica unica"
                        Width="1200"
                        Height="700"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">

    <telerik:RadBusyIndicator x:Name="bsyGrid"
                              Grid.Row="4"
                              BusyContent="Caricamento dati in corso..."
                              FontSize="40"
                              Foreground="{DynamicResource VulpesXSecondBrush}"
                              IsBusy="False"
                              OverlayStyle="{StaticResource WaitOverlayStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <telerik:RadTabControl Grid.Row="0"
                                   VerticalAlignment="Stretch"
                                   BorderThickness="0"
                                   DisplayMemberPath="Content"
                                   DropDownDisplayMode="Visible"
                                   ScrollMode="Viewport">
                <telerik:RadTabItem DropDownContent="DATI ANAGRAFICI" Header="DATI ANAGRAFICI">
                    <telerik:RadTabItem.Content>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <Grid Margin="0,10,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="8*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Codice" />
                                <StackPanel Grid.Row="0"
                                            Grid.Column="1"
                                            HorizontalAlignment="Left"
                                            Orientation="Horizontal">
                                    <telerik:RadNumericUpDown Width="200"
                                                              Margin="5,2,2,2"
                                                              HorizontalAlignment="Left"
                                                              IsEnabled="{Binding IsInsert}"
                                                              Minimum="1"
                                                              NumberDecimalDigits="0"
                                                              Value="{Binding Data.abecod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True}" />
                                    <Button x:Name="cmdFreeIDs"
                                            Margin="5"
                                            BorderBrush="MediumVioletRed"
                                            BorderThickness="0,0,5,0"
                                            Click="cmdFreeIDs_Click"
                                            Content="Trova codici liberi &gt;"
                                            IsEnabled="{Binding IsInsert}" />
                                </StackPanel>
                                <StackPanel Grid.Row="0"
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource VulpesXLabel}" Text="Tipo" />
                                    <telerik:RadComboBox Width="450"
                                                         Margin="5,2,15,2"
                                                         HorizontalAlignment="Stretch"
                                                         HorizontalContentAlignment="Left"
                                                         DisplayMemberPath="Description"
                                                         IsEditable="True"
                                                         IsReadOnly="True"
                                                         ItemsSource="{Binding EntityTypes}"
                                                         SelectedValue="{Binding Data.abetpo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         SelectedValuePath="ID" />
                                </StackPanel>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Tipo societa'" />
                                <StackPanel Grid.Row="1"
                                            Grid.Column="1"
                                            HorizontalAlignment="Left"
                                            Orientation="Horizontal">
                                    <telerik:RadAutoCompleteBox x:Name="acCompanyType"
                                                                MinWidth="500"
                                                                Margin="5,2,15,2"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Center"
                                                                DisplayMemberPath="FullDescriptionSearchable"
                                                                GotFocus="ac_GotFocus"
                                                                ItemsSource="{Binding Data.CompanyTypes}"
                                                                LostFocus="ac_LostFocus"
                                                                NoResultsContent="Nessun tipo societa' trovato"
                                                                SelectedItem="{Binding Data.CompanyType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                SelectionMode="Single"
                                                                TextSearchMode="Contains"
                                                                TextSearchPath="FullDescriptionSearchable"
                                                                WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                </StackPanel>
                                <StackPanel Grid.Row="1"
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource VulpesXLabel}" Text="Utilizzo" />
                                    <telerik:RadComboBox x:Name="cmbEntityUserType"
                                                         Width="450"
                                                         Margin="5,2,15,2"
                                                         HorizontalAlignment="Stretch"
                                                         HorizontalContentAlignment="Left"
                                                         DisplayMemberPath="Description"
                                                         IsEditable="True"
                                                         IsReadOnly="True"
                                                         ItemsSource="{Binding EntityUseTypes}"
                                                         SelectedValue="{Binding Data.abecfe}"
                                                         SelectedValuePath="ID"
                                                         SelectionChanged="cmbEntityUserType_SelectionChanged" />
                                </StackPanel>

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Ragione sociale" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         MaxLength="255"
                                         Text="{Binding Data.abers1}" />
                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Ragione sociale aggiuntiva" />
                                <TextBox Grid.Row="3"
                                         Grid.Column="1"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         MaxLength="255"
                                         Text="{Binding Data.abers2}" />

                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Codice ISO" />
                                <telerik:RadAutoCompleteBox x:Name="acISO"
                                                            Grid.Row="4"
                                                            Grid.Column="1"
                                                            Margin="5,2,15,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.ISOList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun codice trovato"
                                                            SelectedItem="{Binding Data.ISO, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                                <TextBlock Grid.Row="5"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Partita IVA" />
                                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                                    <TextBox Width="200"
                                             Margin="5,0,15,0"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Center"
                                             MaxLength="12"
                                             Text="{Binding Data.abepiv}" />
                                    <TextBlock Style="{StaticResource VulpesXLabel}" Text="Codice fiscale" />
                                    <TextBox Width="200"
                                             Margin="5,0,15,0"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Center"
                                             MaxLength="16"
                                             Text="{Binding Data.abecfi}" />
                                </StackPanel>
                                <TextBlock Grid.Row="7"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Indirizzo" />
                                <TextBox Grid.Row="7"
                                         Grid.Column="1"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         MaxLength="255"
                                         Text="{Binding Data.abeind}" />

                                <TextBlock Grid.Row="8"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Comune" />
                                <telerik:RadAutoSuggestBox x:Name="acCity"
                                                           Grid.Row="8"
                                                           Grid.Column="1"
                                                           Margin="5,2,15,2"
                                                           HorizontalAlignment="Stretch"
                                                           VerticalAlignment="Center"
                                                           DisplayMemberPath="FullDescriptionSearchable"
                                                           ItemsSource="{Binding Data.Cities}"
                                                           NoResultsContent="Nessun comune trovato"
                                                           Text="{Binding Data.abeloc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           TextChanged="acCity_TextChanged"
                                                           TextMemberPath="FullDescriptionSearchable"
                                                           WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                                <TextBlock Grid.Row="9"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Provincia" />
                                <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal">
                                    <telerik:RadAutoCompleteBox x:Name="acState"
                                                                Width="200"
                                                                Margin="5,2,15,2"
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Center"
                                                                DisplayMemberPath="FullDescriptionSearchable"
                                                                GotFocus="ac_GotFocus"
                                                                ItemsSource="{Binding Data.States}"
                                                                LostFocus="ac_LostFocus"
                                                                NoResultsContent="Nessuna provincia trovata"
                                                                SelectedItem="{Binding Data.State, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                SelectionMode="Single"
                                                                TextSearchMode="Contains"
                                                                TextSearchPath="FullDescriptionSearchable"
                                                                WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                    <TextBlock Style="{StaticResource VulpesXLabel}" Text="C.a.p." />
                                    <telerik:RadMaskedNumericInput Width="150"
                                                                   Margin="5,2,15,2"
                                                                   HorizontalAlignment="Left"
                                                                   maskedInput:MaskedInputExtensions.AllowNull="True"
                                                                   maskedInput:MaskedInputExtensions.MaxTextLength="5"
                                                                   maskedInput:MaskedInputExtensions.Maximum="99999"
                                                                   AllowSkipPlaceholders="True"
                                                                   AutoFillNumberGroupSeparators="False"
                                                                   AutoFillZeros="False"
                                                                   FormatString="00000"
                                                                   InputBehavior="Insert"
                                                                   Mask="#####"
                                                                   SelectionOnFocus="SelectAll"
                                                                   SpinMode="Position"
                                                                   TextMode="MaskedText"
                                                                   Value="{Binding Data.abecap, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <TextBlock Grid.Row="10"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Nazione" />
                                <telerik:RadAutoCompleteBox x:Name="acCountry"
                                                            Grid.Row="10"
                                                            Grid.Column="1"
                                                            Margin="5,2,15,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.Countries}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessuna nazione trovata"
                                                            SelectedItem="{Binding Data.Country, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                                <TextBlock Grid.Row="11"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Sede legale" />
                                <telerik:RadToggleSwitchButton Grid.Row="11"
                                                               Grid.Column="1"
                                                               Margin="5,2,15,2"
                                                               CheckedContent="Sì"
                                                               IsChecked="{Binding Data.abetipoBool}"
                                                               UncheckedContent="No" />
                            </Grid>
                        </ScrollViewer>
                    </telerik:RadTabItem.Content>
                </telerik:RadTabItem>
                <telerik:RadTabItem DropDownContent="DATI FISCALI" Header="DATI FISCALI">
                    <telerik:RadTabItem.Content>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <Grid Margin="0,10,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="8*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Indirizzo" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         MaxLength="35"
                                         Text="{Binding Data.abeinl}" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Comune" />
                                <telerik:RadAutoCompleteBox x:Name="acLegalCity"
                                                            Grid.Row="2"
                                                            Grid.Column="1"
                                                            Margin="5,2,15,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.Cities}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun comune trovato"
                                                            SelectedItem="{Binding Data.LegalCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Provincia" />
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                    <telerik:RadAutoCompleteBox x:Name="acLegalState"
                                                                Width="200"
                                                                Margin="5,2,15,2"
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Center"
                                                                DisplayMemberPath="FullDescriptionSearchable"
                                                                GotFocus="ac_GotFocus"
                                                                ItemsSource="{Binding Data.States}"
                                                                LostFocus="ac_LostFocus"
                                                                NoResultsContent="Nessuna provincia trovata"
                                                                SelectedItem="{Binding Data.LegalState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                SelectionMode="Single"
                                                                TextSearchMode="Contains"
                                                                TextSearchPath="FullDescriptionSearchable"
                                                                WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                    <TextBlock Style="{StaticResource VulpesXLabel}" Text="C.a.p." />
                                    <telerik:RadMaskedNumericInput Width="150"
                                                                   Margin="5,2,15,2"
                                                                   HorizontalAlignment="Left"
                                                                   maskedInput:MaskedInputExtensions.AllowNull="True"
                                                                   maskedInput:MaskedInputExtensions.MaxTextLength="5"
                                                                   maskedInput:MaskedInputExtensions.Maximum="99999"
                                                                   AllowSkipPlaceholders="True"
                                                                   AutoFillNumberGroupSeparators="False"
                                                                   AutoFillZeros="False"
                                                                   FormatString="00000"
                                                                   InputBehavior="Insert"
                                                                   Mask="#####"
                                                                   SelectionOnFocus="SelectAll"
                                                                   SpinMode="Position"
                                                                   TextMode="MaskedText"
                                                                   Value="{Binding Data.abecal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <TextBlock Grid.Row="5"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Codice CCIIA" />
                                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                                    <TextBox Width="150"
                                             Margin="5,0,15,0"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Center"
                                             MaxLength="11"
                                             Text="{Binding Data.abeccc}" />
                                    <TextBlock Style="{StaticResource VulpesXLabel}" Text="Tribunale" />
                                    <TextBox Width="150"
                                             Margin="5,0,15,0"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Center"
                                             MaxLength="11"
                                             Text="{Binding Data.abetri}" />
                                </StackPanel>

                                <TextBlock Grid.Row="7"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Data di nascita" />
                                <telerik:RadDateTimePicker Grid.Row="7"
                                                           Grid.Column="1"
                                                           Width="200"
                                                           Margin="5,0,15,0"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data di nascita"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           SelectedValue="{Binding Data.abedna}" />

                                <TextBlock Grid.Row="8"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Luogo di nascita" />
                                <telerik:RadAutoCompleteBox x:Name="acBirthCity"
                                                            Grid.Row="8"
                                                            Grid.Column="1"
                                                            Margin="5,2,15,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.Cities}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun comune trovato"
                                                            SelectedItem="{Binding Data.BirthCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                                <TextBlock Grid.Row="9"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Provincia di nascita" />
                                <TextBox Grid.Row="9"
                                         Grid.Column="1"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         Text="{Binding Data.abepna}" />
                                <TextBlock Grid.Row="10"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Sesso" />
                                <telerik:RadComboBox Grid.Row="10"
                                                     Grid.Column="1"
                                                     Width="200"
                                                     Margin="5,2,15,2"
                                                     HorizontalAlignment="Left"
                                                     HorizontalContentAlignment="Left"
                                                     DisplayMemberPath="Description"
                                                     IsEditable="True"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding Sexes}"
                                                     SelectedValue="{Binding Data.abesex}"
                                                     SelectedValuePath="ID" />

                                <TextBlock Grid.Row="11"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Anno iscrizione" />
                                <telerik:RadMaskedNumericInput Grid.Row="11"
                                                               Grid.Column="1"
                                                               Width="80"
                                                               Margin="5,2,15,2"
                                                               HorizontalAlignment="Left"
                                                               HorizontalContentAlignment="Center"
                                                               maskedInput:MaskedInputExtensions.AllowNull="True"
                                                               maskedInput:MaskedInputExtensions.MaxTextLength="4"
                                                               maskedInput:MaskedInputExtensions.Maximum="9999"
                                                               AllowSkipPlaceholders="True"
                                                               AutoFillNumberGroupSeparators="False"
                                                               AutoFillZeros="False"
                                                               FormatString="0000"
                                                               InputBehavior="Insert"
                                                               Mask="####"
                                                               SelectionOnFocus="SelectAll"
                                                               SpinMode="None"
                                                               TextMode="MaskedText"
                                                               Value="{Binding Data.abeais, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </ScrollViewer>
                    </telerik:RadTabItem.Content>
                </telerik:RadTabItem>
                <telerik:RadTabItem DropDownContent="DATI CLIENTE" Header="DATI CLIENTE" Visibility="{Binding Data.CanCustomerVisibility, Converter={StaticResource boolToVisibilityConverter}}">
                    <telerik:RadTabItem.Content>
                        <telerik:RadTabControl VerticalAlignment="Stretch"
                                               BorderThickness="0"
                                               DisplayMemberPath="Content"
                                               DropDownDisplayMode="Visible"
                                               ScrollMode="Viewport">
                            <telerik:RadTabItem DropDownContent="DATI AMMINISTRATIVI (I)" Header="DATI AMMINISTRATIVI (I)" Visibility="{Binding Data.CanCustomerVisibility}">
                                <telerik:RadTabItem.Content>
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                        <Grid Margin="0,10,10,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70*" />
                                                <ColumnDefinition Width="30*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="35" />
                                                    <RowDefinition Height="35" />
                                                    <RowDefinition Height="35" />
                                                    <RowDefinition Height="35" />
                                                    <RowDefinition Height="10" />
                                                    <RowDefinition Height="35" />
                                                    <RowDefinition Height="10" />
                                                    <RowDefinition Height="35" />
                                                    <RowDefinition Height="35" />
                                                    <RowDefinition Height="10" />
                                                    <RowDefinition Height="35" />
                                                    <RowDefinition Height="35" />
                                                    <RowDefinition Height="35" />
                                                    <RowDefinition Height="35" />
                                                    <RowDefinition Height="35" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="8*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Row="0"
                                                           Grid.Column="0"
                                                           Style="{StaticResource VulpesXLabel}"
                                                           Text="Conto contabile" />
                                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                                    <telerik:RadAutoCompleteBox x:Name="acCustomerGroup"
                                                                                Width="400"
                                                                                Margin="5,2,5,2"
                                                                                HorizontalAlignment="Stretch"
                                                                                VerticalAlignment="Center"
                                                                                DisplayMemberPath="FullDescriptionSearchable"
                                                                                GotFocus="ac_GotFocus"
                                                                                ItemsSource="{Binding CustomerData.GroupsList}"
                                                                                LostFocus="ac_LostFocus"
                                                                                NoResultsContent="Nessun gruppo trovato"
                                                                                SelectedItem="{Binding CustomerData.SelectedGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                SelectionMode="Single"
                                                                                TextSearchMode="Contains"
                                                                                TextSearchPath="FullDescriptionSearchable"
                                                                                WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                                    <telerik:RadAutoCompleteBox x:Name="acCustomerAccount"
                                                                                Width="400"
                                                                                Margin="5,2,5,2"
                                                                                HorizontalAlignment="Stretch"
                                                                                VerticalAlignment="Center"
                                                                                DisplayMemberPath="FullDescriptionSearchable"
                                                                                GotFocus="ac_GotFocus"
                                                                                ItemsSource="{Binding CustomerData.AccountsList}"
                                                                                LostFocus="ac_LostFocus"
                                                                                NoResultsContent="Nessun conto trovato"
                                                                                SelectedItem="{Binding CustomerData.SelectedAccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                SelectionMode="Single"
                                                                                TextSearchMode="Contains"
                                                                                TextSearchPath="FullDescriptionSearchable"
                                                                                WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                                </StackPanel>

                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="0"
                                                           Style="{StaticResource VulpesXLabel}"
                                                           Text="Banca di terzi" />
                                                <telerik:RadAutoCompleteBox x:Name="acCustomerBank"
                                                                            Grid.Row="1"
                                                                            Grid.Column="1"
                                                                            Margin="5,2,5,2"
                                                                            HorizontalAlignment="Stretch"
                                                                            VerticalAlignment="Center"
                                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                                            GotFocus="ac_GotFocus"
                                                                            ItemsSource="{Binding Banks}"
                                                                            LostFocus="ac_LostFocus"
                                                                            NoResultsContent="Nessuna banca trovata"
