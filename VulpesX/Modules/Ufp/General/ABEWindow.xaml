                                                     RowEditEnded="rgvCounterpartsRows_RowEditEnded"
                                                     RowIndicatorVisibility="Collapsed"
                                                     RowValidated="rgvCounterpartsRows_RowValidated"
                                                     RowValidating="rgvCounterpartsRows_RowValidating"
                                                     SearchMode="MatchAnyTerm"
                                                     ShowGroupPanel="False"
                                                     ShowSearchPanel="False"
                                                     ValidatesOnDataErrors="InEditMode">
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding GroupDescription}" Header="Gruppo">
                                            <telerik:GridViewDataColumn.CellEditTemplate>
                                                <DataTemplate>
                                                    <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                                GotFocus="ac_GotFocus"
                                                                                ItemsSource="{Binding GroupsList}"
                                                                                NoResultsContent="Nessun gruppo trovato"
                                                                                SelectedItem="{Binding SelectedGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                SelectionMode="Single"
                                                                                TextSearchMode="Contains"
                                                                                TextSearchPath="FullDescriptionSearchable" />
                                                </DataTemplate>
                                            </telerik:GridViewDataColumn.CellEditTemplate>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding AccountDescription}" Header="Conto">
                                            <telerik:GridViewDataColumn.CellEditTemplate>
                                                <DataTemplate>
                                                    <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                                GotFocus="ac_GotFocus"
                                                                                ItemsSource="{Binding AccountsList}"
                                                                                NoResultsContent="Nessun conto trovato"
                                                                                SelectedItem="{Binding SelectedAccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                SelectionMode="Single"
                                                                                TextSearchMode="Contains"
                                                                                TextSearchPath="FullDescriptionSearchable" />
                                                </DataTemplate>
                                            </telerik:GridViewDataColumn.CellEditTemplate>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="400" DataMemberBinding="{Binding SubaccountDescription}" Header="Sottoconto">
                                            <telerik:GridViewDataColumn.CellEditTemplate>
                                                <DataTemplate>
                                                    <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                                GotFocus="ac_GotFocus"
                                                                                ItemsSource="{Binding SubaccountsList}"
                                                                                NoResultsContent="Nessun sottoconto trovato"
                                                                                SelectedItem="{Binding SelectedSubaccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                SelectionMode="Single"
                                                                                TextSearchMode="Contains"
                                                                                TextSearchPath="FullDescriptionSearchable" />
                                                </DataTemplate>
                                            </telerik:GridViewDataColumn.CellEditTemplate>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewComboBoxColumn Width="70"
                                                                        DataMemberBinding="{Binding cfsegn}"
                                                                        DisplayMemberPath="Description"
                                                                        Header="Segno"
                                                                        IsLightweightModeEnabled="True"
                                                                        ItemsSource="{Binding Signs}"
                                                                        SelectedValueMemberPath="ID" />
                                        <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding CausalDescription}" Header="Causale">
                                            <telerik:GridViewDataColumn.CellEditTemplate>
                                                <DataTemplate>
                                                    <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                                GotFocus="ac_GotFocus"
                                                                                ItemsSource="{Binding CausalsList}"
                                                                                NoResultsContent="Nessuna causale contabile trovata"
                                                                                SelectedItem="{Binding SelectedCausal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                SelectionMode="Single"
                                                                                TextSearchMode="Contains"
                                                                                TextSearchPath="FullDescriptionSearchable" />
                                                </DataTemplate>
                                            </telerik:GridViewDataColumn.CellEditTemplate>
                                        </telerik:GridViewDataColumn>
                                    </telerik:RadGridView.Columns>
                                </telerik:RadGridView>
                            </Grid>
                        </ScrollViewer>
                    </telerik:RadTabItem.Content>
                </telerik:RadTabItem>
                <telerik:RadTabItem DropDownContent="CERTIFICATI" Header="CERTIFICATI" Visibility="{Binding Data.CanCustomerVisibility, Converter={StaticResource boolToVisibilityConverter}}">
                    <telerik:RadTabItem.Content>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <Grid Margin="0,10,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Vertical">
                                    <Grid Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="8*" />
                                            <ColumnDefinition Width="35" />
                                            <ColumnDefinition Width="35" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="11"
                                                   Grid.Column="0"
                                                   Style="{StaticResource VulpesXLabel}"
                                                   Text="Logo" />

                                        <TextBlock Grid.Column="1" Text="{Binding Certificate.clilogonome}" />

                                        <telerik:RadPathButton x:Name="btnCertificateUpload"
                                                               Grid.Column="2"
                                                               Click="btnCertificateUpload_Click"
                                                               Cursor="Hand"
                                                               FontSize="14"
                                                               Foreground="LawnGreen"
                                                               PathGeometry="{DynamicResource UpPath}"
                                                               ToolTip="Upload" />

                                        <telerik:RadPathButton x:Name="btnCertificateOpen"
                                                               Grid.Column="3"
                                                               Click="btnCertificateOpen_Click"
                                                               Cursor="Hand"
                                                               FontSize="14"
                                                               Foreground="LawnGreen"
                                                               PathGeometry="{DynamicResource OpenPath}"
                                                               ToolTip="Apri" />
                                    </Grid>

                                    <Grid Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="8*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="11"
                                                   Grid.Column="0"
                                                   Style="{StaticResource VulpesXLabel}"
                                                   Text="Obbligo controllo di tutti i pezzi" />
                                        <telerik:RadToggleSwitchButton Grid.Row="11"
                                                                       Grid.Column="1"
                                                                       Margin="5,2,15,2"
                                                                       CheckedContent="Sì"
                                                                       IsChecked="{Binding Certificate.anapeobbBool}"
                                                                       UncheckedContent="No" />
                                    </Grid>


                                </StackPanel>


                                <telerik:RadGridView Name="rgvCertificates"
                                                     Grid.Row="1"
                                                     Margin="0"
                                                     AddingNewDataItem="rgvCertificates_AddingNewDataItem"
                                                     AutoGenerateColumns="False"
                                                     CanUserFreezeColumns="False"
                                                     CanUserInsertRows="True"
                                                     IsSearchingDeferred="True"
                                                     ItemsSource="{Binding Certificates}"
                                                     NewRowPosition="Top"
                                                     RowDetailsVisibilityMode="VisibleWhenSelected"
                                                     RowEditEnded="rgvCertificates_RowEditEnded"
                                                     RowIndicatorVisibility="Collapsed"
                                                     RowValidated="rgvCertificates_RowValidated"
                                                     RowValidating="rgvCertificates_RowValidating"
                                                     SearchMode="MatchAnyTerm"
                                                     ShowGroupPanel="False"
                                                     ShowSearchPanel="False"
                                                     ValidatesOnDataErrors="InEditMode">
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding anadescer}" Header="Gruppo" />

                                        <telerik:GridViewComboBoxColumn Width="300"
                                                                        DataMemberBinding="{Binding anaper}"
                                                                        DisplayMemberPath="Description"
                                                                        Header="Tipo"
                                                                        IsLightweightModeEnabled="True"
                                                                        ItemsSource="{Binding CertificateTypes}"
                                                                        SelectedValueMemberPath="ID" />
                                    </telerik:RadGridView.Columns>
                                </telerik:RadGridView>
                            </Grid>
                        </ScrollViewer>
                    </telerik:RadTabItem.Content>
                </telerik:RadTabItem>

                <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                    <telerik:RadTabItem.Content>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <Grid Margin="0,10,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="7*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Inserito il" />
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.AddedText}" />
                                    <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.AddedUserText}" />
                                </StackPanel>

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Ultimo aggiornamento il" />
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.UpdatedText}" />
                                    <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.UpdatedUserText}" />
                                </StackPanel>

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Annullato il" />
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.CanceledText}" />
                                    <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.CanceledUserText}" />
                                </StackPanel>

                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Motivo annullamento" />
                                <TextBlock Grid.Row="4"
                                           Grid.Column="1"
                                           Margin="5,2,2,2"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.canceledNote}" />
                            </Grid>
                        </ScrollViewer>
                    </telerik:RadTabItem.Content>
                </telerik:RadTabItem>
            </telerik:RadTabControl>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="50*" />
                </Grid.ColumnDefinitions>

                <Grid Margin="0,10,10,10" Background="{DynamicResource VulpesXBlueBrush}" Visibility="{Binding Data.IsTop, Converter={StaticResource boolToVisibilityConverter}}">
                    <TextBlock Margin="5,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="22"
                               Text="CLIENTE TOP" />
                </Grid>
                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
                    <Button Name="cmdSave"
                            Click="cmdSave_Click"
                            Content="SALVA"
                            Style="{StaticResource VulpesXConfirmButton}" />
                </StackPanel>
            </Grid>

        </Grid>
    </telerik:RadBusyIndicator>
</sc:FluentDefaultWindow>
