<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Ufp.General.NOTECLI1Window"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Ufp.General"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli nota cliente"
                        Width="800"
                        Height="700"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,15,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="35" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="35" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="7*" />
            </Grid.ColumnDefinitions>


            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Tipo nota" />
            <telerik:RadComboBox Grid.Row="0"
                                 Grid.Column="1"
                                 Width="200"
                                 Margin="5,2,15,2"
                                 HorizontalAlignment="Left"
                                 HorizontalContentAlignment="Left"
                                 DisplayMemberPath="Description"
                                 IsEditable="True"
                                 IsReadOnly="True"
                                 ItemsSource="{Binding NoteTypes}"
                                 SelectedValue="{Binding Data.NOTETI, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 SelectedValuePath="ID" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       VerticalAlignment="Top"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Nota" />
            <TextBox Grid.Row="1"
                     Grid.Column="1"
                     MaxHeight="200"
                     Margin="5,0,15,15"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"
                     VerticalContentAlignment="Top"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     MaxLength="255"
                     MaxLines="21"
                     Text="{Binding Data.notdes}"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />

            <StackPanel Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Orientation="Vertical"
                        Visibility="{Binding Data.MarkDetailVisibility, Converter={StaticResource boolToVisibilityConverter}}">

                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="7*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource VulpesXLabel}" Text="Tipo marcatura" />
                    <telerik:RadComboBox Grid.Column="1"
                                         Width="200"
                                         Margin="5,2,15,2"
                                         HorizontalAlignment="Left"
                                         HorizontalContentAlignment="Left"
                                         DisplayMemberPath="Description"
                                         IsEditable="True"
                                         IsReadOnly="True"
                                         ItemsSource="{Binding MarkTypes}"
                                         SelectedValue="{Binding Data.NOTTIP}"
                                         SelectedValuePath="ID" />
                </Grid>

                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="7*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Style="{StaticResource VulpesXLabel}"
                               Text="Disegno" />
                    <telerik:RadToggleSwitchButton Grid.Row="2"
                                                   Grid.Column="1"
                                                   Margin="5,2,15,2"
                                                   CheckedContent="Sì"
                                                   IsChecked="{Binding Data.NOTDISBool}"
                                                   UncheckedContent="No" />
                </Grid>



                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="7*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Style="{StaticResource VulpesXLabel}"
                               Text="Riferimenti ordine" />
                    <telerik:RadToggleSwitchButton Grid.Row="3"
                                                   Grid.Column="1"
                                                   Margin="5,2,15,2"
                                                   CheckedContent="Sì"
                                                   IsChecked="{Binding Data.NOTRIFBool}"
                                                   UncheckedContent="No" />
                </Grid>

                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="7*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Style="{StaticResource VulpesXLabel}"
                               Text="Testo fisso" />
                    <TextBox Grid.Row="4"
                             Grid.Column="1"
                             Margin="5,0,15,0"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Center"
                             MaxLength="255"
                             Text="{Binding Data.NOTTESTO}" />
                </Grid>



                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="7*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="5"
                               Grid.Column="0"
                               Style="{StaticResource VulpesXLabel}"
                               Text="Logo" />
                    <TextBox Grid.Row="5"
                             Grid.Column="1"
                             Margin="5,0,15,0"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Center"
                             MaxLength="255"
                             Text="{Binding Data.NOTLOGO}" />
                </Grid>

                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="7*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="7"
                               Grid.Column="0"
                               VerticalAlignment="Top"
                               Style="{StaticResource VulpesXLabel}"
                               Text="Note supplementari" />
                    <TextBox Grid.Row="7"
                             Grid.Column="1"
                             Height="130"
                             Margin="5,0,15,15"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"
                             VerticalContentAlignment="Top"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             MaxLength="255"
                             MaxLines="21"
                             Text="{Binding Data.NOTSUPP}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="3"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                <Button Name="cmdCancel"
                        Width="200"
                        Margin="2"
                        BorderBrush="Gold"
                        BorderThickness="5,0,0,0"
                        Click="cmdCancel_Click"
                        Content="USCIRE"
                        FontSize="10" />
                <Button Name="cmdSave"
                        Width="200"
                        Margin="2"
                        BorderBrush="ForestGreen"
                        BorderThickness="5,0,0,0"
                        Click="cmdSave_Click"
                        Content="SALVA"
                        FontSize="10" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</sc:FluentDefaultWindow>
