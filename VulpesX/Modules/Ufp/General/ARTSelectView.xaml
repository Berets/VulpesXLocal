<UserControl x:Class="VulpesX.Modules.Ufp.General.ARTSelectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Ufp.General"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <Grid Name="grdFilters" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="25*" />
                <RowDefinition Height="5" />
                <RowDefinition Height="25*" />
                <RowDefinition Height="5" />
                <RowDefinition Height="25*" />
                <RowDefinition Height="5" />
                <RowDefinition Height="25*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="10*" />
                    <ColumnDefinition Width="10*" />
                    <ColumnDefinition Width="20*" />
                    <ColumnDefinition Width="20*" />
                    <ColumnDefinition Width="20*" />
                    <ColumnDefinition Width="20*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Tipo" />
                    </Grid>
                    <telerik:RadAutoCompleteBox Name="arttipFull"
                                                Grid.Row="1"
                                                HorizontalAlignment="Stretch"
                                                VerticalContentAlignment="Center"
                                                DisplayMemberPath="FullDescription"
                                                GotFocus="RadAutoCompleteBox_GotFocus"
                                                ItemsSource="{Binding TIPTA00Fs}"
                                                LostFocus="RadAutoCompleteBox_LostFocus"
                                                NoResultsContent="Nessun elemento trovato"
                                                SelectedItem="{Binding TIPTA00F, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                Tag="{Binding TIPTA00Fs}"
                                                TextSearchMode="Contains" />
                </Grid>

                <Grid Grid.Column="1" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="ID" />
                    </Grid>
                    <TextBox Grid.Row="1"
                             HorizontalAlignment="Stretch"
                             GotFocus="TextBox_GotFocus"
                             Tag="ID"
                             Text="{Binding Filter_ID}" />
                </Grid>

                <Grid Grid.Column="2" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Disegno" />
                    </Grid>
                    <TextBox Grid.Row="1"
                             HorizontalAlignment="Stretch"
                             GotFocus="TextBox_GotFocus"
                             Tag="artdise"
                             Text="{Binding Filter_artdise}" />
                </Grid>

                <Grid Grid.Column="3" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Analogia" />
                    </Grid>
                    <telerik:RadAutoCompleteBox Name="artfamFull"
                                                Grid.Row="1"
                                                HorizontalAlignment="Stretch"
                                                VerticalContentAlignment="Center"
                                                DisplayMemberPath="FullDescription"
                                                GotFocus="RadAutoCompleteBox_GotFocus"
                                                ItemsSource="{Binding ANALOGIEs}"
                                                LostFocus="RadAutoCompleteBox_LostFocus"
                                                NoResultsContent="Nessun elemento trovato"
                                                SelectedItem="{Binding ANALOGIE, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                Tag="{Binding ANALOGIEs}"
                                                TextSearchMode="Contains" />
                </Grid>

                <Grid Grid.Column="4" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Rivestimento" />
                    </Grid>
                    <telerik:RadAutoCompleteBox Name="artcorFull"
                                                Grid.Row="1"
                                                HorizontalAlignment="Stretch"
                                                VerticalContentAlignment="Center"
                                                DisplayMemberPath="FullDescription"
                                                GotFocus="RadAutoCompleteBox_GotFocus"
                                                ItemsSource="{Binding RIVESTIMENTIs}"
                                                LostFocus="RadAutoCompleteBox_LostFocus"
                                                NoResultsContent="Nessun elemento trovato"
                                                SelectedItem="{Binding RIVESTIMENTI, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                Tag="{Binding RIVESTIMENTIs}"
                                                TextSearchMode="Contains" />
                </Grid>

                <Grid Grid.Column="5" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Tipo materia prima" />
                    </Grid>
                    <telerik:RadAutoCompleteBox Name="arttipmatFull"
                                                Grid.Row="1"
                                                HorizontalAlignment="Stretch"
                                                VerticalContentAlignment="Center"
                                                DisplayMemberPath="FullDescription"
                                                GotFocus="RadAutoCompleteBox_GotFocus"
                                                ItemsSource="{Binding TIPMATPRIs}"
                                                LostFocus="RadAutoCompleteBox_LostFocus"
                                                NoResultsContent="Nessun elemento trovato"
                                                SelectedItem="{Binding TIPMATPRI, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                Tag="{Binding TIPMATPRIs}"
                                                TextSearchMode="Contains" />
                </Grid>

            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20*" />
                    <ColumnDefinition Width="20*" />
                    <ColumnDefinition Width="20*" />
                    <ColumnDefinition Width="20*" />
                    <ColumnDefinition Width="20*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Materia prima" />
                    </Grid>
                    <telerik:RadAutoCompleteBox Name="artmapFull"
                                                Grid.Row="1"
                                                HorizontalAlignment="Stretch"
                                                VerticalContentAlignment="Center"
                                                DisplayMemberPath="FullDescription"
                                                GotFocus="RadAutoCompleteBox_GotFocus"
                                                ItemsSource="{Binding MATERIEPRIMEs}"
                                                LostFocus="RadAutoCompleteBox_LostFocus"
                                                NoResultsContent="Nessun elemento trovato"
                                                SelectedItem="{Binding MATERIEPRIME, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                Tag="{Binding MATERIEPRIMEs}"
                                                TextSearchMode="Contains" />
                </Grid>

                <Grid Grid.Column="1" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Denti" />
                    </Grid>
                    <telerik:RadAutoCompleteBox Name="artdenFull"
                                                Grid.Row="1"
                                                HorizontalAlignment="Stretch"
                                                VerticalContentAlignment="Center"
                                                DisplayMemberPath="FullDescription"
                                                GotFocus="RadAutoCompleteBox_GotFocus"
                                                ItemsSource="{Binding DENTIs}"
                                                LostFocus="RadAutoCompleteBox_LostFocus"
                                                NoResultsContent="Nessun elemento trovato"
                                                SelectedItem="{Binding DENTI, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                Tag="{Binding DENTIs}"
                                                TextSearchMode="Contains" />
                </Grid>

                <Grid Grid.Column="2" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Diametro" />
                    </Grid>
                    <telerik:RadAutoCompleteBox Name="artdiamFull"
                                                Grid.Row="1"
                                                HorizontalAlignment="Stretch"
                                                VerticalContentAlignment="Center"
                                                DisplayMemberPath="FullDescription"
                                                GotFocus="RadAutoCompleteBox_GotFocus"
                                                ItemsSource="{Binding DIAMETROs}"
                                                LostFocus="RadAutoCompleteBox_LostFocus"
                                                NoResultsContent="Nessun elemento trovato"
                                                SelectedItem="{Binding DIAMETRO, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                Tag="{Binding DIAMETROs}"
                                                TextSearchMode="Contains" />
                </Grid>

                <Grid Grid.Column="3" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="L/D" />
                    </Grid>
                    <telerik:RadAutoCompleteBox Name="artldFull"
                                                Grid.Row="1"
                                                HorizontalAlignment="Stretch"
                                                VerticalContentAlignment="Center"
                                                DisplayMemberPath="FullDescription"
                                                GotFocus="RadAutoCompleteBox_GotFocus"
                                                ItemsSource="{Binding LDs}"
                                                LostFocus="RadAutoCompleteBox_LostFocus"
                                                NoResultsContent="Nessun elemento trovato"
                                                SelectedItem="{Binding LD, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                Tag="{Binding LDs}"
                                                TextSearchMode="Contains" />
                </Grid>

                <Grid Grid.Column="4" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Inclinazione elica" />
                    </Grid>
                    <telerik:RadAutoCompleteBox Name="artforiFull"
                                                Grid.Row="1"
                                                HorizontalAlignment="Stretch"
                                                VerticalContentAlignment="Center"
                                                DisplayMemberPath="FullDescription"
                                                GotFocus="RadAutoCompleteBox_GotFocus"
                                                ItemsSource="{Binding FORILUBRIFICATIs}"
                                                LostFocus="RadAutoCompleteBox_LostFocus"
                                                NoResultsContent="Nessun elemento trovato"
                                                SelectedItem="{Binding FORILUBRIFICATI, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                Tag="{Binding FORILUBRIFICATIs}"
                                                TextSearchMode="Contains" />
                </Grid>
            </Grid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20*" />
                    <ColumnDefinition Width="20*" />
                    <ColumnDefinition Width="20*" />
                    <ColumnDefinition Width="20*" />
                    <ColumnDefinition Width="20*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Attacco" />
                    </Grid>
                    <telerik:RadAutoCompleteBox Name="artatcoFull"
                                                Grid.Row="1"
                                                HorizontalAlignment="Stretch"
                                                VerticalContentAlignment="Center"
                                                DisplayMemberPath="FullDescription"
                                                GotFocus="RadAutoCompleteBox_GotFocus"
                                                ItemsSource="{Binding ATTACCOs}"
                                                LostFocus="RadAutoCompleteBox_LostFocus"
                                                NoResultsContent="Nessun elemento trovato"
                                                SelectedItem="{Binding ATTACCO, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                Tag="{Binding ATTACCOs}"
                                                TextSearchMode="Contains" />
                </Grid>

                <Grid Grid.Column="1" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Lunghezza elica (Da | A)" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:RadNumericUpDown Name="artdi3From"
                                                  Grid.Column="0"
                                                  Margin="0,0,2,0"
                                                  NumberDecimalDigits="2"
                                                  ShowButtons="False"
                                                  Tag="artdi3#from"
                                                  Value="{Binding Filter_artdi3_From}" />
                        <telerik:RadNumericUpDown Name="artdi3To"
                                                  Grid.Column="1"
                                                  Margin="2,0,0,0"
                                                  NumberDecimalDigits="2"
                                                  ShowButtons="False"
                                                  Tag="artdi3#to"
                                                  Value="{Binding Filter_artdi3_To}" />
                    </Grid>

                </Grid>

                <Grid Grid.Column="2" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Diametro (Da | A)" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:RadNumericUpDown Name="artdi1From"
                                                  Grid.Column="0"
                                                  Margin="0,0,2,0"
                                                  NumberDecimalDigits="2"
                                                  ShowButtons="False"
                                                  Tag="artdi1#from"
                                                  Value="{Binding Filter_artdi1_From}" />
                        <telerik:RadNumericUpDown Name="artdi1To"
                                                  Grid.Column="1"
                                                  Margin="2,0,0,0"
                                                  NumberDecimalDigits="2"
                                                  ShowButtons="False"
                                                  Tag="artdi1#to"
                                                  Value="{Binding Filter_artdi1_To}" />
                    </Grid>

                </Grid>

                <Grid Grid.Column="3" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Lunghezza (Da | A)" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:RadNumericUpDown Name="artlunFrom"
                                                  Grid.Column="0"
                                                  Margin="0,0,2,0"
                                                  NumberDecimalDigits="2"
                                                  ShowButtons="False"
                                                  Tag="artlun#from"
                                                  Value="{Binding Filter_artlun_From}" />

                        <telerik:RadNumericUpDown Name="artlunTo"
                                                  Grid.Column="1"
                                                  Margin="2,0,0,0"
                                                  NumberDecimalDigits="2"
                                                  ShowButtons="False"
                                                  Tag="artlun#to"
                                                  Value="{Binding Filter_artlun_To}" />
                    </Grid>

                </Grid>

                <Grid Grid.Column="4" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Larghezza (Da | A)" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:RadNumericUpDown Name="artlarFrom"
                                                  Grid.Column="0"
                                                  Margin="0,0,2,0"
                                                  NumberDecimalDigits="2"
                                                  ShowButtons="False"
                                                  Tag="artlar#from"
                                                  Value="{Binding Filter_artlar_From}" />

                        <telerik:RadNumericUpDown Name="artlarTo"
                                                  Grid.Column="1"
                                                  Margin="2,0,0,0"
                                                  NumberDecimalDigits="2"
                                                  ShowButtons="False"
                                                  Tag="artlar#to"
                                                  Value="{Binding Filter_artlar_To}" />
                    </Grid>

                </Grid>

            </Grid>

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20*" />
                    <ColumnDefinition Width="20*" />
                    <ColumnDefinition Width="20*" />
                    <ColumnDefinition Width="20*" />
                    <ColumnDefinition Width="20*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Lunghezza codolo (Da | A)" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:RadNumericUpDown Name="artluncodFrom"
                                                  Grid.Column="0"
                                                  Margin="0,0,2,0"
                                                  NumberDecimalDigits="2"
                                                  ShowButtons="False"
                                                  Tag="artluncod#from"
                                                  Value="{Binding Filter_artluncod_From}" />

                        <telerik:RadNumericUpDown Name="artluncodTo"
                                                  Grid.Column="1"
                                                  Margin="2,0,0,0"
                                                  NumberDecimalDigits="2"
                                                  ShowButtons="False"
                                                  Tag="artluncod#to"
                                                  Value="{Binding Filter_artluncod_To}" />
                    </Grid>

                </Grid>

                <Grid Grid.Column="1" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Lunghezza utile taglio (Da | A)" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:RadNumericUpDown Name="artlinutaFrom"
                                                  Grid.Column="0"
                                                  Margin="0,0,2,0"
                                                  NumberDecimalDigits="2"
                                                  ShowButtons="False"
                                                  Tag="artlinuta#from"
                                                  Value="{Binding Filter_artlinuta_From}" />

                        <telerik:RadNumericUpDown Name="artlinutaTo"
                                                  Grid.Column="1"
                                                  Margin="2,0,0,0"
                                                  NumberDecimalDigits="2"
                                                  ShowButtons="False"
                                                  Tag="artlinuta#to"
                                                  Value="{Binding Filter_artlinuta_To}" />
                    </Grid>

                </Grid>

                <Grid Grid.Column="2" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="Gradini (Da | A)" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <telerik:RadNumericUpDown Name="artaltFrom"
                                                  Grid.Column="0"
                                                  Margin="0,0,2,0"
                                                  GotFocus="RadNumericUpDown_GotFocus"
                                                  NumberDecimalDigits="2"
                                                  ShowButtons="False"
                                                  Tag="artalt#from"
                                                  Value="{Binding Filter_artalt_From}" />

                        <telerik:RadNumericUpDown Name="artaltTo"
                                                  Grid.Column="1"
                                                  Margin="2,0,0,0"
                                                  GotFocus="RadNumericUpDown_GotFocus"
                                                  NumberDecimalDigits="2"
                                                  ShowButtons="False"
                                                  Tag="artalt#to"
                                                  Value="{Binding Filter_artalt_To}" />
                    </Grid>

                </Grid>

                <Grid Grid.Column="3" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="MP assegnata" />
                    </Grid>

                    <TextBox Grid.Row="1"
                             HorizontalAlignment="Stretch"
                             GotFocus="TextBox_GotFocus"
                             Tag="artmp1Full" />

                </Grid>

                <Grid Grid.Column="4" Margin="10,1,10,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                        <TextBlock Margin="5,0,0,0" FontSize="12" Text="FOR assegnata" />
                    </Grid>

                    <TextBox Grid.Row="1"
                             HorizontalAlignment="Stretch"
                             GotFocus="TextBox_GotFocus"
                             Tag="artfor1mFull" />
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Row="1">

            <Button Name="cmdSearch"
                    Margin="10"
                    HorizontalAlignment="Right"
                    Click="cmdSearch_Click"
                    Style="{StaticResource VulpesXConfirmButton}">
                <Button.Content>
                    <telerik:RadBusyIndicator Grid.Row="0"
                                              HorizontalContentAlignment="Center"
                                              VerticalContentAlignment="Center"
                                              BusyContent="..."
                                              Foreground="{DynamicResource VulpesXBrush}"
                                              IsBusy="{Binding IsBusy}">
                        <TextBlock Foreground="{DynamicResource VulpesXSecondBrush}" Text="CERCA (F5)" />
                    </telerik:RadBusyIndicator>
                </Button.Content>
            </Button>
        </Grid>
    </Grid>
</UserControl>
