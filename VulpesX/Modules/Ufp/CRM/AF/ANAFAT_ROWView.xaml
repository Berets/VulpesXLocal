<UserControl x:Class="VulpesX.Modules.Ufp.CRM.AF.ANAFAT_ROWView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VulpesX.Shared.Controls.Converters;assembly=VulpesX.Shared.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Ufp.CRM.AF"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BindingProxy x:Key="Proxy" Data="{Binding}" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30*" />
                <ColumnDefinition Width="70*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="GESTIONE ANALISI DI FATTIBILITA'" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <telerik:RadDatePicker x:Name="dtpYear"
                                       Grid.Column="3"
                                       Margin="5"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Right"
                                       DateSelectionMode="Year"
                                       DisplayFormat="Short"
                                       SelectedValue="{Binding Year, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />

            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Margin="5"
                                         TextChanged="txtSearch_TextChanged"
                                         WatermarkContent="Cerca..." />
        </Grid>

        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     ColumnAggregatesAlignment="NextToGroupKey"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     RowIndicatorVisibility="Collapsed"
                                     RowIsExpandedChanging="GridView_RowIsExpandedChanging"
                                     SelectionMode="Extended"
                                     ShowColumnFooters="True"
                                     ShowGroupFooters="True"
                                     ShowGroupPanel="True">
                    <telerik:RadGridView.ChildTableDefinitions>
                        <telerik:GridViewTableDefinition />
                    </telerik:RadGridView.ChildTableDefinitions>
                    <telerik:RadGridView.ColumnGroups>
                        <telerik:GridViewColumnGroup Name="Nessuno" Header="" />
                        <telerik:GridViewColumnGroup Name="Articolo" Header="Articolo" />
                        <telerik:GridViewColumnGroup Name="MateriaPrima" Header="Materia prima" />
                        <telerik:GridViewColumnGroup Name="Ciclo" Header="Ciclo" />
                        <telerik:GridViewColumnGroup Name="Extra" Header="Extra" />
                    </telerik:RadGridView.ColumnGroups>

                    <telerik:RadGridView.Columns>
                        <telerik:GridViewColumn Width="110">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadButton x:Name="cmdDelete"
                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                       Click="cmdDelete_Click"
                                                       Content="Elimina"
                                                       Style="{StaticResource VulpesXButton}"
                                                       Visibility="{Binding CanDeleteVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn Width="30">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgDuplicate"
                                                      Cursor="Hand"
                                                      FontSize="18"
                                                      Foreground="{DynamicResource VulpesXBrush}"
                                                      Glyph="&#xe65d;"
                                                      MouseDown="rgDuplicate_MouseDown"
                                                      ToolTip="Duplica analisi di fattibilità" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewDataColumn Width="100"
                                                    DataMemberBinding="{Binding afid}"
                                                    Header="Numero"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Right"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEdit_Click"
                                            Content="{Binding Path=afid}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding afdata}"
                                                    Header="Data"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding afclides}" Header="Cliente" />
                        <telerik:GridViewDataColumn ColumnGroupName="Articolo" DataMemberBinding="{Binding Article.ID}" Header="Articolo" />
                        <telerik:GridViewDataColumn ColumnGroupName="Articolo" DataMemberBinding="{Binding Article.artdise}" Header="Disegno">
                            <telerik:GridViewDataColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical">
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="20" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="{Binding Article.artdise, StringFormat=N3}" />
                                            <Path x:Name="patArticleInfo"
                                                  Grid.Column="1"
                                                  Width="14"
                                                  Height="14"
                                                  telerik:RadToolTipService.Placement="RelativePoint"
                                                  telerik:RadToolTipService.PlacementRectangle="50 60 0 0"
                                                  telerik:RadToolTipService.ShowDuration="20000"
                                                  telerik:RadToolTipService.ToolTipContent="{Binding Article}"
                                                  telerik:RadToolTipService.ToolTipContentTemplate="{DynamicResource articleUfpTooltipTemplate}"
                                                  telerik:RadToolTipService.ToolTipOpening="patArticleInfo_ToolTipOpening"
                                                  Data="{DynamicResource InfoPath}"
                                                  Fill="{DynamicResource VulpesXSecondBrush}"
                                                  Stretch="Fill" />
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </telerik:GridViewDataColumn.CellTemplate>
                        </telerik:GridViewDataColumn>

                        <telerik:GridViewDataColumn ColumnGroupName="MateriaPrima" DataMemberBinding="{Binding afmatid}" Header="ID" />
                        <telerik:GridViewDataColumn ColumnGroupName="MateriaPrima" DataMemberBinding="{Binding Material.artdise}" Header="Disegno" />
                        <telerik:GridViewDataColumn ColumnGroupName="MateriaPrima" DataMemberBinding="{Binding afmatpre, StringFormat=N3}" Header="€" />

                        <telerik:GridViewDataColumn ColumnGroupName="Ciclo" DataMemberBinding="{Binding afcicmin, StringFormat=N3}" Header="Minuti" />

                        <telerik:GridViewDataColumn ColumnGroupName="Extra" DataMemberBinding="{Binding afvarnote}" Header="Note" />
                        <telerik:GridViewDataColumn ColumnGroupName="Extra" DataMemberBinding="{Binding afvarpre, StringFormat=N3}" Header="€" />

                        <telerik:GridViewDataColumn ColumnGroupName="Nessuno" DataMemberBinding="{Binding afcomplexitytypeDescription}" Header="Complessità">
                            <telerik:GridViewDataColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Background="{Binding afcomplexitytypeColor, Converter={StaticResource stringToColorConverter}}" Text="{Binding afcomplexitytypeDescription}" TextAlignment="Center" />
                                </DataTemplate>
                            </telerik:GridViewDataColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn ColumnGroupName="Nessuno" DataMemberBinding="{Binding afcustomertypeDescription}" Header="Cliente">
                            <telerik:GridViewDataColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Background="{Binding afcustomertypeColor, Converter={StaticResource stringToColorConverter}}" Text="{Binding afcustomertypeDescription}" TextAlignment="Center" />
                                </DataTemplate>
                            </telerik:GridViewDataColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                    </telerik:RadGridView.Columns>
                    <telerik:RadGridView.HierarchyChildTemplate>
                        <DataTemplate>
                            <Grid>
                                <telerik:RadGridView x:Name="GridViewDetails"
                                                     AutoGenerateColumns="False"
                                                     BorderThickness="0,1,0,1"
                                                     CanUserFreezeColumns="False"
                                                     GridLinesVisibility="None"
                                                     GroupRenderMode="Flat"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding Constant.Pieces}"
                                                     ShowGroupPanel="False">
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding afppiecesfrom, StringFormat=N0}" Header="Da&#10;pezzi" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding afppiecesto, StringFormat=N0}" Header="A&#10;pezzi" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding afppercentage, StringFormat=N3}" Header="%" />
                                        <telerik:GridViewDataColumn Header="Costo&#10;produzione">
                                            <telerik:GridViewDataColumn.HeaderCellStyle>
                                                <Style TargetType="telerik:GridViewHeaderCell">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="telerik:GridViewHeaderCell">
                                                                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                                                    <TextBlock VerticalAlignment="Center" Text="Costo&#10;produzione" />
                                                                    <Path Grid.Column="1"
                                                                          Width="14"
                                                                          Height="14"
                                                                          telerik:RadToolTipService.Placement="RelativePoint"
                                                                          telerik:RadToolTipService.PlacementRectangle="50 60 0 0"
                                                                          telerik:RadToolTipService.ShowDuration="20000"
                                                                          telerik:RadToolTipService.ToolTipContent="{Binding Constant, Source={StaticResource Proxy}}"
                                                                          telerik:RadToolTipService.ToolTipContentTemplate="{DynamicResource afConstProductionTemplate}"
                                                                          Data="{DynamicResource InfoPath}"
                                                                          Fill="{DynamicResource VulpesXSecondBrush}"
                                                                          Stretch="Fill" />
                                                                </StackPanel>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </telerik:GridViewDataColumn.HeaderCellStyle>
                                            <telerik:GridViewDataColumn.CellStyle>
                                                <Style BasedOn="{StaticResource GridViewCellStyle}" TargetType="telerik:GridViewCell">
                                                    <Setter Property="Background" Value="Transparent" />

                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding afppercentage}" Value="0">
                                                            <Setter Property="Background" Value="{DynamicResource VulpesXVioletBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </telerik:GridViewDataColumn.CellStyle>
                                            <telerik:GridViewDataColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Vertical">
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding ProductionCostPresidiato, StringFormat=N3}" />
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource VulpesXGreenBrush}"
                                                                   Text="{Binding ProductionCostAuto, StringFormat=N3}"
                                                                   Visibility="{Binding NetCostAuto, Converter={StaticResource stringNullabilityToVisibilityConverter}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </telerik:GridViewDataColumn.CellTemplate>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Header="Costo&#10;industriale">
                                            <telerik:GridViewDataColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Vertical">
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding NetCostPresidiato, StringFormat=N3}" />
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource VulpesXGreenBrush}"
                                                                   Text="{Binding NetCostAuto, StringFormat=N3}"
                                                                   Visibility="{Binding NetCostAuto, Converter={StaticResource stringNullabilityToVisibilityConverter}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </telerik:GridViewDataColumn.CellTemplate>
                                            <telerik:GridViewDataColumn.CellStyle>
                                                <Style BasedOn="{StaticResource GridViewCellStyle}" TargetType="telerik:GridViewCell">
                                                    <Setter Property="Background" Value="Transparent" />

                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding afppercentage}" Value="0">
                                                            <Setter Property="Background" Value="{DynamicResource VulpesXVioletBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </telerik:GridViewDataColumn.CellStyle>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Header="Costo&#10;Totale">
                                            <telerik:GridViewDataColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Vertical">
                                                        <Grid VerticalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="20" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="{Binding TotalPresidiato, StringFormat=N3}" />
                                                            <Path Grid.Column="1"
                                                                  Width="14"
                                                                  Height="14"
                                                                  telerik:RadToolTipService.Placement="RelativePoint"
                                                                  telerik:RadToolTipService.PlacementRectangle="50 60 0 0"
                                                                  telerik:RadToolTipService.ShowDuration="20000"
                                                                  telerik:RadToolTipService.ToolTipContent="{Binding}"
                                                                  telerik:RadToolTipService.ToolTipContentTemplate="{DynamicResource afTotalCostPreisidiatoTemplate}"
                                                                  Data="{DynamicResource InfoPath}"
                                                                  Fill="{DynamicResource VulpesXSecondBrush}"
                                                                  Stretch="Fill" />
                                                        </Grid>


                                                        <Grid Visibility="{Binding TotalAuto, Converter={StaticResource stringNullabilityToVisibilityConverter}}">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="20" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXGreenBrush}" Text="{Binding TotalAuto, StringFormat=N3}" />
                                                            <Path Grid.Column="1"
                                                                  Width="14"
                                                                  Height="14"
                                                                  telerik:RadToolTipService.Placement="RelativePoint"
                                                                  telerik:RadToolTipService.PlacementRectangle="50 60 0 0"
                                                                  telerik:RadToolTipService.ShowDuration="20000"
                                                                  telerik:RadToolTipService.ToolTipContent="{Binding}"
                                                                  telerik:RadToolTipService.ToolTipContentTemplate="{DynamicResource afTotalCostAutoTemplate}"
                                                                  Data="{DynamicResource InfoPath}"
                                                                  Fill="{DynamicResource VulpesXGreenBrush}"
                                                                  Stretch="Fill" />
                                                        </Grid>

                                                    </StackPanel>
                                                </DataTemplate>
                                            </telerik:GridViewDataColumn.CellTemplate>
                                            <telerik:GridViewDataColumn.CellStyle>
                                                <Style BasedOn="{StaticResource GridViewCellStyle}" TargetType="telerik:GridViewCell">
                                                    <Setter Property="Background" Value="Transparent" />

                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding afppercentage}" Value="0">
                                                            <Setter Property="Background" Value="{DynamicResource VulpesXVioletBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </telerik:GridViewDataColumn.CellStyle>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Header="Prezzo">
                                            <telerik:GridViewDataColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Vertical">
                                                        <Grid VerticalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="20" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="{Binding TotalPricePresidiato, StringFormat=N3}" />
                                                            <Path Grid.Column="1"
                                                                  Width="14"
                                                                  Height="14"
                                                                  telerik:RadToolTipService.Placement="RelativePoint"
                                                                  telerik:RadToolTipService.PlacementRectangle="50 60 0 0"
                                                                  telerik:RadToolTipService.ShowDuration="20000"
                                                                  telerik:RadToolTipService.ToolTipContent="{Binding}"
                                                                  telerik:RadToolTipService.ToolTipContentTemplate="{DynamicResource afTotalPricePreisidiatoTemplate}"
                                                                  Data="{DynamicResource InfoPath}"
                                                                  Fill="{DynamicResource VulpesXSecondBrush}"
                                                                  Stretch="Fill" />
                                                        </Grid>


                                                        <Grid Visibility="{Binding TotalPriceAuto, Converter={StaticResource stringNullabilityToVisibilityConverter}}">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="20" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXGreenBrush}" Text="{Binding TotalPriceAuto, StringFormat=N3}" />
                                                            <Path Grid.Column="1"
                                                                  Width="14"
                                                                  Height="14"
                                                                  telerik:RadToolTipService.Placement="RelativePoint"
                                                                  telerik:RadToolTipService.PlacementRectangle="50 60 0 0"
                                                                  telerik:RadToolTipService.ShowDuration="20000"
                                                                  telerik:RadToolTipService.ToolTipContent="{Binding}"
                                                                  telerik:RadToolTipService.ToolTipContentTemplate="{DynamicResource afTotalPriceAutoTemplate}"
                                                                  Data="{DynamicResource InfoPath}"
                                                                  Fill="{DynamicResource VulpesXGreenBrush}"
                                                                  Stretch="Fill" />
                                                        </Grid>

                                                    </StackPanel>
                                                </DataTemplate>
                                            </telerik:GridViewDataColumn.CellTemplate>
                                            <telerik:GridViewDataColumn.CellStyle>
                                                <Style BasedOn="{StaticResource GridViewCellStyle}" TargetType="telerik:GridViewCell">
                                                    <Setter Property="Background" Value="Transparent" />

                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding afppercentage}" Value="0">
                                                            <Setter Property="Background" Value="{DynamicResource VulpesXVioletBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </telerik:GridViewDataColumn.CellStyle>
                                        </telerik:GridViewDataColumn>
                                    </telerik:RadGridView.Columns>
                                </telerik:RadGridView>
                            </Grid>
                        </DataTemplate>
                    </telerik:RadGridView.HierarchyChildTemplate>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding Items}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>
</UserControl>
