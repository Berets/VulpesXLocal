<UserControl x:Class="VulpesX.Modules.Ufp.CRM.AF.ANAFAT_ROW_ExtraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Ufp.CRM.AF"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{DynamicResource VulpesXFirstAlternativeBrush}">
            <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="NOTE" />
        </Grid>

        <TextBox Grid.Row="1"
                 Height="400"
                 Margin="5"
                 Padding="5,7,0,0"
                 VerticalAlignment="Top"
                 VerticalContentAlignment="Top"
                 AcceptsReturn="True"
                 Text="{Binding Item.afvarnote}" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="20" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="1" Margin="5" Background="{DynamicResource VulpesXVioletBrush}">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="COSTO EXTRA" />
            </Grid>
            <telerik:RadNumericUpDown Name="numTotal"
                                      Grid.Column="2"
                                      Margin="5"
                                      FontSize="22"
                                      ShowButtons="False"
                                      ValueChanged="numTotal_ValueChanged"
                                      Value="{Binding Item.afvarpre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Column="3"
                       VerticalAlignment="Center"
                       FontSize="22"
                       Text="€" />
        </Grid>
    </Grid>
</UserControl>
