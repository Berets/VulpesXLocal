<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Ufp.CRM.AF.ANAFAT_ROWWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:converters="clr-namespace:VulpesX.Shared.Controls.Converters;assembly=VulpesX.Shared.Controls"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Ufp.CRM.AF"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli analisi di fattibilità"
                        Width="768"
                        Height="1024"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        mc:Ignorable="d">

    <sc:FluentDefaultWindow.Resources>
        <converters:AFStepVisibilityConverter x:Key="IndexToVisibilityConverter" />

        <converters:BindingProxy x:Key="Proxy" Data="{Binding}" />
    </sc:FluentDefaultWindow.Resources>

    <telerik:RadBusyIndicator Grid.Row="0"
                              BusyContent="Caricamento articoli e materie prime in corso..."
                              Foreground="{DynamicResource VulpesXBrush}"
                              IsBusy="{Binding IsBusyList}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <telerik:RadTabControl Grid.Row="0"
                                   VerticalAlignment="Stretch"
                                   BorderThickness="0"
                                   DisplayMemberPath="Content"
                                   DropDownDisplayMode="Visible"
                                   ScrollMode="Viewport">
                <telerik:RadTabControl.Items>
                    <telerik:RadTabItem DropDownContent="DATI" Header="DATI">
                        <telerik:RadTabItem.Content>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <telerik:RadExpander x:Name="expArticolo"
                                                     Margin="0,5,0,0"
                                                     VerticalContentAlignment="Top"
                                                     ExpandDirection="Right"
                                                     IsExpanded="True">
                                    <telerik:RadExpander.Header>
                                        <Grid Background="{DynamicResource VulpesXBlueBrush}">
                                            <TextBlock Margin="15,5,5,7"
                                                       VerticalAlignment="Center"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Text="Articolo" />
                                        </Grid>
                                    </telerik:RadExpander.Header>
                                    <telerik:RadExpander.Content>
                                        <Grid MinWidth="400" Visibility="{Binding IsExpanded, ElementName=expArticolo, Converter={StaticResource boolToVisibilityConverter}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="70*" />
                                                <RowDefinition Height="30*" />
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="20" />
                                                    <RowDefinition Height="40" />
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0" Background="{DynamicResource VulpesXTurquoiseBrush}">
                                                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="DATA" />
                                                </Grid>
                                                <telerik:RadDateTimePicker Grid.Row="1"
                                                                           DateSelectionMode="Day"
                                                                           DateTimeWatermarkContent="Scegliere la data"
                                                                           DisplayFormat="Short"
                                                                           InputMode="DatePicker"
                                                                           IsEnabled="{Binding IsInsert}"
                                                                           ParseExact="False"
                                                                           SelectedValue="{Binding Item.afdata, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>

                                            <Grid Grid.Row="1">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="20" />
                                                    <RowDefinition Height="40" />
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0" Background="{DynamicResource VulpesXTurquoiseBrush}">
                                                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="CLIENTE" />
                                                </Grid>
                                                <telerik:RadAutoSuggestBox x:Name="acCustomer"
                                                                           Grid.Row="1"
                                                                           HorizontalAlignment="Stretch"
                                                                           DisplayMemberPath="FullDescriptionSearchable"
                                                                           ItemsSource="{Binding Data.Customers}"
                                                                           NoResultsContent="Nessun cliente trovato"
                                                                           SuggestionChosen="acCustomer_SuggestionChosen"
                                                                           Text="{Binding Item.afclides, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                           TextChanged="acCustomer_TextChanged"
                                                                           TextMemberPath="FullDescriptionSearchable"
                                                                           WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                            </Grid>

                                            <Grid Grid.Row="2">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="20" />
                                                    <RowDefinition Height="40" />
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0" Background="{DynamicResource VulpesXTurquoiseBrush}">
                                                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="ARTICOLO" />
                                                </Grid>
                                                <telerik:RadAutoCompleteBox Name="acArticle"
                                                                            Grid.Row="1"
                                                                            HorizontalAlignment="Stretch"
                                                                            VerticalContentAlignment="Center"
                                                                            DisplayMemberPath="FullDescriptionSearchableUfp"
                                                                            GotFocus="acArticle_GotFocus"
                                                                            ItemsSource="{Binding Item.Articles}"
                                                                            LostFocus="acArticle_LostFocus"
                                                                            NoResultsContent="Nessun elemento trovato"
                                                                            PreviewMouseLeftButtonUp="acArticle_PreviewMouseLeftButtonUp"
                                                                            SelectedItem="{Binding Item.Article, Mode=OneWay}"
                                                                            SelectionChanged="acArticle_SelectionChanged"
                                                                            SelectionMode="Single"
                                                                            Tag="{Binding Item.Articles}"
                                                                            TextSearchMode="Contains" />
                                            </Grid>

                                            <Grid Grid.Row="3">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="30" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0" Background="{DynamicResource VulpesXFirstAlternativeBrush}">
                                                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="DETTAGLI" />
                                                </Grid>
                                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                                    <Border BorderBrush="{DynamicResource VulpesXBlueBrush}" BorderThickness="1">
                                                        <Grid>
                                                            <StackPanel Orientation="Vertical">
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="ID: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.ID}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Disegno: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artdise}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Analogia: " />
                                                                    <TextBlock FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource VulpesXBrush}"
                                                                               Text="{Binding Item.Article.artfamFull}"
                                                                               ToolTip="{Binding Item.Article.artfamFull}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Rivestimento: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artcorFull}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Tipo MP: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.arttipmatFull}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="MP: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artmapFull}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Attacco: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artatcoFull}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Denti: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artdenFull, StringFormat=N2}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Diametro: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artdiamFull, StringFormat=N2}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="L/D: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artldFull, StringFormat=N2}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Inc.elica: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artforiFull, StringFormat=N2}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Lun. elica: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artdi3}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Diametro: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artdi1, StringFormat=N2}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Lunghezza: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artlun, StringFormat=N2}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Larghezza: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artlar, StringFormat=N2}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Lun. codolo: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artluncod}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Lun. utile taglio: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artlinuta, StringFormat=N2}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Gradini: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artalt, StringFormat=N2}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="MP associata: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artmp1Full, StringFormat=N2}" />
                                                                </DockPanel>
                                                                <DockPanel Margin="5,2,0,0">
                                                                    <TextBlock Width="100" Foreground="{DynamicResource VulpesXSecondBrush}" Text="FOR associata: " />
                                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource VulpesXBrush}" Text="{Binding Item.Article.artfor1mFull, StringFormat=N2}" />
                                                                </DockPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </ScrollViewer>
                                            </Grid>

                                            <Grid Grid.Row="4">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="30" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0" Background="{DynamicResource VulpesXFirstAlternativeBrush}">
                                                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="DISEGNI" />
                                                </Grid>

                                                <telerik:RadGridView x:Name="GridArticleDraws"
                                                                     Grid.Row="1"
                                                                     Margin="5"
                                                                     AutoGenerateColumns="False"
                                                                     CanUserFreezeColumns="False"
                                                                     CanUserResizeColumns="False"
                                                                     ColumnAggregatesAlignment="NextToGroupKey"
                                                                     GroupRenderMode="Flat"
                                                                     IsReadOnly="True"
                                                                     ItemsSource="{Binding ArticleDraws}"
                                                                     RowIndicatorVisibility="Collapsed"
                                                                     SelectionMode="Single"
                                                                     ShowColumnFooters="False"
                                                                     ShowGroupFooters="True"
                                                                     ShowGroupPanel="False">
                                                    <telerik:RadGridView.Columns>
                                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding Item1}" Header="Cliente">
                                                            <telerik:GridViewDataColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="20" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0" Text="{Binding Item1}" />
                                                                        <Path x:Name="patDownloadDraw"
                                                                              Grid.Column="1"
                                                                              Width="14"
                                                                              Height="14"
                                                                              Cursor="Hand"
                                                                              Data="{DynamicResource DownloadPath}"
                                                                              Fill="{DynamicResource VulpesXSecondBrush}"
                                                                              PreviewMouseLeftButtonDown="patDownloadDraw_PreviewMouseLeftButtonDown"
                                                                              Stretch="Fill" />
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </telerik:GridViewDataColumn.CellTemplate>
                                                        </telerik:GridViewDataColumn>
                                                    </telerik:RadGridView.Columns>
                                                </telerik:RadGridView>

                                            </Grid>
                                        </Grid>
                                    </telerik:RadExpander.Content>
                                </telerik:RadExpander>

                                <Grid Grid.Column="1" Background="{DynamicResource VulpesXBlueBrush}" />

                                <Grid Grid.Column="2" Visibility="{Binding Item.Article, Converter={StaticResource stringNullabilityToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="100" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <telerik:RadStepProgressBar x:Name="stepProgressBar"
                                                                Grid.Row="0"
                                                                Margin="5,15,0,0"
                                                                HorizontalAlignment="Left"
                                                                AnimationDuration="0.2"
                                                                DisplayMemberPath="Name"
                                                                ItemsSource="{Binding AFSteps}"
                                                                SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}">
                                        <telerik:RadStepProgressBar.ItemContainerStyle>
                                            <Style BasedOn="{StaticResource RadStepProgressBarItemStyle}" TargetType="telerik:RadStepProgressBarItem">
                                                <Setter Property="CompletedIndicatorContent" Value="{Binding Description}" />
                                                <Setter Property="CompletedIndicatorContentTemplate" Value="{x:Null}" />
                                                <Setter Property="NotStartedIndicatorContent" Value="{Binding Description}" />
                                                <Setter Property="NotStartedIndicatorContentTemplate" Value="{x:Null}" />

                                                <Setter Property="ShapeGeometry" Value="M394.1,323.8 L503.7,324 528.5,344.3 502.1,363 392.8,363.1 419.0,344.0 z" />
                                                <Setter Property="ShapeWidth" Value="150" />
                                                <Setter Property="ShapeHeight" Value="50" />
                                                <Setter Property="ShapeStrokeThickness" Value="1" />
                                                <Setter Property="Margin" Value="-36,0,0,0" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type telerik:RadStepProgressBarItem}">
                                                            <Grid x:Name="PART_RootGrid">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <Grid x:Name="PART_Indicator"
                                                                      Grid.Row="1"
                                                                      Grid.Column="1"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center">
                                                                    <Path x:Name="PART_IndicatorGeometry"
                                                                          Width="{TemplateBinding ShapeWidth}"
                                                                          Height="{TemplateBinding ShapeHeight}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          Data="{TemplateBinding ShapeGeometry}"
                                                                          Fill="{TemplateBinding Background}"
                                                                          Stretch="Fill"
                                                                          Stroke="{TemplateBinding ShapeStroke}"
                                                                          StrokeThickness="{TemplateBinding ShapeStrokeThickness}" />
                                                                    <Path x:Name="PART_IndicatorGeometry_MouseOver"
                                                                          Width="{TemplateBinding ShapeWidth}"
                                                                          Height="{TemplateBinding ShapeHeight}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          Data="{TemplateBinding ShapeGeometry}"
                                                                          Opacity="0"
                                                                          Stretch="Fill"
                                                                          Stroke="{DynamicResource QSFTheme_ExampleBorderBrush}"
                                                                          StrokeThickness="{TemplateBinding ShapeStrokeThickness}" />
                                                                    <ContentPresenter x:Name="PART_IndicatorContent"
                                                                                      HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"
                                                                                      ContentSource="NotStartedIndicatorContent"
                                                                                      TextBlock.FontWeight="{TemplateBinding FontWeight}"
                                                                                      TextBlock.Foreground="{TemplateBinding Foreground}" />
                                                                </Grid>
                                                                <ContentPresenter x:Name="Part_AdditionalContent"
                                                                                  Grid.Column="1"
                                                                                  Margin="{TemplateBinding Padding}"
                                                                                  HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"
                                                                                  ContentSource="AdditionalContent" />
                                                                <ContentPresenter x:Name="Part_PrimaryContent"
                                                                                  Grid.Row="2"
                                                                                  Grid.Column="1"
                                                                                  Margin="{TemplateBinding Padding}"
                                                                                  HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"
                                                                                  ContentSource="Content" />
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="Orientation" Value="Vertical">
                                                                    <Setter TargetName="Part_AdditionalContent" Property="Grid.Column" Value="0" />
                                                                    <Setter TargetName="Part_AdditionalContent" Property="Grid.Row" Value="1" />
                                                                    <Setter TargetName="Part_PrimaryContent" Property="Grid.Column" Value="2" />
                                                                    <Setter TargetName="Part_PrimaryContent" Property="Grid.Row" Value="1" />
                                                                </Trigger>
                                                                <Trigger Property="Status" Value="Completed">
                                                                    <Setter TargetName="PART_IndicatorContent" Property="TextBlock.Foreground" Value="{DynamicResource VulpesXSecondBrush}" />

                                                                    <Setter Property="ShapeStroke" Value="{DynamicResource VulpesXBlueBrush}" />
                                                                </Trigger>
                                                                <Trigger Property="Status" Value="Indeterminate">
                                                                    <Setter TargetName="PART_IndicatorGeometry" Property="Fill" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Background}" />
                                                                    <Setter Property="ShapeStroke" Value="{DynamicResource VulpesXBlueBrush}" />
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter Property="ShapeStroke" Value="{DynamicResource VulpesXBlueBrush}" />
                                                                    <Setter TargetName="PART_IndicatorGeometry" Property="Fill" Value="{DynamicResource VulpesXBlueBrush}" />
                                                                </Trigger>
                                                                <MultiTrigger>
                                                                    <MultiTrigger.Conditions>
                                                                        <Condition SourceName="PART_Indicator" Property="IsMouseOver" Value="True" />
                                                                        <Condition Property="IsSelected" Value="True" />
                                                                    </MultiTrigger.Conditions>
                                                                    <Setter Property="ShapeStroke" Value="{DynamicResource VulpesXBlueBrush}" />
                                                                </MultiTrigger>
                                                                <Trigger SourceName="PART_Indicator" Property="IsMouseOver" Value="True">
                                                                    <Trigger.EnterActions>
                                                                        <BeginStoryboard x:Name="SelectedState">
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetName="PART_IndicatorGeometry_MouseOver"
                                                                                                 Storyboard.TargetProperty="Opacity"
                                                                                                 From="0"
                                                                                                 To="1"
                                                                                                 Duration="00:00:00.20" />
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </Trigger.EnterActions>
                                                                    <Trigger.ExitActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetName="PART_IndicatorGeometry_MouseOver"
                                                                                                 Storyboard.TargetProperty="Opacity"
                                                                                                 From="1"
                                                                                                 To="0"
                                                                                                 Duration="00:00:00.20" />
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </Trigger.ExitActions>
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter TargetName="PART_IndicatorContent" Property="Opacity" Value="1" />
                                                                    <Setter TargetName="Part_PrimaryContent" Property="Opacity" Value="1" />
                                                                    <Setter TargetName="Part_AdditionalContent" Property="Opacity" Value="1" />
                                                                </Trigger>
                                                                <MultiTrigger>
                                                                    <MultiTrigger.Conditions>
                                                                        <Condition Property="IsEnabled" Value="False" />
                                                                        <Condition Property="Status" Value="Completed" />
                                                                    </MultiTrigger.Conditions>
                                                                    <Setter TargetName="PART_IndicatorContent" Property="TextBlock.Foreground" Value="{DynamicResource VulpesXGreenBrush}" />
                                                                </MultiTrigger>
                                                                <DataTrigger Binding="{Binding Index, RelativeSource={RelativeSource Self}, Converter={StaticResource IndexConverter}}" Value="1">
                                                                    <Setter Property="Margin" Value="0" />
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </telerik:RadStepProgressBar.ItemContainerStyle>
                                    </telerik:RadStepProgressBar>

                                    <Grid Grid.Row="1">
                                        <telerik:RadBusyIndicator BusyContent="Caricamento listini in corso..."
                                                                  Foreground="{DynamicResource VulpesXBrush}"
                                                                  IsBusy="{Binding IsBusyMaterial}"
                                                                  Visibility="{Binding SelectedIndex, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=0}">
                                            <local:ANAFAT_ROW_MaterialView TextElement.Foreground="{DynamicResource VulpesXSecondBrush}" />
                                        </telerik:RadBusyIndicator>

                                        <telerik:RadBusyIndicator BusyContent="Caricamento cicli in corso..."
                                                                  Foreground="{DynamicResource VulpesXBrush}"
                                                                  IsBusy="{Binding IsBusyCycle}"
                                                                  Visibility="{Binding SelectedIndex, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=1}">
                                            <local:ANAFAT_ROW_CycleView TextElement.Foreground="{DynamicResource VulpesXSecondBrush}" />
                                        </telerik:RadBusyIndicator>

                                        <local:ANAFAT_ROW_ExtraView TextElement.Foreground="{DynamicResource VulpesXSecondBrush}" Visibility="{Binding SelectedIndex, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=2}" />
                                    </Grid>
                                </Grid>

                                <Grid Grid.Column="3" Background="{DynamicResource VulpesXBlueBrush}" />

                                <telerik:RadExpander x:Name="expTotali"
                                                     Grid.Column="4"
                                                     Margin="0,5,0,0"
                                                     VerticalContentAlignment="Top"
                                                     ExpandDirection="Left"
                                                     IsExpanded="True">
                                    <telerik:RadExpander.Header>
                                        <Grid Background="{DynamicResource VulpesXBlueBrush}">
                                            <TextBlock Margin="15,5,5,7"
                                                       VerticalAlignment="Center"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Text="Totali" />
                                        </Grid>
                                    </telerik:RadExpander.Header>
                                    <telerik:RadExpander.Content>
                                        <Grid MinWidth="400" Background="{DynamicResource VulpesXFirstBrush}" Visibility="{Binding IsExpanded, ElementName=expTotali, Converter={StaticResource boolToVisibilityConverter}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" Margin="5">
                                                <StackPanel HorizontalAlignment="Left">
                                                    <telerik:Label Padding="0,0,0,10" Content="Complessità" FontWeight="Bold" />
                                                    <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
