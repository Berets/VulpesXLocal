<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Ufp.Tables.Accounting.LIBRIIVAWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Ufp.Tables.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli libro IVA"
                        Width="700"
                        Height="700"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="DATI" Header="DATI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />

                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*" />
                                <ColumnDefinition Width="6*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Codice" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Width="100"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     IsEnabled="{Binding IsInsert}"
                                     MaxLength="2"
                                     Text="{Binding Data.livcod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Descrizione" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="50"
                                     Text="{Binding Data.livdes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Tipo" />
                            <telerik:RadComboBox Grid.Row="2"
                                                 Grid.Column="1"
                                                 Width="200"
                                                 Margin="5,2,15,2"
                                                 HorizontalAlignment="Left"
                                                 HorizontalContentAlignment="Left"
                                                 DisplayMemberPath="Description"
                                                 IsEditable="True"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding BookTypes}"
                                                 SelectedValue="{Binding Data.livtip, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 SelectedValuePath="ID" />

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Sezionale" />
                            <TextBox Grid.Row="3"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="50"
                                     Text="{Binding Data.livpro, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Protocollo automatico" />
                            <telerik:RadToggleSwitchButton Grid.Row="4"
                                                           Grid.Column="1"
                                                           Margin="5,0,0,0"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.livaut}"
                                                           IsChecked="{Binding Data.livautBool}"
                                                           UncheckedContent="No" />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Numerazione pagine" />
                            <telerik:RadToggleSwitchButton Grid.Row="5"
                                                           Grid.Column="1"
                                                           Margin="5,0,0,0"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.livagg}"
                                                           IsChecked="{Binding Data.livaggBool}"
                                                           UncheckedContent="No" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="CONTI" Header="CONTI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="25" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />

                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXSubtitle}"
                                       Text="CONTO IVA" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Gruppo" />
                            <telerik:RadAutoCompleteBox x:Name="acIVAGroup"
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        Width="400"
                                                        Margin="5,2,5,2"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Data.GroupsList}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun gruppo trovato"
                                                        SelectedItem="{Binding Data.SelectedIVAGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Conto" />
                            <telerik:RadAutoCompleteBox x:Name="acIVAAccount"
                                                        Grid.Row="2"
                                                        Grid.Column="1"
                                                        Width="400"
                                                        Margin="5,2,5,2"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Data.IVAAccountList}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun conto trovato"
                                                        SelectedItem="{Binding Data.SelectedIVAAccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Sottoconto" />
                            <telerik:RadAutoCompleteBox x:Name="acIVASubaccount"
                                                        Grid.Row="3"
                                                        Grid.Column="1"
                                                        Width="400"
                                                        Margin="5,2,5,2"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Data.IVASubaccountList}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun sottoconto trovato"
                                                        SelectedItem="{Binding Data.SelectedIVASubaccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXSubtitle}"
                                       Text="CONTO ERARIO" />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Gruppo" />
                            <telerik:RadAutoCompleteBox x:Name="acErarioGroup"
                                                        Grid.Row="5"
                                                        Grid.Column="1"
                                                        Width="400"
                                                        Margin="5,2,5,2"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Data.GroupsList}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun gruppo trovato"
                                                        SelectedItem="{Binding Data.SelectedErarioGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Conto" />
                            <telerik:RadAutoCompleteBox x:Name="acErarioAccount"
                                                        Grid.Row="6"
                                                        Grid.Column="1"
                                                        Width="400"
                                                        Margin="5,2,5,2"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Data.ErarioAccountsList}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun conto trovato"
                                                        SelectedItem="{Binding Data.SelectedErarioAccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Sottoconto" />
                            <telerik:RadAutoCompleteBox x:Name="acErarioSubaccount"
                                                        Grid.Row="7"
                                                        Grid.Column="1"
                                                        Width="400"
                                                        Margin="5,2,5,2"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Data.ErarioSubaccountList}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun sottoconto trovato"
                                                        SelectedItem="{Binding Data.SelectedErarioSubaccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="9"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Causale giroconto" />
                            <telerik:RadAutoCompleteBox x:Name="acGiroCausal"
                                                        Grid.Row="9"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Causals}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessuna causale trovata"
                                                        SelectedItem="{Binding SelectedGiroCausal, Mode=TwoWay}"
                                                        SelectionChanged="acGiroCausal_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            <TextBlock Grid.Row="10"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Causale storno IVA ind." />
                            <telerik:RadAutoCompleteBox x:Name="acStornoCausal"
                                                        Grid.Row="10"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Causals}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessuna causale trovata"
                                                        SelectedItem="{Binding SelectedStornoCausal, Mode=TwoWay}"
                                                        SelectionChanged="acStornoCausal_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Inserito il" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultimo aggiornamento il" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedUserText}" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
