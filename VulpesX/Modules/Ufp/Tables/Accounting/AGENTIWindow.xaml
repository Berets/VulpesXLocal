<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Ufp.Tables.Accounting.AGENTIWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Ufp.Tables.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli agente"
                        Width="1024"
                        Height="700"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Name="tabMain"
                               Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport"
                               SelectionChanged="tabMain_SelectionChanged">

            <telerik:RadTabItem DropDownContent="DATI" Header="DATI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">

                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Codice" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="100"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         IsEnabled="{Binding IsInsert}"
                                         MaxLength="3"
                                         Text="{Binding Data.agecod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Descrizione" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="255"
                                     Text="{Binding Data.agedes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Provvigione" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadNumericUpDown Width="200"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          Minimum="0"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.agepvg, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Tipo calcolo" />
                            <telerik:RadComboBox Grid.Row="3"
                                                 Grid.Column="1"
                                                 Width="200"
                                                 Margin="5,2,15,2"
                                                 HorizontalAlignment="Left"
                                                 HorizontalContentAlignment="Left"
                                                 DisplayMemberPath="Description"
                                                 IsEditable="True"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding Data.ComputeTypes}"
                                                 SelectedValue="{Binding Data.agecal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 SelectedValuePath="ID" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Tipo liquidazione" />
                            <telerik:RadComboBox Grid.Row="4"
                                                 Grid.Column="1"
                                                 Width="200"
                                                 Margin="5,2,15,2"
                                                 HorizontalAlignment="Left"
                                                 HorizontalContentAlignment="Left"
                                                 DisplayMemberPath="Description"
                                                 IsEditable="True"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding Data.LiquidationTypes}"
                                                 SelectedValue="{Binding Data.ageliq, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 SelectedValuePath="ID" />
                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Tipo agente" />
                            <telerik:RadComboBox Grid.Row="5"
                                                 Grid.Column="1"
                                                 Width="200"
                                                 Margin="5,2,15,2"
                                                 HorizontalAlignment="Left"
                                                 HorizontalContentAlignment="Left"
                                                 DisplayMemberPath="Description"
                                                 IsEditable="True"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding Data.AgentTypesUfp}"
                                                 SelectedValue="{Binding Data.ageflg, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 SelectedValuePath="ID" />
                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Codice fornitore" />

                            <telerik:RadAutoCompleteBox x:Name="acSupplier"
                                                        Grid.Row="6"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Suppliers}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding SelectedSupplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acSupplier_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />


                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Telefono" />
                            <TextBox Grid.Row="7"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="255"
                                     Text="{Binding Data.agetel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Fax" />
                            <TextBox Grid.Row="8"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="255"
                                     Text="{Binding Data.agefax, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="9"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="E-mail" />
                            <TextBox Grid.Row="9"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="255"
                                     Text="{Binding Data.agemail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="10"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Invio e-mail schedulata"
                                       TextAlignment="Right" />
                            <telerik:RadToggleSwitchButton Grid.Row="10"
                                                           Grid.Column="1"
                                                           Margin="5,0,0,0"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.ageinvmail}"
                                                           IsChecked="{Binding Data.ageinvmailBool}"
                                                           UncheckedContent="No" />

                            <TextBlock Grid.Row="11"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Agente in stampe"
                                       TextAlignment="Right" />
                            <telerik:RadToggleSwitchButton Grid.Row="11"
                                                           Grid.Column="1"
                                                           Margin="5,0,0,0"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.ageflg2}"
                                                           IsChecked="{Binding Data.ageflg2Bool}"
                                                           UncheckedContent="No" />

                            <TextBlock Grid.Row="12"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Agente attivo"
                                       TextAlignment="Right" />
                            <telerik:RadToggleSwitchButton Grid.Row="12"
                                                           Grid.Column="1"
                                                           Margin="5,0,0,0"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.ageflg}"
                                                           IsChecked="{Binding Data.ageflgBool}"
                                                           UncheckedContent="No" />

                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="ECCEZIONI CAUSALE" Header="ECCEZIONI CAUSALE">
                <telerik:RadTabItem.Content>
                    <telerik:RadGridView Name="rgvCausals"
                                         Grid.Row="3"
                                         Grid.ColumnSpan="2"
                                         Margin="0"
                                         AddingNewDataItem="rgvCausals_AddingNewDataItem"
                                         AutoGenerateColumns="False"
                                         CanUserFreezeColumns="False"
                                         CanUserInsertRows="True"
                                         IsSearchingDeferred="True"
                                         ItemsSource="{Binding ExceptionsCausal}"
                                         NewRowPosition="Top"
                                         RowDetailsVisibilityMode="VisibleWhenSelected"
                                         RowEditEnded="rgvCausals_RowEditEnded"
                                         RowIndicatorVisibility="Collapsed"
                                         RowValidated="rgvCausals_RowValidated"
                                         RowValidating="rgvCausals_RowValidating"
                                         SearchMode="MatchAnyTerm"
                                         ShowGroupPanel="False"
                                         ShowSearchPanel="False"
                                         ValidatesOnDataErrors="InEditMode">
                        <telerik:RadGridView.Columns>

                            <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding CustomerDescription}" Header="Cliente">
                                <telerik:GridViewDataColumn.CellEditTemplate>
                                    <DataTemplate>
                                        <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                    GotFocus="ac_GotFocus"
                                                                    ItemsSource="{Binding Customers}"
                                                                    LostFocus="ac_LostFocus"
                                                                    NoResultsContent="Nessun cliente trovato"
                                                                    SelectedItem="{Binding SelectedCustomer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    SelectionMode="Single"
                                                                    TextSearchMode="Contains"
                                                                    TextSearchPath="FullDescriptionSearchable" />
                                    </DataTemplate>
                                </telerik:GridViewDataColumn.CellEditTemplate>
                            </telerik:GridViewDataColumn>

                            <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding OrderCausalDescription}" Header="Causale">
                                <telerik:GridViewDataColumn.CellEditTemplate>
                                    <DataTemplate>
                                        <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                    GotFocus="ac_GotFocus"
                                                                    ItemsSource="{Binding OrderCausals}"
                                                                    LostFocus="ac_LostFocus"
                                                                    NoResultsContent="Nessuna causale trovata"
                                                                    SelectedItem="{Binding SelectedOrderCausal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    SelectionMode="Single"
                                                                    TextSearchMode="Contains"
                                                                    TextSearchPath="FullDescriptionSearchable" />
                                    </DataTemplate>
                                </telerik:GridViewDataColumn.CellEditTemplate>
                            </telerik:GridViewDataColumn>

                            <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding SupplierDescription}" Header="Fornitore">
                                <telerik:GridViewDataColumn.CellEditTemplate>
                                    <DataTemplate>
                                        <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                    GotFocus="ac_GotFocus"
                                                                    ItemsSource="{Binding Suppliers}"
                                                                    LostFocus="ac_LostFocus"
                                                                    NoResultsContent="Nessun fornitore trovato"
                                                                    SelectedItem="{Binding SelectedSupplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    SelectionMode="Single"
                                                                    TextSearchMode="Contains"
                                                                    TextSearchPath="FullDescriptionSearchable" />
                                    </DataTemplate>
                                </telerik:GridViewDataColumn.CellEditTemplate>
                            </telerik:GridViewDataColumn>

                            <telerik:GridViewDataColumn DataMemberBinding="{Binding appsca1}" Header="Scaglione 1" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding appscaper1}" Header="%" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding appsca2}" Header="Scaglione 2" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding appscaper2}" Header="%" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding appsca3}" Header="Scaglione 3" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding appscaper3}" Header="%" />
                        </telerik:RadGridView.Columns>
                    </telerik:RadGridView>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem Name="tabArticle" DropDownContent="ECCEZIONI ARTICOLO" Header="ECCEZIONI ARTICOLO">
                <telerik:RadTabItem.Content>
                    <telerik:RadBusyIndicator x:Name="bsyGrid"
                                              Grid.Row="2"
                                              BusyContent="Caricamento dati in corso..."
                                              Foreground="{DynamicResource VulpesXBrush}"
                                              IsBusy="{Binding IsBusy}"
                                              OverlayStyle="{StaticResource WaitOverlayStyle}">
                        <telerik:RadGridView Name="rgvArticles"
                                             Grid.Row="3"
                                             Grid.ColumnSpan="2"
                                             Margin="0"
                                             AddingNewDataItem="rgvArticles_AddingNewDataItem"
                                             AutoGenerateColumns="False"
                                             CanUserFreezeColumns="False"
                                             CanUserInsertRows="True"
                                             IsSearchingDeferred="True"
                                             ItemsSource="{Binding ExceptionsArticle}"
                                             NewRowPosition="Top"
                                             RowDetailsVisibilityMode="VisibleWhenSelected"
                                             RowEditEnded="rgvArticles_RowEditEnded"
                                             RowIndicatorVisibility="Collapsed"
                                             RowValidated="rgvArticles_RowValidated"
                                             RowValidating="rgvArticles_RowValidating"
                                             SearchMode="MatchAnyTerm"
                                             ShowGroupPanel="False"
                                             ShowSearchPanel="False"
                                             ValidatesOnDataErrors="InEditMode">
                            <telerik:RadGridView.Columns>

                                <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding CustomerDescription}" Header="Cliente">
                                    <telerik:GridViewDataColumn.CellEditTemplate>
                                        <DataTemplate>
                                            <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                        GotFocus="ac_GotFocus"
                                                                        ItemsSource="{Binding Customers}"
                                                                        LostFocus="ac_LostFocus"
                                                                        NoResultsContent="Nessun cliente trovato"
                                                                        SelectedItem="{Binding SelectedCustomer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                        SelectionMode="Single"
                                                                        TextSearchMode="Contains"
                                                                        TextSearchPath="FullDescriptionSearchable" />
                                        </DataTemplate>
                                    </telerik:GridViewDataColumn.CellEditTemplate>
                                </telerik:GridViewDataColumn>

                                <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding ArticleDescription}" Header="Articolo">
                                    <telerik:GridViewDataColumn.CellEditTemplate>
                                        <DataTemplate>
                                            <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchableUfp"
                                                                        GotFocus="ac_GotFocus"
                                                                        ItemsSource="{Binding Articles}"
                                                                        LostFocus="ac_LostFocus"
                                                                        NoResultsContent="Nessun articolo trovato"
                                                                        SelectedItem="{Binding SelectedArticle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                        SelectionMode="Single"
                                                                        TextSearchMode="Contains"
                                                                        TextSearchPath="FullDescriptionSearchableUfp" />
                                        </DataTemplate>
                                    </telerik:GridViewDataColumn.CellEditTemplate>
                                </telerik:GridViewDataColumn>

                                <telerik:GridViewDataColumn DataMemberBinding="{Binding ageperc}" Header="%" />

                            </telerik:RadGridView.Columns>
                        </telerik:RadGridView>
                    </telerik:RadBusyIndicator>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="ENASARCO" Header="ENASARCO">
                <telerik:RadTabItem.Content>
                    <telerik:RadGridView Name="rgvEnasarco"
                                         Grid.Row="3"
                                         Grid.ColumnSpan="2"
                                         Margin="0"
                                         AddingNewDataItem="rgvEnasarco_AddingNewDataItem"
                                         AutoGenerateColumns="False"
                                         CanUserFreezeColumns="False"
                                         CanUserInsertRows="True"
                                         IsSearchingDeferred="True"
                                         ItemsSource="{Binding Enasarcos}"
                                         NewRowPosition="Top"
                                         RowDetailsVisibilityMode="VisibleWhenSelected"
                                         RowEditEnded="rgvEnasarco_RowEditEnded"
                                         RowIndicatorVisibility="Collapsed"
                                         RowIsExpandedChanging="rgvEnasarco_RowIsExpandedChanging"
                                         RowValidated="rgvEnasarco_RowValidated"
                                         RowValidating="rgvEnasarco_RowValidating"
                                         SearchMode="MatchAnyTerm"
                                         ShowGroupPanel="False"
                                         ShowSearchPanel="False"
                                         ValidatesOnDataErrors="InEditMode">
                        <telerik:RadGridView.ChildTableDefinitions>
                            <telerik:GridViewTableDefinition />
                        </telerik:RadGridView.ChildTableDefinitions>
                        <telerik:RadGridView.Columns>
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding enaann}" Header="Anno" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding enaperazi, StringFormat=N3}" Header="% carico azienda" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding enaannmax, StringFormat=N3}" Header="Massimale annuo" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding Used, StringFormat=N3}" Header="Utilizzato" />
                        </telerik:RadGridView.Columns>
                        <telerik:RadGridView.HierarchyChildTemplate>
                            <DataTemplate>
                                <Grid>
                                    <telerik:RadGridView x:Name="GridViewDetails"
                                                         AutoGenerateColumns="False"
                                                         BorderThickness="0,1,0,1"
                                                         CanUserFreezeColumns="False"
                                                         GridLinesVisibility="None"
                                                         GroupRenderMode="Flat"
                                                         IsReadOnly="True"
                                                         ItemsSource="{Binding Items}"
                                                         ShowGroupPanel="False">
                                        <telerik:RadGridView.Columns>


                                            <telerik:GridViewCheckBoxColumn Width="40"
                                                                            DataMemberBinding="{Binding fattstampaBool}"
                                                                            Header="S"
                                                                            HeaderTextAlignment="Center"
                                                                            IsReadOnly="True"
                                                                            TextAlignment="Center" />
                                            <telerik:GridViewCheckBoxColumn Width="40"
                                                                            DataMemberBinding="{Binding accountedBool}"
                                                                            Header="C"
                                                                            HeaderTextAlignment="Center"
                                                                            IsReadOnly="True"
                                                                            TextAlignment="Center" />
                                            <telerik:GridViewDataColumn DataMemberBinding="{Binding fattnum}" Header="Fattura n." IsReadOnly="True">
                                                <telerik:GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button x:Name="cmdEdit"
                                                                Margin="3"
                                                                HorizontalContentAlignment="Left"
                                                                BorderBrush="{DynamicResource VulpesXBrush}"
                                                                Click="cmdEdit_Click"
                                                                Content="{Binding Path=fattnum}"
                                                                Cursor="Hand"
                                                                Foreground="{DynamicResource VulpesXBrush}" />
                                                    </DataTemplate>
                                                </telerik:GridViewColumn.CellTemplate>
                                            </telerik:GridViewDataColumn>
                                            <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy"
                                                                        DataMemberBinding="{Binding fattdata}"
                                                                        Header="Data"
                                                                        HeaderTextAlignment="Center"
                                                                        IsReadOnly="True"
                                                                        TextAlignment="Center" />
                                            <telerik:GridViewDataColumn DataMemberBinding="{Binding fattpiva}" Header="Partita IVA" IsReadOnly="True" />
                                            <telerik:GridViewDataColumn Width="300"
                                                                        DataMemberBinding="{Binding fattabers1}"
                                                                        Header="Fornitore"
                                                                        IsReadOnly="True"
                                                                        Tag="supplier" />
                                            <telerik:GridViewDataColumn Width="300"
                                                                        DataMemberBinding="{Binding Supplier.FullDescriptionSearchable}"
                                                                        Header="Fornitore gestionale"
                                                                        IsReadOnly="False" />
                                            <telerik:GridViewDataColumn Width="120"
                                                                        DataFormatString="N2"
                                                                        DataMemberBinding="{Binding fattimpo}"
                                                                        Header="Imponibile"
                                                                        HeaderTextAlignment="Right"
                                                                        IsReadOnly="True"
                                                                        TextAlignment="Right" />
                                            <telerik:GridViewDataColumn Width="120"
                                                                        DataFormatString="N2"
                                                                        DataMemberBinding="{Binding fattimposta}"
                                                                        Header="Imposta"
                                                                        HeaderTextAlignment="Right"
                                                                        IsReadOnly="True"
                                                                        TextAlignment="Right" />
                                            <telerik:GridViewDataColumn Width="120"
                                                                        DataFormatString="N2"
                                                                        DataMemberBinding="{Binding fatttot}"
                                                                        Header="Totale"
                                                                        HeaderTextAlignment="Right"
                                                                        IsReadOnly="True"
                                                                        TextAlignment="Right" />
                                            <telerik:GridViewDataColumn Width="120"
                                                                        DataFormatString="N2"
                                                                        DataMemberBinding="{Binding fattimpobol}"
                                                                        Header="Importo bollo"
                                                                        HeaderTextAlignment="Right"
                                                                        IsReadOnly="True"
                                                                        TextAlignment="Right" />
                                            <telerik:GridViewDataColumn Width="120"
                                                                        DataFormatString="N2"
                                                                        DataMemberBinding="{Binding fattimporite}"
                                                                        Header="Importo rit."
                                                                        HeaderTextAlignment="Right"
                                                                        IsReadOnly="True"
                                                                        TextAlignment="Right" />
                                            <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                                        DataMemberBinding="{Binding fattdataric}"
                                                                        Header="Data ricezione"
                                                                        HeaderTextAlignment="Center"
                                                                        IsReadOnly="True"
                                                                        TextAlignment="Center" />
                                            <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                                        DataMemberBinding="{Binding fattdatasca}"
                                                                        Header="Data download"
                                                                        HeaderTextAlignment="Center"
                                                                        IsReadOnly="True"
                                                                        TextAlignment="Center" />
                                            <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                                        DataMemberBinding="{Binding accounted}"
                                                                        Header="Data contabilizzazione"
                                                                        HeaderTextAlignment="Center"
                                                                        IsReadOnly="True"
                                                                        TextAlignment="Center" />
                                            <telerik:GridViewDataColumn DataMemberBinding="{Binding accounted_UserID}" Header="Contabilizzata da" IsReadOnly="True" />
                                            <telerik:GridViewDataColumn DataMemberBinding="{Binding fattidsdi}" Header="Identificativo SDI" IsReadOnly="True" />
                                            <telerik:GridViewDataColumn Width="250"
                                                                        DataMemberBinding="{Binding fattnomefileric}"
                                                                        Header="Nome file XML"
                                                                        IsReadOnly="True" />
                                            <telerik:GridViewDataColumn DataMemberBinding="{Binding AccountingText}"
                                                                        Header="Registrazione"
                                                                        HeaderTextAlignment="Center"
                                                                        IsReadOnly="True"
                                                                        TextAlignment="Center">
                                                <telerik:GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button x:Name="cmdViewAccounting"
                                                                Margin="3"
                                                                HorizontalContentAlignment="Left"
                                                                BorderBrush="{DynamicResource VulpesXBrush}"
                                                                Click="cmdViewAccounting_Click"
                                                                Content="{Binding Path=AccountingText}"
                                                                Cursor="Hand"
                                                                Foreground="{DynamicResource VulpesXBrush}" />
                                                    </DataTemplate>
                                                </telerik:GridViewColumn.CellTemplate>
                                            </telerik:GridViewDataColumn>
                                            <telerik:GridViewDataColumn Width="200"
                                                                        DataMemberBinding="{Binding fattcausaledes}"
                                                                        Header="Causale"
                                                                        IsReadOnly="True" />
                                            <telerik:GridViewDataColumn DataMemberBinding="{Binding Causal.FullDescriptionSearchable}" Header="Causale gestionale" IsReadOnly="True" />
                                            <telerik:GridViewDataColumn DataMemberBinding="{Binding fattcoddest}"
                                                                        Header="Codice destinatario"
                                                                        HeaderTextAlignment="Center"
                                                                        IsReadOnly="True"
                                                                        TextAlignment="Center" />
                                            <telerik:GridViewDataColumn Width="250"
                                                                        DataMemberBinding="{Binding fattpec}"
                                                                        Header="PEC"
                                                                        IsReadOnly="True" />
                                            <telerik:GridViewDataColumn Width="200"
                                                                        DataMemberBinding="{Binding TaxRegime.FullDescriptionSearchable}"
                                                                        Header="Regime fiscale"
                                                                        IsReadOnly="True" />
                                            <telerik:GridViewDataColumn Width="120"
                                                                        DataMemberBinding="{Binding ISO.FullDescriptionSearchable}"
                                                                        Header="ISO"
                                                                        IsReadOnly="True" />
                                            <telerik:GridViewDataColumn Width="200"
                                                                        DataMemberBinding="{Binding fattforloca}"
                                                                        Header="Località"
                                                                        IsReadOnly="True" />
                                            <telerik:GridViewDataColumn DataMemberBinding="{Binding fattforprov}" Header="Prov." IsReadOnly="True" />
                                            <telerik:GridViewDataColumn Width="200"
                                                                        DataMemberBinding="{Binding fattforinde}"
                                                                        Header="Indirizzo"
                                                                        IsReadOnly="True" />
                                            <telerik:GridViewDataColumn DataMemberBinding="{Binding fattforcap}" Header="C.a.p." IsReadOnly="True" />
                                            <telerik:GridViewDataColumn Width="250"
                                                                        DataMemberBinding="{Binding DocumentType.FullDescriptionSearchable}"
                                                                        Header="Tipo documento"
                                                                        IsReadOnly="True" />

                                        </telerik:RadGridView.Columns>
                                    </telerik:RadGridView>
                                </Grid>
                            </DataTemplate>
                        </telerik:RadGridView.HierarchyChildTemplate>

                    </telerik:RadGridView>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
