<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Ufp.Tables.Accounting.VETTORIWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Ufp.Tables.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli vettore"
                        Width="900"
                        Height="500"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">

            <telerik:RadTabItem DropDownContent="DATI" Header="DATI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Codice" />
                            <telerik:RadNumericUpDown Grid.Row="0"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      IsEnabled="{Binding IsInsert}"
                                                      Minimum="1"
                                                      NumberDecimalDigits="0"
                                                      Value="{Binding Data.vetcod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Descrizione" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="50"
                                     Text="{Binding Data.vetdes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Indirizzo" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="255"
                                     Text="{Binding Data.vetind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Citta'" />
                            <telerik:RadAutoCompleteBox x:Name="acCity"
                                                        Grid.Row="3"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Cities}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun comune trovato"
                                                        SelectedItem="{Binding SelectedCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acCity_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Provincia" />
                            <telerik:RadAutoCompleteBox x:Name="acState"
                                                        Grid.Row="4"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding States}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessuna provincia trovata"
                                                        SelectedItem="{Binding SelectedState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acState_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="C.a.p." />
                            <telerik:RadNumericUpDown Grid.Row="5"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      Maximum="99999"
                                                      Minimum="1"
                                                      NumberDecimalDigits="0"
                                                      Value="{Binding Data.vetcap, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />


                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Codice albo" />
                            <TextBox Grid.Row="8"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="50"
                                     Text="{Binding Data.vetcalb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="9"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Partita IVA" />
                            <telerik:RadNumericUpDown Grid.Row="9"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      Maximum="99999999999"
                                                      Minimum="0"
                                                      NumberDecimalDigits="0"
                                                      Value="{Binding Data.vetpiva, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />


                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="SPESE" Header="SPESE">
                <telerik:RadTabItem.Content>
                    <telerik:RadGridView Name="rgvExpense"
                                         Grid.Row="3"
                                         Grid.ColumnSpan="2"
                                         Margin="0"
                                         AddingNewDataItem="rgvExpense_AddingNewDataItem"
                                         AutoGenerateColumns="False"
                                         CanUserFreezeColumns="False"
                                         CanUserInsertRows="True"
                                         IsSearchingDeferred="True"
                                         ItemsSource="{Binding Expenses}"
                                         NewRowPosition="Top"
                                         RowDetailsVisibilityMode="VisibleWhenSelected"
                                         RowEditEnded="rgvExpense_RowEditEnded"
                                         RowIndicatorVisibility="Collapsed"
                                         RowValidated="rgvExpense_RowValidated"
                                         RowValidating="rgvExpense_RowValidating"
                                         SearchMode="MatchAnyTerm"
                                         ShowGroupPanel="False"
                                         ShowSearchPanel="False"
                                         ValidatesOnDataErrors="InEditMode">
                        <telerik:RadGridView.Columns>

                            <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding ISODescription}" Header="Iso">
                                <telerik:GridViewDataColumn.CellEditTemplate>
                                    <DataTemplate>
                                        <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                    GotFocus="ac_GotFocus"
                                                                    ItemsSource="{Binding ISOs}"
                                                                    LostFocus="ac_LostFocus"
                                                                    NoResultsContent="Nessun ISO trovato"
                                                                    SelectedItem="{Binding SelectedISO, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    SelectionMode="Single"
                                                                    TextSearchMode="Contains"
                                                                    TextSearchPath="FullDescriptionSearchable" />
                                    </DataTemplate>
                                </telerik:GridViewDataColumn.CellEditTemplate>
                            </telerik:GridViewDataColumn>

                            <telerik:GridViewDataColumn DataMemberBinding="{Binding vetpes}" Header="Da peso" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding Vetapes}" Header="A peso" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding vetpre}" Header="Spese" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding vetcos}" Header="Costo" />

                        </telerik:RadGridView.Columns>
                    </telerik:RadGridView>

                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
