<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Ufp.Tables.CRM.AF.ANAFAT_CONSTWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Ufp.Tables.CRM.AF"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Parametri Analisi fattibilità"
                        Width="800"
                        Height="768"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabControl.Items>
                <telerik:RadTabItem DropDownContent="DATI" Header="DATI">
                    <telerik:RadTabItem.Content>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <Grid Margin="0,15,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="15" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="15" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="15" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="15" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4*" />
                                    <ColumnDefinition Width="6*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Periodo" />
                                <telerik:RadDateTimePicker x:Name="rdtPeriod"
                                                           Grid.Row="0"
                                                           Grid.Column="1"
                                                           Margin="5,0,5,0"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Month"
                                                           DateTimeWatermarkContent="Scegliere il periodo"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           IsEnabled="{Binding IsInsert}"
                                                           ParseExact="False"
                                                           SelectedValue="{Binding Data.afdata, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Attivo"
                                           TextAlignment="Right" />
                                <telerik:RadToggleSwitchButton Grid.Row="1"
                                                               Grid.Column="1"
                                                               Margin="5,0,0,0"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Data.IsActive}"
                                                               IsChecked="{Binding Data.IsActive}"
                                                               UncheckedContent="No" />

                                <Border Grid.Row="2"
                                        Grid.RowSpan="2"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="5,0,5,0"
                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                        BorderThickness="1">
                                    <TextBlock Padding="0"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Opacity=".8"
                                               Text="PRODUZIONE"
                                               TextAlignment="Center"
                                               Typography.Capitals="AllSmallCaps">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="270" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </Border>

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Presidiato" />
                                <telerik:RadNumericUpDown Grid.Row="2"
                                                          Grid.Column="1"
                                                          Margin="5,5,10,5"
                                                          Minimum="0"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.afproductionpre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Non presidiato" />
                                <telerik:RadNumericUpDown Grid.Row="3"
                                                          Grid.Column="1"
                                                          Margin="5,5,10,5"
                                                          Minimum="0"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.afproductionaut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Border Grid.Row="5"
                                        Grid.RowSpan="3"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="5,0,5,0"
                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                        BorderThickness="1">
                                    <TextBlock Padding="0"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Opacity=".8"
                                               Text="COMPLESSITA'"
                                               TextAlignment="Center"
                                               Typography.Capitals="AllSmallCaps">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="270" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </Border>

                                <TextBlock Grid.Row="5"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Standard" />
                                <telerik:RadNumericUpDown Grid.Row="5"
                                                          Grid.Column="1"
                                                          Margin="5,5,10,5"
                                                          Minimum="0"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.afcomplexitysta, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="6"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Media" />
                                <telerik:RadNumericUpDown Grid.Row="6"
                                                          Grid.Column="1"
                                                          Margin="5,5,10,5"
                                                          Minimum="0"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.afcomplexitymed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="7"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Complessa" />
                                <telerik:RadNumericUpDown Grid.Row="7"
                                                          Grid.Column="1"
                                                          Margin="5,5,10,5"
                                                          Minimum="0"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.afcomplexitycom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Border Grid.Row="9"
                                        Grid.RowSpan="2"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="5,0,5,0"
                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                        BorderThickness="1">
                                    <TextBlock Padding="0"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Opacity=".8"
                                               Text="MARG. CLIENTE"
                                               TextAlignment="Center"
                                               Typography.Capitals="AllSmallCaps">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="270" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </Border>

                                <TextBlock Grid.Row="9"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="ICO" />
                                <telerik:RadNumericUpDown Grid.Row="9"
                                                          Grid.Column="1"
                                                          Margin="5,5,10,5"
                                                          Minimum="0"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.afcliico, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="10"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Diretto" />
                                <telerik:RadNumericUpDown Grid.Row="10"
                                                          Grid.Column="1"
                                                          Margin="5,5,10,5"
                                                          Minimum="0"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.afclidir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Border Grid.Row="12"
                                        Grid.RowSpan="2"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="5,0,5,0"
                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                        BorderThickness="1">
                                    <TextBlock Padding="0"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Opacity=".8"
                                               Text="PROV. CLIENTE"
                                               TextAlignment="Center"
                                               Typography.Capitals="AllSmallCaps">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="270" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </Border>

                                <TextBlock Grid.Row="12"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="ICO" />
                                <telerik:RadNumericUpDown Grid.Row="12"
                                                          Grid.Column="1"
                                                          Margin="5,5,10,5"
                                                          Minimum="0"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.afproico, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="13"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Diretto" />
                                <telerik:RadNumericUpDown Grid.Row="13"
                                                          Grid.Column="1"
                                                          Margin="5,5,10,5"
                                                          Minimum="0"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.afprodir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <telerik:RadGridView x:Name="GridQuantity"
                                                     Grid.Row="15"
                                                     Grid.ColumnSpan="2"
                                                     Margin="5"
                                                     AddingNewDataItem="GridQuantity_AddingNewDataItem"
                                                     AutoGenerateColumns="False"
                                                     CanUserDeleteRows="True"
                                                     CanUserFreezeColumns="False"
                                                     CanUserInsertRows="True"
                                                     CanUserResizeColumns="False"
                                                     GroupRenderMode="Flat"
                                                     ItemsSource="{Binding Data.Pieces}"
                                                     NewRowPosition="Bottom"
                                                     RowValidating="GridQuantity_RowValidating"
                                                     ShowGroupPanel="False">
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewDataColumn DataFormatString="N0" DataMemberBinding="{Binding afppiecesfrom}" Header="Da pezzi" />

                                        <telerik:GridViewDataColumn DataFormatString="N0" DataMemberBinding="{Binding afppiecesto}" Header="A pezzi" />

                                        <telerik:GridViewDataColumn DataFormatString="N2" DataMemberBinding="{Binding afppercentage}" Header="%" />
                                        <telerik:GridViewComboBoxColumn DataMemberBinding="{Binding afpproductiontype}"
                                                                        DisplayMemberPath="Description"
                                                                        Header="Tipo produzione"
                                                                        IsLightweightModeEnabled="True"
                                                                        ItemsSource="{Binding ProductionTypes}"
                                                                        SelectedValueMemberPath="ID" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding afpproductionpre_enabled}" Header="Abilita non presidiato">
                                            <telerik:GridViewDataColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding afpproductionpre_enabled}" />
                                                </DataTemplate>
                                            </telerik:GridViewDataColumn.CellTemplate>
                                            <telerik:GridViewDataColumn.CellEditTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding afpproductionpre_enabled}" />
                                                </DataTemplate>
                                            </telerik:GridViewDataColumn.CellEditTemplate>
                                        </telerik:GridViewDataColumn>
                                    </telerik:RadGridView.Columns>
                                </telerik:RadGridView>
                            </Grid>
                        </ScrollViewer>
                    </telerik:RadTabItem.Content>
                </telerik:RadTabItem>
                <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                    <telerik:RadTabItem.Content>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <Grid Margin="0,10,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="7*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Inserito il" />
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.AddedText}" />
                                    <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.AddedUserText}" />
                                </StackPanel>

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Ultimo aggiornamento il" />
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.UpdatedText}" />
                                    <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.UpdatedUserText}" />
                                </StackPanel>

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Annullato il" />
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.CanceledText}" />
                                    <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.CanceledUserText}" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </telerik:RadTabItem.Content>
                </telerik:RadTabItem>
            </telerik:RadTabControl.Items>
        </telerik:RadTabControl>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
