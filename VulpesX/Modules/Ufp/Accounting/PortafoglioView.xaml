<UserControl x:Class="VulpesX.Modules.Ufp.Accounting.PortafoglioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Ufp.Accounting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="GESTIONE PORTAFOGLIO" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="CREA DISTINTA"
                        Style="{StaticResource VulpesXInsertButton}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Margin="5"
                                         TextChanged="txtSearch_TextChanged"
                                         WatermarkContent="Cerca..." />
        </Grid>

        <telerik:RadTabControl Grid.Row="2"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="DISPOSIZIONI" Header="DISPOSIZIONI">
                <telerik:RadTabItem.Content>
                    <telerik:RadBusyIndicator x:Name="bsyGrid"
                                              BusyContent="Caricamento dati in corso..."
                                              Foreground="{DynamicResource VulpesXBrush}"
                                              IsBusy="{Binding IsBusy}"
                                              OverlayStyle="{StaticResource WaitOverlayStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="8.5*" />
                                <ColumnDefinition Width="1.5*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Margin="10,0,10,0"
                                           HorizontalAlignment="Right"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Da scadenza" />
                                <telerik:RadDateTimePicker Name="rdtFrom"
                                                           Margin="5"
                                                           HorizontalAlignment="Stretch"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Dal"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           SelectedValue="{Binding From}"
                                                           SelectionChanged="rdtFrom_SelectionChanged" />

                                <TextBlock Margin="10,0,10,0"
                                           HorizontalAlignment="Right"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="a scadenza" />
                                <telerik:RadDateTimePicker Name="rdtTo"
                                                           Margin="5"
                                                           HorizontalAlignment="Stretch"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Dal"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           SelectedValue="{Binding To}"
                                                           SelectionChanged="rdtTo_SelectionChanged" />

                                <TextBlock Margin="10,0,10,0"
                                           HorizontalAlignment="Right"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Visualizza" />
                                <telerik:RadComboBox x:Name="cmbStatus"
                                                     Margin="5"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Center"
                                                     DisplayMemberPath="Description"
                                                     SelectedValuePath="ID"
                                                     SelectionChanged="cmbStatus_SelectionChanged" />
                            </StackPanel>
                            <telerik:RadGridView x:Name="GridView"
                                                 Grid.Row="1"
                                                 Grid.Column="0"
                                                 AutoGenerateColumns="False"
                                                 BeginningEdit="GridView_BeginningEdit"
                                                 CanUserDeleteRows="False"
                                                 CanUserFreezeColumns="False"
                                                 CanUserInsertRows="False"
                                                 CanUserResizeColumns="False"
                                                 CellEditEnded="GridView_CellEditEnded"
                                                 EditTriggers="Default"
                                                 EnableLostFocusSelectedState="False"
                                                 GroupRenderMode="Flat"
                                                 IsSynchronizedWithCurrentItem="False"
                                                 ItemsSource="{Binding Items}"
                                                 RowIndicatorVisibility="Collapsed"
                                                 SelectionMode="Multiple"
                                                 ShowGroupPanel="True">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewSelectColumn />
                                    <telerik:GridViewColumn Width="110">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadButton x:Name="cmdDelete"
                                                                   telerik:TouchManager.TouchMode="HitTestHidden"
                                                                   BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                                   Click="cmdDelete_Click"
                                                                   Content="Elimina"
                                                                   Style="{StaticResource VulpesXButton}"
                                                                   Visibility="{Binding CanDeleteVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewColumn Width="30">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadGlyph x:Name="rgDuplicate"
                                                                  Cursor="Hand"
                                                                  FontSize="18"
                                                                  Foreground="{DynamicResource VulpesXBrush}"
                                                                  Glyph="&#xe65d;"
                                                                  MouseDown="rgDuplicate_MouseDown"
                                                                  ToolTip="Duplica la disposizione" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding StatusDescriptionUfp}" Header="Stato" IsReadOnly="True" />
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding CustomerDescription}" Header="Cliente" IsReadOnly="True" />
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding N6REGI}" Header="Registrazione" IsReadOnly="True" />
                                    <telerik:GridViewDataColumn Width="130"
                                                                DataFormatString="dd/MM/yyyy"
                                                                DataMemberBinding="{Binding N6DARE}"
                                                                Header="Data registrazione"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />

                                    <telerik:GridViewDataColumn Width="130"
                                                                DataFormatString="dd/MM/yyyy"
                                                                DataMemberBinding="{Binding N6SCAD}"
                                                                Header="Scadenza"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center">
                                        <telerik:GridViewDataColumn.CellEditTemplate>
                                            <DataTemplate>
                                                <telerik:RadDateTimePicker Width="100"
                                                                           Margin="1"
                                                                           HorizontalAlignment="Left"
                                                                           VerticalAlignment="Center"
                                                                           DateSelectionMode="Day"
                                                                           DateTimeWatermarkContent=""
                                                                           DisplayFormat="Short"
                                                                           InputMode="DatePicker"
                                                                           IsEnabled="{Binding Tag, RelativeSource={RelativeSource AncestorType=telerik:RadGridView}}"
                                                                           SelectedValue="{Binding N6SCAD, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </telerik:GridViewDataColumn.CellEditTemplate>
                                    </telerik:GridViewDataColumn>
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding N6RIFE}" Header="Riferimento" IsReadOnly="True" />
                                    <telerik:GridViewDataColumn Width="130"
                                                                DataFormatString="dd/MM/yyyy"
                                                                DataMemberBinding="{Binding N6DARI}"
                                                                Header="Data riferimento"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn DataFormatString="N2"
                                                                DataMemberBinding="{Binding N6IMEU}"
                                                                Header="Importo"
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right">
                                        <telerik:GridViewDataColumn.CellEditTemplate>
                                            <DataTemplate>
                                                <telerik:RadNumericUpDown Minimum="0"
                                                                          NumberDecimalDigits="2"
                                                                          ShowButtons="False"
                                                                          Value="{Binding N6IMEU, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </telerik:GridViewDataColumn.CellEditTemplate>
                                    </telerik:GridViewDataColumn>
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding CustomerBankDescription}"
                                                                Header="Banca cliente"
                                                                IsReadOnly="False"
                                                                UniqueName="colCustomerBank">
                                        <telerik:GridViewDataColumn.CellEditTemplate>
                                            <DataTemplate>
                                                <telerik:RadAutoCompleteBox HorizontalAlignment="Stretch"
                                                                            VerticalAlignment="Center"
                                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                                            GotFocus="ac_GotFocus"
                                                                            ItemsSource="{Binding Banks}"
                                                                            LostFocus="ac_LostFocus"
                                                                            NoResultsContent="Nessuna banca trovata"
                                                                            SelectedItem="{Binding SelectedCustomerBank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                            SelectionMode="Single"
                                                                            TextSearchMode="Contains"
                                                                            TextSearchPath="FullDescriptionSearchable"
                                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                            </DataTemplate>
                                        </telerik:GridViewDataColumn.CellEditTemplate>
                                    </telerik:GridViewDataColumn>

                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding N6NUDI}" Header="N° distinta" IsReadOnly="True" />
                                    <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy"
                                                                DataMemberBinding="{Binding N6DADI}"
                                                                Header="Data distinta"
                                                                IsReadOnly="True" />
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding BankDescription}" Header="Banca assuntrice" IsReadOnly="True" />
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>

                            <StackPanel Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="10,2,2,2"
                                        VerticalAlignment="Bottom"
                                        Orientation="Vertical">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5*" />
                                        <ColumnDefinition Width="5*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Bottom"
                                               Style="{DynamicResource VulpesXSubtitle}"
                                               Text="SELEZIONATE" />
                                    <TextBlock Grid.Column="1"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Bottom"
                                               Style="{DynamicResource VulpesXData}"
                                               Text="{Binding TotalAmountSelected, StringFormat=N2}" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5*" />
                                        <ColumnDefinition Width="5*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               HorizontalAlignment="Right"
                                               Style="{DynamicResource VulpesXSubtitle}"
                                               Text="TOTALE" />
                                    <TextBlock Grid.Column="1"
                                               HorizontalAlignment="Right"
                                               Style="{DynamicResource VulpesXData}"
                                               Text="{Binding TotalAmount, StringFormat=N2}" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </telerik:RadBusyIndicator>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="STORICO DISTINTE" Header="STORICO DISTINTE">
                <telerik:RadTabItem.Content>
                    <telerik:RadBusyIndicator x:Name="bsyGridDist"
                                              BusyContent="Caricamento dati in corso..."
                                              Foreground="{DynamicResource VulpesXBrush}"
                                              IsBusy="{Binding IsBusyHistory}"
                                              OverlayStyle="{StaticResource WaitOverlayStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="35" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <telerik:RadComboBox x:Name="cmbYear"
                                                     Grid.Row="1"
                                                     Grid.Column="1"
                                                     Width="100"
                                                     Margin="5"
                                                     HorizontalAlignment="Left"
                                                     VerticalAlignment="Center"
                                                     HorizontalContentAlignment="Center"
                                                     DisplayMemberPath="eseann"
                                                     SelectionChanged="cmbYear_SelectionChanged" />
                            </StackPanel>


                            <telerik:RadGridView x:Name="GridViewDist"
                                                 Grid.Row="1"
                                                 Grid.Column="0"
                                                 AutoGenerateColumns="False"
                                                 CanUserFreezeColumns="False"
                                                 CanUserResizeColumns="False"
                                                 GroupRenderMode="Flat"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding PagedSource, ElementName=rdpGridDist}"
                                                 RowIndicatorVisibility="Hidden"
                                                 SelectionMode="Single"
                                                 ShowGroupPanel="True">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewColumn Width="30">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadGlyph x:Name="rgDelete"
                                                                  Cursor="{Binding DeleteCursor}"
                                                                  FontSize="18"
                                                                  Foreground="{DynamicResource VulpesXRedBrush}"
                                                                  Glyph="&#xe10c;"
                                                                  MouseDown="rgDelete_MouseDown"
                                                                  ToolTip="{Binding DeleteToolTip}"
                                                                  Visibility="{Binding DeleteIconVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewColumn Width="30">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadGlyph x:Name="rgAccounting"
                                                                  Cursor="{Binding AccountingCursor}"
                                                                  FontSize="18"
                                                                  Foreground="{DynamicResource VulpesXBrush}"
                                                                  Glyph="&#xe10f;"
                                                                  MouseDown="rgAccounting_MouseDown"
                                                                  ToolTip="{Binding AccountingToolTip}"
                                                                  Visibility="{Binding AccountingIconVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewColumn Width="30">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadGlyph x:Name="rgGenerate"
                                                                  Cursor="Hand"
                                                                  FontSize="18"
                                                                  Foreground="{DynamicResource VulpesXGreenBrush}"
                                                                  Glyph="&#xe941;"
                                                                  MouseDown="rgGenerate_MouseDown"
                                                                  ToolTip="Genera il file CBI da inviare alla banca" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewDataColumn Width="150"
                                                                DataMemberBinding="{Binding id}"
                                                                Header="Distinta n."
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button x:Name="cmdEditDist"
                                                        Margin="3"
                                                        HorizontalContentAlignment="Center"
                                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                                        Click="cmdEditDist_Click"
                                                        Content="{Binding Path=id}"
                                                        Cursor="Hand"
                                                        Foreground="{DynamicResource VulpesXBrush}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewDataColumn>
                                    <telerik:GridViewDataColumn Width="160"
                                                                DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                                DataMemberBinding="{Binding extraction_date}"
                                                                Header="Data estrazione"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="120"
                                                                DataFormatString="N2"
                                                                DataMemberBinding="{Binding amount}"
                                                                Header="Importo"
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="500" DataMemberBinding="{Binding BankDescription}" Header="Banca" />
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>
                            <telerik:RadDataPager x:Name="rdpGridDist"
                                                  Grid.Row="2"
                                                  Grid.Column="0"
                                                  Margin="0,-1,0,0"
                                                  DisplayMode="FirstLastPreviousNextNumeric, Text"
                                                  FontSize="12"
                                                  IsTotalItemCountFixed="True"
                                                  PageSize="20"
                                                  Source="{Binding ItemsDist}" />
                        </Grid>
                    </telerik:RadBusyIndicator>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>
    </Grid>
</UserControl>
