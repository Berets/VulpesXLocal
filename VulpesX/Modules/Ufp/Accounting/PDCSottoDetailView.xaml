<UserControl x:Class="VulpesX.Modules.Ufp.Accounting.PDCSottoDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:culture="clr-namespace:System.Globalization;assembly=mscorlib"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Ufp.Accounting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Border Margin="5,1,1,1"
            Padding="1"
            BorderBrush="{DynamicResource VulpesXBrush}"
            BorderThickness="2">

        <ScrollViewer HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Margin="15,0,0,10"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Top"
                           FontSize="20"
                           Foreground="{DynamicResource VulpesXBrush}"
                           Text="DETTAGLI SOTTOCONTO" />

                <TextBlock Grid.Row="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Top"
                           FontSize="20"
                           Foreground="{DynamicResource VulpesXBrush}"
                           Text="{Binding Data.P3DES1}"
                           Typography.Capitals="AllSmallCaps" />

                <StackPanel Grid.Row="1" Orientation="Vertical">

                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="7*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,15,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource VulpesXSecondBrush}"
                                   Text="Gruppo" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Width="60"
                                       Margin="5,0,15,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource VulpesXBrush}"
                                       Text="{Binding Data.P1GRUP}" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Conto" />
                            <TextBlock Width="60"
                                       Margin="5,0,15,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource VulpesXBrush}"
                                       Text="{Binding Data.P2CONT}" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="7*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,0,15,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource VulpesXSecondBrush}"
                                   Text="Codice" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Width="100"
                                 Margin="5,0,15,0"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"
                                 IsEnabled="{Binding IsInsert}"
                                 MaxLength="6"
                                 Text="{Binding Data.P3SOTC}" />
                    </Grid>

                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="7*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Margin="0,0,15,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource VulpesXSecondBrush}"
                                   Text="Descrizione" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Margin="5,0,15,0"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"
                                 MaxLength="35"
                                 Text="{Binding Data.P3DES1}" />
                    </Grid>

                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="7*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Margin="0,0,15,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource VulpesXSecondBrush}"
                                   Text="Descrizione agg." />
                        <TextBox Grid.Row="3"
                                 Grid.Column="1"
                                 Margin="5,0,15,0"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"
                                 MaxLength="35"
                                 Text="{Binding Data.P3DES2}" />
                    </Grid>

                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="7*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Margin="0,0,15,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource VulpesXSecondBrush}"
                                   Text="Cliente/Fornitore" />
                        <telerik:RadComboBox Grid.Row="4"
                                             Grid.Column="1"
                                             Margin="5,5,15,5"
                                             DisplayMemberPath="Description"
                                             ItemsSource="{Binding CFTypes}"
                                             SelectedValue="{Binding Data.P3CLFO}"
                                             SelectedValuePath="ID" />
                    </Grid>


                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="7*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="5"
                                   Grid.Column="0"
                                   Margin="0,0,15,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource VulpesXSecondBrush}"
                                   Text="Settore" />
                        <telerik:RadComboBox Grid.Row="5"
                                             Grid.Column="1"
                                             Margin="5,5,15,5"
                                             DisplayMemberPath="Description"
                                             ItemsSource="{Binding OBCPTypes}"
                                             SelectedValue="{Binding Data.p3tcon}"
                                             SelectedValuePath="ID" />
                    </Grid>

                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="7*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="6"
                                   Grid.Column="0"
                                   Margin="0,0,15,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource VulpesXSecondBrush}"
                                   Text="Obbligo contropartita" />
                        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                            <telerik:RadToggleSwitchButton CheckedContent="Sì"
                                                           Content="{Binding Data.P3OBCP}"
                                                           IsChecked="{Binding Data.P3OBCPBool}"
                                                           UncheckedContent="No" />
                            <TextBlock Margin="15,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Conto IVA" />
                            <telerik:RadToggleSwitchButton CheckedContent="Sì"
                                                           Content="{Binding Data.p3coni}"
                                                           IsChecked="{Binding Data.p3coniBool}"
                                                           UncheckedContent="No" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="7*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="7"
                                   Grid.Column="0"
                                   Margin="0,0,15,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource VulpesXSecondBrush}"
                                   Text="Utilizzo gruppo" />
                        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
                            <telerik:RadToggleSwitchButton CheckedContent="Sì"
                                                           Content="{Binding Data.p3utgr}"
                                                           IsChecked="{Binding Data.p3utgrBool}"
                                                           UncheckedContent="" />
                            <TextBlock Margin="15,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Gestione in valuta" />
                            <telerik:RadToggleSwitchButton CheckedContent="Sì"
                                                           Content="{Binding Data.p3gvalBool}"
                                                           IsChecked="{Binding Data.p3gvalBool, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           UncheckedContent="No" />
                        </StackPanel>

                    </Grid>


                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="7*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="10"
                                   Grid.Column="0"
                                   Margin="0,0,15,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource VulpesXSecondBrush}"
                                   Text="Società di riferimento" />
                        <telerik:RadComboBox Grid.Row="10"
                                             Grid.Column="1"
                                             Margin="5,5,15,5"
                                             DisplayMemberPath="SOMDES"
                                             ItemsSource="{Binding Companies}"
                                             SelectedValue="{Binding Data.p3sociTrimmed}"
                                             SelectedValuePath="SOMCOD"
                                             SelectionChanged="RadComboBox_SelectionChanged" />
                    </Grid>

                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="7*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="6"
                                   Grid.Column="0"
                                   Margin="0,0,15,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource VulpesXSecondBrush}"
                                   Text="Raggruppamento stampa mastrini" />
                        <TextBox Grid.Row="6"
                                 Grid.Column="1"
                                 Margin="5,0,15,0"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"
                                 MaxLength="35"
                                 Text="{Binding Data.p3ragmas}" />
                    </Grid>

                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="7*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Margin="0,0,15,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource VulpesXRedBrush}"
                                   Text="Obsoleto" />
                        <telerik:RadToggleSwitchButton Grid.Column="1"
                                                       CheckedContent="Sì"
                                                       Content="{Binding Data.p3est2Bool}"
                                                       IsChecked="{Binding Data.p3est2Bool, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       UncheckedContent="No" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Button Name="cmdSave"
                            Click="cmdSave_Click"
                            Content="SALVA"
                            Style="{StaticResource VulpesXConfirmButton}" />
                </StackPanel>
            </Grid>

        </ScrollViewer>
    </Border>

</UserControl>
