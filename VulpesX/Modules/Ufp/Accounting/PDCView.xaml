<UserControl x:Class="VulpesX.Modules.Ufp.Accounting.PDCView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VulpesX.Shared.Controls.Converters;assembly=VulpesX.Shared.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Ufp.Accounting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToColorConverter x:Key="boolToColorConverter"
                                         DefaultColor="{StaticResource VulpesXSecondBrush}"
                                         FalseColor="{StaticResource VulpesXSecondBrush}"
                                         TrueColor="{StaticResource VulpesXRedBrush}" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Margin="15,0,0,0"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Center"
                   FontSize="20"
                   Foreground="{DynamicResource VulpesXBrush}"
                   Text="PIANO DEI CONTI" />
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" />
                <ColumnDefinition Width="5*" />
            </Grid.ColumnDefinitions>

            <telerik:RadBusyIndicator x:Name="bsyGrid"
                                      Grid.Row="4"
                                      Grid.Column="0"
                                      BusyContent="Caricamento dati in corso..."
                                      Foreground="{DynamicResource VulpesXBrush}"
                                      IsBusy="{Binding IsBusy}"
                                      OverlayStyle="{StaticResource WaitOverlayStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.Resources>
                        <ResourceDictionary>
                            <DataTemplate x:Key="YearTemplate">
                                <Grid Visibility="{Binding Visibility}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <telerik:RadGlyph Grid.Row="0"
                                                      Grid.Column="0"
                                                      FontSize="16"
                                                      Foreground="{DynamicResource VulpesXBrush}"
                                                      Glyph="{StaticResource GlyphDragAndDrop}" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Margin="5,0"
                                               Text="{Binding P4ANNO}" />

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="2"
                                               Margin="5,0"
                                               FontStyle="Italic"
                                               Text="Periodo" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="3"
                                               Margin="5,0"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Text="D" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="4"
                                               Margin="5,0"
                                               Text="{Binding p4dpe, StringFormat=N2}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="5"
                                               Margin="5,0"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Text="A" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="6"
                                               Margin="5,0"
                                               Text="{Binding p4ape, StringFormat=N2}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="7"
                                               Margin="5,0"
                                               FontStyle="Italic"
                                               Text="=&gt;" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="8"
                                               Margin="5,0"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Text="{Binding PeriodBalanceSign}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="9"
                                               Margin="5,0"
                                               Text="{Binding PeriodBalance, StringFormat=N2}" />

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="2"
                                               Margin="5,0"
                                               FontStyle="Italic"
                                               Text="Esercizio" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="3"
                                               Margin="5,0"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Text="D" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="4"
                                               Margin="5,0"
                                               Text="{Binding p4dee, StringFormat=N2}" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="5"
                                               Margin="5,0"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Text="A" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="6"
                                               Margin="5,0"
                                               Text="{Binding p4aee, StringFormat=N2}" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="7"
                                               Margin="5,0"
                                               FontStyle="Italic"
                                               Text="=&gt;" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="8"
                                               Margin="5,0"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Text="{Binding YearBalanceSign}" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="9"
                                               Margin="5,0"
                                               Text="{Binding YearBalance, StringFormat=N2}" />
                                </Grid>
                            </DataTemplate>

                            <HierarchicalDataTemplate x:Key="SubaccountTemplate" ItemTemplate="{StaticResource YearTemplate}" ItemsSource="{Binding Years}">
                                <StackPanel Orientation="Horizontal" Visibility="{Binding Visibility}">
                                    <telerik:RadGlyph FontSize="16" Foreground="{DynamicResource VulpesXBrush}" Glyph="{StaticResource GlyphCategorize}" />
                                    <TextBlock Margin="5,0" Text="{Binding P3SOTC}" />
                                    <TextBlock Foreground="{Binding p3est2Bool, Converter={StaticResource boolToColorConverter}}" Text="{Binding P3DES1}" />
                                    <TextBlock Text=" - " Visibility="{Binding p3ragmas, Converter={StaticResource stringNullabilityToVisibilityConverter}}" />
                                    <TextBlock Text="{Binding p3ragmas}" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                            <HierarchicalDataTemplate x:Key="AccountTemplate" ItemTemplate="{StaticResource SubaccountTemplate}" ItemsSource="{Binding Subaccounts}">
                                <StackPanel Orientation="Horizontal" Visibility="{Binding Visibility}">
                                    <telerik:RadGlyph FontSize="16" Foreground="{DynamicResource VulpesXBrush}" Glyph="{StaticResource GlyphGridLayout}" />
                                    <TextBlock Margin="5,0" Text="{Binding P2CONT}" />
                                    <TextBlock Text="{Binding P2DES1}" />
                                    <TextBlock Text=" - " Visibility="{Binding p2ragmas, Converter={StaticResource stringNullabilityToVisibilityConverter}}" />
                                    <TextBlock Text="{Binding p2ragmas}" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                            <HierarchicalDataTemplate x:Key="GroupTemplate" ItemTemplate="{StaticResource AccountTemplate}" ItemsSource="{Binding Accounts}">
                                <StackPanel Orientation="Horizontal" Visibility="{Binding Visibility}">
                                    <telerik:RadGlyph FontSize="16" Foreground="{DynamicResource VulpesXBrush}" Glyph="{StaticResource GlyphGroup}" />
                                    <TextBlock Margin="5,0" Text="{Binding P1GRUP}" />
                                    <TextBlock Text="{Binding P1DES1}" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </ResourceDictionary>
                    </Grid.Resources>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <telerik:RadWatermarkTextBox x:Name="txtSearchGroups"
                                                     Grid.Column="0"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Stretch"
                                                     SelectionOnFocus="SelectAll"
                                                     TextChanged="txtSearch_TextChanged"
                                                     WatermarkContent="Cerca gruppi" />
                        <telerik:RadWatermarkTextBox x:Name="txtSearchAccounts"
                                                     Grid.Column="1"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Stretch"
                                                     SelectionOnFocus="SelectAll"
                                                     TextChanged="txtSearch_TextChanged"
                                                     WatermarkContent="Cerca conti" />
                        <telerik:RadWatermarkTextBox x:Name="txtSearchSubaccounts"
                                                     Grid.Column="2"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Stretch"
                                                     SelectionOnFocus="SelectAll"
                                                     TextChanged="txtSearch_TextChanged"
                                                     WatermarkContent="Cerca sottoconti" />
                        <telerik:RadWatermarkTextBox x:Name="txtSearchYears"
                                                     Grid.Column="3"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Stretch"
                                                     SelectionOnFocus="SelectAll"
                                                     TextChanged="txtSearch_TextChanged"
                                                     WatermarkContent="Cerca anni" />
                    </Grid>

                    <telerik:RadTreeView x:Name="treePDC"
                                         Grid.Row="1"
                                         Padding="0"
                                         BorderThickness="0"
                                         IsEditable="False"
                                         IsExpandOnSingleClickEnabled="False"
                                         IsSingleExpandPath="False"
                                         IsVirtualizing="False"
                                         ItemTemplate="{StaticResource GroupTemplate}"
                                         ItemsSource="{Binding Items}"
                                         SelectionChanged="treePDC_SelectionChanged"
                                         SelectionMode="Single">
                        <telerik:RadContextMenu.ContextMenu>
                            <telerik:RadContextMenu x:Name="cmTree" Opening="cmTree_Opening">
                                <telerik:RadMenuItem x:Name="rmiAddGroup"
                                                     Click="rmiAddGroup_Click"
                                                     Header="Aggiungi gruppo"
                                                     Typography.Capitals="AllSmallCaps">
                                    <telerik:RadMenuItem.Icon>
                                        <Image Width="16"
                                               Height="16"
                                               Source="{telerik:RadGlyph Glyph={StaticResource GlyphGroup}}"
                                               Stretch="Uniform" />
                                    </telerik:RadMenuItem.Icon>
                                </telerik:RadMenuItem>
                                <telerik:RadMenuItem x:Name="rmiDeleteGroup"
                                                     Click="rmiDeleteGroup_Click"
                                                     Header="Elimina gruppo"
                                                     Typography.Capitals="AllSmallCaps">
                                    <telerik:RadMenuItem.Icon>
                                        <telerik:RadGlyph FontSize="16" Foreground="{DynamicResource VulpesXRedBrush}" Glyph="{StaticResource GlyphGroup}" />
                                    </telerik:RadMenuItem.Icon>
                                </telerik:RadMenuItem>
                                <telerik:RadMenuItem x:Name="rmiAddAccount"
                                                     Click="rmiAddAccount_Click"
                                                     Header="Aggiungi conto"
                                                     Typography.Capitals="AllSmallCaps">
                                    <telerik:RadMenuItem.Icon>
                                        <Image Width="16"
                                               Height="16"
                                               Source="{telerik:RadGlyph Glyph={StaticResource GlyphGridLayout}}"
                                               Stretch="Uniform" />
                                    </telerik:RadMenuItem.Icon>
                                </telerik:RadMenuItem>
                                <telerik:RadMenuItem x:Name="rmiDeleteAccount"
                                                     Click="rmiDeleteAccount_Click"
                                                     Header="Elimina conto"
                                                     Typography.Capitals="AllSmallCaps">
                                    <telerik:RadMenuItem.Icon>
                                        <telerik:RadGlyph FontSize="16" Foreground="{DynamicResource VulpesXRedBrush}" Glyph="{StaticResource GlyphGridLayout}" />
                                    </telerik:RadMenuItem.Icon>
                                </telerik:RadMenuItem>
                                <telerik:RadMenuItem x:Name="rmiAddSubaccount"
                                                     Click="rmiAddSubaccount_Click"
                                                     Header="Aggiungi sottoconto"
                                                     Typography.Capitals="AllSmallCaps">
                                    <telerik:RadMenuItem.Icon>
                                        <Image Width="16"
                                               Height="16"
                                               Source="{telerik:RadGlyph Glyph={StaticResource GlyphCategorize}}"
                                               Stretch="Uniform" />
                                    </telerik:RadMenuItem.Icon>
                                </telerik:RadMenuItem>
                                <telerik:RadMenuItem x:Name="rmiDeleteSubaccount"
                                                     Click="rmiDeleteSubaccount_Click"
                                                     Header="Elimina sottoconto"
                                                     Typography.Capitals="AllSmallCaps">
                                    <telerik:RadMenuItem.Icon>
                                        <telerik:RadGlyph FontSize="16" Foreground="{DynamicResource VulpesXRedBrush}" Glyph="{StaticResource GlyphCategorize}" />
                                    </telerik:RadMenuItem.Icon>
                                </telerik:RadMenuItem>
                                <telerik:RadMenuItem x:Name="rmiAddYear"
                                                     Click="rmiAddYear_Click"
                                                     Header="Aggiungi anno"
                                                     Typography.Capitals="AllSmallCaps">
                                    <telerik:RadMenuItem.Icon>
                                        <Image Width="16"
                                               Height="16"
                                               Source="{telerik:RadGlyph Glyph={StaticResource GlyphDragAndDrop}}"
                                               Stretch="Uniform" />
                                    </telerik:RadMenuItem.Icon>
                                </telerik:RadMenuItem>
                                <telerik:RadMenuItem x:Name="rmiDeleteYear"
                                                     Click="rmiDeleteYear_Click"
                                                     Header="Elimina anno"
                                                     Typography.Capitals="AllSmallCaps">
                                    <telerik:RadMenuItem.Icon>
                                        <telerik:RadGlyph FontSize="16" Foreground="{DynamicResource VulpesXRedBrush}" Glyph="{StaticResource GlyphDragAndDrop}" />
                                    </telerik:RadMenuItem.Icon>
                                </telerik:RadMenuItem>
                            </telerik:RadContextMenu>
                        </telerik:RadContextMenu.ContextMenu>
                    </telerik:RadTreeView>
                </Grid>
            </telerik:RadBusyIndicator>

            <DockPanel x:Name="dockDetails"
                       Grid.Column="2"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch" />
        </Grid>
    </Grid>

</UserControl>
