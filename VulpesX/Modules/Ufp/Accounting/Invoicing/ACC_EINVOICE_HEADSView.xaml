<UserControl x:Class="VulpesX.Modules.Ufp.Accounting.Invoicing.ACC_EINVOICE_HEADSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cellSelectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Ufp.Accounting.Invoicing"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Style="{StaticResource VulpesXTitle}" Text="GESTIONE FATTURE ELETTRONICHE" />


        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="40" />
                <RowDefinition Height="5" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50*" />
                    <ColumnDefinition Width="50*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Left" Orientation="Horizontal">
                    <Button Name="cmdDownload"
                            Width="200"
                            Margin="5"
                            HorizontalAlignment="Left"
                            Click="cmdDownload_Click"
                            Content="SCARICA FATTURE"
                            FontSize="12"
                            Style="{StaticResource VulpesXConfirmButton}" />
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock Grid.Column="0"
                               Margin="0,0,10,0"
                               Style="{StaticResource VulpesXLabel}"
                               Text="Periodo"
                               TextAlignment="Right" />
                    <telerik:RadDateTimePicker x:Name="rdtPeriod"
                                               Width="200"
                                               Margin="5,0,5,0"
                                               VerticalAlignment="Center"
                                               DateSelectionMode="Month"
                                               DateTimeWatermarkContent="Scegliere il periodo"
                                               DisplayFormat="Short"
                                               InputMode="DatePicker"
                                               ParseExact="False"
                                               SelectedValue="{Binding Period, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                               SelectionChanged="rdtPeriod_SelectionChanged" />
                </StackPanel>
            </Grid>



            <Grid Grid.Row="1" HorizontalAlignment="Stretch">
                <telerik:RadWatermarkTextBox Name="txtSearch"
                                             Margin="5"
                                             TextChanged="txtSearch_TextChanged"
                                             WatermarkContent="Cerca..." />
            </Grid>

            <telerik:RadBusyIndicator x:Name="bsyGrid"
                                      Grid.Row="3"
                                      BusyContent="Caricamento dati in corso..."
                                      Foreground="{DynamicResource VulpesXBrush}"
                                      IsBusy="{Binding IsBusy}"
                                      OverlayStyle="{StaticResource WaitOverlayStyle}">
                <Grid>
                    <Grid.Resources>
                        <DataTemplate x:Key="InvoiceAttachmentsIcon">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="{Binding InvoiceAttachmentsStatusColor}" Cursor="{Binding InvoiceAttachmentsCursor}">
                                    <Label x:Name="label" ToolTip="{Binding InvoiceAttachmentsStatusText}">
                                        <telerik:RadGlyph x:Name="rgInvoiceAttachmentsIcon"
                                                          Cursor="Hand"
                                                          FontSize="14"
                                                          Foreground="{Binding InvoiceAttachmentsStatusColor, Converter={StaticResource stringToColorConverter}}"
                                                          Glyph="&#xe10e;"
                                                          MouseDown="rgInvoiceAttachmentsIcon_MouseDown" />
                                    </Label>
                                </Border>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding InvoiceAttachmentsText}" />
                            </Grid>
                        </DataTemplate>
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="35" />
                    </Grid.RowDefinitions>
                    <telerik:RadGridView x:Name="GridView"
                                         Grid.Row="0"
                                         AutoGenerateColumns="False"
                                         BeginningEdit="GridView_BeginningEdit"
                                         CanUserFreezeColumns="True"
                                         CanUserResizeColumns="True"
                                         GroupRenderMode="Flat"
                                         ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                         LeftFrozenColumnCount="8"
                                         RowIndicatorVisibility="Collapsed"
                                         RowValidating="GridView_RowValidating"
                                         SelectionMode="Single"
                                         ShowGroupPanel="True">
                        <telerik:RadContextMenu.ContextMenu>
                            <telerik:RadContextMenu x:Name="cmGridReceived" Opening="cmGridReceived_Opening">
                                <telerik:RadMenuItem x:Name="rmiAccountingReceived"
                                                     Click="rmiAccountingReceived_Click"
                                                     Header="Contabilizzazione"
                                                     Typography.Capitals="AllSmallCaps">
                                    <telerik:RadMenuItem.Icon>
                                        <Image Width="16"
                                               Height="16"
                                               Source="{telerik:RadGlyph Glyph={StaticResource GlyphLinkHorizontal}}"
                                               Stretch="Uniform" />
                                    </telerik:RadMenuItem.Icon>
                                </telerik:RadMenuItem>
                            </telerik:RadContextMenu>
                        </telerik:RadContextMenu.ContextMenu>
                        <telerik:RadGridView.Resources>
                            <cellSelectors:eInvoiceEntityCellSelector x:Key="eInvoiceEntityCellSelector">
                                <cellSelectors:eInvoiceEntityCellSelector.SupplierCreateStyle>
                                    <DataTemplate>
                                        <Button x:Name="cmdAddEntity"
                                                Margin="3"
                                                HorizontalContentAlignment="Left"
                                                BorderBrush="Gold"
                                                Click="cmdAddEntity_Click"
                                                Content="{Binding Path=fattabers1}"
                                                Cursor="Hand"
                                                Foreground="Gold"
                                                ToolTip="Non è stata trovata nessuna anagrafica corrispondente, cliccare qui per crearla" />
                                    </DataTemplate>
                                </cellSelectors:eInvoiceEntityCellSelector.SupplierCreateStyle>
                                <cellSelectors:eInvoiceEntityCellSelector.SupplierStandardStyle>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Path=fattabers1}" />
                                    </DataTemplate>
                                </cellSelectors:eInvoiceEntityCellSelector.SupplierStandardStyle>
                                <cellSelectors:eInvoiceEntityCellSelector.CustomerCreateStyle>
                                    <DataTemplate>
                                        <Button x:Name="cmdAddEntity"
                                                Margin="3"
                                                HorizontalContentAlignment="Left"
                                                BorderBrush="Gold"
                                                Click="cmdAddEntity_Click"
                                                Content="{Binding Path=fattclirags}"
                                                Cursor="Hand"
                                                Foreground="Gold"
                                                ToolTip="Non è stata trovata nessuna anagrafica corrispondente, cliccare qui per crearla" />
                                    </DataTemplate>
                                </cellSelectors:eInvoiceEntityCellSelector.CustomerCreateStyle>
                                <cellSelectors:eInvoiceEntityCellSelector.CustomerStandardStyle>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Path=fattclirags}" />
                                    </DataTemplate>
                                </cellSelectors:eInvoiceEntityCellSelector.CustomerStandardStyle>
                            </cellSelectors:eInvoiceEntityCellSelector>
                        </telerik:RadGridView.Resources>
                        <telerik:RadGridView.Columns>
                            <telerik:GridViewColumn Width="90">
                                <telerik:GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <telerik:RadButton x:Name="cmdDelete"
                                                           telerik:TouchManager.TouchMode="HitTestHidden"
                                                           BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                           Click="cmdDelete_Click"
                                                           Content="Elimina"
                                                           Style="{StaticResource VulpesXButton}" />
                                    </DataTemplate>
                                </telerik:GridViewColumn.CellTemplate>
                            </telerik:GridViewColumn>
                            <telerik:GridViewColumn Width="30">
                                <telerik:GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <telerik:RadGlyph x:Name="rgPrint"
                                                          Cursor="Hand"
                                                          FontSize="16"
                                                          Foreground="{DynamicResource VulpesXGreenBrush}"
                                                          Glyph="&#xe90e;"
                                                          MouseDown="rgPrint_MouseDown"
                                                          ToolTip="Stampa la fattura in formato standard" />
                                    </DataTemplate>
                                </telerik:GridViewColumn.CellTemplate>
                            </telerik:GridViewColumn>
                            <telerik:GridViewColumn Width="30">
                                <telerik:GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <telerik:RadGlyph x:Name="rgCheckInvoice"
                                                          Cursor="Hand"
                                                          FontSize="16"
                                                          Foreground="{DynamicResource VulpesXBrush}"
                                                          Glyph="&#xe13d;"
                                                          MouseDown="rgCheckInvoice_MouseDown"
                                                          ToolTip="Confronto righe - entrata merce" />
                                    </DataTemplate>
                                </telerik:GridViewColumn.CellTemplate>
                            </telerik:GridViewColumn>

                            <telerik:GridViewDataColumn Width="80"
                                                        CellTemplate="{StaticResource InvoiceAttachmentsIcon}"
                                                        Header="Allegati"
                                                        IsReadOnly="True" />
                            <telerik:GridViewCheckBoxColumn Width="40"
                                                            DataMemberBinding="{Binding fattstampaBool}"
                                                            Header="S"
                                                            HeaderTextAlignment="Center"
                                                            IsReadOnly="True"
                                                            TextAlignment="Center" />
                            <telerik:GridViewCheckBoxColumn Width="40"
                                                            DataMemberBinding="{Binding accountedBool}"
                                                            Header="C"
                                                            HeaderTextAlignment="Center"
                                                            IsReadOnly="True"
                                                            TextAlignment="Center" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding fattnum}" Header="Fattura n." IsReadOnly="True">
                                <telerik:GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button x:Name="cmdEdit"
                                                Margin="3"
                                                HorizontalContentAlignment="Left"
                                                BorderBrush="{DynamicResource VulpesXBrush}"
                                                Click="cmdEdit_Click"
                                                Content="{Binding Path=fattnum}"
                                                Cursor="Hand"
                                                Foreground="{DynamicResource VulpesXBrush}" />
                                    </DataTemplate>
                                </telerik:GridViewColumn.CellTemplate>
                            </telerik:GridViewDataColumn>
                            <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy"
                                                        DataMemberBinding="{Binding fattdata}"
                                                        Header="Data"
                                                        HeaderTextAlignment="Center"
                                                        IsReadOnly="True"
                                                        TextAlignment="Center" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding fattpiva}" Header="Partita IVA" IsReadOnly="True" />
                            <telerik:GridViewDataColumn Width="300"
                                                        CellTemplateSelector="{StaticResource eInvoiceEntityCellSelector}"
                                                        DataMemberBinding="{Binding fattabers1}"
                                                        Header="Fornitore"
                                                        IsReadOnly="True"
                                                        Tag="supplier" />
                            <telerik:GridViewDataColumn Width="300"
                                                        DataMemberBinding="{Binding Supplier.FullDescriptionSearchable}"
                                                        Header="Fornitore gestionale"
                                                        IsReadOnly="False">
                                <telerik:GridViewDataColumn.CellEditTemplate>
                                    <DataTemplate>
                                        <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                    ItemsSource="{Binding Suppliers}"
                                                                    NoResultsContent="Nessun fornitore di costo trovato"
                                                                    SelectedItem="{Binding Supplier, Mode=TwoWay}"
                                                                    SelectionMode="Single"
                                                                    TextSearchMode="Contains"
                                                                    TextSearchPath="FullDescriptionSearchable" />
                                    </DataTemplate>
                                </telerik:GridViewDataColumn.CellEditTemplate>
                            </telerik:GridViewDataColumn>
                            <telerik:GridViewColumn Width="30">
                                <telerik:GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <telerik:RadGlyph x:Name="rgAbe"
                                                          Cursor="Hand"
                                                          FontSize="14"
                                                          Foreground="{DynamicResource VulpesXGreenBrush}"
                                                          Glyph="&#xe13e;"
                                                          MouseDown="rgAbe_MouseDown"
                                                          ToolTip="Visualizza anagrafica" />
                                    </DataTemplate>
                                </telerik:GridViewColumn.CellTemplate>
                            </telerik:GridViewColumn>
                            <telerik:GridViewDataColumn Width="120"
                                                        DataFormatString="N2"
                                                        DataMemberBinding="{Binding fattimpo}"
                                                        Header="Imponibile"
                                                        HeaderTextAlignment="Right"
                                                        IsReadOnly="True"
                                                        TextAlignment="Right" />
                            <telerik:GridViewDataColumn Width="120"
                                                        DataFormatString="N2"
                                                        DataMemberBinding="{Binding fattimposta}"
                                                        Header="Imposta"
                                                        HeaderTextAlignment="Right"
                                                        IsReadOnly="True"
                                                        TextAlignment="Right" />
                            <telerik:GridViewDataColumn Width="120"
                                                        DataFormatString="N2"
                                                        DataMemberBinding="{Binding fatttot}"
                                                        Header="Totale"
                                                        HeaderTextAlignment="Right"
                                                        IsReadOnly="True"
                                                        TextAlignment="Right" />
                            <telerik:GridViewDataColumn Width="120"
                                                        DataFormatString="N2"
                                                        DataMemberBinding="{Binding fattimpobol}"
                                                        Header="Importo bollo"
                                                        HeaderTextAlignment="Right"
                                                        IsReadOnly="True"
                                                        TextAlignment="Right" />
                            <telerik:GridViewDataColumn Width="120"
                                                        DataFormatString="N2"
                                                        DataMemberBinding="{Binding fattimporite}"
                                                        Header="Importo rit."
                                                        HeaderTextAlignment="Right"
                                                        IsReadOnly="True"
                                                        TextAlignment="Right" />
                            <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                        DataMemberBinding="{Binding fattdataric}"
                                                        Header="Data ricezione"
                                                        HeaderTextAlignment="Center"
                                                        IsReadOnly="True"
                                                        TextAlignment="Center" />
                            <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                        DataMemberBinding="{Binding fattdatasca}"
                                                        Header="Data download"
                                                        HeaderTextAlignment="Center"
                                                        IsReadOnly="True"
                                                        TextAlignment="Center" />
                            <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                        DataMemberBinding="{Binding accounted}"
                                                        Header="Data contabilizzazione"
                                                        HeaderTextAlignment="Center"
                                                        IsReadOnly="True"
                                                        TextAlignment="Center" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding accounted_UserID}" Header="Contabilizzata da" IsReadOnly="True" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding fattidsdi}" Header="Identificativo SDI" IsReadOnly="True" />
                            <telerik:GridViewDataColumn Width="250"
                                                        DataMemberBinding="{Binding fattnomefileric}"
                                                        Header="Nome file XML"
                                                        IsReadOnly="True" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding AccountingText}"
                                                        Header="Registrazione"
                                                        HeaderTextAlignment="Center"
                                                        IsReadOnly="True"
                                                        TextAlignment="Center">
                                <telerik:GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button x:Name="cmdViewAccounting"
                                                Margin="3"
                                                HorizontalContentAlignment="Left"
                                                BorderBrush="{DynamicResource VulpesXBrush}"
                                                Click="cmdViewAccounting_Click"
                                                Content="{Binding Path=AccountingText}"
                                                Cursor="Hand"
                                                Foreground="{DynamicResource VulpesXBrush}"
                                                IsEnabled="{Binding Path=ViewAccountingEnabled}" />
                                    </DataTemplate>
                                </telerik:GridViewColumn.CellTemplate>
                            </telerik:GridViewDataColumn>
                            <telerik:GridViewDataColumn Width="200"
                                                        DataMemberBinding="{Binding fattcausaledes}"
                                                        Header="Causale"
                                                        IsReadOnly="True" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding Causal.FullDescriptionSearchable}" Header="Causale gestionale" IsReadOnly="True" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding fattcoddest}"
                                                        Header="Codice destinatario"
                                                        HeaderTextAlignment="Center"
                                                        IsReadOnly="True"
                                                        TextAlignment="Center" />
                            <telerik:GridViewDataColumn Width="250"
                                                        DataMemberBinding="{Binding fattpec}"
                                                        Header="PEC"
                                                        IsReadOnly="True" />
                            <telerik:GridViewDataColumn Width="200"
                                                        DataMemberBinding="{Binding TaxRegime.FullDescriptionSearchable}"
                                                        Header="Regime fiscale"
                                                        IsReadOnly="True" />
                            <telerik:GridViewDataColumn Width="120"
                                                        DataMemberBinding="{Binding ISO.FullDescriptionSearchable}"
                                                        Header="ISO"
                                                        IsReadOnly="True" />
                            <telerik:GridViewDataColumn Width="200"
                                                        DataMemberBinding="{Binding fattforloca}"
                                                        Header="Località"
                                                        IsReadOnly="True" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding fattforprov}" Header="Prov." IsReadOnly="True" />
                            <telerik:GridViewDataColumn Width="200"
                                                        DataMemberBinding="{Binding fattforinde}"
                                                        Header="Indirizzo"
                                                        IsReadOnly="True" />
                            <telerik:GridViewDataColumn DataMemberBinding="{Binding fattforcap}" Header="C.a.p." IsReadOnly="True" />
                            <telerik:GridViewDataColumn Width="250"
                                                        DataMemberBinding="{Binding DocumentType.FullDescriptionSearchable}"
                                                        Header="Tipo documento"
                                                        IsReadOnly="True" />
                        </telerik:RadGridView.Columns>
                    </telerik:RadGridView>
                    <telerik:RadDataPager x:Name="rdpGrid"
                                          Grid.Row="1"
                                          Margin="0,-1,0,0"
                                          DisplayMode="FirstLastPreviousNextNumeric, Text"
                                          FontSize="12"
                                          IsTotalItemCountFixed="True"
                                          PageSize="20"
                                          Source="{Binding Items}" />
                </Grid>
            </telerik:RadBusyIndicator>
        </Grid>
    </Grid>
</UserControl>
