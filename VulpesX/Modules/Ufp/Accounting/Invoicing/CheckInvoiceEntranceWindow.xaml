<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Ufp.Accounting.Invoicing.CheckInvoiceEntranceWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Ufp.Accounting.Invoicing"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Controllo righe fatture con entrata merce"
                        Width="800"
                        Height="450"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">

    <sc:FluentDefaultWindow.Resources>
        <selectors:CheckInvoiceSelector x:Key="checkInvoiceSelector">
            <selectors:CheckInvoiceSelector.Collegato>
                <Style BasedOn="{StaticResource GridViewCellStyle}" TargetType="telerik:GridViewCell">
                    <Setter Property="Background" Value="{StaticResource VulpesXGreenBrush}" />
                </Style>
            </selectors:CheckInvoiceSelector.Collegato>
            <selectors:CheckInvoiceSelector.NonCollegato>
                <Style BasedOn="{StaticResource GridViewCellStyle}" TargetType="telerik:GridViewCell">
                    <Setter Property="Background" Value="{StaticResource VulpesXRedBrush}" />
                </Style>
            </selectors:CheckInvoiceSelector.NonCollegato>
        </selectors:CheckInvoiceSelector>
    </sc:FluentDefaultWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*" />
            <ColumnDefinition Width="50*" />
        </Grid.ColumnDefinitions>

        <telerik:RadBusyIndicator Grid.Column="0"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="{DynamicResource VulpesXFirstAlternativeBrush}">
                    <TextBlock Margin="5,0,0,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource VulpesXBrush}"
                               Text="RIGHE FATTURA" />
                </Grid>

                <Grid Grid.Row="1" HorizontalAlignment="Stretch">
                    <telerik:RadWatermarkTextBox Name="txtSearch"
                                                 Margin="5"
                                                 TextChanged="txtSearch_TextChanged"
                                                 WatermarkContent="Cerca..." />
                </Grid>

                <telerik:RadGridView Name="rgvRows"
                                     Grid.Row="2"
                                     AutoGenerateColumns="False"
                                     GridLinesVisibility="Both"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Items}"
                                     SelectionChanged="rgvRows_SelectionChanged"
                                     SelectionMode="Single"
                                     SelectionUnit="FullRow"
                                     ShowGroupPanel="False"
                                     ShowSearchPanel="False">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewDataColumn CellStyleSelector="{StaticResource checkInvoiceSelector}" DataMemberBinding="{Binding ArticoloFull}" Header="Articolo" />
                        <telerik:GridViewDataColumn DataFormatString="{}{0:N2}" DataMemberBinding="{Binding Quantita}" Header="Quantita" />
                        <telerik:GridViewDataColumn DataFormatString="{}{0:N2}" DataMemberBinding="{Binding Prezzo}" Header="Prezzo" />
                        <telerik:GridViewDataColumn DataFormatString="{}{0:N2}" DataMemberBinding="{Binding Totale}" Header="Totale" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding DDTID}" Header="DDT" />
                        <telerik:GridViewDataColumn DataFormatString="{}{0:dd/MM/yyyy}" DataMemberBinding="{Binding DDTData}" Header="DDT Data" />
                    </telerik:RadGridView.Columns>

                    <telerik:RadGridView.SortDescriptors>
                        <telerik:SortDescriptor Member="DDTID" SortDirection="Ascending" />
                    </telerik:RadGridView.SortDescriptors>
                </telerik:RadGridView>
            </Grid>
        </telerik:RadBusyIndicator>

        <telerik:RadBusyIndicator Grid.Column="1"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusyEntrances}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="{DynamicResource VulpesXFirstAlternativeBrush}">
                    <TextBlock Margin="5,0,0,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource VulpesXBrush}"
                               Text="ENTRATE MERCI" />
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60*" />
                        <ColumnDefinition Width="40*" />
                    </Grid.ColumnDefinitions>
                    <telerik:RadWatermarkTextBox Name="txtSearchEntrance"
                                                 Grid.Column="0"
                                                 Margin="5"
                                                 TextChanged="txtSearchEntrance_TextChanged"
                                                 WatermarkContent="Cerca..." />

                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Margin="5,0,0,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource VulpesXSecondBrush}"
                                   Text="NUMERO DDT : " />
                        <TextBox x:Name="txtDDT"
                                 Grid.Column="1"
                                 Margin="5"
                                 HorizontalAlignment="Stretch" />
                        <Button x:Name="btnSearchEntrata"
                                Grid.Column="2"
                                Margin="5"
                                BorderBrush="{StaticResource VulpesXGreenBrush}"
                                Click="btnSearchEntrata_Click"
                                Content="CERCA"
                                Style="{StaticResource VulpesXButton}" />
                    </Grid>
                </Grid>

                <telerik:RadGridView Name="rgvEntrances"
                                     Grid.Row="2"
                                     AutoGenerateColumns="False"
                                     GridLinesVisibility="Both"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Entrances}"
                                     SelectionMode="Single"
                                     SelectionUnit="FullRow"
                                     ShowGroupPanel="False"
                                     ShowSearchPanel="False">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding ArticoloID}" Header="Articolo" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding ArticoloDisegno}" Header="Disegno" />
                        <telerik:GridViewDataColumn DataFormatString="{}{0:N2}" DataMemberBinding="{Binding Quantita}" Header="Quantita" />
                        <telerik:GridViewDataColumn DataFormatString="{}{0:N2}" DataMemberBinding="{Binding Prezzo}" Header="Prezzo" />
                        <telerik:GridViewDataColumn Header="">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgLink"
                                                      Cursor="Hand"
                                                      FontSize="16"
                                                      Foreground="{DynamicResource VulpesXGreenBrush}"
                                                      Glyph="&#xe10f;"
                                                      MouseDown="rgLink_MouseDown"
                                                      ToolTip="Conferma prezzo" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                    </telerik:RadGridView.Columns>

                    <telerik:RadGridView.SortDescriptors>
                        <telerik:SortDescriptor Member="DDTID" SortDirection="Ascending" />
                    </telerik:RadGridView.SortDescriptors>
                </telerik:RadGridView>
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>
</sc:FluentDefaultWindow>
