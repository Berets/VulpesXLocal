<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Ufp.Production.ARTICLE_JOBS_TIMESWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Ufp.Production"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Tempi commesse"
                        Width="1024"
                        Height="768"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <telerik:RadGridView x:Name="GridOrders"
                             Grid.Column="0"
                             Margin="5"
                             AutoGenerateColumns="False"
                             CanUserFreezeColumns="False"
                             CanUserResizeColumns="False"
                             ColumnAggregatesAlignment="NextToGroupKey"
                             GroupRenderMode="Flat"
                             IsReadOnly="True"
                             ItemsSource="{Binding Orders}"
                             RowIndicatorVisibility="Collapsed"
                             SelectionChanged="GridOrders_SelectionChanged"
                             SelectionMode="Single"
                             ShowColumnFooters="False"
                             ShowGroupFooters="False"
                             ShowGroupPanel="False">
            <telerik:RadGridView.Columns>
                <telerik:GridViewDataColumn DataMemberBinding="{Binding Commessa}" Header="Commessa" />
            </telerik:RadGridView.Columns>
        </telerik:RadGridView>

        <Grid x:Name="grdTimes" Grid.Column="1" />
    </Grid>
</sc:FluentDefaultWindow>
