<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.DWH.DWHQueryWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.DWH"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli QUERY"
                        Width="1024"
                        Height="768"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,15,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="7*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Titolo" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsInsert}"
                         MaxLength="25"
                         Text="{Binding Data.Titolo}" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           VerticalAlignment="Top"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Descrizione" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="5,0,15,5"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         VerticalContentAlignment="Top"
                         AcceptsReturn="True"
                         MaxLength="255"
                         Text="{Binding Data.description}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           VerticalAlignment="Top"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Query" />
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         MinHeight="400"
                         MaxHeight="400"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Top"
                         VerticalContentAlignment="Top"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         Text="{Binding Data.Query}"
                         TextChanged="TextBox_TextChanged"
                         VerticalScrollBarVisibility="Auto" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,5,0,0"
                           VerticalAlignment="Top"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Parametri" />
                <ScrollViewer Grid.Row="3"
                              Grid.Column="1"
                              Margin="5,5,15,0"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Name="stkParameters" MaxHeight="200" DockPanel.Dock="Right" />
                </ScrollViewer>

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Stored procedure" />
                <telerik:RadToggleSwitchButton Grid.Row="4"
                                               Grid.Column="1"
                                               Margin="5,0,15,0"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               IsChecked="{Binding Data.EStoredProcedure}" />

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Nome Stored procedure" />
                <TextBox Grid.Row="5"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         MaxLength="25"
                         Text="{Binding Data.StoredProcedureName}" />
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
