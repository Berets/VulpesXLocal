<UserControl x:Class="VulpesX.Modules.Default.DWH.DWHView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.DWH"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pivot="http://schemas.telerik.com/2008/xaml/presentation/pivot"
             xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">

    <UserControl.Resources>
        <pivot:QuickStyle x:Key="PurpleHeavyStyle">
            <pivot:QuickStyle.HeaderRow>
                <pivot:ElementProperties BorderBrush="{telerik:Office2019Resource ResourceKey=MainBorderBrush}" BorderThickness="1" />
            </pivot:QuickStyle.HeaderRow>
            <pivot:QuickStyle.GrandTotalRow>
                <pivot:ElementProperties Background="{telerik:Office2019Resource ResourceKey=AccentMouseOverBorderBrush}"
                                         BorderBrush="{telerik:Office2019Resource ResourceKey=AccentMouseOverBorderBrush}"
                                         BorderThickness="1"
                                         FontWeight="SemiBold"
                                         Foreground="{telerik:Office2019Resource ResourceKey=CheckedForegroundBrush}" />
            </pivot:QuickStyle.GrandTotalRow>
            <pivot:QuickStyle.GrandTotalColumn>
                <pivot:ElementProperties Background="{telerik:Office2019Resource ResourceKey=AccentMouseOverBorderBrush}"
                                         BorderBrush="{telerik:Office2019Resource ResourceKey=AccentMouseOverBorderBrush}"
                                         BorderThickness="1"
                                         FontWeight="SemiBold"
                                         Foreground="{telerik:Office2019Resource ResourceKey=CheckedForegroundBrush}" />
            </pivot:QuickStyle.GrandTotalColumn>
            <pivot:QuickStyle.RowSubgroups>
                <pivot:ElementProperties Background="{telerik:Office2019Resource ResourceKey=AlternativeBackgroundBrush}"
                                         BorderBrush="{telerik:Office2019Resource ResourceKey=MainBorderBrush}"
                                         BorderThickness="1"
                                         FontWeight="SemiBold"
                                         Foreground="{DynamicResource VulpesXBrush}" />
            </pivot:QuickStyle.RowSubgroups>
            <pivot:QuickStyle.ColumnSubgroups>
                <pivot:ElementProperties Background="{telerik:Office2019Resource ResourceKey=AlternativeBackgroundBrush}"
                                         BorderBrush="{telerik:Office2019Resource ResourceKey=MainBorderBrush}"
                                         BorderThickness="1"
                                         FontWeight="SemiBold"
                                         Foreground="{telerik:Office2019Resource ResourceKey=AccentBackgroundBrush}" />
            </pivot:QuickStyle.ColumnSubgroups>
            <pivot:QuickStyle.SubtotalRows>
                <pivot:ElementProperties Background="{telerik:Office2019Resource ResourceKey=SecondaryBackgroundBrush}"
                                         BorderBrush="{telerik:Office2019Resource ResourceKey=MainBorderBrush}"
                                         BorderThickness="1"
                                         FontWeight="SemiBold"
                                         Foreground="{telerik:Office2019Resource ResourceKey=MainForegroundBrush}" />
            </pivot:QuickStyle.SubtotalRows>
            <pivot:QuickStyle.SubtotalColumns>
                <pivot:ElementProperties Background="{telerik:Office2019Resource ResourceKey=SecondaryBackgroundBrush}"
                                         BorderBrush="{telerik:Office2019Resource ResourceKey=MainBorderBrush}"
                                         BorderThickness="1"
                                         FontWeight="SemiBold"
                                         Foreground="{telerik:Office2019Resource ResourceKey=MainForegroundBrush}" />
            </pivot:QuickStyle.SubtotalColumns>
            <pivot:QuickStyle.ColumnFirstAlternationPattern>
                <pivot:AlternationElementProperties AlternationCount="1"
                                                    BorderBrush="{telerik:Office2019Resource ResourceKey=MainBorderBrush}"
                                                    BorderThickness="1"
                                                    Foreground="{telerik:Office2019Resource ResourceKey=MainForegroundBrush}" />
            </pivot:QuickStyle.ColumnFirstAlternationPattern>
            <pivot:QuickStyle.ColumnSecondAlternationPattern>
                <pivot:AlternationElementProperties AlternationCount="1"
                                                    BorderBrush="{telerik:Office2019Resource ResourceKey=MainBorderBrush}"
                                                    BorderThickness="1"
                                                    Foreground="{telerik:Office2019Resource ResourceKey=MainForegroundBrush}" />
            </pivot:QuickStyle.ColumnSecondAlternationPattern>
            <pivot:QuickStyle.RowFirstAlternationPattern>
                <pivot:AlternationElementProperties AlternationCount="1"
                                                    BorderBrush="{telerik:Office2019Resource ResourceKey=MainBorderBrush}"
                                                    BorderThickness="1"
                                                    Foreground="{telerik:Office2019Resource ResourceKey=MainForegroundBrush}" />
            </pivot:QuickStyle.RowFirstAlternationPattern>
            <pivot:QuickStyle.RowSecondAlternationPattern>
                <pivot:AlternationElementProperties AlternationCount="1"
                                                    BorderBrush="{telerik:Office2019Resource ResourceKey=MainBorderBrush}"
                                                    BorderThickness="1"
                                                    Foreground="{telerik:Office2019Resource ResourceKey=MainForegroundBrush}" />
            </pivot:QuickStyle.RowSecondAlternationPattern>
        </pivot:QuickStyle>

    </UserControl.Resources>

    <Grid>
        <Grid.Resources>
            <HierarchicalDataTemplate x:Key="FolderTemplate" ItemsSource="{Binding Childs}">
                <Grid Height="30" HorizontalAlignment="Stretch">
                    <TextBlock Margin="5"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="{Binding StreamName}"
                               TextAlignment="Left" />
                </Grid>
            </HierarchicalDataTemplate>

            <HierarchicalDataTemplate x:Key="SaveTemplate">
                <Grid Height="40" Margin="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="5*" />
                            <RowDefinition Height="5*" />
                        </Grid.RowDefinitions>
                        <Path Grid.Row="0"
                              Width="14"
                              Height="14"
                              HorizontalAlignment="Center"
                              Data="{DynamicResource InfoPath}"
                              Fill="{DynamicResource VulpesXSecondBrush}"
                              Stretch="UniformToFill"
                              ToolTip="{Binding description}"
                              Visibility="{Binding HaveDescription, Converter={StaticResource boolToVisibilityConverter}}" />
                        <Path Grid.Row="1"
                              Width="16"
                              Height="14"
                              HorizontalAlignment="Center"
                              Data="{DynamicResource PrivatePath}"
                              Fill="{DynamicResource VulpesXSecondBrush}"
                              Stretch="UniformToFill"
                              ToolTip="Privata"
                              Visibility="{Binding IsPersonal, Converter={StaticResource boolToVisibilityConverter}}" />
                    </Grid>

                    <Grid Grid.Column="1" HorizontalAlignment="Stretch">
                        <TextBlock Margin="5"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource VulpesXSecondBrush}"
                                   Text="{Binding StreamName}"
                                   TextAlignment="Left"
                                   TextWrapping="Wrap" />
                    </Grid>

                    <Grid Grid.Column="2" HorizontalAlignment="Stretch" Background="{DynamicResource GXDarkBrush}">
                        <telerik:RadButton Name="btnRunTemplate"
                                           HorizontalAlignment="Right"
                                           BorderThickness="0"
                                           Click="BtnRunTemplate_Click">
                            <telerik:RadButton.Content>
                                <Path Height="15"
                                      Data="{DynamicResource ArrowRightPath}"
                                      Fill="{DynamicResource VulpesXSecondBrush}"
                                      Stretch="Uniform" />
                            </telerik:RadButton.Content>
                        </telerik:RadButton>
                    </Grid>

                    <telerik:RadContextMenu.ContextMenu>
                        <telerik:RadContextMenu x:Name="radContextMenu">
                            <telerik:RadContextMenu.Items>
                                <telerik:RadMenuItem Name="ctxEditTemplate" Click="CtxEditTemplate_Click" Header="Modifica" />
                                <telerik:RadMenuItem Name="ctxRemoveTemplate" Click="CtxRemoveTemplate_Click" Header="Elimina" />
                            </telerik:RadContextMenu.Items>
                        </telerik:RadContextMenu>
                    </telerik:RadContextMenu.ContextMenu>
                </Grid>
            </HierarchicalDataTemplate>

            <selectors:DWHTemplateSelector x:Key="navigationTemplateSelector" FolderTemplate="{StaticResource FolderTemplate}" SaveTemplate="{StaticResource SaveTemplate}" />
        </Grid.Resources>

        <telerik:RadDocking x:Name="radDocking1"
                            Padding="0"
                            BorderThickness="0"
                            CanAutoHideAreaExceedScreen="True"
                            RetainPaneSizeMode="DockingAndFloating">

            <telerik:RadDocking.DocumentHost>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20" />
                        <RowDefinition Height="2" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="2" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBrush}">
                        <StackPanel Margin="5,0,0,0" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="QUERY: " />
                            <TextBlock Name="txtQuery"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Text="" />
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="1" Background="{DynamicResource VulpesXFirstBrush}" />
                    <Grid Grid.Row="2" Background="{DynamicResource VulpesXBrush}">
                        <StackPanel Margin="5,0,0,0" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="TEMPLATE: " />
                            <TextBlock Name="txtTemplate"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Text="" />
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="3" Background="{DynamicResource VulpesXFirstBrush}" />
                    <Grid Grid.Row="4" Background="{DynamicResource VulpesXBrush}">
                        <StackPanel Margin="5,0,0,0" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="PARAMETRI: " />
                            <TextBlock Name="txtParameters"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Text="" />
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="5" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <pivot:RadPivotGrid x:Name="pivotGrid"
                                            Grid.Row="5"
                                            CanUserResizeColumns="True"
                                            ColumnGrandTotalsPosition="{Binding ElementName=ColumnGrandTotalsPosition, Path=SelectedItem, Mode=TwoWay}"
                                            ColumnSubTotalsPosition="{Binding ElementName=ColumnSubTotalsPosition, Path=SelectedItem, Mode=TwoWay}"
                                            HorizontalLayout="{Binding ElementName=HorizontalLayout, Path=SelectedItem, Mode=TwoWay}"
                                            QuickStyle="{StaticResource PurpleHeavyStyle}"
                                            RowGrandTotalsPosition="{Binding ElementName=RowGrandTotalsPosition, Path=SelectedItem, Mode=TwoWay}"
                                            RowSubTotalsPosition="{Binding ElementName=RowSubTotalsPosition, Path=SelectedItem, Mode=TwoWay}"
                                            ShowAggregateValuesInline="{Binding ElementName=ShowAggregateValuesInline, Path=IsChecked, Mode=TwoWay}"
                                            VerticalLayout="{Binding ElementName=VerticalLayout, Path=SelectedItem, Mode=TwoWay}" />
                    </ScrollViewer>

                </Grid>
            </telerik:RadDocking.DocumentHost>

            <telerik:RadSplitContainer Name="LeftContainer" Width="410" InitialPosition="DockedLeft">
                <telerik:RadPaneGroup>
                    <telerik:RadPane CanFloat="False" CanUserClose="False" Header="Queries">
                        <telerik:RadBusyIndicator BusyContent="Caricamento dati in corso..."
                                                  Foreground="{DynamicResource VulpesXBrush}"
                                                  IsBusy="{Binding IsBusyQueries}"
                                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
                            <Grid Background="{DynamicResource VulpesXFirstBrush}">
                                <ListView Name="lsvQuery"
                                          Grid.Row="1"
                                          HorizontalContentAlignment="Stretch"
                                          Background="Transparent"
                                          ItemsSource="{Binding Queries}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Height="40" HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="50" />
                                                </Grid.ColumnDefinitions>

                                                <Path Grid.Column="0"
                                                      Width="18"
                                                      Height="18"
                                                      VerticalAlignment="Center"
                                                      Data="{DynamicResource InfoPath}"
                                                      Fill="{DynamicResource VulpesXSecondBrush}"
                                                      Stretch="Fill"
                                                      ToolTip="{Binding description}"
                                                      Visibility="{Binding HaveDescription, Converter={StaticResource boolToVisibilityConverter}}" />

                                                <TextBlock Grid.Column="1"
                                                           Margin="5"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                                           Text="{Binding Titolo}"
                                                           TextAlignment="Left" />
                                                <telerik:RadButton Name="btnRun"
                                                                   Grid.Column="2"
                                                                   Margin="5"
                                                                   HorizontalAlignment="Right"
                                                                   Click="BtnRun_Click">
                                                    <telerik:RadButton.Content>
                                                        <Path Height="15"
                                                              Data="{DynamicResource ArrowRightPath}"
                                                              Fill="{DynamicResource VulpesXSecondBrush}"
                                                              Stretch="Uniform" />
                                                    </telerik:RadButton.Content>
                                                </telerik:RadButton>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </telerik:RadBusyIndicator>
                    </telerik:RadPane>

                    <telerik:RadPane CanFloat="False" CanUserClose="False" Header="Templates">
                        <telerik:RadBusyIndicator BusyContent="Caricamento dati in corso..."
                                                  Foreground="{DynamicResource VulpesXBrush}"
                                                  IsBusy="{Binding IsBusyTemplates}"
                                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
                            <Grid Background="{DynamicResource VulpesXFirstBrush}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <telerik:RadWatermarkTextBox Name="txtSearchTemplates"
                                                             Grid.Row="0"
                                                             Margin="5"
                                                             TextChanged="txtSearchTemplates_TextChanged"
                                                             WatermarkContent="Cerca..." />

                                <telerik:RadTreeView Name="rtvTemplate"
                                                     Grid.Row="1"
                                                     IsExpandOnSingleClickEnabled="True"
                                                     IsTextSearchEnabled="True"
                                                     ItemContainerStyle="{DynamicResource TreeViewItemNavigationTemplate}"
                                                     ItemTemplateSelector="{StaticResource navigationTemplateSelector}"
                                                     ItemsSource="{Binding Templates}" />
                            </Grid>
                        </telerik:RadBusyIndicator>
                    </telerik:RadPane>
                </telerik:RadPaneGroup>
            </telerik:RadSplitContainer>

            <telerik:RadSplitContainer Name="RightContainer" Width="610" InitialPosition="DockedRight">
                <telerik:RadPaneGroup>
                    <telerik:RadPane CanFloat="False" CanUserClose="False" Header="Pivot editor">
                        <telerik:RadBusyIndicator BusyContent="Caricamento dati in corso..."
                                                  Foreground="{DynamicResource VulpesXBrush}"
                                                  IsBusy="{Binding IsBusy}"
                                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="80" />
                                </Grid.RowDefinitions>

                                <telerik:RadTabControl Grid.Row="0">
                                    <telerik:RadTabControl.Items>
                                        <telerik:RadTabItem Header="Campi">
                                            <pivot:RadPivotFieldList x:Name="pivotFieldList" Grid.Row="0" />
                                        </telerik:RadTabItem>
                                        <telerik:RadTabItem Header="Layout">
                                            <StackPanel Margin="4">
                                                <TextBlock Margin="0,8,0,4" Text="Pivot layouts" />

                                                <TextBlock Margin="0,4,0,0" Text="VerticalLayout:" />
                                                <telerik:RadComboBox x:Name="VerticalLayout"
                                                                     Height="Auto"
                                                                     Margin="0,2,2,0"
                                                                     SelectedIndex="0">
                                                    <pivot:PivotLayoutType>Compact</pivot:PivotLayoutType>
                                                    <pivot:PivotLayoutType>Outline</pivot:PivotLayoutType>
                                                    <pivot:PivotLayoutType>Tabular</pivot:PivotLayoutType>
                                                </telerik:RadComboBox>

                                                <TextBlock Grid.Column="1" Margin="0,4,0,0" Text="HorizontalLayout:" />
                                                <telerik:RadComboBox x:Name="HorizontalLayout"
                                                                     Height="Auto"
                                                                     Margin="2,2,0,2"
                                                                     SelectedIndex="2">
                                                    <pivot:PivotLayoutType>Compact</pivot:PivotLayoutType>
                                                    <pivot:PivotLayoutType>Outline</pivot:PivotLayoutType>
                                                    <pivot:PivotLayoutType>Tabular</pivot:PivotLayoutType>
                                                </telerik:RadComboBox>

                                                <TextBlock Margin="0,16,0,8" Text="Row totals positioning" />
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="Subtotals:" />
                                                    <telerik:RadComboBox x:Name="RowSubTotalsPosition"
                                                                         Grid.Row="1"
                                                                         Margin="0,2,2,2"
                                                                         SelectedIndex="2"
                                                                         ToolTipService.ToolTip="RowSubTotalsPosition">
                                                        <pivot:RowTotalsPosition>Top</pivot:RowTotalsPosition>
                                                        <pivot:RowTotalsPosition>None</pivot:RowTotalsPosition>
                                                        <pivot:RowTotalsPosition>Bottom</pivot:RowTotalsPosition>
                                                    </telerik:RadComboBox>

                                                    <TextBlock Grid.Column="1" Margin="2,0,0,0" Text="Grandtotals:" />
                                                    <telerik:RadComboBox x:Name="RowGrandTotalsPosition"
                                                                         Grid.Row="1"
                                                                         Grid.Column="1"
                                                                         Margin="2,2,0,2"
                                                                         SelectedIndex="2"
                                                                         ToolTipService.ToolTip="RowGrandTotalsPosition">
                                                        <pivot:RowTotalsPosition>Top</pivot:RowTotalsPosition>
                                                        <pivot:RowTotalsPosition>None</pivot:RowTotalsPosition>
                                                        <pivot:RowTotalsPosition>Bottom</pivot:RowTotalsPosition>
                                                    </telerik:RadComboBox>
                                                </Grid>

                                                <TextBlock Margin="0,16,0,8" Text="Column totals positioning" />

                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="Subtotals:" />
                                                    <telerik:RadComboBox x:Name="ColumnSubTotalsPosition"
                                                                         Grid.Row="1"
                                                                         Margin="0,2,2,2"
                                                                         SelectedIndex="2"
                                                                         ToolTipService.ToolTip="ColumnSubTotalsPosition">
                                                        <pivot:ColumnTotalsPosition>Left</pivot:ColumnTotalsPosition>
                                                        <pivot:ColumnTotalsPosition>None</pivot:ColumnTotalsPosition>
                                                        <pivot:ColumnTotalsPosition>Right</pivot:ColumnTotalsPosition>
                                                    </telerik:RadComboBox>

                                                    <TextBlock Grid.Column="1" Margin="2,0,0,0" Text="Grandtotals:" />
                                                    <telerik:RadComboBox x:Name="ColumnGrandTotalsPosition"
                                                                         Grid.Row="1"
                                                                         Grid.Column="1"
                                                                         Margin="2,2,0,2"
                                                                         SelectedIndex="2"
                                                                         ToolTipService.ToolTip="ColumnGrandTotalsPosition">
                                                        <pivot:ColumnTotalsPosition>Left</pivot:ColumnTotalsPosition>
                                                        <pivot:ColumnTotalsPosition>None</pivot:ColumnTotalsPosition>
                                                        <pivot:ColumnTotalsPosition>Right</pivot:ColumnTotalsPosition>
                                                    </telerik:RadComboBox>
                                                </Grid>

                                                <CheckBox x:Name="ShowAggregateValuesInline" Margin="0,16,0,4" Content="ShowAggregateValues Inline" />
                                            </StackPanel>
                                        </telerik:RadTabItem>
                                    </telerik:RadTabControl.Items>
                                </telerik:RadTabControl>

                                <Grid Grid.Row="1">
                                    <telerik:RadButton Name="btnExcel"
                                                       Width="50"
                                                       Margin="5,5,0,45"
                                                       HorizontalAlignment="Left"
                                                       BorderBrush="{DynamicResource VulpesXGreenBrush}"
                                                       Click="BtnExcel_Click"
                                                       Content="Pivot"
                                                       Style="{StaticResource VulpesXButton}" />
                                    <telerik:RadButton Name="btnExcelStatic"
                                                       Width="50"
                                                       Margin="60,5,0,45"
                                                       HorizontalAlignment="Left"
                                                       BorderBrush="{DynamicResource VulpesXGreenBrush}"
                                                       Click="btnExcelStatic_Click"
                                                       Content="Excel"
                                                       Style="{StaticResource VulpesXButton}" />

                                    <CheckBox x:Name="chkExcelFilter" Margin="5,45,160,5" Content="Filtra excel" />
                                    <telerik:RadButton Name="btnSaveTemplate"
                                                       Grid.Row="1"
                                                       Width="150"
                                                       Height="30"
                                                       Margin="5"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Top"
                                                       BorderBrush="{DynamicResource VulpesXFluentBlueBrush}"
                                                       Click="BtnSaveTemplate_Click"
                                                       Content="Salva template"
                                                       Style="{StaticResource VulpesXButton}" />
                                    <telerik:RadButton Name="btnSaveAsNewTemplate"
                                                       Grid.Row="1"
                                                       Width="150"
                                                       Height="30"
                                                       Margin="5"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Bottom"
                                                       BorderBrush="{DynamicResource VulpesXFluentBlueBrush}"
                                                       Click="BtnSaveAsNewTemplate_Click"
                                                       Content="Salva come nuovo"
                                                       Style="{StaticResource VulpesXButton}" />
                                </Grid>
                            </Grid>
                        </telerik:RadBusyIndicator>
                    </telerik:RadPane>
                </telerik:RadPaneGroup>
            </telerik:RadSplitContainer>
        </telerik:RadDocking>


    </Grid>

</UserControl>
