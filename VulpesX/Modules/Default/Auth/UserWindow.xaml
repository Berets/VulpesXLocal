<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Auth.UserWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Auth"
                        xmlns:maskedInput="clr-namespace:Telerik.Windows.Controls.MaskedInput;assembly=Telerik.Windows.Controls.Input"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Profilo utente"
                        Width="650"
                        Height="650"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="DATI PRINCIPALI" Header="DATI PRINCIPALI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="70" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>


                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="ID" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Style="{StaticResource VulpesXData}"
                                       Text="{Binding Data.USRID}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Societa' preferenziale" />
                            <telerik:RadComboBox Grid.Row="1"
                                                 Grid.Column="1"
                                                 Width="300"
                                                 Margin="15,2,15,2"
                                                 HorizontalAlignment="Left"
                                                 HorizontalContentAlignment="Left"
                                                 DisplayMemberPath="SOMDES"
                                                 IsEditable="True"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding Companies}"
                                                 SelectedValue="{Binding Data.USRPRECOM}"
                                                 SelectedValuePath="SOMCOD" />

                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="2"
                                       Style="{StaticResource VulpesXSubtitle}"
                                       Text="Cambio password" />

                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="2"
                                       Width="400"
                                       Height="70"
                                       Margin="50,5,0,5"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Stretch"
                                       FontSize="16"
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Sia nella vecchia password che nelle nuove NON vanno specificati i primi 4 caratteri che rimarranno gli stessi"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Password attuale" />
                            <PasswordBox x:Name="pbOldPassword"
                                         Grid.Row="8"
                                         Grid.Column="1"
                                         Width="350"
                                         Margin="2"
                                         HorizontalAlignment="Left"
                                         MaxLength="255" />

                            <TextBlock Grid.Row="9"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Nuova password" />
                            <PasswordBox x:Name="pbNewPassword"
                                         Grid.Row="9"
                                         Grid.Column="1"
                                         Width="350"
                                         Margin="2"
                                         HorizontalAlignment="Left"
                                         MaxLength="255" />

                            <TextBlock Grid.Row="10"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Conferma password" />
                            <PasswordBox x:Name="pbConfirmPassword"
                                         Grid.Row="10"
                                         Grid.Column="1"
                                         Width="350"
                                         Margin="2"
                                         HorizontalAlignment="Left"
                                         MaxLength="255" />

                            <Button Name="cmdPasswordChange"
                                    Grid.Row="11"
                                    Grid.Column="1"
                                    Width="350"
                                    Margin="2"
                                    HorizontalAlignment="Left"
                                    BorderBrush="{DynamicResource VulpesXVioletBrush}"
                                    Click="cmdPasswordChange_Click"
                                    Content="SALVA LA NUOVA PASSWORD"
                                    Style="{StaticResource VulpesXButton}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="WIDGET" Header="WIDGET">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="70" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*" />
                                <ColumnDefinition Width="6*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Allarmi quantita' magazzino" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadToggleSwitchButton Grid.Row="0"
                                                               Grid.Column="1"
                                                               Margin="5,0,0,0"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Data.usrwidqta}"
                                                               IsChecked="{Binding Data.usrwidqta}"
                                                               UncheckedContent="No" />
                                <TextBlock Margin="15,0,0,0" Style="{StaticResource VulpesXLabel}" Text="Refresh (secondi)" />
                                <telerik:RadMaskedNumericInput Width="100"
                                                               Margin="5,2,15,2"
                                                               HorizontalAlignment="Left"
                                                               maskedInput:MaskedInputExtensions.AllowNull="True"
                                                               maskedInput:MaskedInputExtensions.MaxTextLength="5"
                                                               maskedInput:MaskedInputExtensions.Maximum="999999"
                                                               AllowSkipPlaceholders="True"
                                                               AutoFillNumberGroupSeparators="False"
                                                               AutoFillZeros="False"
                                                               FormatString="000000"
                                                               InputBehavior="Insert"
                                                               Mask="######"
                                                               SelectionOnFocus="SelectAll"
                                                               SpinMode="Position"
                                                               TextMode="MaskedText"
                                                               Value="{Binding Data.usrwidqtatim, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
