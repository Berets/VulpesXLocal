<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Auth.CompanyWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:culture="clr-namespace:System.Globalization;assembly=mscorlib"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Auth"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli societari"
                        Width="1000"
                        Height="700"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="DATI GENERALI" Header="DATI GENERALI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="200" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="5"
                                    Grid.Column="1"
                                    Margin="5,0,15,0"
                                    Padding="3"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="White"
                                    BorderBrush="Black"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    MouseDown="imgLogo_MouseDown"
                                    ToolTip="Clicca qui per modificare il logo associato alla societa'">
                                <Image x:Name="imgLogo"
                                       Margin="5"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Cursor="Hand"
                                       Source="{Binding LogoData}"
                                       Stretch="Fill"
                                       ToolTip="Clicca qui per modificare il logo associato alla societa'" />
                            </Border>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Codice" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Width="100"
                                       Margin="5,0,15,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource VulpesXData}"
                                       Text="{Binding Data.SOMCOD, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ragione sociale" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="50"
                                     Text="{Binding Data.SOMDES, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ragione sociale stampe" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="50"
                                     Text="{Binding Details.azrssl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Sigla" />
                            <TextBox Grid.Row="3"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="20"
                                     Text="{Binding Details.azsigl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Lingua default" />
                            <telerik:RadComboBox Grid.Row="4"
                                                 Grid.Column="1"
                                                 Margin="5,0,15,0"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Center"
                                                 DisplayMemberPath="lindes"
                                                 ItemsSource="{Binding LingueDefault}"
                                                 SelectedValue="{Binding Details.azlinguadefault, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 SelectedValuePath="lincod"
                                                 SelectionChanged="cmbLingueDefault_SelectionChanged"
                                                 TextSearch.TextPath="lindes" />
                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       VerticalAlignment="Top"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Logo" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="SEDE LEGALE" Header="SEDE LEGALE">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Indirizzo" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="50"
                                     Text="{Binding Details.azinsl}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Comune" />
                            <telerik:RadAutoCompleteBox x:Name="acLegalCity"
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        ItemsSource="{Binding Cities}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun comune trovato"
                                                        SelectedItem="{Binding SelectedLegalCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acLegalCity_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Provincia" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadAutoCompleteBox x:Name="acLegalState"
                                                            Width="200"
                                                            Margin="5,2,15,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            ItemsSource="{Binding States}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessuna provincia trovata"
                                                            SelectedItem="{Binding SelectedLegalState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionChanged="acLegalState_SelectionChanged"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="C.a.p." />
                                <telerik:RadNumericUpDown Width="200"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          Maximum="99999"
                                                          Minimum="1"
                                                          NumberDecimalDigits="0"
                                                          Value="{Binding Details.azcasl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <telerik:RadNumericUpDown.NumberFormatInfo>
                                        <culture:NumberFormatInfo NumberGroupSeparator="" />
                                    </telerik:RadNumericUpDown.NumberFormatInfo>
                                </telerik:RadNumericUpDown>
                            </StackPanel>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Partita IVA" />
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="200"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         MaxLength="12"
                                         Text="{Binding Details.azpaiv}" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Codice fiscale" />
                                <TextBox Width="200"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         MaxLength="11"
                                         Text="{Binding Details.azcofi}" />
                            </StackPanel>

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Codice fiscale legale rapp." />
                            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="200"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         MaxLength="11"
                                         Text="{Binding Details.azcflr}" />
                            </StackPanel>

                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Capitale sociale" />
                            <telerik:RadNumericUpDown Grid.Row="6"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      Minimum="0"
                                                      NumberDecimalDigits="2"
                                                      Value="{Binding Details.azcapsoc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Codice R.E.A." />
                            <TextBox Grid.Row="7"
                                     Grid.Column="1"
                                     Width="200"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     MaxLength="10"
                                     Text="{Binding Details.azcodrea}" />
                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Direzione e coordinamento" />
                            <TextBox Grid.Row="8"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="100"
                                     Text="{Binding Details.azdirez}" />

                            <TextBlock Grid.Row="9"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Telefono" />
                            <TextBox Grid.Row="9"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="50"
                                     Text="{Binding Details.AZTel}" />
                            <TextBlock Grid.Row="10"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Email" />
                            <TextBox Grid.Row="10"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="255"
                                     Text="{Binding Details.AZMail}" />
                            <TextBlock Grid.Row="11"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Web" />
                            <TextBox Grid.Row="11"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="255"
                                     Text="{Binding Details.AZUrl}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="SEDE OPERATIVA" Header="SEDE OPERATIVA">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Indirizzo" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="50"
                                     Text="{Binding Details.azinsa}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Comune" />
                            <telerik:RadAutoCompleteBox x:Name="acWorkingCity"
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        ItemsSource="{Binding Cities}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun comune trovato"
                                                        SelectedItem="{Binding SelectedWorkingCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acWorkingCity_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Provincia" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadAutoCompleteBox x:Name="acWorkingState"
                                                            Width="200"
                                                            Margin="5,2,15,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            ItemsSource="{Binding States}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessuna provincia trovata"
                                                            SelectedItem="{Binding SelectedWorkingState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionChanged="acWorkingState_SelectionChanged"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="C.a.p." />
                                <telerik:RadNumericUpDown Width="200"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          Maximum="99999"
                                                          Minimum="1"
                                                          NumberDecimalDigits="0"
                                                          Value="{Binding Details.azcasa, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <telerik:RadNumericUpDown.NumberFormatInfo>
                                        <culture:NumberFormatInfo NumberGroupSeparator="" />
                                    </telerik:RadNumericUpDown.NumberFormatInfo>
                                </telerik:RadNumericUpDown>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="ALTRI" Header="ALTRI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="200" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       VerticalAlignment="Top"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Loghi certificazioni" />
                            <Border Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="5,0,15,0"
                                    Padding="3"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Background="White"
                                    BorderBrush="Black"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    MouseDown="imgLogoCerts_MouseDown"
                                    ToolTip="Clicca qui per modificare il logo delle certificazioni">
                                <Image x:Name="imgLogoCerts"
                                       Margin="5"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Cursor="Hand"
                                       Source="{Binding CertsLogoData}"
                                       Stretch="Fill"
                                       ToolTip="Clicca qui per modificare il logo delle certificazioni" />
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="PERSONALIZZAZIONI" Header="PERSONALIZZAZIONI">
                <telerik:RadTabItem.Content>
                    <telerik:RadTabControl VerticalAlignment="Stretch"
                                           BorderThickness="0"
                                           DisplayMemberPath="Content"
                                           DropDownDisplayMode="Visible"
                                           ScrollMode="Viewport">
                        <telerik:RadTabItem DropDownContent="CRM" Header="CRM">
                            <telerik:RadTabItem.Content>
                                <telerik:RadTabControl VerticalAlignment="Stretch"
                                                       BorderThickness="0"
                                                       DisplayMemberPath="Content"
                                                       DropDownDisplayMode="Visible"
                                                       ScrollMode="Viewport">
                                    <telerik:RadTabItem DropDownContent="Analisi fattibilità" Header="Analisi fattibilità">
                                        <telerik:RadTabItem.Content>
                                            <telerik:RadTabControl VerticalAlignment="Stretch"
                                                                   BorderThickness="0"
                                                                   DisplayMemberPath="Content"
                                                                   DropDownDisplayMode="Visible"
                                                                   ScrollMode="Viewport">
                                                <telerik:RadTabItem DropDownContent="Funzioni" Header="Funzioni">
                                                    <telerik:RadTabItem.Content>
                                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                                            <Grid Margin="0,10,10,0">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="*" />
                                                                </Grid.RowDefinitions>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="3*" />
                                                                    <ColumnDefinition Width="2*" />
                                                                    <ColumnDefinition Width="3*" />
                                                                    <ColumnDefinition Width="2*" />
                                                                </Grid.ColumnDefinitions>

                                                                <TextBlock Grid.Row="1"
                                                                           Grid.Column="0"
                                                                           Style="{StaticResource VulpesXLabel}"
                                                                           Text="Stampa note articolo" />
                                                                <telerik:RadToggleSwitchButton Grid.Row="1"
                                                                                               Grid.Column="1"
                                                                                               Margin="5,0,0,0"
                                                                                               CheckedContent="Sì"
                                                                                               Content="{Binding Details.azpnotafa}"
                                                                                               IsChecked="{Binding Details.azpnotafa}"
                                                                                               UncheckedContent="No" />
                                                            </Grid>
                                                        </ScrollViewer>
                                                    </telerik:RadTabItem.Content>
                                                </telerik:RadTabItem>
                                            </telerik:RadTabControl>
                                        </telerik:RadTabItem.Content>
                                    </telerik:RadTabItem>
                                    <telerik:RadTabItem DropDownContent="Offerte" Header="Offerte">
                                        <telerik:RadTabItem.Content>
                                            <telerik:RadTabControl VerticalAlignment="Stretch"
                                                                   BorderThickness="0"
                                                                   DisplayMemberPath="Content"
                                                                   DropDownDisplayMode="Visible"
                                                                   ScrollMode="Viewport">
                                                <telerik:RadTabItem DropDownContent="Funzioni" Header="Funzioni">
                                                    <telerik:RadTabItem.Content>
                                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                                            <Grid Margin="0,10,10,0">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="35" />
                                                                    <RowDefinition Height="*" />
                                                                </Grid.RowDefinitions>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="3*" />
                                                                    <ColumnDefinition Width="2*" />
                                                                    <ColumnDefinition Width="3*" />
                                                                    <ColumnDefinition Width="2*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Row="1"
                                                                           Grid.Column="0"
                                                                           Style="{StaticResource VulpesXLabel}"
                                                                           Text="Usa codici cliente" />
                                                                <telerik:RadToggleSwitchButton Grid.Row="1"
                                                                                               Grid.Column="1"
                                                                                               Margin="5,0,0,0"
                                                                                               CheckedContent="Sì"
                                                                                               Content="{Binding Details.AZCUSOFF}"
                                                                                               IsChecked="{Binding Details.AZCUSOFF}"
                                                                                               UncheckedContent="No" />
                                                                <TextBlock Grid.Row="2"
                                                                           Grid.Column="0"
                                                                           Style="{StaticResource VulpesXLabel}"
                                                                           Text="Utente corrente in Cc" />
                                                                <telerik:RadToggleSwitchButton Grid.Row="2"
                                                                                               Grid.Column="1"
                                                                                               Margin="5,0,0,0"
                                                                                               CheckedContent="Sì"
                                                                                               Content="{Binding Details.AZCCOFF}"
                                                                                               IsChecked="{Binding Details.AZCCOFF}"
                                                                                               UncheckedContent="No" />
                                                                <TextBlock Grid.Row="3"
                                                                           Grid.Column="0"
                                                                           Style="{StaticResource VulpesXLabel}"
                                                                           Text="Stampa note articolo" />
                                                                <telerik:RadToggleSwitchButton Grid.Row="3"
                                                                                               Grid.Column="1"
                                                                                               Margin="5,0,0,0"
                                                                                               CheckedContent="Sì"
                                                                                               Content="{Binding Details.azpnotoff}"
                                                                                               IsChecked="{Binding Details.azpnotoff}"
                                                                                               UncheckedContent="No" />
                                                                <TextBlock Grid.Row="4"
                                                                           Grid.Column="0"
                                                                           Style="{StaticResource VulpesXLabel}"
                                                                           Text="Stampa agenti in dettagli" />
                                                                <telerik:RadToggleSwitchButton Grid.Row="4"
                                                                                               Grid.Column="1"
                                                                                               Margin="5,0,0,0"
                                                                                               CheckedContent="Sì"
                                                                                               Content="{Binding Details.azagedoff}"
                                                                                               IsChecked="{Binding Details.azagedoff}"
                                                                                               UncheckedContent="No" />
                                                            </Grid>
                                                        </ScrollViewer>
                                                    </telerik:RadTabItem.Content>
                                                </telerik:RadTabItem>
