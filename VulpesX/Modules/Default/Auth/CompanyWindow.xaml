                                                             DisplayMemberPath="Description"
                                                             IsEditable="True"
                                                             IsReadOnly="True"
                                                             ItemsSource="{Binding ShareholderTypes}"
                                                             SelectedValue="{Binding Details.azsocuni, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             SelectedValuePath="ID" />

                                        <TextBlock Grid.Row="8"
                                                   Grid.Column="0"
                                                   Style="{StaticResource VulpesXLabel}"
                                                   Text="Stato liquidazione" />
                                        <telerik:RadComboBox Grid.Row="8"
                                                             Grid.Column="1"
                                                             Width="250"
                                                             Margin="5,2,15,2"
                                                             HorizontalAlignment="Left"
                                                             HorizontalContentAlignment="Left"
                                                             DisplayMemberPath="Description"
                                                             IsEditable="True"
                                                             IsReadOnly="True"
                                                             ItemsSource="{Binding LiquidationStatuses}"
                                                             SelectedValue="{Binding Details.azstaliq, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             SelectedValuePath="ID" />

                                        <TextBlock Grid.Row="9"
                                                   Grid.Column="0"
                                                   Style="{StaticResource VulpesXLabel}"
                                                   Text="Percorso salvataggio XML" />
                                        <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal">
                                            <TextBox Width="430"
                                                     Margin="5,0,0,0"
                                                     HorizontalAlignment="Left"
                                                     VerticalAlignment="Center"
                                                     MaxLength="1000"
                                                     Text="{Binding Details.azeipath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <telerik:RadButton x:Name="cmdSelectEIPath"
                                                               Margin="5"
                                                               telerik:TouchManager.TouchMode="HitTestHidden"
                                                               BorderBrush="DeepSkyBlue"
                                                               BorderThickness="5,0,0,0"
                                                               Click="cmdSelectEIPath_Click"
                                                               Content="..." />
                                        </StackPanel>

                                    </Grid>
                                </ScrollViewer>
                            </telerik:RadTabItem.Content>
                        </telerik:RadTabItem>
                        <telerik:RadTabItem DropDownContent="Contabilità" Header="Contabilità">
                            <telerik:RadTabItem.Content>
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                    <Grid Margin="0,10,10,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="9*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Style="{StaticResource VulpesXSubtitle}"
                                                   Text="Abbuoni" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Margin="0,0,3,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Style="{DynamicResource VulpesXLabel}"
                                                   Text="Gruppo"
                                                   TextAlignment="Right" />
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                            <telerik:RadAutoCompleteBox Width="150"
                                                                        Margin="1"
                                                                        HorizontalAlignment="Left"
                                                                        VerticalContentAlignment="Center"
                                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                                        GotFocus="ac_GotFocus"
                                                                        ItemsSource="{Binding Details.GroupsList}"
                                                                        LostFocus="ac_LostFocus"
                                                                        NoResultsContent="Nessun gruppo trovato"
                                                                        SelectedItem="{Binding Details.SelectedGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                        SelectionMode="Single"
                                                                        TextSearchMode="Contains"
                                                                        TextSearchPath="FullDescriptionSearchable" />
                                            <TextBlock Width="60"
                                                       Margin="0,0,3,0"
                                                       VerticalAlignment="Center"
                                                       FontWeight="Bold"
                                                       Style="{DynamicResource VulpesXLabel}"
                                                       Text="Conto"
                                                       TextAlignment="Right" />
                                            <telerik:RadAutoCompleteBox Width="240"
                                                                        Margin="1"
                                                                        HorizontalAlignment="Left"
                                                                        VerticalContentAlignment="Center"
                                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                                        GotFocus="ac_GotFocus"
                                                                        ItemsSource="{Binding Details.AccountsList}"
                                                                        LostFocus="ac_LostFocus"
                                                                        NoResultsContent="Nessun conto trovato"
                                                                        SelectedItem="{Binding Details.SelectedAccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                        SelectionMode="Single"
                                                                        TextSearchMode="Contains"
                                                                        TextSearchPath="FullDescriptionSearchable" />
                                            <TextBlock Width="90"
                                                       Margin="0,0,3,0"
                                                       VerticalAlignment="Center"
                                                       FontWeight="Bold"
                                                       Style="{DynamicResource VulpesXLabel}"
                                                       Text="Sottoconto"
                                                       TextAlignment="Right" />
                                            <telerik:RadAutoCompleteBox Width="300"
                                                                        Margin="1"
                                                                        HorizontalAlignment="Left"
                                                                        VerticalContentAlignment="Center"
                                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                                        GotFocus="ac_GotFocus"
                                                                        ItemsSource="{Binding Details.SubaccountsList}"
                                                                        LostFocus="ac_LostFocus"
                                                                        NoResultsContent="Nessun sottoconto trovato"
                                                                        SelectedItem="{Binding Details.SelectedSubaccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                        SelectionMode="Single"
                                                                        TextSearchMode="Contains"
                                                                        TextSearchPath="FullDescriptionSearchable" />
                                        </StackPanel>

                                        <TextBlock Grid.Row="3"
                                                   Grid.Column="0"
                                                   Style="{StaticResource VulpesXLabel}"
                                                   Text="Chiusura di esercizio per C/F" />
                                        <telerik:RadToggleSwitchButton Grid.Row="3"
                                                                       Grid.Column="1"
                                                                       Margin="5,0,0,0"
                                                                       CheckedContent="Sì"
                                                                       Content="{Binding Details.aziconchiuclifor}"
                                                                       IsChecked="{Binding Details.aziconchiuclifor}"
                                                                       UncheckedContent="No" />
                                    </Grid>
                                </ScrollViewer>
                            </telerik:RadTabItem.Content>
                        </telerik:RadTabItem>
                        <telerik:RadTabItem DropDownContent="Asset" Header="Asset">
                            <telerik:RadTabItem.Content>
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                    <Grid Margin="0,10,10,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="5*" />
                                            <ColumnDefinition Width="5*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Style="{StaticResource VulpesXLabel}"
                                                   Text="Gestione [Passaggio]" />
                                        <telerik:RadToggleSwitchButton Grid.Row="1"
                                                                       Grid.Column="1"
                                                                       Margin="5,0,0,0"
                                                                       CheckedContent="Sì"
                                                                       Content="{Binding Details.azaststep}"
                                                                       IsChecked="{Binding Details.azaststep}"
                                                                       UncheckedContent="No" />
                                    </Grid>
                                </ScrollViewer>
                            </telerik:RadTabItem.Content>
                        </telerik:RadTabItem>
                    </telerik:RadTabControl>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="EMAIL" Header="EMAIL">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="15" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="8*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Server SMTP" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="300"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="left"
                                         VerticalAlignment="Center"
                                         MaxLength="255"
                                         Text="{Binding Details.azsmtp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Width="50"
                                           Margin="0,0,5,0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Porta"
                                           TextAlignment="Right" />
                                <telerik:RadNumericUpDown Width="100"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          Maximum="999999"
                                                          Minimum="0"
                                                          NumberDecimalDigits="0"
                                                          ShowButtons="False"
                                                          Value="{Binding Details.azsmtpport, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Width="70"
                                           Margin="0,0,5,0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Usa TLS"
                                           TextAlignment="Right" />
                                <telerik:RadToggleSwitchButton Margin="5,0,0,0"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Details.azusetls}"
                                                               IsChecked="{Binding Details.azusetls}"
                                                               UncheckedContent="No" />
                            </StackPanel>

                            <!--  generic address  -->
                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXSubtitle}"
                                       Text="INDIRIZZO GENERICO"
                                       TextAlignment="Right" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Style="{StaticResource VulpesXSubtitleInfo}"
                                       Text="(comunicazioni interne,segnalazione errori)" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Nome utente" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="300"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="left"
                                         VerticalAlignment="Center"
                                         MaxLength="255"
                                         Text="{Binding Details.azuser, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Nome visualizzato" />
                                <TextBox Width="300"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="left"
                                         VerticalAlignment="Center"
                                         MaxLength="255"
                                         Text="{Binding Details.azusrname, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Password" />
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadPasswordBox x:Name="pbSMTPPassword"
                                                        Width="300"
                                                        Margin="5,5,15,0"
                                                        HorizontalAlignment="Left"
                                                        ShowPasswordButtonVisibility="Always" />
                                <Button x:Name="cmdTestSMTP"
                                        Margin="5"
                                        Click="cmdTestSMTP_Click"
                                        Content="Verifica la connessione al server SMTP" />
                            </StackPanel>
                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Invia una mail di prova" />
                            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="txtEmailAddress"
                                         Width="400"
                                         Margin="5,0,5,0"
                                         HorizontalAlignment="left"
                                         VerticalAlignment="Center"
                                         MaxLength="255" />
                                <Button x:Name="cmdTestEmail"
                                        Width="100"
                                        Margin="5"
                                        Click="cmdTestEmail_Click"
                                        Content="INVIA" />
                            </StackPanel>

                            <!--  CRM address  -->
                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXSubtitle}"
                                       Text="INDIRIZZO CRM"
                                       TextAlignment="Right" />
                            <TextBlock Grid.Row="7"
                                       Grid.Column="1"
                                       Style="{StaticResource VulpesXSubtitleInfo}"
                                       Text="(invio offerte,ordini,DDT,fatture)" />
                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Nome utente" />
                            <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="300"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="left"
                                         VerticalAlignment="Center"
                                         MaxLength="255"
                                         Text="{Binding Details.azusrcrm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Nome visualizzato" />
                                <TextBox Width="300"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="left"
                                         VerticalAlignment="Center"
                                         MaxLength="255"
                                         Text="{Binding Details.azusrcrmname, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Grid.Row="9"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Password" />
                            <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadPasswordBox x:Name="pbSMTPPasswordCRM"
                                                        Width="300"
                                                        Margin="5,5,15,0"
                                                        HorizontalAlignment="Left"
                                                        ShowPasswordButtonVisibility="Always" />
                                <Button x:Name="cmdTestSMTPCRM"
                                        Margin="5"
                                        Click="cmdTestSMTPCRM_Click"
                                        Content="Verifica la connessione al server SMTP" />
                            </StackPanel>
                            <TextBlock Grid.Row="10"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Invia una mail di prova" />
                            <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="txtEmailAddressCRM"
                                         Width="400"
                                         Margin="5,0,5,0"
                                         HorizontalAlignment="left"
                                         VerticalAlignment="Center"
                                         MaxLength="255" />
                                <Button x:Name="cmdTestEmailCRM"
                                        Width="100"
                                        Margin="5"
                                        Click="cmdTestEmailCRM_Click"
                                        Content="INVIA" />
                            </StackPanel>

                            <!--  SRM address  -->
                            <TextBlock Grid.Row="12"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXSubtitle}"
                                       Text="INDIRIZZO SRM"
                                       TextAlignment="Right" />
                            <TextBlock Grid.Row="12"
                                       Grid.Column="1"
                                       Style="{StaticResource VulpesXSubtitleInfo}"
                                       Text="(invio ordini di acquisto,richiesta di offerte)" />
                            <TextBlock Grid.Row="13"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Nome utente" />
                            <StackPanel Grid.Row="13" Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="300"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="left"
                                         VerticalAlignment="Center"
                                         MaxLength="255"
                                         Text="{Binding Details.azusrsrm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Nome visualizzato" />
                                <TextBox Width="300"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="left"
                                         VerticalAlignment="Center"
                                         MaxLength="255"
                                         Text="{Binding Details.azusrsrmname, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Grid.Row="14"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Password" />
                            <StackPanel Grid.Row="14" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadPasswordBox x:Name="pbSMTPPasswordSRM"
                                                        Width="300"
                                                        Margin="5,5,15,0"
                                                        HorizontalAlignment="Left"
                                                        ShowPasswordButtonVisibility="Always" />
                                <Button x:Name="cmdTestSMTPSRM"
                                        Margin="5"
                                        Click="cmdTestSMTPSRM_Click"
                                        Content="Verifica la connessione al server SMTP" />
                            </StackPanel>
                            <TextBlock Grid.Row="15"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Invia una mail di prova" />
                            <StackPanel Grid.Row="15" Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="txtEmailAddressSRM"
                                         Width="400"
                                         Margin="5,0,5,0"
                                         HorizontalAlignment="left"
                                         VerticalAlignment="Center"
                                         MaxLength="255" />
                                <Button x:Name="cmdTestEmailSRM"
                                        Width="100"
                                        Margin="5"
                                        Click="cmdTestEmailSRM_Click"
                                        Content="INVIA" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="UTENTI" Header="UTENTI">
                <telerik:RadTabItem.Content>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30*" />
                            <ColumnDefinition Width="70*" />
                        </Grid.ColumnDefinitions>
                        <telerik:RadGridView Name="grdUsers"
                                             Grid.Column="0"
                                             AutoGenerateColumns="False"
                                             ItemsSource="{Binding Users}"
                                             SelectionChanged="grdUsers_SelectionChanged"
                                             ShowGroupPanel="False">
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding USRID}" Header="Utente" IsReadOnly="True" />
                            </telerik:RadGridView.Columns>
                        </telerik:RadGridView>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="40" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Background="{DynamicResource VulpesXFirstAlternativeBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Margin="5,0,0,0"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource VulpesXBlueBrush}"
                                           Text="Administrator" />

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                                    <telerik:RadToggleSwitchButton Margin="10,0,0,0" IsChecked="{Binding SelectedUser.SelectedCompany.AccessCompany.acsadmin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Background="{DynamicResource VulpesXFirstAlternativeBrush}" IsEnabled="{Binding SelectedUser.SelectedCompany.AccessCompany.acsadmin, Converter={StaticResource boolNegateConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50*" />
                                    <ColumnDefinition Width="50*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Margin="5,0,0,0"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource VulpesXBlueBrush}"
                                           Text="Abilitazioni menu" />

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                                    <Button Name="btnMenuSelectAll"
                                            Margin="3"
                                            Click="btnMenuSelectAll_Click"
                                            Content="SELEZIONA TUTTO" />
                                    <Button x:Name="btnMenuDeselectAll"
                                            Margin="3"
                                            Click="btnMenuDeselectAll_Click"
                                            Content="DESELEZIONA TUTTO" />
                                </StackPanel>
                            </Grid>

                            <telerik:RadTreeListView x:Name="rtlMenus"
                                                     Grid.Row="2"
                                                     AutoExpandItems="True"
                                                     AutoGenerateColumns="False"
                                                     CanUserFreezeColumns="False"
                                                     CanUserSortColumns="False"
                                                     ColumnWidth="*"
                                                     EnableColumnGroupsVirtualization="False"
                                                     EnableColumnVirtualization="False"
                                                     EnableRowVirtualization="False"
                                                     IsEnabled="{Binding SelectedUser.SelectedAccessCompany.acsadmin, Converter={StaticResource boolNegateConverter}}"
                                                     IsFilteringAllowed="False"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding Menus}"
                                                     RowIsExpandedChanging="rtlMenus_RowIsExpandedChanging">
                                <telerik:RadTreeListView.ChildTableDefinitions>
                                    <telerik:TreeListViewTableDefinition ItemsSource="{Binding SubItems}" />
                                </telerik:RadTreeListView.ChildTableDefinitions>
                                <telerik:RadTreeListView.Columns>
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding Name}" Header="Menu" IsReadOnly="True" />
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding IsEnabled}" Header="Abilita">
                                        <telerik:GridViewDataColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadToggleSwitchButton Name="rtsMenuItem" IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEnabledChanging}" />
                                            </DataTemplate>
                                        </telerik:GridViewDataColumn.CellTemplate>
                                    </telerik:GridViewDataColumn>
                                </telerik:RadTreeListView.Columns>
                            </telerik:RadTreeListView>

                            <Grid Grid.Row="3" Background="{DynamicResource VulpesXFirstAlternativeBrush}">
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource VulpesXBlueBrush}"
                                           Text="Abilitazioni funzioni" />
                            </Grid>

                            <Grid Grid.Row="4" IsEnabled="{Binding SelectedUser.SelectedAccessCompany.acsadmin, Converter={StaticResource boolNegateConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXDarkAlternativeBrush}">
                                        <TextBlock Margin="5,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource VulpesXBlueBrush}"
                                                   Text="Offerte" />
                                    </Grid>

                                    <StackPanel Grid.Row="1" Orientation="Vertical">
                                        <DockPanel Margin="5">
                                            <TextBlock Width="200" Text="Firma commerciale" />
                                            <telerik:RadToggleSwitchButton IsChecked="{Binding UserRoles.canOffersSignCommercial}" />
                                        </DockPanel>
                                        <DockPanel Margin="5">
                                            <TextBlock Width="200" Text="Firma tecnica" />
                                            <telerik:RadToggleSwitchButton IsChecked="{Binding UserRoles.canOffersSignTech}" />
                                        </DockPanel>
                                        <DockPanel Margin="5">
                                            <TextBlock Width="200" Text="Transforma" />
                                            <telerik:RadToggleSwitchButton IsChecked="{Binding UserRoles.canTransformOffers}" />
                                        </DockPanel>
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXDarkAlternativeBrush}">
                                        <TextBlock Margin="5,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource VulpesXBlueBrush}"
                                                   Text="Ordini" />
                                    </Grid>

                                    <StackPanel Grid.Row="1" Orientation="Vertical">
                                        <DockPanel Margin="5">
                                            <TextBlock Width="200" Text="Firma commerciale" />
                                            <telerik:RadToggleSwitchButton IsChecked="{Binding UserRoles.canOrdersSignCommercial}" />
                                        </DockPanel>
                                        <DockPanel Margin="5">
                                            <TextBlock Width="200" Text="Firma tecnica" />
                                            <telerik:RadToggleSwitchButton IsChecked="{Binding UserRoles.canOrdersSignTech}" />
                                        </DockPanel>
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXDarkAlternativeBrush}">
                                        <TextBlock Margin="5,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource VulpesXBlueBrush}"
                                                   Text="RDA" />
                                    </Grid>

                                    <StackPanel Grid.Row="1" Orientation="Vertical">
                                        <DockPanel Margin="5">
                                            <TextBlock Width="200" Text="Approva" />
                                            <telerik:RadToggleSwitchButton IsChecked="{Binding UserRoles.canApproveRDA}" />
                                        </DockPanel>
                                        <DockPanel Margin="5">
                                            <TextBlock Width="200" Text="Transforma" />
                                            <telerik:RadToggleSwitchButton IsChecked="{Binding UserRoles.canTransformRDA}" />
                                        </DockPanel>
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXDarkAlternativeBrush}">
                                        <TextBlock Margin="5,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource VulpesXBlueBrush}"
                                                   Text="ODA" />
                                    </Grid>

                                    <StackPanel Grid.Row="1" Orientation="Vertical">
                                        <DockPanel Margin="5">
                                            <TextBlock Width="200" Text="Firma commerciale" />
                                            <telerik:RadToggleSwitchButton IsChecked="{Binding UserRoles.canPOSignCommercial}" />
                                        </DockPanel>
                                        <DockPanel Margin="5">
                                            <TextBlock Width="200" Text="Firma gestionale" />
                                            <telerik:RadToggleSwitchButton IsChecked="{Binding UserRoles.canPOSignManagement}" />
                                        </DockPanel>
                                        <DockPanel Margin="5">
                                            <TextBlock Width="200" Text="Invio" />
                                            <telerik:RadToggleSwitchButton IsChecked="{Binding UserRoles.canPOSend}" />
                                        </DockPanel>
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXDarkAlternativeBrush}">
                                        <TextBlock Margin="5,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource VulpesXBlueBrush}"
                                                   Text="Dettagli utente" />
                                    </Grid>

                                    <StackPanel Grid.Row="1" Orientation="Vertical">
                                        <DockPanel Margin="5">
                                            <TextBlock Width="200" Text="Agente collegato" />
                                            <telerik:RadComboBox DisplayMemberPath="agedes"
                                                                 ItemsSource="{Binding UserRoles.Agents}"
                                                                 SelectedValue="{Binding UserRoles.agentID}"
                                                                 SelectedValuePath="agecod" />
                                        </DockPanel>
                                        <DockPanel Margin="5">
                                            <TextBlock Width="200" Text="Ruolo attività" />
                                            <telerik:RadComboBox DisplayMemberPath="Description"
                                                                 ItemsSource="{Binding UserRoles.CrmRoles}"
                                                                 SelectedValue="{Binding UserRoles.crmRole}"
                                                                 SelectedValuePath="ID" />
                                        </DockPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <!--<telerik:RadGridView Name="grdUserRole"
                                         AutoGenerateColumns="False"
                                         ItemsSource="{Binding UsersRoles}"
                                         RowEditEnded="grdUserRole_RowEditEnded">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewComboBoxColumn Width="90"
                                                            DataMemberBinding="{Binding agentID}"
                                                            DisplayMemberPath="agedes"
                                                            Header="Agente"
                                                            IsLightweightModeEnabled="True"
                                                            ItemsSourceBinding="{Binding Agents}"
                                                            SelectedValueMemberPath="agecod" />

                                    <telerik:GridViewComboBoxColumn Width="90"
                                                            DataMemberBinding="{Binding crmRole}"
                                                            DisplayMemberPath="Description"
                                                            Header="Attività - Ruolo"
                                                            IsLightweightModeEnabled="True"
                                                            ItemsSourceBinding="{Binding CrmRoles}"
                                                            SelectedValueMemberPath="ID" />
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>-->


                            <StackPanel Grid.Row="5"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                <Button Name="cmdSaveMenus"
                                        Margin="5"
                                        Click="cmdSaveMenus_Click"
                                        Content="SALVA ABILITAZIONI"
                                        Style="{StaticResource VulpesXConfirmButton}" />
                            </StackPanel>
                        </Grid>
                    </Grid>

                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>

            <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Inserito il" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Details.AddedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Details.AddedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultimo aggiornamento il" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Details.UpdatedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Details.UpdatedUserText}" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>

        </telerik:RadTabControl>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>

    </Grid>

</sc:FluentDefaultWindow>
