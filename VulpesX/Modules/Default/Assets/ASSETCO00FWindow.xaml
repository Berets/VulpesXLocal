<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Assets.ASSETCO00FWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Assets"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Contatti dell'asset"
                        Width="1024"
                        Height="768"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <telerik:RadBusyIndicator x:Name="bsyGrid"
                                      Grid.Row="0"
                                      BusyContent="Caricamento dati in corso..."
                                      Foreground="{DynamicResource VulpesXBrush}"
                                      IsBusy="{Binding IsBusy}"
                                      OverlayStyle="{StaticResource WaitOverlayStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="35" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="5*" />
                    </Grid.ColumnDefinitions>
                    <telerik:RadGridView x:Name="GridView"
                                         Grid.Row="0"
                                         Grid.Column="0"
                                         AddingNewDataItem="GridView_AddingNewDataItem"
                                         AutoGenerateColumns="False"
                                         CanUserFreezeColumns="False"
                                         CanUserInsertRows="True"
                                         CanUserResizeColumns="False"
                                         GroupRenderMode="Flat"
                                         IsReadOnly="{Binding IsEnabled}"
                                         ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                         NewRowPosition="Top"
                                         RowDetailsVisibilityMode="VisibleWhenSelected"
                                         RowEditEnded="GridView_RowEditEnded"
                                         RowIndicatorVisibility="Collapsed"
                                         RowValidating="GridView_RowValidating"
                                         SelectionChanged="GridView_SelectionChanged"
                                         ShowGroupPanel="False">
                        <telerik:RadGridView.Columns>
                            <telerik:GridViewToggleRowDetailsColumn />
                            <telerik:GridViewComboBoxColumn Width="190"
                                                            DataMemberBinding="{Binding role_id}"
                                                            DisplayMemberPath="description"
                                                            Header="Ruolo del contatto"
                                                            IsLightweightModeEnabled="True"
                                                            ItemsSourceBinding="{Binding ContactRoles}"
                                                            SelectedValueMemberPath="id" />
                            <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Nome" />
                        </telerik:RadGridView.Columns>
                        <telerik:RadGridView.RowDetailsTemplate>
                            <DataTemplate>
                                <Grid x:Name="grdContactNote" Margin="3" PreviewKeyDown="grdContactNote_PreviewKeyDown">
                                    <StackPanel Width="400" Orientation="Horizontal">
                                        <TextBlock Margin="0,0,5,0"
                                                   VerticalAlignment="Top"
                                                   FontWeight="Bold"
                                                   Text="Note"
                                                   TextAlignment="Right" />
                                        <TextBox Width="390"
                                                 Height="40"
                                                 Margin="1"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Top"
                                                 VerticalContentAlignment="Top"
                                                 AcceptsReturn="True"
                                                 FontSize="10"
                                                 IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType=telerik:RadGridView}}"
                                                 Text="{Binding note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </telerik:RadGridView.RowDetailsTemplate>
                    </telerik:RadGridView>
                    <telerik:RadDataPager x:Name="rdpGrid"
                                          Grid.Row="1"
                                          Grid.Column="0"
                                          Margin="0,-1,0,0"
                                          DisplayMode="FirstLastPreviousNextNumeric, Text"
                                          FontSize="12"
                                          IsTotalItemCountFixed="True"
                                          PageSize="20"
                                          Source="{Binding Head.Contacts}" />

                    <telerik:RadGridView x:Name="GridViewDetails"
                                         Grid.Row="0"
                                         Grid.Column="2"
                                         AddingNewDataItem="GridViewDetails_AddingNewDataItem"
                                         AutoGenerateColumns="False"
                                         CanUserFreezeColumns="False"
                                         CanUserInsertRows="True"
                                         CanUserResizeColumns="False"
                                         GroupRenderMode="Flat"
                                         IsReadOnly="{Binding IsEnabled}"
                                         ItemsSource="{Binding PagedSource, ElementName=rdpGridDetails}"
                                         NewRowPosition="Top"
                                         RowDetailsVisibilityMode="VisibleWhenSelected"
                                         RowEditEnded="GridViewDetails_RowEditEnded"
                                         RowIndicatorVisibility="Collapsed"
                                         RowValidating="GridViewDetails_RowValidating"
                                         ShowGroupPanel="False">
                        <telerik:RadGridView.Columns>
                            <telerik:GridViewToggleRowDetailsColumn />
                            <telerik:GridViewComboBoxColumn Width="120"
                                                            DataMemberBinding="{Binding contact_type_id}"
                                                            DisplayMemberPath="description"
                                                            Header="Tipo contatto"
                                                            IsLightweightModeEnabled="True"
                                                            ItemsSourceBinding="{Binding ContactTypes}"
                                                            SelectedValueMemberPath="id" />
                            <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding contact, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Header="Contatto" />
                        </telerik:RadGridView.Columns>
                        <telerik:RadGridView.RowDetailsTemplate>
                            <DataTemplate>
                                <Grid x:Name="grdContactDetailNote" Margin="3" PreviewKeyDown="grdContactDetailNote_PreviewKeyDown">
                                    <StackPanel Width="400" Orientation="Horizontal">
                                        <TextBlock Margin="0,0,5,0"
                                                   VerticalAlignment="Top"
                                                   FontWeight="Bold"
                                                   Text="Note"
                                                   TextAlignment="Right" />
                                        <TextBox Width="390"
                                                 Height="40"
                                                 Margin="1"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Top"
                                                 VerticalContentAlignment="Top"
                                                 AcceptsReturn="True"
                                                 FontSize="10"
                                                 IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType=telerik:RadGridView}}"
                                                 Text="{Binding note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </telerik:RadGridView.RowDetailsTemplate>
                    </telerik:RadGridView>
                    <telerik:RadDataPager x:Name="rdpGridDetails"
                                          Grid.Row="1"
                                          Grid.Column="2"
                                          Margin="0,-1,0,0"
                                          DisplayMode="FirstLastPreviousNextNumeric, Text"
                                          FontSize="12"
                                          IsTotalItemCountFixed="True"
                                          PageSize="20" />
                </Grid>
            </telerik:RadBusyIndicator>

            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
                <Button Name="cmdSave"
                        Click="cmdSave_Click"
                        Content="SALVA"
                        Style="{StaticResource VulpesXConfirmButton}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</sc:FluentDefaultWindow>
