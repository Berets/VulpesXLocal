<UserControl x:Class="VulpesX.Modules.Default.Assets.ASSET00FView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Assets"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="GESTIONE ASSETS" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Margin="5"
                                         TextChanged="txtSearch_TextChanged"
                                         WatermarkContent="Cerca..." />
        </Grid>

        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <Grid.Resources>
                    <DataTemplate x:Key="AssetAttachmentsIcon">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="35" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BorderBrush="{Binding AssetAttachmentsStatusColor, Converter={StaticResource stringToColorConverter}}" Cursor="Hand">
                                <Label x:Name="label" ToolTip="{Binding AssetAttachmentsStatusText}">
                                    <telerik:RadGlyph x:Name="rgAssetAttachmentsIcon"
                                                      FontSize="14"
                                                      Foreground="{Binding AssetAttachmentsStatusColor, Converter={StaticResource stringToColorConverter}}"
                                                      Glyph="&#xe10e;"
                                                      MouseDown="rgAssetAttachmentsIcon_MouseDown" />
                                </Label>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding AttachmentsCount}" />
                        </Grid>
                    </DataTemplate>
                </Grid.Resources>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     RowIndicatorVisibility="Hidden"
                                     ShowGroupPanel="True">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewColumn Width="110">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadButton x:Name="cmdDelete"
                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                       Click="cmdDelete_Click"
                                                       Content="Elimina"
                                                       Style="{StaticResource VulpesXButton}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn Width="30">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgDetails"
                                                      Cursor="Hand"
                                                      FontSize="14"
                                                      Foreground="{Binding DetailsColor, Converter={StaticResource stringToColorConverter}}"
                                                      Glyph="&#xe670;"
                                                      MouseDown="rgDetails_MouseDown"
                                                      ToolTip="Visualizza i dettagli di questo asset" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn Width="30">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgContacts"
                                                      Cursor="Hand"
                                                      FontSize="14"
                                                      Foreground="{Binding AssetContactsStatusColor, Converter={StaticResource stringToColorConverter}}"
                                                      Glyph="&#xe81b;"
                                                      MouseDown="rgContacts_MouseDown"
                                                      ToolTip="{Binding AssetContactsStatusText}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewDataColumn Width="80" CellTemplate="{StaticResource AssetAttachmentsIcon}" Header="Allegati" />
                        <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding id}" Header="Codice">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Left"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEdit_Click"
                                            Content="{Binding Path=id}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="350" DataMemberBinding="{Binding description}" Header="Descrizione" />
                        <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding Location.FullDescriptionSearchable}" Header="Ubicazione" />
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding purchase_date}"
                                                    Header="Acquisto"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding installation_date}"
                                                    Header="Installazione"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding first_use_date}"
                                                    Header="Primo utilizzo"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="140"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding warranty_expiry_date}"
                                                    Header="Scadenza garanzia"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding Items}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>

</UserControl>
