<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Assets.ASSED00FWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Assets"
                        xmlns:maskedInput="clr-namespace:Telerik.Windows.Controls.MaskedInput;assembly=Telerik.Windows.Controls.Input"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli asset"
                        Width="1000"
                        Height="750"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.Column="0" VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="{DynamicResource VulpesXBrush}" BorderThickness="1">
                <TextBlock Padding="0"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXBrush}"
                           Opacity=".8"
                           Text="COMPONENTI"
                           TextAlignment="Center"
                           Typography.Capitals="AllSmallCaps">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="270" />
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Border>

            <telerik:RadGridView Name="rgvRows"
                                 Grid.Column="1"
                                 AddingNewDataItem="rgvRows_AddingNewDataItem"
                                 AreRowDetailsFrozen="True"
                                 AutoGenerateColumns="False"
                                 CanUserFreezeColumns="False"
                                 CanUserInsertRows="True"
                                 Deleted="rgvRows_Deleted"
                                 GroupRenderMode="Flat"
                                 IsSearchingDeferred="True"
                                 ItemsSource="{Binding Rows}"
                                 NewRowPosition="Top"
                                 RowDetailsVisibilityChanged="rgvRows_RowDetailsVisibilityChanged"
                                 RowEditEnded="rgvRows_RowEditEnded"
                                 RowIndicatorVisibility="Collapsed"
                                 RowValidating="rgvRows_RowValidating"
                                 SearchMode="MatchAnyTerm"
                                 ShowGroupPanel="False"
                                 ShowSearchPanel="False"
                                 Tag="{Binding ShowStep}"
                                 ToolTipService.ShowOnDisabled="True"
                                 ValidatesOnDataErrors="InEditMode">
                <telerik:RadGridView.Columns>
                    <telerik:GridViewToggleRowDetailsColumn />
                    <telerik:GridViewDataColumn Width="60"
                                                DataMemberBinding="{Binding position}"
                                                Header="Riga"
                                                HeaderTextAlignment="Right"
                                                IsReadOnly="True"
                                                IsVisible="False"
                                                TextAlignment="Right" />
                    <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding description}" Header="Descrizione">
                        <telerik:GridViewDataColumn.CellEditTemplate>
                            <DataTemplate>
                                <TextBox MaxLength="255" Text="{Binding description, Mode=TwoWay}" />
                            </DataTemplate>
                        </telerik:GridViewDataColumn.CellEditTemplate>
                    </telerik:GridViewDataColumn>
                    <telerik:GridViewDataColumn Width="300"
                                                DataMemberBinding="{Binding Product.FullDescriptionSearchable}"
                                                Header="Articolo"
                                                IsReadOnly="False">
                        <telerik:GridViewDataColumn.CellEditTemplate>
                            <DataTemplate>
                                <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Products}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun articolo trovato"
                                                            SelectedItem="{Binding Product, Mode=TwoWay}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable" />
                            </DataTemplate>
                        </telerik:GridViewDataColumn.CellEditTemplate>
                    </telerik:GridViewDataColumn>
                    <telerik:GridViewDataColumn Width="100"
                                                DataMemberBinding="{Binding quantity, StringFormat=N6}"
                                                Header="Quantita'"
                                                HeaderTextAlignment="Right"
                                                TextAlignment="Right">
                        <telerik:GridViewDataColumn.CellEditTemplate>
                            <DataTemplate>
                                <telerik:RadNumericUpDown Minimum="0" NumberDecimalDigits="6" Value="{Binding quantity}" />
                            </DataTemplate>
                        </telerik:GridViewDataColumn.CellEditTemplate>
                    </telerik:GridViewDataColumn>
                    <telerik:GridViewDataColumn Width="60"
                                                DataMemberBinding="{Binding Product.UnitaID}"
                                                Header="UM"
                                                HeaderTextAlignment="Center"
                                                IsReadOnly="True"
                                                TextAlignment="Center" />
                    <telerik:GridViewDataColumn Width="150"
                                                DataMemberBinding="{Binding QuantityAvailable}"
                                                Header="Q.ta' disponibile"
                                                HeaderTextAlignment="Right"
                                                IsReadOnly="True"
                                                TextAlignment="Right" />
                </telerik:RadGridView.Columns>
                <telerik:RadGridView.RowDetailsTemplate>
                    <DataTemplate>
                        <Grid x:Name="grdDetails" Margin="3" PreviewKeyDown="grdDetails_PreviewKeyDown">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="10" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="60" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="635" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,0,5,0"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Text="Descrizione"
                                       TextAlignment="Right" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Width="650"
                                     Margin="1"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Top"
                                     FontSize="10"
                                     IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType=telerik:RadGridView}}"
                                     Text="{Binding description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Margin="0,0,3,0"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Text="Articolo"
                                       TextAlignment="Right" />
                            <StackPanel Grid.Row="2"
                                        Grid.Column="1"
                                        HorizontalAlignment="Left"
                                        Orientation="Horizontal">
                                <telerik:RadAutoCompleteBox Width="350"
                                                            Margin="1"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Stretch"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Products}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun articolo trovato"
                                                            SelectedItem="{Binding Product, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable" />
                                <TextBlock Width="90"
                                           Margin="0,0,5,0"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"
                                           Text="Quantità"
                                           TextAlignment="Right" />
                                <telerik:RadNumericUpDown Width="100"
                                                          Margin="2"
                                                          FontSize="10"
                                                          Minimum="0"
                                                          NumberDecimalDigits="6"
                                                          ShowButtons="False"
                                                          Value="{Binding quantity}" />
                                <TextBlock Margin="5,0,3,0"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"
                                           Style="{DynamicResource VulpesXData}"
                                           Text="{Binding Product.UnitaID}"
                                           TextAlignment="Left" />
                            </StackPanel>

                            <Grid Grid.Row="3"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="3"
                                  Visibility="{Binding Tag, RelativeSource={RelativeSource AncestorType=telerik:RadGridView}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="795" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Margin="0,0,5,0"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"
                                           Text="Passaggio"
                                           TextAlignment="Right" />
                                <telerik:RadMaskedNumericInput Grid.Column="1"
                                                               Width="60"
                                                               Margin="1"
                                                               HorizontalAlignment="Left"
                                                               HorizontalContentAlignment="Center"
                                                               maskedInput:MaskedInputExtensions.AllowNull="True"
                                                               maskedInput:MaskedInputExtensions.MaxTextLength="2"
                                                               maskedInput:MaskedInputExtensions.Maximum="99"
                                                               AllowSkipPlaceholders="True"
                                                               AutoFillNumberGroupSeparators="False"
                                                               AutoFillZeros="False"
                                                               FormatString="00"
                                                               InputBehavior="Insert"
                                                               Mask="##"
                                                               SelectionOnFocus="SelectAll"
                                                               SpinMode="Position"
                                                               TextMode="MaskedText"
                                                               Value="{Binding step, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Margin="0,0,5,0"
                                       VerticalAlignment="Top"
                                       FontWeight="Bold"
                                       Text="Nota"
                                       TextAlignment="Right" />
                            <TextBox Grid.Row="4"
                                     Grid.Column="1"
                                     Width="650"
                                     Height="40"
                                     Margin="1"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Top"
                                     VerticalContentAlignment="Top"
                                     AcceptsReturn="True"
                                     FontSize="10"
                                     IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType=telerik:RadGridView}}"
                                     Text="{Binding note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Border Grid.Row="1"
                                    Grid.RowSpan="2"
                                    Grid.Column="2"
                                    Margin="15,0,0,5"
                                    BorderBrush="Gold"
                                    BorderThickness="2"
                                    CornerRadius="5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="16" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Padding="0"
                                               VerticalAlignment="Top"
                                               Foreground="Gold"
                                               Text="Quantita' allarme"
                                               TextAlignment="Center"
                                               Typography.Capitals="AllSmallCaps" />
                                    <TextBlock Grid.Row="1"
                                               VerticalAlignment="Stretch"
                                               FontSize="14"
                                               Foreground="Gold"
                                               Text="{Binding Product.store_warning_qty, StringFormat=N6}"
                                               TextAlignment="Center"
                                               Typography.Capitals="AllSmallCaps" />
                                </Grid>
                            </Border>
                            <Border Grid.Row="3"
                                    Grid.RowSpan="2"
                                    Grid.Column="2"
                                    Margin="15,0,0,5"
                                    BorderBrush="OrangeRed"
                                    BorderThickness="2"
                                    CornerRadius="5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="16" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Padding="0"
                                               VerticalAlignment="Top"
                                               Foreground="OrangeRed"
                                               Text="Quantita' minima"
                                               TextAlignment="Center"
                                               Typography.Capitals="AllSmallCaps" />
                                    <TextBlock Grid.Row="1"
                                               VerticalAlignment="Stretch"
                                               FontSize="14"
                                               Foreground="OrangeRed"
                                               Text="{Binding Product.store_min_stock, StringFormat=N6}"
                                               TextAlignment="Center"
                                               Typography.Capitals="AllSmallCaps" />
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </telerik:RadGridView.RowDetailsTemplate>
            </telerik:RadGridView>
        </Grid>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
