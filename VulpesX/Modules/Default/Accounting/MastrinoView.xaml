<UserControl x:Class="VulpesX.Modules.Default.Accounting.MastrinoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="INTERROGAZIONE MASTRINI" />
                <TextBlock Margin="15,5,0,0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Valori in" />
                <TextBlock Margin="5,5,0,0"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="DeepSkyBlue"
                           Text="{Binding CurrencyText}" />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <telerik:RadComboBox x:Name="cmbYear"
                                     Width="100"
                                     Margin="5"
                                     HorizontalAlignment="Left"
                                     HorizontalContentAlignment="Right"
                                     DisplayMemberPath="eseann"
                                     SelectionChanged="cmbYear_SelectionChanged" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Margin="5"
                                         TextChanged="txtSearch_TextChanged"
                                         WatermarkContent="Cerca..." />
        </Grid>

        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     RowIndicatorVisibility="Hidden"
                                     ShowGroupPanel="True">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewDataColumn Width="80"
                                                    DataMemberBinding="{Binding P1GRUP}"
                                                    Header="Gruppo"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="80"
                                                    DataMemberBinding="{Binding P2CONT}"
                                                    Header="Conto"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataMemberBinding="{Binding P3SOTC}"
                                                    Header="Sottoconto"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="450" DataMemberBinding="{Binding SubaccountDescription}" Header="Descrizione">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdCompute"
                                            Margin="3"
                                            HorizontalContentAlignment="Left"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdCompute_Click"
                                            Content="{Binding Path=SubaccountDescription}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="160"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding P4DATA}"
                                                    Header="Data ultima chiusura"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="60"
                                                    DataMemberBinding="{Binding BalanceSign}"
                                                    Header="D/A"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="180"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding Balance}"
                                                    Header="Saldo ultima chiusura"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding Items}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>

</UserControl>
