<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.PNDuplicateWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Duplica registrazione contabile"
                        Width="800"
                        Height="300"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">

    <telerik:RadBusyIndicator Name="bsyIndicator"
                              BusyContent="Sto importando"
                              Foreground="{DynamicResource VulpesXBrush}"
                              IsBusy="{Binding IsBusy}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35" />
                        <RowDefinition Height="35" />
                        <RowDefinition Height="35" />
                        <RowDefinition Height="35" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="8*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Esercizio" />
                    <telerik:RadComboBox x:Name="cmbAccountingYear"
                                         Grid.Row="0"
                                         Grid.Column="1"
                                         Width="150"
                                         Margin="5,5,15,5"
                                         HorizontalAlignment="Left"
                                         HorizontalContentAlignment="Right"
                                         DisplayMemberPath="eseann"
                                         SelectedValue="{Binding AccountingYear, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         SelectedValuePath="eseann" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Data registrazione" />
                    <telerik:RadDateTimePicker Grid.Row="1"
                                               Grid.Column="1"
                                               Margin="5,0,15,0"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               DateSelectionMode="Day"
                                               DateTimeWatermarkContent="Scegliere la data per la registrazione"
                                               DisplayFormat="Short"
                                               InputMode="DatePicker"
                                               SelectedValue="{Binding Date}" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Causale" />
                    <telerik:RadAutoCompleteBox x:Name="acCausal"
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                Margin="5,2,15,2"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Center"
                                                DisplayMemberPath="FullDescriptionSearchable"
                                                GotFocus="ac_GotFocus"
                                                ItemsSource="{Binding Causals}"
                                                NoResultsContent="Nessuna causale trovata"
                                                SelectedItem="{Binding SelectedCausal, Mode=TwoWay}"
                                                SelectionMode="Single"
                                                TextSearchMode="Contains"
                                                TextSearchPath="FullDescriptionSearchable"
                                                WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Style="{StaticResource VulpesXLabel}"
                               Text="Storno" />
                    <telerik:RadToggleSwitchButton Grid.Row="3"
                                                   Grid.Column="1"
                                                   Margin="5,0,0,0"
                                                   CheckedContent="Sì"
                                                   IsChecked="{Binding IsRemove}"
                                                   UncheckedContent="No" />
                </Grid>
            </ScrollViewer>

            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
                <Button Name="cmdConfirm"
                        Click="cmdConfirm_Click"
                        Content="CONFERMA"
                        Style="{StaticResource VulpesXConfirmButton}" />

            </StackPanel>

        </Grid>
    </telerik:RadBusyIndicator>
</sc:FluentDefaultWindow>
