<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.AccountingDetailWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Stampa definitiva fattura, selezione della data"
                        Width="800"
                        Height="750"
                        Background="{DynamicResource VulpesXDarkWindowsBackgroundBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="None"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,10,0"
                   HorizontalAlignment="Stretch"
                   Style="{StaticResource VulpesXTitle}"
                   Text="{Binding Title}"
                   TextAlignment="Center"
                   Typography.Capitals="AllSmallCaps" />

        <telerik:RadGridView Grid.Row="1"
                             Margin="5"
                             AutoGenerateColumns="False"
                             IsReadOnly="True"
                             ItemsSource="{Binding Data}"
                             ShowGroupPanel="False">
            <telerik:RadGridView.Columns>
                <telerik:GridViewDataColumn Width="500" DataMemberBinding="{Binding Description}" Header="Sottoconto contabile" />
                <telerik:GridViewDataColumn Width="160"
                                            DataFormatString="N2"
                                            DataMemberBinding="{Binding Saldo}"
                                            Header="Saldo"
                                            HeaderTextAlignment="Right"
                                            TextAlignment="Right" />
            </telerik:RadGridView.Columns>
        </telerik:RadGridView>

        <StackPanel Grid.Row="2"
                    Margin="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Width="200"
                    Margin="2"
                    BorderBrush="Gold"
                    BorderThickness="5,0,0,0"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    FontSize="10"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
