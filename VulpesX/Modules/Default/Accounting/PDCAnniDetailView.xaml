<UserControl x:Class="VulpesX.Modules.Default.Accounting.PDCAnniDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:culture="clr-namespace:System.Globalization;assembly=mscorlib"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Border Margin="5,1,1,1"
            Padding="1"
            BorderBrush="{DynamicResource VulpesXBrush}"
            BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="5" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Margin="15,0,0,0"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Center"
                       FontSize="20"
                       Foreground="{DynamicResource VulpesXBrush}"
                       Text="DETTAGLI ANNO" />
            <TextBlock Grid.Row="0"
                       Margin="0,0,15,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="20"
                       Foreground="{DynamicResource VulpesXBrush}"
                       Text="{Binding Data.P4ANNO}"
                       Typography.Capitals="AllSmallCaps" />
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="7*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Gruppo" />
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Width="60"
                               Margin="5,0,15,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource VulpesXBrush}"
                               Text="{Binding Data.P1GRUP}" />
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Conto" />
                    <TextBlock Width="60"
                               Margin="5,0,15,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource VulpesXBrush}"
                               Text="{Binding Data.P2CONT}" />
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Sottoconto" />
                    <TextBlock Width="80"
                               Margin="5,0,15,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource VulpesXBrush}"
                               Text="{Binding Data.P3SOTC}" />
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Anno" />
                <telerik:RadNumericUpDown Grid.Row="1"
                                          Grid.Column="1"
                                          Width="120"
                                          Margin="5,0,15,0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          IsEnabled="{Binding IsInsert}"
                                          Maximum="9999"
                                          NumberDecimalDigits="0"
                                          ShowButtons="False"
                                          Value="{Binding Data.P4ANNO}">
                    <telerik:RadNumericUpDown.NumberFormatInfo>
                        <culture:NumberFormatInfo NumberGroupSeparator="" />
                    </telerik:RadNumericUpDown.NumberFormatInfo>
                </telerik:RadNumericUpDown>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Data ult. chiusura" />
                <telerik:RadDateTimePicker Grid.Row="2"
                                           Grid.Column="1"
                                           Width="150"
                                           Margin="5,0,15,0"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent="Scegliere la data "
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           SelectedValue="{Binding Data.P4DATA}" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Ult. pag. mastrino st." />
                <telerik:RadNumericUpDown Grid.Row="3"
                                          Grid.Column="1"
                                          Width="120"
                                          Margin="5,0,15,0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Maximum="9999"
                                          NumberDecimalDigits="0"
                                          ShowButtons="False"
                                          Value="{Binding Data.P4PAM2}">
                    <telerik:RadNumericUpDown.NumberFormatInfo>
                        <culture:NumberFormatInfo NumberGroupSeparator="" />
                    </telerik:RadNumericUpDown.NumberFormatInfo>
                </telerik:RadNumericUpDown>

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="DARE periodo" />
                <telerik:RadNumericUpDown Grid.Row="4"
                                          Grid.Column="1"
                                          Width="250"
                                          Margin="5,0,15,0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          NumberDecimalDigits="2"
                                          Value="{Binding Data.P4DAPE}" />

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="AVERE periodo" />
                <telerik:RadNumericUpDown Grid.Row="5"
                                          Grid.Column="1"
                                          Width="250"
                                          Margin="5,0,15,0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          NumberDecimalDigits="2"
                                          Value="{Binding Data.P4AVPE}" />

                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="DARE esercizio" />
                <telerik:RadNumericUpDown Grid.Row="6"
                                          Grid.Column="1"
                                          Width="250"
                                          Margin="5,0,15,0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          NumberDecimalDigits="2"
                                          Value="{Binding Data.P4DAES}" />

                <TextBlock Grid.Row="7"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="AVERE esercizio" />
                <telerik:RadNumericUpDown Grid.Row="7"
                                          Grid.Column="1"
                                          Width="250"
                                          Margin="5,0,15,0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          NumberDecimalDigits="2"
                                          Value="{Binding Data.P4AVES}" />

                <TextBlock Grid.Row="8"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Margin="15,0,15,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXBrush}"
                           Text="RIEPILOGO SALDI"
                           Typography.Capitals="AllSmallCaps" />

                <TextBlock Grid.Row="9"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="PERIODO" />
                <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Margin="5,0,15,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{DynamicResource VulpesXBrush}"
                               Text="{Binding Data.PeriodBalanceSign}" />
                    <TextBlock Margin="5,0,15,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{DynamicResource VulpesXBrush}"
                               Text="{Binding Data.PeriodBalance, StringFormat=N2}" />
                </StackPanel>

                <TextBlock Grid.Row="10"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="ESERCIZIO" />
                <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Margin="5,0,15,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{DynamicResource VulpesXBrush}"
                               Text="{Binding Data.YearBalanceSign}" />
                    <TextBlock Margin="5,0,15,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{DynamicResource VulpesXBrush}"
                               Text="{Binding Data.YearBalance, StringFormat=N2}" />
                </StackPanel>

                <TextBlock Grid.Row="11"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="TOTALE" />
                <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Margin="5,0,15,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{DynamicResource VulpesXBrush}"
                               Text="{Binding Data.TotalBalanceSign}" />
                    <TextBlock Margin="5,0,15,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="18"
                               Foreground="{DynamicResource VulpesXBrush}"
                               Text="{Binding Data.TotalBalance, StringFormat=N2}" />
                </StackPanel>

                <StackPanel Grid.Row="12"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Orientation="Horizontal">
                    <Button Name="cmdSave"
                            Click="cmdSave_Click"
                            Content="SALVA"
                            Style="{StaticResource VulpesXConfirmButton}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>

</UserControl>
