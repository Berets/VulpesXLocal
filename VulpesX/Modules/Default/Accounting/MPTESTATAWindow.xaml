<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.MPTESTATAWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Mandato di pagamento"
                        Width="1024"
                        Height="680"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40*" />
            <RowDefinition Height="60*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>


        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*" />
                    <ColumnDefinition Width="2.5*" />
                    <ColumnDefinition Width="2.5*" />
                    <ColumnDefinition x:Name="col3" Width="2.5*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Esercizio" />
                <telerik:RadComboBox x:Name="cmbAccountingYear"
                                     Grid.Row="0"
                                     Grid.Column="1"
                                     Width="150"
                                     Margin="5,5,15,5"
                                     HorizontalAlignment="Left"
                                     HorizontalContentAlignment="Right"
                                     DisplayMemberPath="eseann"
                                     IsEnabled="{Binding Data.IsEnabled}"
                                     SelectedValue="{Binding Data.MPANNO, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="eseann" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Data mandato" />
                <telerik:RadDateTimePicker Grid.Row="1"
                                           Grid.Column="1"
                                           Margin="5,2,15,2"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent="Scegliere la data mandato"
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           IsEnabled="{Binding Data.IsEnabled}"
                                           SelectedValue="{Binding Data.MPDATA}" />

                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Data valuta" />
                <telerik:RadDateTimePicker Grid.Row="1"
                                           Grid.Column="3"
                                           Margin="5,2,15,2"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent="Scegliere la data valuta"
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           IsEnabled="{Binding Data.IsEnabled}"
                                           SelectedValue="{Binding Data.MPDVAL}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Tipo mandato" />
                <telerik:RadAutoCompleteBox x:Name="acType"
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="3"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            IsEnabled="{Binding Data.IsEnabled}"
                                            ItemsSource="{Binding Types}"
                                            LostFocus="acType_LostFocus"
                                            NoResultsContent="Nessun tipo trovato"
                                            SelectedItem="{Binding SelectedType, Mode=TwoWay}"
                                            SelectionChanged="acType_SelectionChanged"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Banca interna" />
                <telerik:RadAutoCompleteBox x:Name="acInternalBank"
                                            Grid.Row="3"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="3"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            IsEnabled="{Binding Data.IsEnabled}"
                                            ItemsSource="{Binding Banks}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessuna banca trovata"
                                            SelectedItem="{Binding SelectedBank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionChanged="acInternalBank_SelectionChanged"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
            </Grid>
        </ScrollViewer>

        <telerik:RadGridView Name="rgvRows"
                             Grid.Row="1"
                             Margin="0"
                             AddingNewDataItem="rgvRows_AddingNewDataItem"
                             AutoGenerateColumns="False"
                             CanUserFreezeColumns="False"
                             CanUserInsertRows="True"
                             Deleted="rgvRows_Deleted"
                             IsReadOnly="{Binding Data.IsReadOnly}"
                             IsSearchingDeferred="True"
                             ItemsSource="{Binding Rows}"
                             NewRowPosition="Top"
                             RowDetailsVisibilityMode="VisibleWhenSelected"
                             RowEditEnded="rgvRows_RowEditEnded"
                             RowIndicatorVisibility="Collapsed"
                             RowValidated="rgvRows_RowValidated"
                             RowValidating="rgvRows_RowValidating"
                             SearchMode="MatchAnyTerm"
                             SelectionMode="Single"
                             ShowGroupPanel="False"
                             ShowSearchPanel="False"
                             Tag="{Binding IsEnabled}"
                             ValidatesOnDataErrors="InEditMode">
            <telerik:RadGridView.Columns>

                <telerik:GridViewDataColumn Width="100"
                                            DataMemberBinding="{Binding MPPOSI}"
                                            Header="*"
                                            IsReadOnly="True"
                                            TextAlignment="Center" />
                <telerik:GridViewDataColumn Width="250"
                                            DataMemberBinding="{Binding EntityDescription}"
                                            Header="Ragione sociale"
                                            IsReadOnlyBinding="{Binding IsEntityReadonly}">
                    <telerik:GridViewDataColumn.CellEditTemplate>
                        <DataTemplate>
                            <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                        ItemsSource="{Binding EntitiesList}"
                                                        NoResultsContent="Nessuna anagrafica trovata"
                                                        SelectedItem="{Binding SelectedEntity, Mode=TwoWay}"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable" />
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellEditTemplate>
                </telerik:GridViewDataColumn>
                <telerik:GridViewColumn Width="30">
                    <telerik:GridViewColumn.CellTemplate>
                        <DataTemplate>
                            <telerik:RadGlyph x:Name="rgSelectEC"
                                              Cursor="Hand"
                                              FontSize="14"
                                              Foreground="{DynamicResource VulpesXGreenBrush}"
                                              Glyph="&#xe134;"
                                              MouseDown="rgSelectEC_MouseDown"
                                              ToolTip="Apri l'estratto conto dettagliato"
                                              Visibility="{Binding SelectECVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                        </DataTemplate>
                    </telerik:GridViewColumn.CellTemplate>
                </telerik:GridViewColumn>

                <telerik:GridViewDataColumn DataFormatString="N2"
                                            DataMemberBinding="{Binding M3IMEU}"
                                            Header="Importo"
                                            HeaderTextAlignment="Right"
                                            TextAlignment="Right" />
                <telerik:GridViewDataColumn DataMemberBinding="{Binding M3SEGN}"
                                            Header="Segno"
                                            HeaderTextAlignment="Right"
                                            IsReadOnly="True"
                                            TextAlignment="Right" />

                <telerik:GridViewDataColumn DataMemberBinding="{Binding M3RIFE}"
                                            Header="Riferimento"
                                            HeaderTextAlignment="Right"
                                            TextAlignment="Right" />
                <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy"
                                            DataMemberBinding="{Binding M3DARE}"
                                            Header="Data riferimento"
                                            HeaderTextAlignment="Right"
                                            TextAlignment="Right" />

                <telerik:GridViewDataColumn DataMemberBinding="{Binding M3DOCU}"
                                            Header="Documento"
                                            HeaderTextAlignment="Right"
                                            TextAlignment="Right" />
                <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy"
                                            DataMemberBinding="{Binding M3DODO}"
                                            Header="Data documento"
                                            HeaderTextAlignment="Right"
                                            TextAlignment="Right" />
            </telerik:RadGridView.Columns>
            <telerik:RadGridView.RowDetailsTemplate>
                <DataTemplate>
                    <StackPanel Margin="10" HorizontalAlignment="Stretch" Orientation="Horizontal">
                        <TextBlock FontWeight="Bold" Text="Note: " />
                        <TextBox Width="650"
                                 IsEnabled="{Binding RelativeSource={RelativeSource AncestorType=telerik:RadGridView}, Path=Tag}"
                                 MaxLength="50"
                                 Text="{Binding M3DESC}" />
                    </StackPanel>
                </DataTemplate>
            </telerik:RadGridView.RowDetailsTemplate>
        </telerik:RadGridView>

        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Width="130"
                    Click="cmdSave_Click"
                    Content="CONFERMA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
