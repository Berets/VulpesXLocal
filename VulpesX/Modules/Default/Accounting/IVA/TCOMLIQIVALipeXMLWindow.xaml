<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.IVA.TCOMLIQIVALipeXMLWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting.IVA"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Generazione XML LIPE per invio telematico"
                        Width="800"
                        Height="350"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="7*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Partita IVA"
                           TextAlignment="Right" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Style="{StaticResource VulpesXData}"
                           Text="{Binding VATID}"
                           TextAlignment="Left" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Codice fiscale"
                           TextAlignment="Right" />
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Style="{StaticResource VulpesXData}"
                           Text="{Binding FiscalIDSender}"
                           TextAlignment="Left" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Codice carica"
                           TextAlignment="Right" />
                <telerik:RadComboBox Grid.Row="3"
                                     Grid.Column="1"
                                     Margin="5,2,15,2"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     IsEditable="True"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Titles}"
                                     SelectedValue="{Binding TitleID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Codice fiscale intermediario"
                           TextAlignment="Right" />
                <TextBox Grid.Row="4"
                         Grid.Column="1"
                         Width="250"
                         Margin="5,2,15,2"
                         HorizontalAlignment="Left"
                         MaxLength="16"
                         Text="{Binding BrokerFiscalID}" />

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Impegno alla presentazione"
                           TextAlignment="Right" />
                <telerik:RadComboBox Grid.Row="5"
                                     Grid.Column="1"
                                     Margin="5,2,15,2"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     IsEditable="True"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Presentations}"
                                     SelectedValue="{Binding PresentationID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>


    </Grid>
</sc:FluentDefaultWindow>
