<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.IVA.TCOMLIQIVALipeWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting.IVA"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Contabilizzazione fattura"
                        Width="500"
                        Height="300"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5*" />
                    <ColumnDefinition Width="5*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Anno contabile"
                           TextAlignment="Right" />
                <telerik:RadComboBox x:Name="cmbAccountingYear"
                                     Grid.Row="0"
                                     Grid.Column="1"
                                     Width="100"
                                     Margin="5"
                                     HorizontalAlignment="Left"
                                     HorizontalContentAlignment="Right"
                                     DisplayMemberPath="eseann"
                                     SelectionChanged="cmbAccountingYear_SelectionChanged" />

                <TextBlock Grid.Row="1"
                           Grid.ColumnSpan="2"
                           HorizontalAlignment="Center"
                           Style="{DynamicResource VulpesXData}"
                           Text="{Binding YearInfo}"
                           TextAlignment="Center" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Periodo da elaborare"
                           TextAlignment="Right" />
                <telerik:RadComboBox Grid.Row="2"
                                     Grid.Column="1"
                                     Width="200"
                                     Margin="5,2,15,2"
                                     HorizontalAlignment="Left"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     IsEditable="True"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Quarters}"
                                     SelectedValue="{Binding QuarterID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>

    </Grid>
</sc:FluentDefaultWindow>
