<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.IVA.IVABookWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting.IVA"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Lancia la stampa dei libri IVA"
                        Width="600"
                        Height="350"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">

    <telerik:RadBusyIndicator x:Name="bsyGrid"
                              BusyContent="Caricamento dati in corso..."
                              Foreground="{DynamicResource VulpesXBrush}"
                              IsBusy="{Binding IsBusy}"
                              OverlayStyle="{StaticResource WaitOverlayStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>


            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="10" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*" />
                        <ColumnDefinition Width="6*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Esercizio" />
                    <telerik:RadComboBox x:Name="cmbAccountingYear"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Width="150"
                                         Margin="5,5,15,5"
                                         HorizontalAlignment="Left"
                                         HorizontalContentAlignment="Right"
                                         DisplayMemberPath="eseann"
                                         SelectionChanged="cmbAccountingYear_SelectionChanged" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Libro IVA" />
                    <telerik:RadAutoCompleteBox x:Name="acIVABook"
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                Margin="5,2,15,2"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Center"
                                                DisplayMemberPath="FullDescriptionSearchable"
                                                GotFocus="ac_GotFocus"
                                                ItemsSource="{Binding IVABooks}"
                                                LostFocus="ac_LostFocus"
                                                NoResultsContent="Nessun codice trovato"
                                                SelectedItem="{Binding SelectedIVABook, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                TextSearchMode="Contains"
                                                TextSearchPath="FullDescriptionSearchable"
                                                WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />


                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Stampa dal" />
                    <telerik:RadDateTimePicker Grid.Row="3"
                                               Grid.Column="1"
                                               Width="150"
                                               Margin="5,0,15,0"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               DateSelectionMode="Day"
                                               DateTimeWatermarkContent="Scegliere la data dalla quale stampare"
                                               DisplayFormat="Short"
                                               InputMode="DatePicker"
                                               SelectedValue="{Binding PrintSince}" />

                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Stampa fino al" />
                    <telerik:RadDateTimePicker Grid.Row="4"
                                               Grid.Column="1"
                                               Width="150"
                                               Margin="5,0,15,0"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               DateSelectionMode="Day"
                                               DateTimeWatermarkContent="Scegliere la data fino a cui stampare"
                                               DisplayFormat="Short"
                                               InputMode="DatePicker"
                                               SelectedValue="{Binding PrintUntil}" />

                    <TextBlock Grid.Row="5"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Stampa definitiva" />
                    <telerik:RadToggleSwitchButton Grid.Row="5"
                                                   Grid.Column="1"
                                                   Margin="5,0,0,0"
                                                   CheckedContent="Sì"
                                                   Content="{Binding IsDefinitive}"
                                                   IsChecked="{Binding IsDefinitive}"
                                                   UncheckedContent="No" />
                </Grid>
            </ScrollViewer>


            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
                <Button Name="cmdExcel"
                        Width="130"
                        Click="cmdExcel_Click"
                        Content="EXCEL"
                        Style="{StaticResource VulpesXConfirmButton}" />
                <Button Name="cmdSave"
                        Width="130"
                        Click="cmdSave_Click"
                        Content="CONFERMA"
                        Style="{StaticResource VulpesXConfirmButton}" />
            </StackPanel>
        </Grid>
    </telerik:RadBusyIndicator>
</sc:FluentDefaultWindow>
