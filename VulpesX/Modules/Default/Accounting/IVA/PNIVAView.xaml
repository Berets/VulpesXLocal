<UserControl x:Class="VulpesX.Modules.Default.Accounting.IVA.PNIVAView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting.IVA"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Style="{StaticResource VulpesXTitle}" Text="GESTIONE PRIMA NOTA IVA" />

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="8*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Margin="5,0,0,0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Libro IVA"
                           TextAlignment="Right" />
                <telerik:RadAutoCompleteBox x:Name="acIVABook"
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            ItemsSource="{Binding IVABooks}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun codice trovato"
                                            SelectedItem="{Binding SelectedIVABook, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionChanged="acIVABook_SelectionChanged"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Tipo" TextAlignment="Right" />
                <telerik:RadComboBox x:Name="cmbPrintStatus"
                                     Grid.Column="2"
                                     Margin="5,2,15,2"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     DisplayMemberPath="Description"
                                     ItemsSource="{Binding PrintedStatuses}"
                                     SelectedItem="{Binding SelectedPrintedStatus}"
                                     SelectionChanged="cmbPrintStatus_SelectionChanged"
                                     Text="{Binding SelectedPrintedStatus.Description}" />

                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Dal" TextAlignment="Right" />
                <telerik:RadDateTimePicker Width="150"
                                           Margin="5,2,5,2"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent=""
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           SelectedValue="{Binding SinceDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           SelectionChanged="RadDateTimePicker_SelectionChanged" />

                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Al" TextAlignment="Right" />
                <telerik:RadDateTimePicker Width="150"
                                           Margin="5,2,15,2"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent=""
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           SelectedValue="{Binding UntilDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           SelectionChanged="RadDateTimePicker_SelectionChanged" />

                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Data scadenza" TextAlignment="Right" />
                <telerik:RadDateTimePicker Width="150"
                                           Margin="5,2,5,2"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent=""
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           SelectedValue="{Binding ExpireDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           SelectionChanged="RadDateTimePicker_SelectionChanged" />
                <telerik:RadToggleSwitchButton x:Name="chkOnlyUnpaid"
                                               Margin="5,0,0,0"
                                               Checked="chkOnlyUnpaid_Checked"
                                               CheckedContent="Solo non pagate"
                                               Content="{Binding OnlyUnpaid}"
                                               IsChecked="{Binding OnlyUnpaid}"
                                               Unchecked="chkOnlyUnpaid_Checked"
                                               UncheckedContent="Tutte" />
            </StackPanel>

        </Grid>

        <Grid Grid.Row="2">
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Margin="5"
                                         TextChanged="txtSearch_TextChanged"
                                         WatermarkContent="Cerca..." />
        </Grid>
        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="3"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     BeginningEdit="GridView_BeginningEdit"
                                     CanUserDeleteRows="False"
                                     CanUserFreezeColumns="False"
                                     CanUserInsertRows="False"
                                     CanUserResizeColumns="True"
                                     CellEditEnded="GridView_CellEditEnded"
                                     EditTriggers="Default"
                                     GroupRenderMode="Flat"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     RowDetailsVisibilityMode="Collapsed"
                                     RowIndicatorVisibility="Collapsed"
                                     SelectionMode="Extended"
                                     ShowGroupPanel="True">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewToggleRowDetailsColumn />
                        <telerik:GridViewDataColumn Width="70"
                                                    DataMemberBinding="{Binding N4REGI}"
                                                    Header="N. reg."
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding N4DARE}"
                                                    Header="Data reg."
                                                    HeaderTextAlignment="Center"
                                                    IsReadOnly="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="70"
                                                    DataMemberBinding="{Binding N4DOCU}"
                                                    Header="Prot."
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding N4DADO}"
                                                    Header="Data prot."
                                                    HeaderTextAlignment="Center"
                                                    IsReadOnly="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="70"
                                                    DataMemberBinding="{Binding N4RIFE}"
                                                    Header="Rife."
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding N4DARI}"
                                                    Header="Data rife."
                                                    HeaderTextAlignment="Center"
                                                    IsReadOnly="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding N4DTSCPG}"
                                                    Header="Data scad."
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center">
                            <telerik:GridViewDataColumn.CellEditTemplate>
                                <DataTemplate>
                                    <telerik:RadDateTimePicker Width="100"
                                                               Margin="1"
                                                               HorizontalAlignment="Left"
                                                               VerticalAlignment="Center"
                                                               DateSelectionMode="Day"
                                                               DateTimeWatermarkContent=""
                                                               DisplayFormat="Short"
                                                               InputMode="DatePicker"
                                                               IsEnabled="{Binding Tag, RelativeSource={RelativeSource AncestorType=telerik:RadGridView}}"
                                                               SelectedValue="{Binding N4DTSCPG, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Tag="EXP" />
                                </DataTemplate>
                            </telerik:GridViewDataColumn.CellEditTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding N4DTPGEF}"
                                                    Header="Data pag."
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center">
                            <telerik:GridViewDataColumn.CellEditTemplate>
                                <DataTemplate>
                                    <telerik:RadDateTimePicker Width="100"
                                                               Margin="1"
                                                               HorizontalAlignment="Left"
                                                               VerticalAlignment="Center"
                                                               DateSelectionMode="Day"
                                                               DateTimeWatermarkContent=""
                                                               DisplayFormat="Short"
                                                               InputMode="DatePicker"
                                                               IsEnabled="{Binding Tag, RelativeSource={RelativeSource AncestorType=telerik:RadGridView}}"
                                                               SelectedValue="{Binding N4DTPGEF, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Tag="PAY" />
                                </DataTemplate>
                            </telerik:GridViewDataColumn.CellEditTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="105"
                                                    DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                    DataMemberBinding="{Binding N4DAST}"
                                                    Header="Data stampa"
                                                    HeaderTextAlignment="Center"
                                                    IsReadOnly="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="200"
                                                    DataMemberBinding="{Binding CausalFullDescription}"
                                                    Header="Causale"
                                                    HeaderTextAlignment="Left"
                                                    IsReadOnly="True"
                                                    TextAlignment="Left" />
                        <telerik:GridViewDataColumn Width="55"
                                                    DataMemberBinding="{Binding N4TCLF}"
                                                    Header="C/F"
                                                    HeaderTextAlignment="Center"
                                                    IsReadOnly="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="250"
                                                    DataMemberBinding="{Binding EntityFullDescription}"
                                                    Header=""
                                                    HeaderTextAlignment="Left"
                                                    IsReadOnly="True"
                                                    TextAlignment="Left" />
                        <telerik:GridViewDataColumn Width="60"
                                                    DataMemberBinding="{Binding RateFullID}"
                                                    Header="Aliq."
                                                    HeaderTextAlignment="Left"
                                                    IsReadOnly="True"
                                                    TextAlignment="Left" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding N4IVEU}"
                                                    Header="IVA"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding N4IIEU}"
                                                    Header="IVA indet."
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding N4IMEU}"
                                                    Header="Imponibile"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="60"
                                                    DataMemberBinding="{Binding N4SEGN}"
                                                    Header="+/-"
                                                    HeaderTextAlignment="Center"
                                                    IsReadOnly="True"
                                                    TextAlignment="Center" />
                    </telerik:RadGridView.Columns>

                    <telerik:RadGridView.RowDetailsTemplate>
                        <DataTemplate>
                            <StackPanel Margin="20,10,20,10" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Anno contabile" TextAlignment="Right" />
                                <TextBlock Margin="0,0,10,0"
                                           FontWeight="Normal"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding N4ANNO}"
                                           TextAlignment="Right" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Data registrazione" TextAlignment="Right" />
                                <TextBlock Margin="0,0,10,0"
                                           FontWeight="Normal"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding N4DARE, StringFormat=dd/MM/yyyy}"
                                           TextAlignment="Right" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Riga" TextAlignment="Right" />
                                <TextBlock Margin="0,0,10,0"
                                           FontWeight="Normal"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding N4RIGA}"
                                           TextAlignment="Right" />
                            </StackPanel>
                        </DataTemplate>
                    </telerik:RadGridView.RowDetailsTemplate>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding Items}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>

</UserControl>
