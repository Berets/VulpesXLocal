<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.Reports.ExpiresReportWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting.Reports"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Stampa scadenziari clienti/fornitori"
                        Width="800"
                        Height="350"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>


        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="10" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="6*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Tipo" />
                <telerik:RadComboBox x:Name="cmbEntityType"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Width="200"
                                     Margin="5"
                                     HorizontalAlignment="Left"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     IsEditable="True"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding EntityTypes}"
                                     SelectedItem="{Binding SelectedEntityType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="{Binding EntityDescription}" />
                <telerik:RadAutoCompleteBox x:Name="acEntity"
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            ItemsSource="{Binding Entities}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun codice trovato"
                                            SelectedItem="{Binding SelectedEntity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Tutti" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="{Binding SelectedEntityPaymentDescription}" />
                <telerik:RadAutoCompleteBox x:Name="acPaymentType"
                                            Grid.Row="3"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            ItemsSource="{Binding PaymentTypes}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun codice trovato"
                                            SelectedItem="{Binding SelectedPaymentType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />


                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Scadenza (tutte se lasciato vuoto)" />
                <telerik:RadDateTimePicker Grid.Row="4"
                                           Grid.Column="1"
                                           Width="150"
                                           Margin="5,0,15,0"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent="Tutte le scadenze"
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           SelectedValue="{Binding ExpireDate}" />

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Esegui anche il pareggiamento partite" />
                <telerik:RadToggleSwitchButton Grid.Row="5"
                                               Grid.Column="1"
                                               Margin="5,0,0,0"
                                               CheckedContent="Sì"
                                               Content="{Binding RunEqualization}"
                                               IsChecked="{Binding RunEqualization}"
                                               UncheckedContent="No" />

                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Raggruppa per" />
                <telerik:RadComboBox x:Name="cmbGroupingType"
                                     Grid.Row="6"
                                     Grid.Column="1"
                                     Width="200"
                                     Margin="5"
                                     HorizontalAlignment="Left"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     IsEditable="True"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding GroupingTypes}"
                                     SelectedItem="{Binding SelectedGroupingType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />

            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="STAMPA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
