<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.Reports.BatchReportWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting.Reports"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Estrazione partitario Clienti | Fornitori"
                        Width="600"
                        Height="260"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        mc:Ignorable="d">

    <telerik:RadBusyIndicator x:Name="bsyGrid"
                              Grid.Row="3"
                              BusyContent="Caricamento dati in corso..."
                              Foreground="{DynamicResource VulpesXBrush}"
                              IsBusy="{Binding IsBusy}"
                              OverlayStyle="{StaticResource WaitOverlayStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>


            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*" />
                        <ColumnDefinition Width="5*" />
                    </Grid.ColumnDefinitions>


                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Tipo" />
                    <telerik:RadComboBox x:Name="cmbEntityType"
                                         Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="5"
                                         HorizontalAlignment="Stretch"
                                         HorizontalContentAlignment="Left"
                                         DisplayMemberPath="Description"
                                         IsEditable="True"
                                         IsReadOnly="True"
                                         ItemsSource="{Binding CFFlags}"
                                         SelectedValue="{Binding EntityType}"
                                         SelectedValuePath="ID" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Dal " />
                    <telerik:RadDateTimePicker Grid.Row="1"
                                               Grid.Column="1"
                                               Width="150"
                                               Margin="5,0,15,0"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               DateSelectionMode="Day"
                                               DateTimeWatermarkContent="Scegliere la data di inizio"
                                               DisplayFormat="Short"
                                               InputMode="DatePicker"
                                               SelectedValue="{Binding From}" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Al " />
                    <telerik:RadDateTimePicker Grid.Row="2"
                                               Grid.Column="1"
                                               Width="150"
                                               Margin="5,0,15,0"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               DateSelectionMode="Day"
                                               DateTimeWatermarkContent="Scegliere la data di fine"
                                               DisplayFormat="Short"
                                               InputMode="DatePicker"
                                               SelectedValue="{Binding To}" />
                </Grid>
            </ScrollViewer>

            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
                <Button Name="cmdExcel"
                        Width="130"
                        Click="cmdExcel_Click"
                        Content="EXCEL"
                        Style="{StaticResource VulpesXConfirmButton}" />
            </StackPanel>
        </Grid>
    </telerik:RadBusyIndicator>
</sc:FluentDefaultWindow>
