<UserControl x:Class="VulpesX.Modules.Default.Accounting.PDCSottoDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:culture="clr-namespace:System.Globalization;assembly=mscorlib"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Border Margin="5,1,1,1"
            Padding="1"
            BorderBrush="{DynamicResource VulpesXBrush}"
            BorderThickness="2">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="15,0,0,0"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Center"
                       FontSize="20"
                       Foreground="{DynamicResource VulpesXBrush}"
                       Text="DETTAGLI SOTTOCONTO" />
            <TextBlock Grid.Row="0"
                       Margin="0,0,15,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="20"
                       Foreground="{DynamicResource VulpesXBrush}"
                       Text="{Binding Data.P3DES1}"
                       Typography.Capitals="AllSmallCaps" />

            <ScrollViewer Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <DockPanel HorizontalAlignment="Stretch" LastChildFill="True">



                    <telerik:RadTabControl HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           BorderThickness="0"
                                           DisplayMemberPath="Content"
                                           DropDownDisplayMode="Visible"
                                           ScrollMode="Viewport">
                        <telerik:RadTabItem DropDownContent="GENERALI" Header="GENERALI">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="7*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Gruppo" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Width="60"
                                               Margin="5,0,15,0"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Foreground="DeepSkyBlue"
                                               Text="{Binding Data.P1GRUP}" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Margin="0,0,15,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXSecondBrush}"
                                               Text="Conto" />
                                    <TextBlock Width="60"
                                               Margin="5,0,15,0"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Text="{Binding Data.P2CONT}" />
                                </StackPanel>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Codice" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Width="100"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         IsEnabled="{Binding IsInsert}"
                                         MaxLength="6"
                                         Text="{Binding Data.P3SOTC}" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Descrizione" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         MaxLength="35"
                                         Text="{Binding Data.P3DES1}" />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Descrizione agg." />
                                <TextBox Grid.Row="3"
                                         Grid.Column="1"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         MaxLength="35"
                                         Text="{Binding Data.P3DES2}" />

                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Cliente/Fornitore" />
                                <telerik:RadComboBox Grid.Row="4"
                                                     Grid.Column="1"
                                                     Margin="5,5,15,5"
                                                     DisplayMemberPath="Description"
                                                     ItemsSource="{Binding CFTypes}"
                                                     SelectedValue="{Binding Data.P3CLFO}"
                                                     SelectedValuePath="ID" />

                                <TextBlock Grid.Row="5"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Settore" />
                                <telerik:RadComboBox Grid.Row="5"
                                                     Grid.Column="1"
                                                     Margin="5,5,15,5"
                                                     DisplayMemberPath="Description"
                                                     ItemsSource="{Binding OBCPTypes}"
                                                     SelectedValue="{Binding Data.p3tcon}"
                                                     SelectedValuePath="ID" />

                                <TextBlock Grid.Row="6"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Obbligo contropartita" />
                                <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                                    <telerik:RadToggleSwitchButton CheckedContent="Sì"
                                                                   Content="{Binding Data.P3OBCP}"
                                                                   IsChecked="{Binding Data.P3OBCPBool}"
                                                                   UncheckedContent="No" />
                                    <TextBlock Margin="15,0,15,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXSecondBrush}"
                                               Text="Conto IVA" />
                                    <telerik:RadToggleSwitchButton CheckedContent="Sì"
                                                                   Content="{Binding Data.p3coni}"
                                                                   IsChecked="{Binding Data.p3coniBool}"
                                                                   UncheckedContent="No" />
                                </StackPanel>

                                <TextBlock Grid.Row="7"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Utilizzo gruppo" />
                                <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
                                    <telerik:RadToggleSwitchButton CheckedContent="Sì"
                                                                   Content="{Binding Data.p3utgr}"
                                                                   IsChecked="{Binding Data.p3utgrBool}"
                                                                   UncheckedContent="" />
                                    <TextBlock Margin="15,0,15,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXSecondBrush}"
                                               Text="Spesometro" />
                                    <telerik:RadToggleSwitchButton CheckedContent="Sì"
                                                                   Content="{Binding Data.p3flSpeso}"
                                                                   IsChecked="{Binding Data.p3flSpesoBool, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                   UncheckedContent="No" />
                                </StackPanel>

                                <TextBlock Grid.Row="8"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Conto esterno" />
                                <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                                    <telerik:RadNumericUpDown Width="120"
                                                              Margin="5,0,15,0"
                                                              HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Center"
                                                              Maximum="999999"
                                                              NumberDecimalDigits="0"
                                                              ShowButtons="False"
                                                              Value="{Binding Data.p3este}">
                                        <telerik:RadNumericUpDown.NumberFormatInfo>
                                            <culture:NumberFormatInfo NumberGroupSeparator="" />
                                        </telerik:RadNumericUpDown.NumberFormatInfo>
                                    </telerik:RadNumericUpDown>
                                    <TextBlock Margin="15,0,15,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXSecondBrush}"
                                               Text="Alternativo" />
                                    <telerik:RadNumericUpDown Width="120"
                                                              Margin="5,0,15,0"
                                                              HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Center"
                                                              Maximum="999999"
                                                              NumberDecimalDigits="0"
                                                              ShowButtons="False"
                                                              Value="{Binding Data.p3est2}">
                                        <telerik:RadNumericUpDown.NumberFormatInfo>
                                            <culture:NumberFormatInfo NumberGroupSeparator="" />
                                        </telerik:RadNumericUpDown.NumberFormatInfo>
                                    </telerik:RadNumericUpDown>
                                </StackPanel>

                                <TextBlock Grid.Row="9"
                                           Grid.Column="0"
                                           Margin="15,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Studi di settore" />
                                <telerik:RadNumericUpDown Grid.Row="9"
                                                          Grid.Column="1"
                                                          Width="120"
                                                          Margin="5,0,15,0"
                                                          HorizontalAlignment="Left"
                                                          VerticalAlignment="Center"
                                                          Maximum="999999"
                                                          NumberDecimalDigits="0"
                                                          ShowButtons="False"
                                                          Value="{Binding Data.p3sett}">
                                    <telerik:RadNumericUpDown.NumberFormatInfo>
                                        <culture:NumberFormatInfo NumberGroupSeparator="" />
                                    </telerik:RadNumericUpDown.NumberFormatInfo>
                                </telerik:RadNumericUpDown>

                                <TextBlock Grid.Row="10"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Società di riferimento" />
                                <telerik:RadComboBox Grid.Row="10"
                                                     Grid.Column="1"
                                                     Margin="5,5,15,5"
                                                     DisplayMemberPath="SOMDES"
                                                     ItemsSource="{Binding Companies}"
                                                     SelectedValue="{Binding Data.p3soci}"
                                                     SelectedValuePath="SOMCOD"
                                                     SelectionChanged="RadComboBox_SelectionChanged" />

                                <TextBlock Grid.Row="11"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Tipo BlackList" />
                                <telerik:RadComboBox Grid.Row="11"
                                                     Grid.Column="1"
                                                     Margin="5,5,15,5"
                                                     DisplayMemberPath="Description"
                                                     ItemsSource="{Binding BLTypes}"
                                                     SelectedValue="{Binding Data.p3tipbl}"
                                                     SelectedValuePath="ID" />

                            </Grid>
                        </telerik:RadTabItem>
                        <telerik:RadTabItem DropDownContent="BILANCIO" Header="BILANCIO">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="80" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="80" />
                                    <RowDefinition Height="40*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="7*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Voci bilancio CEE" />
                                <telerik:RadAutoCompleteBox x:Name="acCEE"
                                                            Grid.Row="1"
                                                            Grid.Column="1"
                                                            Grid.ColumnSpan="3"
                                                            Margin="5,0,25,0"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding CEEs}"
                                                            LostFocus="acCEE_LostFocus"
                                                            NoResultsContent="Nessuna voce trovata"
                                                            SelectedItem="{Binding SelectedCEEItem, Mode=TwoWay}"
                                                            SelectionChanged="acCEE_SelectionChanged"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare le voci..." />
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Vertical">
                                    <TextBlock Margin="2"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               FontSize="16"
                                               Foreground="DeepSkyBlue"
                                               Text="{Binding SelectedCEEItem.Description}"
                                               Typography.Capitals="AllSmallCaps" />
                                    <TextBlock Margin="2"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               FontSize="16"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Text="{Binding SelectedCEEItem.DescriptionExtended}"
                                               Typography.Capitals="AllSmallCaps" />
                                </StackPanel>

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Voci bilancio CEE alt." />
                                <telerik:RadAutoCompleteBox x:Name="acCEEAlt"
                                                            Grid.Row="3"
                                                            Grid.Column="1"
                                                            Grid.ColumnSpan="3"
                                                            Margin="5,0,25,0"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding CEEs}"
                                                            LostFocus="acCEEAlt_LostFocus"
                                                            NoResultsContent="Nessuna voce trovata"
                                                            SelectedItem="{Binding SelectedCEEItemAlt, Mode=TwoWay}"
                                                            SelectionChanged="acCEEAlt_SelectionChanged"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare le voci..." />
                                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Vertical">
                                    <TextBlock Margin="2"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               FontSize="16"
                                               Foreground="DeepSkyBlue"
                                               Text="{Binding SelectedCEEItemAlt.Description}"
                                               Typography.Capitals="AllSmallCaps" />
                                    <TextBlock Margin="2"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               FontSize="16"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Text="{Binding SelectedCEEItemAlt.DescriptionExtended}"
                                               Typography.Capitals="AllSmallCaps" />
                                </StackPanel>

                            </Grid>
                        </telerik:RadTabItem>
                        <telerik:RadTabItem DropDownContent="ALTRI" Header="ALTRI">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="7*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Filiale" />
                                <telerik:RadAutoCompleteBox x:Name="acBranch"
                                                            Grid.Row="1"
                                                            Grid.Column="1"
                                                            Margin="5,0,25,0"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Branches}"
                                                            LostFocus="acBranch_LostFocus"
                                                            NoResultsContent="Nessuna filiale trovata"
                                                            SelectedItem="{Binding SelectedBranch, Mode=TwoWay}"
                                                            SelectionChanged="acBranch_SelectionChanged"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare per cercare..." />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Banca" />
                                <telerik:RadAutoCompleteBox x:Name="acBank"
                                                            Grid.Row="2"
                                                            Grid.Column="1"
                                                            MinWidth="381"
                                                            MaxWidth="{Binding ElementName=acBank, Path=ActualWidth}"
                                                            Margin="5,0,25,0"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            IsEnabled="{Binding IsBankEnabled}"
                                                            ItemsSource="{Binding Banks}"
                                                            LostFocus="acBank_LostFocus"
                                                            NoResultsContent="Nessuna banca trovata"
                                                            SelectedItem="{Binding SelectedBank, Mode=TwoWay}"
                                                            SelectionChanged="acBank_SelectionChanged"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare per cercare..." />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Margin="0,0,15,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="C/C n." />
                                <TextBlock Grid.Row="3"
                                           Grid.Column="1"
                                           Margin="2"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           Foreground="{DynamicResource VulpesXBrush}"
                                           Text="{Binding SelectedBank.abicon}"
                                           Typography.Capitals="AllSmallCaps" />
                            </Grid>
                        </telerik:RadTabItem>
                    </telerik:RadTabControl>
                </DockPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Name="cmdSave"
                        Click="cmdSave_Click"
                        Content="SALVA"
                        Style="{StaticResource VulpesXConfirmButton}" />
            </StackPanel>
        </Grid>
    </Border>

</UserControl>
