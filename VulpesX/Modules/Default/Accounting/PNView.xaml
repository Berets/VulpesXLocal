<UserControl x:Class="VulpesX.Modules.Default.Accounting.PNView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VulpesX.Shared.Controls.Converters;assembly=VulpesX.Shared.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:StringToColorConverter x:Key="stringToColorConverter" DefaultColor="{StaticResource VulpesXSecondBrush}" OrangeRedColor="{StaticResource VulpesXRedBrush}" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="MANUTENZIONE PRIMA NOTA" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <telerik:RadDatePicker x:Name="dtpYear"
                                       Grid.Column="1"
                                       Margin="5"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Right"
                                       DateSelectionMode="Year"
                                       DisplayFormat="Short"
                                       SelectedValue="{Binding Year, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       SelectionChanged="dtpYear_SelectionChanged" />
                <telerik:RadDropDownButton x:Name="rddbInsert"
                                           Width="200"
                                           Margin="5"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Stretch"
                                           HorizontalContentAlignment="Center"
                                           BorderBrush="{DynamicResource VulpesXBrush}"
                                           BorderThickness="5,1,1,1"
                                           Content="INSERIMENTO"
                                           IsEnabled="False">
                    <telerik:RadDropDownButton.DropDownContent>
                        <telerik:RadContextMenu>
                            <telerik:RadMenuItem x:Name="rmiInsertStandard"
                                                 Width="200"
                                                 Click="rmiInsertStandard_Click"
                                                 Cursor="Hand"
                                                 Foreground="{DynamicResource VulpesXBrush}"
                                                 Header="Inserimento singolo">
                                <telerik:RadMenuItem.Icon>
                                    <telerik:RadGlyph Cursor="Hand"
                                                      FontSize="14"
                                                      Foreground="{DynamicResource VulpesXBrush}"
                                                      Glyph="&#xe907;" />
                                </telerik:RadMenuItem.Icon>
                            </telerik:RadMenuItem>
                            <telerik:RadMenuItem x:Name="rmiInsertRepeat"
                                                 Width="200"
                                                 Click="rmiInsertRepeat_Click"
                                                 Cursor="Hand"
                                                 Foreground="{DynamicResource VulpesXBrush}"
                                                 Header="Inserimento ripetitivo">
                                <telerik:RadMenuItem.Icon>
                                    <telerik:RadGlyph Cursor="Hand"
                                                      FontSize="14"
                                                      Foreground="{DynamicResource VulpesXBrush}"
                                                      Glyph="&#xe905;" />
                                </telerik:RadMenuItem.Icon>
                            </telerik:RadMenuItem>
                        </telerik:RadContextMenu>
                    </telerik:RadDropDownButton.DropDownContent>
                </telerik:RadDropDownButton>
                <Button x:Name="btnImport"
                        Width="110"
                        Margin="5"
                        BorderBrush="{DynamicResource VulpesXGreenBrush}"
                        Click="btnImport_Click"
                        Content="IMPORTA"
                        Style="{StaticResource VulpesXButton}" />
            </StackPanel>
        </Grid>


        <telerik:RadTabControl Grid.Row="1"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="REGISTRAZIONI" Header="REGISTRAZIONI">
                <telerik:RadTabItem.Content>
                    <telerik:RadBusyIndicator x:Name="bsyGrid"
                                              BusyContent="Caricamento dati in corso..."
                                              Foreground="{DynamicResource VulpesXBrush}"
                                              IsBusy="{Binding IsBusy}"
                                              OverlayStyle="{StaticResource WaitOverlayStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="35" />
                            </Grid.RowDefinitions>
                            <Grid.Resources>
                                <selectors:PrimaNotaListSelector x:Key="PrimaNotaListSelector">
                                    <selectors:PrimaNotaListSelector.DefaultRowStyle>
                                        <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow" />
                                    </selectors:PrimaNotaListSelector.DefaultRowStyle>
                                    <selectors:PrimaNotaListSelector.TemporaryRowStyle>
                                        <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                                            <Setter Property="Background" Value="{StaticResource VulpesXRedBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="ToolTip" Value="Registrazione temporanea" />
                                        </Style>
                                    </selectors:PrimaNotaListSelector.TemporaryRowStyle>
                                </selectors:PrimaNotaListSelector>
                            </Grid.Resources>
                            <Grid Grid.Row="0" HorizontalAlignment="Stretch">
                                <telerik:RadWatermarkTextBox Name="txtSearch"
                                                             Margin="5"
                                                             LostFocus="txtSearch_LostFocus"
                                                             Text="{Binding TextFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             WatermarkContent="Cerca..." />
                            </Grid>
                            <telerik:RadGridView x:Name="GridView"
                                                 Grid.Row="1"
                                                 AutoGenerateColumns="False"
                                                 CanUserFreezeColumns="False"
                                                 CanUserResizeColumns="False"
                                                 FieldFilterEditorCreated="GridView_FieldFilterEditorCreated"
                                                 FilterOperatorsLoading="OnRadGridViewFilterOperatorsLoading"
                                                 Filtering="GridView_Filtering"
                                                 FilteringMode="FilterRow"
                                                 GroupRenderMode="Flat"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding Items}"
                                                 RowIndicatorVisibility="Collapsed"
                                                 RowStyleSelector="{StaticResource PrimaNotaListSelector}"
                                                 ShowColumnSortIndexes="True"
                                                 ShowGroupPanel="False"
                                                 Sorting="GridView_Sorting">
                                <telerik:RadContextMenu.ContextMenu>
                                    <telerik:RadContextMenu x:Name="cmPN" Background="#2C2D33" Opening="cmPN_Opening">
                                        <telerik:RadMenuItem x:Name="rmiSelfInvoice"
                                                             Click="rmiSelfInvoice_Click"
                                                             Header="Genera autofattura"
                                                             Typography.Capitals="AllSmallCaps">
                                            <telerik:RadMenuItem.Icon>
                                                <Image Width="16"
                                                       Height="16"
                                                       Source="{telerik:RadGlyph Glyph={StaticResource GlyphReset}}"
                                                       Stretch="Uniform" />
                                            </telerik:RadMenuItem.Icon>
                                        </telerik:RadMenuItem>
                                    </telerik:RadContextMenu>
                                </telerik:RadContextMenu.ContextMenu>
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewColumn Width="80">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadButton x:Name="cmdDelete"
                                                                   telerik:TouchManager.TouchMode="HitTestHidden"
                                                                   BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                                   Click="cmdDelete_Click"
                                                                   Content="Elimina"
                                                                   Style="{StaticResource VulpesXButton}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewDataColumn Width="30"
                                                                DataMemberBinding="{Binding NotBalanced}"
                                                                Header=""
                                                                IsCustomSortingEnabled="True">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadGlyph Cursor="Hand"
                                                                  FontSize="18"
                                                                  Foreground="{DynamicResource VulpesXYellowBrush}"
                                                                  Glyph="&#xe403;"
                                                                  ToolTip="{Binding NotBalancedTooltip}"
                                                                  Visibility="{Binding NotBalancedVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewDataColumn>
                                    <telerik:GridViewColumn Width="30">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadGlyph x:Name="rgPrint"
                                                                  Cursor="Hand"
                                                                  FontSize="18"
                                                                  Foreground="{DynamicResource VulpesXGreenBrush}"
                                                                  Glyph="&#xe90e;"
                                                                  MouseDown="rgPrint_MouseDown"
                                                                  ToolTip="Apri il PDF della registrazione" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewColumn Width="30">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadGlyph x:Name="rgDuplicate"
                                                                  Cursor="Hand"
                                                                  FontSize="18"
                                                                  Foreground="{DynamicResource VulpesXBrush}"
                                                                  Glyph="&#xe65d;"
                                                                  MouseDown="rgDuplicate_MouseDown"
                                                                  ToolTip="Duplica registrazione"
                                                                  Visibility="{Binding DuplicateVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewDataColumn Width="60"
                                                                DataMemberBinding="{Binding N1TmpPNBool}"
                                                                Header="TMP"
                                                                IsCustomSortingEnabled="True" />
                                    <telerik:GridViewDataColumn Width="100"
                                                                DataMemberBinding="{Binding N1REGIText}"
                                                                Header="Nr. reg."
                                                                IsCustomSortingEnabled="True"
                                                                ShowDistinctFilters="False">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button x:Name="cmdEdit"
                                                        Margin="3"
                                                        HorizontalContentAlignment="Right"
                                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                                        Click="cmdEdit_Click"
                                                        Content="{Binding Path=N1REGIText}"
                                                        Cursor="Hand"
                                                        Foreground="{DynamicResource VulpesXBrush}"
                                                        ToolTip="Clicca per modificare la testata" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewDataColumn>
                                    <telerik:GridViewDataColumn Width="100"
                                                                DataMemberBinding="{Binding N1DAREText}"
                                                                Header="Data reg."
                                                                IsCustomSortingEnabled="True"
                                                                ShowDistinctFilters="False"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="75"
                                                                DataMemberBinding="{Binding pncaus}"
                                                                Header="Causale"
                                                                IsCustomSortingEnabled="True"
                                                                ShowDistinctFilters="False"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="200"
                                                                DataMemberBinding="{Binding AccountingCausal.caudes}"
                                                                Header="Descrizione causale"
                                                                IsCustomSortingEnabled="True"
                                                                ShowDistinctFilters="False" />
                                    <telerik:GridViewDataColumn Width="40"
                                                                DataMemberBinding="{Binding pnvdiv}"
                                                                Header="Val."
                                                                IsFilterable="False"
                                                                IsSortable="False"
                                                                ShowDistinctFilters="False"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="160"
                                                                DataFormatString="N2"
                                                                DataMemberBinding="{Binding Amount}"
                                                                Header="Importo"
                                                                HeaderTextAlignment="Right"
                                                                IsCustomSortingEnabled="True"
                                                                ShowDistinctFilters="False"
                                                                TextAlignment="Right">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button x:Name="cmdDetails"
                                                        Margin="3"
                                                        HorizontalContentAlignment="Right"
                                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                                        Click="cmdDetails_Click"
                                                        Content="{Binding Path=Amount}"
                                                        ContentStringFormat="N2"
                                                        Cursor="Hand"
                                                        Foreground="{DynamicResource VulpesXBrush}"
                                                        ToolTip="Clicca per modificare i dettagli" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewDataColumn>
                                    <telerik:GridViewDataColumn Width="130"
                                                                DataMemberBinding="{Binding N1docn}"
                                                                Header="Documento"
                                                                HeaderTextAlignment="Right"
                                                                IsCustomSortingEnabled="True"
                                                                ShowDistinctFilters="False"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="130"
                                                                DataMemberBinding="{Binding N1rifn}"
                                                                Header="Riferimento"
                                                                HeaderTextAlignment="Right"
                                                                IsCustomSortingEnabled="True"
                                                                ShowDistinctFilters="False"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="90"
                                                                DataMemberBinding="{Binding N1CLFO}"
                                                                Header="C/F"
                                                                HeaderTextAlignment="Right"
                                                                IsCustomSortingEnabled="True"
                                                                ShowDistinctFilters="False"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding EntityFullDescription}"
                                                                Header=""
                                                                IsCustomSortingEnabled="True"
                                                                ShowDistinctFilters="False" />
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>
                            <telerik:RadDataPager x:Name="rdpGrid"
                                                  Grid.Row="2"
                                                  Margin="0,-1,0,0"
                                                  DisplayMode="FirstLastPreviousNextNumeric, Text"
                                                  FontSize="12"
                                                  IsTotalItemCountFixed="True"
                                                  ItemCount="{Binding TotalCount}"
                                                  PageIndexChanged="rdpGrid_PageIndexChanged"
                                                  PageSize="{Binding PageSize}"
                                                  PageIndex="{Binding PageRequested, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </telerik:RadBusyIndicator>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="SITUAZIONE CONTABILE" Header="SITUAZIONE CONTABILE">
                <telerik:RadTabItem.Content>
                    <telerik:RadBusyIndicator x:Name="bsyGridSC"
                                              BusyContent="Caricamento dati in corso..."
                                              Foreground="{DynamicResource VulpesXBrush}"
                                              IsBusy="{Binding IsBusySitutation}"
                                              OverlayStyle="{StaticResource WaitOverlayStyle}">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Grid Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5*" />
                                    <ColumnDefinition Width="5*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            HorizontalAlignment="Left"
                                            Orientation="Horizontal">
                                    <Button Name="cmdExportBalance"
                                            Grid.Row="2"
                                            Margin="5"
                                            BorderBrush="Goldenrod"
                                            Click="cmdExportBalance_Click"
                                            Content="ESPORTA BILANCIO CEE"
                                            Foreground="{DynamicResource VulpesXSecondBrush}"
                                            Style="{StaticResource VulpesXInsertButton}" />
                                </StackPanel>
                                <StackPanel Grid.Row="0"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            HorizontalAlignment="Right"
                                            Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource VulpesXLabel}" Text="Centro di costo" TextAlignment="Right" />
                                    <telerik:RadAutoCompleteBox x:Name="acCC"
                                                                Margin="5"
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Center"
                                                                DisplayMemberPath="FullDescriptionSearchable"
                                                                GotFocus="ac_GotFocus"
                                                                ItemsSource="{Binding CostCenters}"
                                                                LostFocus="ac_LostFocus"
                                                                NoResultsContent="Nessun codice trovato"
                                                                SelectedItem="{Binding SelectedCostCenter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                SelectionChanged="acCC_SelectionChanged"
                                                                SelectionMode="Single"
                                                                TextSearchMode="Contains"
                                                                TextSearchPath="FullDescriptionSearchable"
                                                                WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                </StackPanel>

                                <StackPanel Grid.Row="1"
                                            Grid.Column="0"
                                            HorizontalAlignment="Stretch"
                                            Orientation="Vertical">
                                    <!--  ATTIVITA  -->
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="15" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6*" />
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Grid.ColumnSpan="2"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource VulpesXSubtitle}"
                                                   Text="ATTIVITA'"
                                                   TextAlignment="Center" />

                                        <StackPanel x:Name="spAttivitaText"
                                                    Grid.Row="2"
                                                    Grid.Column="0"
                                                    HorizontalAlignment="Stretch"
                                                    Orientation="Vertical" />
                                        <StackPanel x:Name="spAttivitaSaldo"
                                                    Grid.Row="2"
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Stretch"
                                                    Orientation="Vertical" />
                                    </Grid>

                                    <!--  PASSIVITA  -->
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="15" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6*" />
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Grid.ColumnSpan="2"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource VulpesXSubtitle}"
                                                   Text="PASSIVITA'"
                                                   TextAlignment="Center" />

                                        <StackPanel x:Name="spPassivitaText"
                                                    Grid.Row="2"
                                                    Grid.Column="0"
                                                    HorizontalAlignment="Stretch"
                                                    Orientation="Vertical" />
                                        <StackPanel x:Name="spPassivitaSaldo"
                                                    Grid.Row="2"
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Stretch"
                                                    Orientation="Vertical" />
                                    </Grid>

                                    <Rectangle Margin="0,15,0,15"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               Fill="{DynamicResource VulpesXBrush}"
                                               Stroke="{DynamicResource VulpesXBrush}"
                                               StrokeThickness="1" />

                                    <!--  SALDO PROVVISORIO  -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6*" />
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource VulpesXSubtitle}"
                                                   Text="SALDO PROVVISORIO"
                                                   TextAlignment="Right" />
                                        <TextBlock Grid.Column="1"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding AccountingSituation.SaldoAPColore, Converter={StaticResource stringToColorConverter}}"
                                                   Text="{Binding AccountingSituation.SaldoAP, StringFormat=N2}"
                                                   TextAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Row="1"
                                            Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            Orientation="Vertical">
                                    <!--  COSTI  -->
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="15" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6*" />
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Grid.ColumnSpan="2"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource VulpesXSubtitle}"
                                                   Text="COSTI"
                                                   TextAlignment="Center" />

                                        <StackPanel x:Name="spCostiText"
                                                    Grid.Row="2"
                                                    Grid.Column="0"
                                                    HorizontalAlignment="Stretch"
                                                    Orientation="Vertical" />
                                        <StackPanel x:Name="spCostiSaldo"
                                                    Grid.Row="2"
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Stretch"
                                                    Orientation="Vertical" />
                                    </Grid>

                                    <!--  RICAVI  -->
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="15" />
                                            <RowDefinition Height="35" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6*" />
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Grid.ColumnSpan="2"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource VulpesXSubtitle}"
                                                   Text="RICAVI"
                                                   TextAlignment="Center" />

                                        <StackPanel x:Name="spRicaviText"
                                                    Grid.Row="2"
                                                    Grid.Column="0"
                                                    HorizontalAlignment="Stretch"
                                                    Orientation="Vertical" />
                                        <StackPanel x:Name="spRicaviSaldo"
                                                    Grid.Row="2"
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Stretch"
                                                    Orientation="Vertical" />
                                    </Grid>

                                    <Rectangle Margin="0,15,0,15"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               Fill="{DynamicResource VulpesXBrush}"
                                               Stroke="{DynamicResource VulpesXBrush}"
                                               StrokeThickness="1" />

                                    <!--  SALDO PROVVISORIO  -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="6*" />
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource VulpesXSubtitle}"
                                                   Text="SALDO PROVVISORIO"
                                                   TextAlignment="Right" />
                                        <TextBlock Grid.Column="1"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding AccountingSituation.SaldoRCColore, Converter={StaticResource stringToColorConverter}}"
                                                   Text="{Binding AccountingSituation.SaldoRC, StringFormat=N2}"
                                                   TextAlignment="Right" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </telerik:RadBusyIndicator>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>
    </Grid>
</UserControl>
