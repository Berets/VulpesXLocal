<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.Functions.ClosePeriodWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting.Functions"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Lancia la chiusura contabile periodica"
                        Width="600"
                        Height="230"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">

    <telerik:RadBusyIndicator x:Name="bsyGrid"
                              BusyContent="Caricamento dati in corso..."
                              Foreground="{DynamicResource VulpesXBrush}"
                              IsBusy="{Binding IsBusy}"
                              OverlayStyle="{StaticResource WaitOverlayStyle}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*" />
                        <ColumnDefinition Width="5*" />
                    </Grid.ColumnDefinitions>


                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Esercizio" />
                    <telerik:RadComboBox x:Name="cmbAccountingYear"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Width="150"
                                         Margin="5,5,15,5"
                                         HorizontalAlignment="Left"
                                         HorizontalContentAlignment="Right"
                                         DisplayMemberPath="eseann"
                                         SelectionChanged="cmbAccountingYear_SelectionChanged" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Ultima stampa mastrino" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Margin="5,0,0,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXDataBrush}"
                               Text="{Binding UntilDate.Date, StringFormat=d}" />
                </Grid>
            </ScrollViewer>

            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
                <Button Name="cmdSave"
                        Click="cmdSave_Click"
                        Content="CONFERMA"
                        Style="{StaticResource VulpesXConfirmButton}" />
            </StackPanel>
        </Grid>
    </telerik:RadBusyIndicator>
</sc:FluentDefaultWindow>
