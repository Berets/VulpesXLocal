<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.SelectECWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:aggregators="clr-namespace:VulpesX.Shared.Controls.Aggregators;assembly=VulpesX.Shared.Controls"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:drdr="clr-namespace:VulpesX.Shared.Controls.DragDrop;assembly=VulpesX.Shared.Controls"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Width="1024"
                        Height="768"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">

    <sc:FluentDefaultWindow.Resources>
        <selectors:ECFListSelector x:Key="ECFListSelector">
            <selectors:ECFListSelector.DefaultRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="telerik:DragDropManager.AllowDrag" Value="True" />
                </Style>
            </selectors:ECFListSelector.DefaultRowStyle>
            <selectors:ECFListSelector.LockedRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="OrangeRed" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="ToolTip" Value="{Binding LockedInfoText}" />
                    <Setter Property="telerik:DragDropManager.AllowDrag" Value="True" />
                </Style>
            </selectors:ECFListSelector.LockedRowStyle>
        </selectors:ECFListSelector>
    </sc:FluentDefaultWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="35" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*" />
                <ColumnDefinition Width="7.5*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Margin="10,0,0,0"
                        HorizontalAlignment="Stretch"
                        Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Elabora fino al" />
                <telerik:RadDateTimePicker x:Name="rdtLimitDate"
                                           Width="120"
                                           Margin="5,0,5,0"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent="Scegliere la data limite"
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           ParseExact="False"
                                           SelectedValue="{Binding ToDate}"
                                           SelectionChanged="rdtLimitDate_SelectionChanged" />
            </StackPanel>

            <Border Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    BorderBrush="{DynamicResource VulpesXBrush}"
                    BorderThickness="1,0,1,1">
                <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock Margin="0,0,15,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="SALDO ALLA DATA" />
                    <TextBlock Margin="0,0,15,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="DeepSkyBlue"
                               Text="{Binding TotalSign}" />
                    <TextBlock Margin="0,0,25,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="DeepSkyBlue"
                               Text="{Binding TotalAmount, StringFormat=N2}" />
                    <TextBlock Margin="0,0,15,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="SALDO TOTALE SELEZIONATO" />
                    <TextBlock Margin="0,0,15,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="DeepSkyBlue"
                               Text="{Binding TotalSelectedSign}" />
                    <TextBlock Margin="0,0,25,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="DeepSkyBlue"
                               Text="{Binding TotalSelectedAmount, StringFormat=N2}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7.5*" />
                <ColumnDefinition Width="2.5*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Margin="5,0,0,0"
                        HorizontalAlignment="Stretch"
                        Orientation="Horizontal">
                <CheckBox x:Name="chkDrawn"
                          Margin="5,0,0,0"
                          Checked="chkDrawn_Checked"
                          Content="Partite pareggiate"
                          FontWeight="Bold"
                          IsChecked="{Binding HasDrawn}"
                          Unchecked="chkDrawn_Unchecked" />
                <StackPanel x:Name="spDrawnDate" Orientation="Horizontal" Visibility="{Binding HasDrawn, Converter={StaticResource boolToVisibilityConverter}}">
                    <TextBlock Margin="15,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Partite pareggiate dal" />
                    <telerik:RadDateTimePicker x:Name="rdtDrawnLimitDate"
                                               Width="120"
                                               Margin="5,0,0,0"
                                               VerticalAlignment="Center"
                                               DateSelectionMode="Day"
                                               DateTimeWatermarkContent="Scegliere la data"
                                               DisplayFormat="Short"
                                               InputMode="DatePicker"
                                               ParseExact="False"
                                               SelectedValue="{Binding SinceDrawnDate}"
                                               SelectionChanged="rdtDrawnLimitDate_SelectionChanged" />
                </StackPanel>
            </StackPanel>

        </Grid>
        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="247*" />
                    <ColumnDefinition Width="28*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     Grid.ColumnSpan="2"
                                     drdr:ECCFGridViewDragDropBehavior.IsEnabled="True"
                                     AllowDrop="True"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     EnableLostFocusSelectedState="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     IsSynchronizedWithCurrentItem="False"
                                     ItemsSource="{Binding Items}"
                                     RowIndicatorVisibility="Collapsed"
                                     RowStyleSelector="{StaticResource ECFListSelector}"
                                     SelectionChanged="GridView_SelectionChanged"
                                     SelectionMode="Extended"
                                     SelectionUnit="FullRow"
                                     ShowGroupFooters="True"
                                     ShowGroupPanel="True">
                    <telerik:RadGridView.ChildTableDefinitions>
                        <telerik:GridViewTableDefinition>
                            <telerik:GridViewTableDefinition.Relation>
                                <telerik:PropertyRelation />
                            </telerik:GridViewTableDefinition.Relation>
                        </telerik:GridViewTableDefinition>
                    </telerik:RadGridView.ChildTableDefinitions>
                    <telerik:RadGridView.HierarchyChildTemplate>
                        <DataTemplate>
                            <telerik:RadGridView AutoGenerateColumns="False" ItemsSource="{Binding Reminders}">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewDataColumn Width="150"
                                                                DataFormatString="dd/MM/yyyy"
                                                                DataMemberBinding="{Binding solldat}"
                                                                Header="Data sollecito"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding ReminderType.soldes}" Header="Tipo" />
                                    <telerik:GridViewDataColumn Width="140"
                                                                DataFormatString="dd/MM/yyyy"
                                                                DataMemberBinding="{Binding DocumentDate}"
                                                                Header="Data documento"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="100" DataMemberBinding="{Binding DocumentID}" Header="Documento" />
                                    <telerik:GridViewDataColumn Width="120"
                                                                DataFormatString="dd/MM/yyyy"
                                                                DataMemberBinding="{Binding sollscad}"
                                                                Header="Scadenza"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="60"
                                                                DataMemberBinding="{Binding sollsegn}"
                                                                Header="D/A"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="100"
                                                                DataFormatString="N2"
                                                                DataMemberBinding="{Binding sollimpo}"
                                                                FooterTextAlignment="Right"
                                                                Header="Importo"
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding sollcaude}" Header="Causale" />
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>
                        </DataTemplate>
                    </telerik:RadGridView.HierarchyChildTemplate>
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewSelectColumn />
                        <telerik:GridViewDataColumn Width="80"
                                                    DataMemberBinding="{Binding Number}"
                                                    Header="Reg. n."
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding RegistrationDate}"
                                                    Header="Data reg."
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="100" DataMemberBinding="{Binding DocumentID}" Header="Documento" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding DocumentDate}"
                                                    Header="Data doc."
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding ExpireDate}"
                                                    Header="Scadenza"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding CausalFullDescription}" Header="Causale">
                            <telerik:GridViewColumn.AggregateFunctions>
                                <aggregators:ECCFRecap />
                            </telerik:GridViewColumn.AggregateFunctions>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding Dare}"
                                                    FooterTextAlignment="Right"
                                                    Header="Dare"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right">
                            <telerik:GridViewColumn.AggregateFunctions>
                                <aggregators:ECCFDareSum ResultFormatString="{}{0:N2}" />
                            </telerik:GridViewColumn.AggregateFunctions>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding Avere}"
                                                    FooterTextAlignment="Right"
                                                    Header="Avere"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right">
                            <telerik:GridViewColumn.AggregateFunctions>
                                <aggregators:ECCFAvereSum ResultFormatString="{}{0:N2}" />
                            </telerik:GridViewColumn.AggregateFunctions>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="50"
                                                    DataMemberBinding="{Binding CurrencyID}"
                                                    Header="Val."
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="150"
                                                    ColumnGroupName="Partita"
                                                    DataMemberBinding="{Binding Partita}"
                                                    Header="Partita" />
                    </telerik:RadGridView.Columns>
                    <telerik:RadGridView.Resources>
                        <DataTemplate x:Key="DraggedItemTemplate">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Foreground="{DynamicResource VulpesXBrush}" Text="Assegnare alla registrazione " />
                                    <TextBlock Margin="2,0,0,0"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXDataBrush}"
                                               Text="{Binding CurrentDraggedItem.Number}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Foreground="{DynamicResource VulpesXBrush}" Text=" la partita " />
                                    <TextBlock Foreground="{DynamicResource VulpesXDataBrush}" Text="{Binding CurrentDraggedOverItem.DocumentID}" />
                                    <TextBlock Foreground="{DynamicResource VulpesXBrush}" Text="-" />
                                    <TextBlock Foreground="{DynamicResource VulpesXDataBrush}" Text="{Binding CurrentDraggedOverItem.DocumentDate, StringFormat=d}" />
                                    <TextBlock Foreground="{DynamicResource VulpesXBrush}" Text=" con scadenza " />
                                    <TextBlock Foreground="{DynamicResource VulpesXDataBrush}" Text="{Binding CurrentDraggedOverItem.ExpireDate, StringFormat=d}" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </telerik:RadGridView.Resources>
                </telerik:RadGridView>
            </Grid>
        </telerik:RadBusyIndicator>

        <StackPanel Grid.Row="3"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
