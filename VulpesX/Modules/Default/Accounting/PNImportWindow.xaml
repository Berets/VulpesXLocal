<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.PNImportWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Importa prima nota da foglio Excel"
                        Width="600"
                        Height="250"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">

    <telerik:RadBusyIndicator Name="bsyIndicator"
                              BusyContent="Sto importando"
                              Foreground="{DynamicResource VulpesXBrush}"
                              IsBusy="{Binding IsBusy}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35" />
                        <RowDefinition Height="35" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="8*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="File" />

                    <Grid Grid.Row="0" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />

                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtAllegatoPath"
                                 Grid.Column="0"
                                 Margin="5"
                                 IsReadOnly="True" />
                        <Button x:Name="btnAllegatoBrowse"
                                Grid.Column="1"
                                Margin="5"
                                Click="btnAllegatoBrowse_Click"
                                Content="..." />
                    </Grid>
                </Grid>
            </ScrollViewer>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="7*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">

                    <Button x:Name="btnAllegatoDownload"
                            Width="160"
                            Click="btnAllegatoDownload_Click"
                            Content="SCARICA TEMPLATE"
                            Style="{StaticResource VulpesXButton}" />

                </StackPanel>
                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">

                    <Button Name="cmdCancel"
                            Click="cmdCancel_Click"
                            Content="USCIRE"
                            Style="{StaticResource VulpesXCancelButton}" />
                    <Button Name="btnAllegatoUpload"
                            Click="btnAllegatoUpload_Click"
                            Content="SALVA"
                            Style="{StaticResource VulpesXConfirmButton}" />

                </StackPanel>
            </Grid>

        </Grid>
    </telerik:RadBusyIndicator>

</sc:FluentDefaultWindow>
