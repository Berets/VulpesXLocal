<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.ECChangeRefWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Width="600"
                        Height="280"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>


        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="6*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Data riferimento" />
                <telerik:RadDateTimePicker Grid.Row="0"
                                           Grid.Column="1"
                                           Margin="5,0,15,0"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent="Scegliere la data del riferimento"
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           SelectedValue="{Binding ReferenceDate}" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Numero riferimento" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         Text="{Binding ReferenceID}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Scadenza" />
                <telerik:RadDateTimePicker Grid.Row="2"
                                           Grid.Column="1"
                                           Margin="5,0,15,0"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent="Scegliere la data di scadenza"
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           SelectedValue="{Binding ExpireDate}" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Codice pagamento" />
                <telerik:RadAutoCompleteBox x:Name="acPayment"
                                            Grid.Row="3"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescription"
                                            ItemsSource="{Binding Payments}"
                                            LostFocus="acPayment_LostFocus"
                                            NoResultsContent="Nessun pagamento trovato"
                                            SelectedItem="{Binding Payment}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescription"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Tipo pagamento" />
                <telerik:RadAutoCompleteBox x:Name="acPaymentType"
                                            Grid.Row="4"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            ItemsSource="{Binding PaymentTypes}"
                                            LostFocus="acPaymentType_LostFocus"
                                            NoResultsContent="Nessun tipo pagamento trovato"
                                            SelectedItem="{Binding PaymentType}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Width="130"
                    Click="cmdSave_Click"
                    Content="CONFERMA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
