<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.INTRAWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Estrazione file INTRA"
                        Width="500"
                        Height="150"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        mc:Ignorable="d">

    <telerik:RadBusyIndicator BusyContent="Caricamento dati in corso..."
                              Foreground="{DynamicResource VulpesXBrush}"
                              IsBusy="{Binding IsBusy}"
                              OverlayStyle="{StaticResource WaitOverlayStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*" />
                        <ColumnDefinition Width="6*" />
                    </Grid.ColumnDefinitions>


                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Mese" />

                    <telerik:RadDateTimePicker x:Name="rdtPeriod"
                                               Grid.Row="0"
                                               Grid.Column="1"
                                               Margin="5"
                                               VerticalAlignment="Center"
                                               DateSelectionMode="Month"
                                               DateTimeWatermarkContent="Scegliere il periodo"
                                               DisplayFormat="Short"
                                               InputMode="DatePicker"
                                               ParseExact="False"
                                               SelectedValue="{Binding Month, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                </Grid>
            </ScrollViewer>

            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />

                <Button Name="cmdSave"
                        Width="130"
                        Click="cmdSave_Click"
                        Content="ESTRAI"
                        Style="{StaticResource VulpesXConfirmButton}" />
            </StackPanel>
        </Grid>
    </telerik:RadBusyIndicator>
</sc:FluentDefaultWindow>
