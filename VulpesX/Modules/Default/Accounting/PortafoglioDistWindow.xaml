<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.PortafoglioDistWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Seleziona le righe dagli ordini"
                        Width="1000"
                        Height="750"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="CONTENUTO" Header="CONTENUTO">
                <telerik:RadTabItem.Content>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="120" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="40" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock MinWidth="120"
                                           Margin="10,0,0,0"
                                           Style="{DynamicResource VulpesXLabel}"
                                           Text="Banca"
                                           TextAlignment="Right" />
                                <telerik:RadAutoCompleteBox x:Name="acInternalBank"
                                                            Width="750"
                                                            Margin="10,2,5,2"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            IsEnabled="{Binding IsEnabled}"
                                                            ItemsSource="{Binding InternalBanks}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessuna banca trovata"
                                                            SelectedItem="{Binding SelectedInternalBank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionChanged="acInternalBank_SelectionChanged"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <TextBlock MinWidth="120"
                                           Margin="10,0,0,0"
                                           Style="{DynamicResource VulpesXLabel}"
                                           Text="Data estrazione"
                                           TextAlignment="Right" />
                                <TextBlock Margin="10,0,0,0" Style="{DynamicResource VulpesXInfoData}" Text="{Binding Data.accounting_date, StringFormat=dd/MM/yyyy HH:mm:ss}" />
                                <TextBlock MinWidth="120"
                                           Margin="10,0,0,0"
                                           Style="{DynamicResource VulpesXLabel}"
                                           Text="Data contabilizzazione"
                                           TextAlignment="Right" />
                                <TextBlock Margin="10,0,0,0" Style="{DynamicResource VulpesXInfoData}" Text="{Binding Data.extraction_date, StringFormat=dd/MM/yyyy HH:mm:ss}" />

                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Margin="0,0,10,0"
                                       HorizontalAlignment="Right"
                                       Style="{DynamicResource VulpesXData}"
                                       Text="{Binding Data.TotalAmount, StringFormat=N2}" />
                            <TextBlock Grid.Row="2"
                                       Margin="0,0,150,0"
                                       HorizontalAlignment="Right"
                                       Style="{DynamicResource VulpesXSubtitle}"
                                       Text="TOTALE DISTINTA" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Style="{DynamicResource VulpesXTitle}" Text="DISPOSIZIONI" />
                            <Grid Grid.Row="1" Margin="5,5,5,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="35" />
                                </Grid.RowDefinitions>
                                <telerik:RadGridView x:Name="rgvRows"
                                                     Grid.Row="0"
                                                     AutoGenerateColumns="False"
                                                     CanUserFreezeColumns="False"
                                                     CanUserResizeColumns="False"
                                                     GroupRenderMode="Flat"
                                                     IsReadOnly="{Binding IsReadonly}"
                                                     IsSynchronizedWithCurrentItem="False"
                                                     ItemsSource="{Binding Data.Items}"
                                                     RowIndicatorVisibility="Collapsed"
                                                     SelectionMode="Extended"
                                                     ShowGroupPanel="False">
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewSelectColumn IsSelected="False" />
                                        <telerik:GridViewDataColumn Width="320" DataMemberBinding="{Binding CustomerDescription}" Header="Cliente" />
                                        <telerik:GridViewDataColumn Width="100"
                                                                    DataFormatString="dd/MM/yyyy"
                                                                    DataMemberBinding="{Binding N6SCAD}"
                                                                    Header="Scadenza"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="100" DataMemberBinding="{Binding N6RIFE}" Header="Riferimento" />
                                        <telerik:GridViewDataColumn Width="120"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding N6IMEU}"
                                                                    Header="Importo"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right" />
                                        <telerik:GridViewDataColumn Width="350" DataMemberBinding="{Binding CustomerBankDescription}" Header="Banca cliente" />
                                    </telerik:RadGridView.Columns>
                                </telerik:RadGridView>
                            </Grid>
                        </Grid>
                    </Grid>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Inserito il" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultimo aggiornamento il" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedUserText}" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
