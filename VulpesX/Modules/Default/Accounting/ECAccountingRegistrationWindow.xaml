<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.ECAccountingRegistrationWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Registrazione"
                        Width="1024"
                        Height="680"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40*" />
            <RowDefinition Height="60*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>


        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*" />
                    <ColumnDefinition Width="2.5*" />
                    <ColumnDefinition Width="2.5*" />
                    <ColumnDefinition x:Name="col3" Width="2.5*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Esercizio" />
                <telerik:RadComboBox x:Name="cmbAccountingYear"
                                     Grid.Row="0"
                                     Grid.Column="1"
                                     Width="150"
                                     Margin="5,5,15,5"
                                     HorizontalAlignment="Left"
                                     HorizontalContentAlignment="Right"
                                     DisplayMemberPath="eseann"
                                     SelectionChanged="cmbAccountingYear_SelectionChanged" />

                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Data registrazione" />
                <telerik:RadDateTimePicker Grid.Row="0"
                                           Grid.Column="3"
                                           Margin="5,2,15,2"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent="Scegliere la data per la registrazione"
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           SelectedValue="{Binding Date}" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Documento" />
                <TextBox x:Name="txtN1DOCN"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         MaxLength="20"
                         Text="{Binding DocumentID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Data documento" />
                <telerik:RadDateTimePicker Grid.Row="1"
                                           Grid.Column="3"
                                           Margin="5,2,15,2"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent="Scegliere la data del documento"
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           SelectedValue="{Binding DocumentDate}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Causale" />
                <telerik:RadAutoCompleteBox x:Name="acCausal"
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            ItemsSource="{Binding Causals}"
                                            LostFocus="acCausal_LostFocus"
                                            NoResultsContent="Nessuna causale trovata"
                                            SelectedItem="{Binding SelectedCausal, Mode=TwoWay}"
                                            SelectionChanged="acCausal_SelectionChanged"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Banca interna" />
                <telerik:RadAutoCompleteBox x:Name="acInternalBank"
                                            Grid.Row="3"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="3"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            ItemsSource="{Binding Banks}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessuna banca trovata"
                                            SelectedItem="{Binding SelectedBank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
            </Grid>
        </ScrollViewer>

        <telerik:RadGridView Name="rgvRows"
                             Grid.Row="1"
                             Margin="0"
                             AutoGenerateColumns="False"
                             CanUserFreezeColumns="False"
                             CanUserInsertRows="False"
                             IsReadOnly="False"
                             IsSearchingDeferred="True"
                             ItemsSource="{Binding Items}"
                             RowDetailsVisibilityMode="VisibleWhenSelected"
                             RowEditEnded="rgvRows_RowEditEnded"
                             RowValidated="rgvRows_RowValidated"
                             RowValidating="rgvRows_RowValidating"
                             SearchMode="MatchAnyTerm"
                             SelectionMode="Single"
                             ShowGroupPanel="False"
                             ShowSearchPanel="False"
                             ValidatesOnDataErrors="InEditMode">
            <telerik:RadGridView.Columns>

                <telerik:GridViewDataColumn Width="100"
                                            DataFormatString="N2"
                                            DataMemberBinding="{Binding Valore}"
                                            Header="Importo"
                                            TextAlignment="Right">
                    <telerik:GridViewDataColumn.CellEditTemplate>
                        <DataTemplate>
                            <telerik:RadNumericUpDown Minimum="0"
                                                      NumberDecimalDigits="2"
                                                      ShowButtons="False"
                                                      Value="{Binding Valore}" />
                        </DataTemplate>
                    </telerik:GridViewDataColumn.CellEditTemplate>
                </telerik:GridViewDataColumn>
                <telerik:GridViewDataColumn Width="100"
                                            DataMemberBinding="{Binding Segno}"
                                            Header="Segno"
                                            IsReadOnly="True"
                                            TextAlignment="Center" />
                <telerik:GridViewDataColumn DataMemberBinding="{Binding ReferenceID}"
                                            Header="Riferimento ID"
                                            HeaderTextAlignment="Right"
                                            TextAlignment="Right" />
                <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy"
                                            DataMemberBinding="{Binding ReferenceDate}"
                                            Header="Data riferimento"
                                            HeaderTextAlignment="Right"
                                            TextAlignment="Right" />
                <!--<telerik:GridViewComboBoxColumn DataMemberBinding="{Binding TypeID}"
                                                DisplayMemberPath="Description"
                                                Header="Tipo"
                                                IsLightweightModeEnabled="True"
                                                ItemsSource="{Binding Types}"
                                                SelectedValueMemberPath="ID" />-->
            </telerik:RadGridView.Columns>
            <telerik:RadGridView.RowDetailsTemplate>
                <DataTemplate>
                    <StackPanel Margin="10" HorizontalAlignment="Stretch" Orientation="Horizontal">
                        <TextBlock FontWeight="Bold" Text="Note: " />
                        <TextBox Width="650"
                                 IsEnabled="{Binding RelativeSource={RelativeSource AncestorType=telerik:RadGridView}, Path=Tag}"
                                 MaxLength="50"
                                 Text="{Binding Note}" />
                    </StackPanel>
                </DataTemplate>
            </telerik:RadGridView.RowDetailsTemplate>
        </telerik:RadGridView>

        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Width="130"
                    Click="cmdSave_Click"
                    Content="CONFERMA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
