<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.Invoicing.SelectPrintTypeWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting.Invoicing"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Scegli formato di stampa"
                        Width="600"
                        Height="200"
                        ResizeMode="NoResize"
                        ShowInTaskbar="False"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2" />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"
                   FontSize="14"
                   Foreground="{DynamicResource VulpesXSecondBrush}"
                   Text="Formato AssoInvoice"
                   TextAlignment="Right" />
        <Button Name="cmdPrintAssoXML"
                Grid.Row="1"
                Grid.Column="1"
                Margin="5"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Right"
                BorderBrush="{DynamicResource VulpesXVioletBrush}"
                Click="cmdPrintAssoXML_Click"
                Content="XML"
                FontSize="12"
                Style="{StaticResource VulpesXButton}" />
        <Button Name="cmdPrintAssoPDF"
                Grid.Row="1"
                Grid.Column="2"
                Margin="5"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Right"
                BorderBrush="{DynamicResource VulpesXRedBrush}"
                Click="cmdPrintAssoPDF_Click"
                Content="PDF"
                FontSize="12"
                Style="{StaticResource VulpesXButton}" />

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"
                   FontSize="14"
                   Foreground="{DynamicResource VulpesXSecondBrush}"
                   Text="Formato Agenzia delle Entrate"
                   TextAlignment="Right" />
        <Button Name="cmdPrintAEXML"
                Grid.Row="2"
                Grid.Column="1"
                Margin="5"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Right"
                BorderBrush="{DynamicResource VulpesXVioletBrush}"
                Click="cmdPrintAEXML_Click"
                Content="XML"
                FontSize="12"
                Style="{StaticResource VulpesXButton}" />
        <Button Name="cmdPrintAEPDF"
                Grid.Row="2"
                Grid.Column="2"
                Margin="5"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Right"
                BorderBrush="{DynamicResource VulpesXRedBrush}"
                Click="cmdPrintAEPDF_Click"
                Content="PDF"
                FontSize="12"
                Style="{StaticResource VulpesXButton}" />

        <StackPanel Grid.Row="3"
                    Grid.Column="1"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
        </StackPanel>

    </Grid>
</sc:FluentDefaultWindow>
