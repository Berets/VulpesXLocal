<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.Invoicing.WaitDownloadWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting.Invoicing"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Width="450"
                        Height="100"
                        ResizeMode="NoResize"
                        ShowInTaskbar="False"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="None"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{DynamicResource VulpesXSubtitle}" Text="Download delle fatture in corso, attendere prego..." />

        <StackPanel Grid.Row="1" Orientation="Vertical">
            <ProgressBar x:Name="pbCounter"
                         Height="30"
                         Margin="5"
                         HorizontalAlignment="Stretch"
                         Foreground="MediumVioletRed" />
            <TextBlock x:Name="tbCurrent"
                       Margin="5,2,5,2"
                       HorizontalAlignment="Stretch"
                       FontSize="12"
                       Foreground="White" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
