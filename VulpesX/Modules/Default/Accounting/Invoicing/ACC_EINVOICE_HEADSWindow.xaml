<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.Invoicing.ACC_EINVOICE_HEADSWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting.Invoicing"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli fattura elettronica"
                        Width="1200"
                        Height="800"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="GENERALI" Header="GENERALI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="8*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Numero" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattnum}" />
                                <TextBlock Width="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="del"
                                           TextAlignment="Right" />
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattdata, StringFormat=dd/MM/yyyy}" />
                                <TextBlock Width="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Partita IVA"
                                           TextAlignment="Right" />
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattpiva}" />
                                <TextBlock Width="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Codice SDI"
                                           TextAlignment="Right" />
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattidsdi}" />
                                <TextBlock Width="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Ricevuta il"
                                           TextAlignment="Right" />
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattdataric, StringFormat=dd/MM/yyyy HH:mm:ss}" />
                            </StackPanel>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Nome file" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattnomefileric}" />
                                <TextBlock Width="150"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Codice destinatario"
                                           TextAlignment="Right" />
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattcoddest}" />
                                <TextBlock Width="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="PEC"
                                           TextAlignment="Right" />
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattpec}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Cliente ricevuto" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.CustomerReceivedFullDescription}" />
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattcliinde}" />
                                <TextBlock Width="15"
                                           Margin="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="-"
                                           TextAlignment="Right" />
                                <TextBlock Margin="5,0,0,0" Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattcliloca}" />
                                <TextBlock Width="15"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="("
                                           TextAlignment="Right" />
                                <TextBlock Margin="0" Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattclipro}" />
                                <TextBlock Width="15"
                                           Margin="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="),"
                                           TextAlignment="Right" />
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattclicap}" />
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattclinaz}" />
                            </StackPanel>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Fornitore ricevuto" />
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattabers1}" />
                            </StackPanel>
                            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattforinde}" />
                                <TextBlock Width="15"
                                           Margin="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="-"
                                           TextAlignment="Right" />
                                <TextBlock Margin="5,0,0,0" Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattforloca}" />
                                <TextBlock Width="15"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="("
                                           TextAlignment="Right" />
                                <TextBlock Margin="0" Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattforprov}" />
                                <TextBlock Width="15"
                                           Margin="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="),"
                                           TextAlignment="Right" />
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattforcap}" />
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattfornazi}" />
                            </StackPanel>

                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Fornitore identificato" />
                            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.Supplier.FullDescriptionNotSearchable}" />
                            </StackPanel>

                            <Border Grid.Row="7"
                                    Grid.RowSpan="3"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Margin="5,0,5,0"
                                    BorderBrush="{DynamicResource VulpesXBrush}"
                                    BorderThickness="1">
                                <TextBlock Padding="0"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXBrush}"
                                           Opacity=".8"
                                           Text="IMPORTI"
                                           TextAlignment="Center"
                                           Typography.Capitals="AllSmallCaps">
                                    <TextBlock.LayoutTransform>
                                        <RotateTransform Angle="270" />
                                    </TextBlock.LayoutTransform>
                                </TextBlock>
                            </Border>
                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Imponibile" />
                            <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattimpo, StringFormat=N2}" />
                                <TextBlock Width="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Imposta"
                                           TextAlignment="Right" />
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattimposta, StringFormat=N2}" />
                                <TextBlock Width="120"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Arrotondamento"
                                           TextAlignment="Right" />
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattarrotondamento, StringFormat=N2}" />
                                <TextBlock Width="120"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="TOTALE"
                                           TextAlignment="Right" />
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fatttot, StringFormat=N2}" />
                            </StackPanel>
                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Importo bollo" />
                            <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattimpobol, StringFormat=N2}" />
                            </StackPanel>

                            <TextBlock Grid.Row="10"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Causale ricevuta" />
                            <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattcausaledes}" />
                            </StackPanel>

                            <TextBlock Grid.Row="11"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Causale identificata" />
                            <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.Causal.FullDescriptionNotSearchable}" />
                            </StackPanel>

                            <TextBlock Grid.Row="12"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Anno e numero registrazione" />
                            <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattannoreg}" />
                                <TextBlock Width="15"
                                           Margin="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="/"
                                           TextAlignment="Center" />
                                <TextBlock Margin="0" Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattnumreg}" />
                                <TextBlock Width="120"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="N. riferimento"
                                           TextAlignment="Right" />
                                <TextBlock Margin="0" Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattrife}" />
                                <TextBlock Width="120"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Data riferimento"
                                           TextAlignment="Right" />
                                <TextBlock Margin="0" Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.fattdatarife, StringFormat=dd/MM/yyyy}" />
                                <TextBlock Width="200"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="ISO"
                                           TextAlignment="Right" />
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.ISO.FullDescriptionNotSearchable}" />
                            </StackPanel>

                            <TextBlock Grid.Row="13"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Tipo documento" />
                            <StackPanel Grid.Row="13" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.DocumentType.FullDescriptionNotSearchable}" />
                                <TextBlock Width="120"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Regime fiscale"
                                           TextAlignment="Right" />
                                <TextBlock Style="{StaticResource VulpesXInfoData}" Text="{Binding Data.TaxRegime.FullDescriptionNotSearchable}" />
                            </StackPanel>

                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="DETTAGLI" Header="DETTAGLI">
                <telerik:RadTabItem.Content>
                    <Grid>
                        <telerik:RadGridView Name="rgvRows"
                                             Margin="10"
                                             AutoGenerateColumns="False"
                                             CanUserInsertRows="False"
                                             GroupRenderMode="Flat"
                                             IsReadOnly="True"
                                             IsSearchingDeferred="True"
                                             ItemsSource="{Binding Data.Rows}"
                                             RowIndicatorVisibility="Collapsed"
                                             SearchMode="MatchAnyTerm"
                                             ShowGroupPanel="False"
                                             ShowSearchPanel="False"
                                             ToolTipService.ShowOnDisabled="True">
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewToggleRowDetailsColumn ToolTip="Mostra sconti e ulteriori codici articolo" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattriga}"
                                                            Header=""
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn Width="450" DataMemberBinding="{Binding fattartdes}" Header="Descrizione articolo" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattqta, StringFormat=N6}"
                                                            Header="Quantita'"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattumi}" Header="UM" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattprz, StringFormat=N2}"
                                                            Header="Prezzo"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fatttotriga, StringFormat=N2}"
                                                            Header="Totale riga"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattaliriga, StringFormat=N2}"
                                                            Header="Aliquota"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding Nature.FullDescriptionNotSearchable}" Header="Natura" />
                            </telerik:RadGridView.Columns>
                            <telerik:RadGridView.RowDetailsTemplate>
                                <DataTemplate>
                                    <Grid Margin="3">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="150" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="5*" />
                                            <ColumnDefinition Width="5*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30" />
                                                <ColumnDefinition Width="500" />
                                                <ColumnDefinition Width="30" />
                                                <ColumnDefinition Width="500" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" BorderBrush="{DynamicResource VulpesXBrush}" BorderThickness="1">
                                                <TextBlock Padding="0"
                                                           HorizontalAlignment="Stretch"
                                                           VerticalAlignment="Stretch"
                                                           Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                                                           FontSize="18"
                                                           Foreground="{DynamicResource VulpesXBrush}"
                                                           Opacity=".8"
                                                           Text="COD. ARTICOLI"
                                                           TextAlignment="Center"
                                                           Typography.Capitals="AllSmallCaps">
                                                    <TextBlock.LayoutTransform>
                                                        <RotateTransform Angle="270" />
                                                    </TextBlock.LayoutTransform>
                                                </TextBlock>
                                            </Border>
                                            <telerik:RadGridView Name="rgvPids"
                                                                 Grid.Column="1"
                                                                 AutoGenerateColumns="False"
                                                                 IsReadOnly="True"
                                                                 ItemsSource="{Binding PIDs}"
                                                                 RowIndicatorVisibility="Collapsed"
                                                                 ShowGroupPanel="False"
                                                                 ShowSearchPanel="False">
                                                <telerik:RadGridView.Columns>
                                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding artprog}"
                                                                                Header=""
                                                                                HeaderTextAlignment="Right"
                                                                                TextAlignment="Right" />
                                                    <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding artvalcod}" Header="Codice articolo" />
                                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding artipcod}" Header="Tipo codice" />
                                                </telerik:RadGridView.Columns>
                                            </telerik:RadGridView>
                                            <Border Grid.Column="2" BorderBrush="{DynamicResource VulpesXBrush}" BorderThickness="1">
                                                <TextBlock Padding="0"
                                                           HorizontalAlignment="Stretch"
                                                           VerticalAlignment="Stretch"
                                                           Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                                                           FontSize="18"
                                                           Foreground="{DynamicResource VulpesXBrush}"
                                                           Opacity=".8"
                                                           Text="SCONTI/MAGG."
                                                           TextAlignment="Center"
                                                           Typography.Capitals="AllSmallCaps">
                                                    <TextBlock.LayoutTransform>
                                                        <RotateTransform Angle="270" />
                                                    </TextBlock.LayoutTransform>
                                                </TextBlock>
                                            </Border>
                                            <telerik:RadGridView Name="rgvSms"
                                                                 Grid.Column="3"
                                                                 AutoGenerateColumns="False"
                                                                 IsReadOnly="True"
                                                                 ItemsSource="{Binding SMs}"
                                                                 RowIndicatorVisibility="Collapsed"
                                                                 ShowGroupPanel="False"
                                                                 ShowSearchPanel="False"
                                                                 ValidatesOnDataErrors="InEditMode">
                                                <telerik:RadGridView.Columns>
                                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding Progsc}"
                                                                                Header=""
                                                                                HeaderTextAlignment="Right"
                                                                                TextAlignment="Right" />
                                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding SMTypeDescription}" Header="Tipo" />
                                                    <telerik:GridViewDataColumn Width="150"
                                                                                DataMemberBinding="{Binding scimpo, StringFormat=N2}"
                                                                                Header="Valore"
                                                                                HeaderTextAlignment="Right"
                                                                                TextAlignment="Right" />
                                                    <telerik:GridViewDataColumn Width="150"
                                                                                DataMemberBinding="{Binding scperc, StringFormat=N2}"
                                                                                Header="%"
                                                                                HeaderTextAlignment="Right"
                                                                                TextAlignment="Right" />
                                                </telerik:RadGridView.Columns>
                                            </telerik:RadGridView>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </telerik:RadGridView.RowDetailsTemplate>
                        </telerik:RadGridView>
                    </Grid>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="SCONTI/MAGGIORAZIONI" Header="SCONTI/MAGGIORAZIONI">
                <telerik:RadTabItem.Content>
                    <Grid>
                        <telerik:RadGridView Name="rgvSMs"
                                             Margin="10"
                                             AutoGenerateColumns="False"
                                             CanUserInsertRows="False"
                                             GroupRenderMode="Flat"
                                             IsReadOnly="True"
                                             IsSearchingDeferred="True"
                                             ItemsSource="{Binding Data.SMs}"
                                             RowIndicatorVisibility="Collapsed"
                                             SearchMode="MatchAnyTerm"
                                             ShowGroupPanel="False"
                                             ShowSearchPanel="False"
                                             ToolTipService.ShowOnDisabled="True">
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding sctprog}"
                                                            Header=""
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding SMTypeDescription}" Header="Tipo" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding sctimpo, StringFormat=N2}"
                                                            Header="Sconto valore"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding sctperc, StringFormat=N2}"
                                                            Header="Sconto %"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                            </telerik:RadGridView.Columns>
                        </telerik:RadGridView>
                    </Grid>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="IVA" Header="IVA">
                <telerik:RadTabItem.Content>
                    <Grid>
                        <telerik:RadGridView Name="rgvVATs"
                                             Margin="10"
                                             AutoGenerateColumns="False"
                                             CanUserInsertRows="False"
                                             GroupRenderMode="Flat"
                                             IsReadOnly="True"
                                             IsSearchingDeferred="True"
                                             ItemsSource="{Binding Data.VATs}"
                                             RowIndicatorVisibility="Collapsed"
                                             SearchMode="MatchAnyTerm"
                                             ShowGroupPanel="False"
                                             ShowSearchPanel="False"
                                             ToolTipService.ShowOnDisabled="True">
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattprog}"
                                                            Header=""
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding Fattaliq}"
                                                            Header="Aliquota (%)"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattimpodett, StringFormat=N2}"
                                                            Header="Imponibile"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattimpostadett, StringFormat=N2}"
                                                            Header="Imposta"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding SelectedNature.FullDescriptionNotSearchable}" Header="Natura" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding CollectabilityDescription}" Header="Esigibilità" />
                                <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding fattrifenorm}" Header="Riferimento normativo" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattarrotondamento, StringFormat=N2}"
                                                            Header="Arrotondamento"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                            </telerik:RadGridView.Columns>
                        </telerik:RadGridView>
                    </Grid>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="SCADENZE" Header="SCADENZE">
                <telerik:RadTabItem.Content>
                    <Grid>
                        <telerik:RadGridView Name="rgvExpires"
                                             Margin="10"
                                             AutoGenerateColumns="False"
                                             CanUserInsertRows="False"
                                             GroupRenderMode="Flat"
                                             IsReadOnly="True"
                                             IsSearchingDeferred="True"
                                             ItemsSource="{Binding Data.Expires}"
                                             RowIndicatorVisibility="Collapsed"
                                             SearchMode="MatchAnyTerm"
                                             ShowGroupPanel="False"
                                             ShowSearchPanel="False"
                                             ToolTipService.ShowOnDisabled="True">
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattdatascad, StringFormat=dd/MM/yyyy}"
                                                            Header="Data scadenza"
                                                            HeaderTextAlignment="Center"
                                                            TextAlignment="Center" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattimpscad, StringFormat=N2}"
                                                            Header="Importo"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding PaymentType.FullDescriptionNotSearchable}" Header="Tipo pagamento FE" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding PaymentTypeInternal.FullDescriptionNotSearchable}" Header="Tipo pagamento" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattabi}"
                                                            Header="ABI"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattcab}"
                                                            Header="CAB"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding fattistu}" Header="Banca" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattiban}" Header="IBAN" />
                                <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding PaymentConditionDescription}" Header="Modalità pagamento" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding FATTCODPAGV}" Header="Codice riconciliazione" />
                            </telerik:RadGridView.Columns>
                        </telerik:RadGridView>
                    </Grid>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="DDT" Header="DDT">
                <telerik:RadTabItem.Content>
                    <Grid>
                        <telerik:RadGridView Name="rgvDDTs"
                                             Margin="10"
                                             AutoGenerateColumns="False"
                                             CanUserInsertRows="False"
                                             GroupRenderMode="Flat"
                                             IsReadOnly="True"
                                             IsSearchingDeferred="True"
                                             ItemsSource="{Binding Data.DDTs}"
                                             RowIndicatorVisibility="Collapsed"
                                             SearchMode="MatchAnyTerm"
                                             ShowGroupPanel="False"
                                             ShowSearchPanel="False"
                                             ToolTipService.ShowOnDisabled="True">
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding ddtriga}"
                                                            Header=""
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding ddtdata, StringFormat=dd/MM/yyyy}"
                                                            Header="Data documento"
                                                            HeaderTextAlignment="Center"
                                                            TextAlignment="Center" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding ddtnum}"
                                                            Header="Numero DDT"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding ddtriferiga}"
                                                            Header="Riga DDT"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                            </telerik:RadGridView.Columns>
                        </telerik:RadGridView>
                    </Grid>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="ORDINI ACQUISTO" Header="ORDINI ACQUISTO">
                <telerik:RadTabItem.Content>
                    <Grid>
                        <telerik:RadGridView Name="rgvPOs"
                                             Margin="10"
                                             AutoGenerateColumns="False"
                                             CanUserInsertRows="False"
                                             GroupRenderMode="Flat"
                                             IsReadOnly="True"
                                             IsSearchingDeferred="True"
                                             ItemsSource="{Binding Data.POs}"
                                             RowIndicatorVisibility="Collapsed"
                                             SearchMode="MatchAnyTerm"
                                             ShowGroupPanel="False"
                                             ShowSearchPanel="False"
                                             ToolTipService.ShowOnDisabled="True">
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding riga}"
                                                            Header=""
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding numitem}"
                                                            Header="Rif. interno"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding iddocumento}" Header="Documento" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding datadoc, StringFormat=dd/MM/yyyy}"
                                                            Header="Data documento"
                                                            HeaderTextAlignment="Center"
                                                            TextAlignment="Center" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding rigarife}"
                                                            Header="Riga rif. fatt."
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                            </telerik:RadGridView.Columns>
                        </telerik:RadGridView>
                    </Grid>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="CASSA PREVIDENZIALE" Header="CASSA PREVIDENZIALE">
                <telerik:RadTabItem.Content>
                    <Grid>
                        <telerik:RadGridView Name="rgvCPs"
                                             Margin="10"
                                             AutoGenerateColumns="False"
                                             CanUserInsertRows="False"
                                             GroupRenderMode="Flat"
                                             IsReadOnly="True"
                                             IsSearchingDeferred="True"
                                             ItemsSource="{Binding Data.CPs}"
                                             RowIndicatorVisibility="Collapsed"
                                             SearchMode="MatchAnyTerm"
                                             ShowGroupPanel="False"
                                             ShowSearchPanel="False"
                                             ToolTipService.ShowOnDisabled="True">
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding progcassa}"
                                                            Header=""
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding CPType.FullDescriptionNotSearchable}" Header="Tipo cassa" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding Nature.FullDescriptionNotSearchable}" Header="Natura cassa" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding impocassa, StringFormat=N2}"
                                                            Header="Importo cassa"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding alicassa, StringFormat=N0}"
                                                            Header="Aliquota"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding impcontricassa, StringFormat=N2}"
                                                            Header="Importo contributo"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding aliivacassa, StringFormat=N2}"
                                                            Header="Importo contributo"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding ritecassa}"
                                                            Header="Soggetto a ritenuta"
                                                            HeaderTextAlignment="Center"
                                                            TextAlignment="Center" />
                                <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding rifammicassa}" Header="Riferimento amministrazione" />
                            </telerik:RadGridView.Columns>
                        </telerik:RadGridView>
                    </Grid>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="DATI RITENUTA" Header="DATI RITENUTA">
                <telerik:RadTabItem.Content>
                    <Grid>
                        <telerik:RadGridView Name="rgvRITs"
                                             Margin="10"
                                             AutoGenerateColumns="False"
                                             CanUserInsertRows="False"
                                             GroupRenderMode="Flat"
                                             IsReadOnly="True"
                                             IsSearchingDeferred="True"
                                             ItemsSource="{Binding Data.RITs}"
                                             RowIndicatorVisibility="Collapsed"
                                             SearchMode="MatchAnyTerm"
                                             ShowGroupPanel="False"
                                             ShowSearchPanel="False"
                                             ToolTipService.ShowOnDisabled="True">
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding progrit}"
                                                            Header=""
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding Ritenuta.FullDescriptionNotSearchable}" Header="Tipo ritenuta" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding importo, StringFormat=N2}"
                                                            Header="Importo ritenuta"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding aliquota, StringFormat=N2}"
                                                            Header="Aliquota ritenuta"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding causalepagamento}" Header="Causale pagamento" />
                            </telerik:RadGridView.Columns>
                        </telerik:RadGridView>
                    </Grid>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="FATT. COLLEGATE" Header="FATT. COLLEGATE">
                <telerik:RadTabItem.Content>
                    <Grid>
                        <telerik:RadGridView Name="rgvLinkeds"
                                             Margin="10"
                                             AutoGenerateColumns="False"
                                             CanUserInsertRows="False"
                                             GroupRenderMode="Flat"
                                             IsReadOnly="True"
                                             IsSearchingDeferred="True"
                                             ItemsSource="{Binding Data.Linkeds}"
                                             RowIndicatorVisibility="Collapsed"
                                             SearchMode="MatchAnyTerm"
                                             ShowGroupPanel="False"
                                             ShowSearchPanel="False"
                                             ToolTipService.ShowOnDisabled="True">
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattcollriga}"
                                                            Header=""
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattcolliddocumento}" Header="N. documento" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattcolldatadoc, StringFormat=dd/MM/yyyy}"
                                                            Header="Data documento"
                                                            HeaderTextAlignment="Center"
                                                            TextAlignment="Center" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding fattcollriferiga}"
                                                            Header="Riga rif."
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                            </telerik:RadGridView.Columns>
                        </telerik:RadGridView>
                    </Grid>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Inserito il" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultimo aggiornamento il" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Annullato il" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Motivo annullamento" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Margin="5,2,2,2"
                                       Style="{StaticResource VulpesXData}"
                                       Text="{Binding Data.canceledNote}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>

        <StackPanel Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
