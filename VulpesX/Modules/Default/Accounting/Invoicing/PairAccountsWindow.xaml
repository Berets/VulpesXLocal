<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.Invoicing.PairAccountsWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting.Invoicing"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Raggruppa le righe di fattura per contropartita"
                        Width="1100"
                        Height="750"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="4*" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="5*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Margin="10,0,0,0" Style="{DynamicResource VulpesXLabel}" Text="Fornitore" />
            <TextBlock Margin="10,0,0,0" Style="{DynamicResource VulpesXData}" Text="{Binding SupplierDescription}" />
            <TextBlock Margin="10,0,0,0" Style="{DynamicResource VulpesXLabel}" Text="Fattura" />
            <TextBlock Margin="10,0,0,0" Style="{DynamicResource VulpesXData}" Text="{Binding InvoiceText}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Style="{DynamicResource VulpesXTitle}" Text="CONTROPARTITE" />
            <Grid Grid.Row="1" Margin="5,5,5,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="rgvPNRows"
                                     Grid.Row="0"
                                     AddingNewDataItem="rgvPNRows_AddingNewDataItem"
                                     AutoGenerateColumns="False"
                                     CanUserDeleteRows="True"
                                     CanUserFreezeColumns="False"
                                     CanUserInsertRows="True"
                                     CanUserResizeColumns="False"
                                     Deleted="rgvPNRows_Deleted"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="False"
                                     IsSynchronizedWithCurrentItem="True"
                                     ItemsSource="{Binding PNRows}"
                                     NewRowPosition="Top"
                                     RowIndicatorVisibility="Collapsed"
                                     RowValidated="rgvPNRows_RowValidated"
                                     RowValidating="rgvPNRows_RowValidating"
                                     SelectionChanged="rgvPNRows_SelectionChanged"
                                     SelectionChanging="rgvPNRows_SelectionChanging"
                                     SelectionMode="Single"
                                     ShowGroupPanel="False">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewSelectColumn />
                        <telerik:GridViewDataColumn Width="50"
                                                    DataMemberBinding="{Binding N1RIGA, Mode=TwoWay}"
                                                    Header="#"
                                                    HeaderTextAlignment="Center"
                                                    IsReadOnly="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="200"
                                                    DataMemberBinding="{Binding SelectedGroup.FullDescriptionSearchable}"
                                                    Header="Gruppo"
                                                    IsReadOnly="False">
                            <telerik:GridViewDataColumn.CellEditTemplate>
                                <DataTemplate>
                                    <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                ItemsSource="{Binding GroupsList}"
                                                                NoResultsContent="Nessun gruppo trovato"
                                                                SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                                                                SelectionMode="Single"
                                                                TextSearchMode="Contains"
                                                                TextSearchPath="FullDescriptionSearchable" />
                                </DataTemplate>
                            </telerik:GridViewDataColumn.CellEditTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="200"
                                                    DataMemberBinding="{Binding SelectedAccount.FullDescriptionSearchable}"
                                                    Header="Conto"
                                                    IsReadOnly="False">
                            <telerik:GridViewDataColumn.CellEditTemplate>
                                <DataTemplate>
                                    <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                ItemsSource="{Binding AccountsList}"
                                                                NoResultsContent="Nessun conto trovato"
                                                                SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                                                                SelectionMode="Single"
                                                                TextSearchMode="Contains"
                                                                TextSearchPath="FullDescriptionSearchable" />
                                </DataTemplate>
                            </telerik:GridViewDataColumn.CellEditTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="250"
                                                    DataMemberBinding="{Binding SelectedSubaccount.FullDescriptionSearchable}"
                                                    Header="Sottoconto"
                                                    IsReadOnly="False">
                            <telerik:GridViewDataColumn.CellEditTemplate>
                                <DataTemplate>
                                    <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                ItemsSource="{Binding SubaccountsList}"
                                                                NoResultsContent="Nessun sottoconto trovato"
                                                                SelectedItem="{Binding SelectedSubaccount, Mode=TwoWay}"
                                                                SelectionMode="Single"
                                                                TextSearchMode="Contains"
                                                                TextSearchPath="FullDescriptionSearchable" />
                                </DataTemplate>
                            </telerik:GridViewDataColumn.CellEditTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding N1IMEU, StringFormat=N2}"
                                                    Header="Importo"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding SelectedCostCenter.FullDescriptionSearchable}" Header="Centro di costo">
                            <telerik:GridViewDataColumn.CellEditTemplate>
                                <DataTemplate>
                                    <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                ItemsSource="{Binding CostCentersList}"
                                                                NoResultsContent="Nessun centro di costo trovato"
                                                                SelectedItem="{Binding SelectedCostCenter, Mode=TwoWay}"
                                                                SelectionMode="Single"
                                                                TextSearchMode="Contains"
                                                                TextSearchPath="FullDescriptionSearchable" />
                                </DataTemplate>
                            </telerik:GridViewDataColumn.CellEditTemplate>
                        </telerik:GridViewDataColumn>
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
            </Grid>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Style="{DynamicResource VulpesXTitle}" Text="IVA" />
            <Grid Grid.Row="1" Margin="5,5,5,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="rgvPNIVARows"
                                     Grid.Row="0"
                                     AddingNewDataItem="rgvPNIVARows_AddingNewDataItem"
                                     AutoGenerateColumns="False"
                                     CanUserDeleteRows="True"
                                     CanUserFreezeColumns="False"
                                     CanUserInsertRows="True"
                                     CanUserResizeColumns="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="False"
                                     IsSynchronizedWithCurrentItem="True"
                                     ItemsSource="{Binding PNIVARows}"
                                     NewRowPosition="Top"
                                     RowIndicatorVisibility="Collapsed"
                                     RowValidated="rgvPNIVARows_RowValidated"
                                     RowValidating="rgvPNIVARows_RowValidating"
                                     SelectionMode="Single"
                                     ShowGroupPanel="False">
                    <telerik:RadContextMenu.ContextMenu>
                        <telerik:RadContextMenu x:Name="cmGridReceived" Background="#2C2D33" Opening="cmGridReceived_Opening">
                            <telerik:RadMenuItem x:Name="rmiAddPNRow"
                                                 Background="{DynamicResource VulpesXBrush}"
                                                 Click="rmiAddPNRow_Click"
                                                 Foreground="Black"
                                                 Header="Aggiungi riga prima nota"
                                                 Typography.Capitals="AllSmallCaps">
                                <telerik:RadMenuItem.Icon>
                                    <Image Width="16"
                                           Height="16"
                                           Source="{telerik:RadGlyph Glyph={StaticResource GlyphArrowChevronUp}}"
                                           Stretch="Uniform" />
                                </telerik:RadMenuItem.Icon>
                            </telerik:RadMenuItem>
                        </telerik:RadContextMenu>
                    </telerik:RadContextMenu.ContextMenu>
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding Fattaliq}"
                                                    Header="Aliquota fattura el."
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding SelectedRate.FullDescriptionSearchable}" Header="Aliquota assegnata">
                            <telerik:GridViewDataColumn.CellEditTemplate>
                                <DataTemplate>
                                    <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                ItemsSource="{Binding Rates}"
                                                                NoResultsContent="Nessuna aliquota trovata"
                                                                SelectedItem="{Binding SelectedRate, Mode=TwoWay}"
                                                                SelectionMode="Single"
                                                                TextSearchMode="Contains"
                                                                TextSearchPath="FullDescriptionSearchable" />
                                </DataTemplate>
                            </telerik:GridViewDataColumn.CellEditTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding fattimpodett, StringFormat=N2}"
                                                    Header="Imponibile"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="False"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding fattimpostadett, StringFormat=N2}"
                                                    Header="Imposta"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="False"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding SelectedNature.FullDescriptionSearchable}" Header="Natura" IsReadOnly="False">
                            <telerik:GridViewDataColumn.CellEditTemplate>
                                <DataTemplate>
                                    <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                ItemsSource="{Binding Natures}"
                                                                NoResultsContent="Nessuna natura trovata"
                                                                SelectedItem="{Binding SelectedNature, Mode=TwoWay}"
                                                                SelectionMode="Single"
                                                                TextSearchMode="Contains"
                                                                TextSearchPath="FullDescriptionSearchable" />
                                </DataTemplate>
                            </telerik:GridViewDataColumn.CellEditTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding fattrifenorm}" Header="Riferimento normativo" IsReadOnly="False" />
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
            </Grid>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Style="{DynamicResource VulpesXTitle}" Text="RIGHE DA FATTURA" />
            <Grid Grid.Row="1" Margin="5,5,5,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="rgvRows"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Rows}"
                                     RowIndicatorVisibility="Collapsed"
                                     SelectionChanged="rgvRows_SelectionChanged"
                                     SelectionMode="Multiple"
                                     ShowGroupPanel="False">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewSelectColumn IsSelected="False" />
                        <telerik:GridViewDataColumn Width="500"
                                                    DataMemberBinding="{Binding fattartdes}"
                                                    Header="Articolo"
                                                    IsReadOnly="True" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding fatttotriga, StringFormat=N2}"
                                                    Header="Totale riga"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding fattaliriga, StringFormat=N0}"
                                                    Header="Aliquota"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding fattqta, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}"
                                                    Header="Accorpato al conto"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="4"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
