<UserControl x:Class="VulpesX.Modules.Default.Accounting.ACC_PLAFONDView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="DICHIARAZIONI D'INTENTO CLIENTI" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Name="cmdSettings"
                        Width="180"
                        Margin="5"
                        Click="cmdSettings_Click"
                        Style="{StaticResource VulpesXButton}"
                        ToolTip="Clicca per modificare le impostazioni generali delle dichiarazioni d'intento">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <telerik:RadGlyph FontSize="14" Foreground="{DynamicResource VulpesXBrush}" Glyph="&#xe13a;" />
                            <TextBlock Margin="5,0,0,0" FontSize="11" Text="IMPOSTAZIONI" />
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />

                <telerik:RadDatePicker x:Name="dtpYear"
                                       Margin="5"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Right"
                                       DateSelectionMode="Year"
                                       DisplayFormat="Short"
                                       SelectedValue="{Binding Year, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       SelectionChanged="dtpYear_SelectionChanged" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Grid.Column="1"
                                         Margin="5"
                                         TextChanged="txtSearch_TextChanged"
                                         WatermarkContent="Cerca..." />
        </Grid>

        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     DataLoaded="GridView_DataLoaded"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     RowIndicatorVisibility="Hidden"
                                     SelectionMode="Multiple"
                                     ShowGroupPanel="True">
                    <telerik:RadContextMenu.ContextMenu>
                        <telerik:RadContextMenu x:Name="cnPlafond">
                            <telerik:RadMenuItem x:Name="rmiClose"
                                                 Click="rmiClose_Click"
                                                 Header="Chiudi dichiarazioni di intento"
                                                 Typography.Capitals="AllSmallCaps">
                                <telerik:RadMenuItem.Icon>
                                    <Image Width="16"
                                           Height="16"
                                           Source="{telerik:RadGlyph Glyph={StaticResource GlyphReset}}"
                                           Stretch="Uniform" />
                                </telerik:RadMenuItem.Icon>
                            </telerik:RadMenuItem>
                        </telerik:RadContextMenu>
                    </telerik:RadContextMenu.ContextMenu>
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewSelectColumn />
                        <telerik:GridViewColumn Width="110">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadButton x:Name="cmdDelete"
                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                       Click="cmdDelete_Click"
                                                       Content="Elimina"
                                                       Style="{StaticResource VulpesXButton}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding Customer.FullDescriptionSearchable}" Header="Cliente" />
                        <telerik:GridViewDataColumn Width="80"
                                                    DataMemberBinding="{Binding cliannosol}"
                                                    Header="Anno"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="80"
                                                    DataMemberBinding="{Binding cliprog}"
                                                    Header="Prog."
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Right"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEdit_Click"
                                            Content="{Binding Path=cliprog}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding clistart}"
                                                    Header="Inizio validita'"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding clidatchi}"
                                                    Header="Data chiusura"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="150"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding cliimpesefino}"
                                                    Header="Esenzione fino a"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="150"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding cliimpfattprog}"
                                                    Header="Fatturato progressivo"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="150"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding cliimpfattprovv}"
                                                    Header="Fatturato provvisorio"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding Items}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>

</UserControl>
