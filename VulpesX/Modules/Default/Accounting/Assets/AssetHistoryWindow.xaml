<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.Assets.AssetHistoryWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting.Assets"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Aggiornamento cespiti"
                        Width="500"
                        Height="260"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="None"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="7*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Anno"
                   TextAlignment="Right"
                   TextWrapping="Wrap" />
        <telerik:RadDatePicker x:Name="rdpDate"
                               Grid.Row="1"
                               Grid.Column="1"
                               Width="140"
                               Margin="5,0,15,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               HorizontalContentAlignment="Right"
                               DateSelectionMode="Year"
                               DateTimeWatermarkContent="Scegliere un anno"
                               DisplayFormat="Short" />
        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Tipo"
                   TextAlignment="Right"
                   TextWrapping="Wrap" />
        <telerik:RadComboBox Grid.Row="2"
                             Grid.Column="1"
                             Width="200"
                             Margin="5,2,15,2"
                             HorizontalAlignment="Left"
                             HorizontalContentAlignment="Left"
                             DisplayMemberPath="Description"
                             IsEditable="True"
                             IsReadOnly="True"
                             ItemsSource="{Binding ComputeTypes}"
                             SelectedValue="{Binding SelectedComputeType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             SelectedValuePath="ID" />
        <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Data inizio calcolo"
                   TextAlignment="Right"
                   TextWrapping="Wrap" />
        <telerik:RadDateTimePicker x:Name="rdpDateFrom"
                                   Grid.Row="3"
                                   Grid.Column="1"
                                   Width="140"
                                   Margin="5,0,15,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   DateSelectionMode="Day"
                                   DateTimeWatermarkContent="Scegliere la data"
                                   DisplayFormat="Short"
                                   InputMode="DatePicker"
                                   SelectedValue="{Binding SelectedDateFrom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock Grid.Row="4"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Data fine calcolo"
                   TextAlignment="Right"
                   TextWrapping="Wrap" />
        <telerik:RadDateTimePicker x:Name="rdpDateTo"
                                   Grid.Row="4"
                                   Grid.Column="1"
                                   Width="140"
                                   Margin="5,0,15,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   DateSelectionMode="Day"
                                   DateTimeWatermarkContent="Scegliere la data"
                                   DisplayFormat="Short"
                                   InputMode="DatePicker"
                                   SelectedValue="{Binding SelectedDateTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Grid.Row="6"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
