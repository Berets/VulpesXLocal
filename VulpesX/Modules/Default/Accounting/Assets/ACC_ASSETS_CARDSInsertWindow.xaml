<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.Assets.ACC_ASSETS_CARDSInsertWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting.Assets"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Width="500"
                        Height="280"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="None"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="8*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Anno"
                   TextAlignment="Right"
                   TextWrapping="Wrap" />
        <telerik:RadDatePicker x:Name="rdpDate"
                               Grid.Row="1"
                               Grid.Column="1"
                               Width="130"
                               Margin="2"
                               HorizontalAlignment="Left"
                               HorizontalContentAlignment="Right"
                               DateSelectionMode="Year"
                               DateTimeWatermarkContent="Scegliere un anno"
                               DisplayFormat="Short" />

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Gruppo"
                   TextAlignment="Right"
                   TextWrapping="Wrap" />
        <telerik:RadAutoCompleteBox x:Name="acGroup"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="5,2,15,2"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    DisplayMemberPath="FullDescriptionSearchable"
                                    GotFocus="ac_GotFocus"
                                    ItemsSource="{Binding Groups}"
                                    LostFocus="ac_LostFocus"
                                    NoResultsContent="Nessun codice trovato"
                                    SelectionChanged="acGroup_SelectionChanged"
                                    SelectionMode="Single"
                                    TextSearchMode="Contains"
                                    TextSearchPath="FullDescriptionSearchable"
                                    WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

        <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Conto"
                   TextAlignment="Right"
                   TextWrapping="Wrap" />
        <telerik:RadAutoCompleteBox x:Name="acAccount"
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Margin="5,2,15,2"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    DisplayMemberPath="FullDescriptionSearchable"
                                    GotFocus="ac_GotFocus"
                                    ItemsSource="{Binding Accounts}"
                                    LostFocus="ac_LostFocus"
                                    NoResultsContent="Nessun codice trovato"
                                    SelectionChanged="acAccount_SelectionChanged"
                                    SelectionMode="Single"
                                    TextSearchMode="Contains"
                                    TextSearchPath="FullDescriptionSearchable"
                                    WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

        <TextBlock Grid.Row="4"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Sottoconto"
                   TextAlignment="Right"
                   TextWrapping="Wrap" />
        <telerik:RadAutoCompleteBox x:Name="acSubaccount"
                                    Grid.Row="4"
                                    Grid.Column="1"
                                    Margin="5,2,15,2"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    DisplayMemberPath="FullDescriptionSearchable"
                                    GotFocus="ac_GotFocus"
                                    ItemsSource="{Binding Subaccounts}"
                                    LostFocus="ac_LostFocus"
                                    NoResultsContent="Nessun codice trovato"
                                    SelectionChanged="acSubaccount_SelectionChanged"
                                    SelectionMode="Single"
                                    TextSearchMode="Contains"
                                    TextSearchPath="FullDescriptionSearchable"
                                    WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

        <StackPanel Grid.Row="6"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
