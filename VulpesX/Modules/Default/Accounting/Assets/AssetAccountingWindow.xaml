<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.Assets.AssetAccountingWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting.Assets"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Contabilizzazione cespiti"
                        Width="600"
                        Height="220"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="None"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="7*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Esercizio"
                   TextAlignment="Right"
                   TextWrapping="Wrap" />
        <telerik:RadComboBox x:Name="cmbAccountingYear"
                             Grid.Row="1"
                             Grid.Column="1"
                             Width="150"
                             Margin="5,5,15,5"
                             HorizontalAlignment="Left"
                             HorizontalContentAlignment="Right"
                             DisplayMemberPath="eseann"
                             SelectionChanged="cmbAccountingYear_SelectionChanged" />
        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Data contabilizzazione"
                   TextAlignment="Right"
                   TextWrapping="Wrap" />
        <telerik:RadDateTimePicker x:Name="rdpDateTo"
                                   Grid.Row="2"
                                   Grid.Column="1"
                                   Width="140"
                                   Margin="5,0,15,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   DateSelectionMode="Day"
                                   DateTimeWatermarkContent="Scegliere la data"
                                   DisplayFormat="Short"
                                   InputMode="DatePicker"
                                   SelectedValue="{Binding SelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Causale"
                   TextAlignment="Right"
                   TextWrapping="Wrap" />
        <telerik:RadAutoCompleteBox x:Name="acCausal"
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Margin="5,2,15,2"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    DisplayMemberPath="FullDescriptionSearchable"
                                    GotFocus="ac_GotFocus"
                                    ItemsSource="{Binding Causals}"
                                    LostFocus="ac_LostFocus"
                                    NoResultsContent="Nessun codice trovato"
                                    SelectedItem="{Binding SelectedCausal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SelectionMode="Single"
                                    TextSearchMode="Contains"
                                    TextSearchPath="FullDescriptionSearchable"
                                    WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />



        <StackPanel Grid.Row="5"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
