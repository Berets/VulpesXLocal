<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Accounting.PNTESTATAWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli della testata registrazione di prima nota"
                        Width="950"
                        Height="450"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="GENERALI" Header="GENERALI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.5*" />
                                <ColumnDefinition Width="2.5*" />
                                <ColumnDefinition Width="2.5*" />
                                <ColumnDefinition x:Name="col3" Width="2.5*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Esercizio contabile" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Margin="5,0,15,0"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"
                                       Foreground="DeepSkyBlue"
                                       Text="{Binding Data.N1ANNO}" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="2"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Valuta" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="3"
                                       Margin="5,0,15,0"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"
                                       Foreground="DeepSkyBlue"
                                       Text="{Binding Data.pnvcod}" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="3"
                                       Margin="35,0,15,0"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"
                                       Foreground="DeepSkyBlue"
                                       Text="{Binding Data.pnvdiv}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Data registrazione" />
                            <telerik:RadDateTimePicker Grid.Row="1"
                                                       Grid.Column="1"
                                                       Margin="5,0,15,0"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Center"
                                                       DateSelectionMode="Day"
                                                       DateTimeWatermarkContent="Scegliere la data per la registrazione"
                                                       DisplayFormat="Short"
                                                       InputMode="DatePicker"
                                                       IsEnabled="{Binding IsEnabled}"
                                                       SelectedValue="{Binding Data.N1DARE}" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="2"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Registrazione provvisoria" />
                            <CheckBox Grid.Row="1"
                                      Grid.Column="3"
                                      Margin="5,0,0,0"
                                      FontSize="14"
                                      FontWeight="Bold"
                                      Foreground="{DynamicResource VulpesXSecondBrush}"
                                      IsChecked="{Binding Data.N1TmpPNBool}"
                                      IsEnabled="{Binding IsEnabled}" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Causale" />
                            <telerik:RadAutoCompleteBox x:Name="acCausal"
                                                        Grid.Row="2"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        IsEnabled="{Binding IsEnabled}"
                                                        ItemsSource="{Binding Causals}"
                                                        LostFocus="acCausal_LostFocus"
                                                        NoResultsContent="Nessuna causale trovata"
                                                        SelectedItem="{Binding SelectedCausal, Mode=TwoWay}"
                                                        SelectionChanged="acCausal_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="2"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Importo" />
                            <telerik:RadNumericUpDown Grid.Row="2"
                                                      Grid.Column="3"
                                                      Margin="5,0,25,3"
                                                      VerticalAlignment="Bottom"
                                                      IsEnabled="{Binding IsInsert}"
                                                      Minimum="0"
                                                      NumberDecimalDigits="2"
                                                      Value="{Binding Data.Amount, Mode=TwoWay}" />

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Forza protocollo" />
                            <telerik:RadToggleSwitchButton Grid.Row="3"
                                                           Grid.Column="1"
                                                           Margin="5,0,0,0"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.ForceProtocol}"
                                                           IsChecked="{Binding Data.ForceProtocol}"
                                                           UncheckedContent="No" />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Documento" />
                            <TextBox x:Name="txtN1DOCN"
                                     Grid.Row="4"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     IsEnabled="{Binding IsEnabled}"
                                     MaxLength="20"
                                     Text="{Binding Data.N1docn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="2"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Data documento" />
                            <telerik:RadDateTimePicker Grid.Row="4"
                                                       Grid.Column="3"
                                                       Margin="5,0,25,0"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Center"
                                                       DateSelectionMode="Day"
                                                       DateTimeWatermarkContent="Scegliere la data del documento"
                                                       DisplayFormat="Short"
                                                       InputMode="DatePicker"
                                                       IsEnabled="{Binding IsEnabled}"
                                                       SelectedValue="{Binding Data.N1docd}" />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Riferimento" />
                            <TextBox Grid.Row="5"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     IsEnabled="{Binding IsEnabled}"
                                     MaxLength="20"
                                     Text="{Binding Data.N1rifn}" />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="2"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Data riferimento" />
                            <telerik:RadDateTimePicker Grid.Row="5"
                                                       Grid.Column="3"
                                                       Margin="5,0,25,0"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Center"
                                                       DateSelectionMode="Day"
                                                       DateTimeWatermarkContent="Scegliere la data del riferimento"
                                                       DisplayFormat="Short"
                                                       InputMode="DatePicker"
                                                       IsEnabled="{Binding IsEnabled}"
                                                       SelectedValue="{Binding Data.N1rifd}" />

                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Tipo codice" />
                            <telerik:RadComboBox x:Name="cmbEntityType"
                                                 Grid.Row="6"
                                                 Grid.Column="1"
                                                 Margin="5,2,15,2"
                                                 HorizontalAlignment="Stretch"
                                                 HorizontalContentAlignment="Left"
                                                 DisplayMemberPath="Description"
                                                 IsEditable="True"
                                                 IsEnabled="{Binding IsEnabled}"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding CFFlags}"
                                                 SelectedValue="{Binding Data.N1FLCF}"
                                                 SelectedValuePath="ID"
                                                 SelectionChanged="cmbEntityType_SelectionChanged" />

                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Anagrafica" />
                            <telerik:RadAutoCompleteBox x:Name="acCode"
                                                        Grid.Row="7"
                                                        Grid.Column="1"
                                                        Grid.ColumnSpan="3"
                                                        Margin="5,0,25,0"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        IsEnabled="{Binding IsEnabled}"
                                                        ItemsSource="{Binding Codes}"
                                                        LostFocus="acCode_LostFocus"
                                                        NoResultsContent="Nessuna anagrafica trovata"
                                                        SelectedItem="{Binding SelectedEntity, Mode=TwoWay}"
                                                        SelectionChanged="acCode_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la ragione sociale per cercare un soggetto..." />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Inserito il" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultimo aggiornamento il" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Annullato il" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Motivo annullamento" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Margin="5,2,2,2"
                                       Style="{StaticResource VulpesXData}"
                                       Text="{Binding Data.canceledNote}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
