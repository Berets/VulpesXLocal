<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Production.ProductionOrderConfirmWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Production"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Conferma revisione e quantita' prima del lancio"
                        Width="1000"
                        Height="550"
                        Closing="Window_Closing"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="None"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35" />
                <RowDefinition Height="2" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="35" />
                <RowDefinition Height="2" />
                <RowDefinition Height="25" />
                <RowDefinition Height="35" />
                <RowDefinition Height="35" />
                <RowDefinition Height="*" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="5" />
                <RowDefinition Height="35" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Grid.ColumnSpan="4"
                       Margin="0,0,10,0"
                       HorizontalAlignment="Stretch"
                       Style="{StaticResource VulpesXTitle}"
                       Text="Conferma revisione e quantita' per la produzione"
                       TextAlignment="Center"
                       Typography.Capitals="AllSmallCaps" />

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Ordine"
                       TextAlignment="Right" />
            <TextBlock Grid.Row="2"
                       Grid.Column="1"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding Order.ID}" />

            <TextBlock Grid.Row="2"
                       Grid.Column="2"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Data consegna"
                       TextAlignment="Right" />
            <TextBlock Grid.Row="2"
                       Grid.Column="3"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding Order.DataConsegna, StringFormat='{}{0:dd/MM/yyyy}'}" />


            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Cliente"
                       TextAlignment="Right" />
            <TextBlock Grid.Row="3"
                       Grid.Column="1"
                       Grid.ColumnSpan="3"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding Order.FullCustomerDescription}" />

            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Articolo"
                       TextAlignment="Right" />
            <TextBlock Grid.Row="4"
                       Grid.Column="1"
                       Grid.ColumnSpan="3"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding Order.FullProductDescription}" />

            <TextBlock Grid.Row="5"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Revisione"
                       TextAlignment="Right" />
            <telerik:RadComboBox Grid.Row="5"
                                 Grid.Column="1"
                                 Grid.ColumnSpan="3"
                                 Margin="15,2,15,2"
                                 HorizontalAlignment="Stretch"
                                 HorizontalContentAlignment="Left"
                                 IsEditable="True"
                                 IsReadOnly="True"
                                 ItemsSource="{Binding Revisions}"
                                 SelectedValue="{Binding Order.RevisioneID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="7"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Quantità ordinata"
                       TextAlignment="Right" />
            <StackPanel Grid.Row="7"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Orientation="Horizontal">
                <TextBlock Width="150"
                           Style="{StaticResource VulpesXData}"
                           Text="{Binding OriginalQuantity, StringFormat='{}{0,24:N6}'}"
                           TextAlignment="Right" />
                <TextBlock Margin="10,0,0,0" Style="{StaticResource VulpesXLabel}" Text="{Binding Order.UM}" />
            </StackPanel>

            <TextBlock Grid.Row="8"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Quantità disponibile"
                       TextAlignment="Right" />
            <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                <TextBlock Width="150"
                           Style="{StaticResource VulpesXData}"
                           Text="{Binding QuantityAvailable, StringFormat='{}{0,24:N6}'}"
                           TextAlignment="Right" />
                <TextBlock Margin="10,0,0,0" Style="{StaticResource VulpesXLabel}" Text="{Binding Order.UM}" />
            </StackPanel>
            <TextBlock Grid.Row="8"
                       Grid.Column="2"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Quantità da produrre"
                       TextAlignment="Right" />
            <StackPanel Grid.Row="8"
                        Grid.Column="3"
                        Grid.ColumnSpan="2"
                        Orientation="Horizontal">
                <telerik:RadNumericUpDown x:Name="rnToProduce"
                                          Width="200"
                                          Margin="10,5,5,5"
                                          Minimum="0"
                                          NumberDecimalDigits="6"
                                          Value="{Binding QuantityToProduce, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Margin="10,0,0,0" Style="{StaticResource VulpesXLabel}" Text="{Binding Order.UM}" />
            </StackPanel>

            <TextBlock Grid.Row="9"
                       Grid.Column="0"
                       Grid.ColumnSpan="4"
                       VerticalAlignment="Top"
                       Style="{StaticResource VulpesXSubtitle}"
                       Text="Quantità da impegnare"
                       TextAlignment="Center" />
            <Grid Grid.Row="10"
                  Grid.RowSpan="4"
                  Grid.Column="1"
                  Grid.ColumnSpan="3"
                  VerticalAlignment="Top">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="10,0,10,0" Orientation="Horizontal">
                    <TextBlock Width="150"
                               VerticalAlignment="Center"
                               Style="{StaticResource VulpesXLabel}"
                               Text="Lotto"
                               Typography.Capitals="AllSmallCaps" />
                    <TextBlock Width="150"
                               Margin="5,0,15,2"
                               VerticalAlignment="Center"
                               Style="{StaticResource VulpesXLabel}"
                               Text="Q.tà disponibile"
                               TextAlignment="Right"
                               Typography.Capitals="AllSmallCaps" />
                    <TextBlock Width="150"
                               Margin="5,0,5,2"
                               VerticalAlignment="Center"
                               Style="{StaticResource VulpesXLabel}"
                               Text="Q.tà da impegnare"
                               TextAlignment="Right"
                               Typography.Capitals="AllSmallCaps" />
                    <TextBlock Width="150"
                               Margin="5,0,5,2"
                               VerticalAlignment="Center"
                               Style="{StaticResource VulpesXLabel}"
                               Text="Q.tà già impegnata"
                               TextAlignment="Right"
                               Typography.Capitals="AllSmallCaps" />
                </StackPanel>
                <telerik:RadListBox x:Name="rlbStocks"
                                    Grid.Row="1"
                                    Margin="10,5,10,5"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    BorderThickness="0"
                                    ItemsSource="{Binding AvailableStocks}"
                                    ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                    ScrollViewer.VerticalScrollBarVisibility="Visible">
                    <telerik:RadListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Height="30" Orientation="Horizontal">
                                <TextBlock Width="150" VerticalAlignment="Center" Text="{Binding Lot}" />
                                <TextBlock Width="150"
                                           Margin="5,2,15,2"
                                           VerticalAlignment="Center"
                                           Text="{Binding QuantityAvailable, StringFormat='{}{0,24:N6}'}"
                                           TextAlignment="Right" />
                                <telerik:RadNumericUpDown x:Name="rnuToEngage"
                                                          Width="150"
                                                          Margin="5,2,5,2"
                                                          VerticalAlignment="Center"
                                                          Minimum="0"
                                                          NumberDecimalDigits="6"
                                                          ShowButtons="False"
                                                          ValueChanged="rnuToEngage_ValueChanged"
                                                          Value="{Binding QuantityToEngage}" />
                                <TextBlock Width="150"
                                           Margin="5,2,15,2"
                                           VerticalAlignment="Center"
                                           Text="{Binding QuantityEngagedForOrder, StringFormat='{}{0,24:N6}'}"
                                           TextAlignment="Right" />
                            </StackPanel>
                        </DataTemplate>
                    </telerik:RadListBox.ItemTemplate>
                </telerik:RadListBox>
            </Grid>


        </Grid>
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="CONFERMA E PROCEDI"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
