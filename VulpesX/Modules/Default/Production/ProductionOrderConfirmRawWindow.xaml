<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Production.ProductionOrderConfirmRawWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Production"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Conferma materie prime"
                        Width="1000"
                        Height="700"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="None"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35" />
                <RowDefinition Height="2" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="5" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>
            <Grid.Resources>
                <selectors:LaunchRawListSelector x:Key="LaunchRawListSelector">
                    <selectors:LaunchRawListSelector.ReadyRowStyle>
                        <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                            <Setter Property="Foreground" Value="{DynamicResource VulpesXGreenBrush}" />
                            <Setter Property="ToolTip" Value="Materia prima totalmente disponibile" />
                        </Style>
                    </selectors:LaunchRawListSelector.ReadyRowStyle>
                    <selectors:LaunchRawListSelector.PartialRowStyle>
                        <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                            <Setter Property="Foreground" Value="{DynamicResource VulpesXYellowBrush}" />
                            <Setter Property="ToolTip" Value="Materia prima parzialmente disponibile" />
                        </Style>
                    </selectors:LaunchRawListSelector.PartialRowStyle>
                    <selectors:LaunchRawListSelector.MissingRowStyle>
                        <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                            <Setter Property="Foreground" Value="{DynamicResource VulpesXRedBrush}" />
                            <Setter Property="ToolTip" Value="Materia prima non disponibile" />
                        </Style>
                    </selectors:LaunchRawListSelector.MissingRowStyle>
                    <selectors:LaunchRawListSelector.AvailableRowStyle>
                        <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                            <Setter Property="Foreground" Value="{DynamicResource VulpesXVioletBrush}" />
                            <Setter Property="ToolTip" Value="Materia prima non disponibile" />
                        </Style>
                    </selectors:LaunchRawListSelector.AvailableRowStyle>
                </selectors:LaunchRawListSelector>
            </Grid.Resources>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Grid.ColumnSpan="4"
                       Margin="0,0,10,0"
                       HorizontalAlignment="Stretch"
                       Style="{StaticResource VulpesXTitle}"
                       Text="Conferma materie prime"
                       TextAlignment="Center"
                       Typography.Capitals="AllSmallCaps" />

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Ordine"
                       TextAlignment="Right" />
            <TextBlock Grid.Row="2"
                       Grid.Column="1"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding Order.ID}" />

            <TextBlock Grid.Row="2"
                       Grid.Column="2"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Data consegna"
                       TextAlignment="Right" />
            <TextBlock Grid.Row="2"
                       Grid.Column="3"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding Order.DataConsegna, StringFormat='dd/MM/yyyy'}" />

            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Cliente"
                       TextAlignment="Right" />
            <TextBlock Grid.Row="3"
                       Grid.Column="1"
                       Grid.ColumnSpan="3"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding Order.FullCustomerDescription}" />

            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Articolo"
                       TextAlignment="Right" />
            <TextBlock Grid.Row="4"
                       Grid.Column="1"
                       Grid.ColumnSpan="3"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding Order.FullProductDescription}" />

            <TextBlock Grid.Row="5"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Revisione"
                       TextAlignment="Right" />
            <TextBlock Grid.Row="5"
                       Grid.Column="1"
                       Grid.ColumnSpan="3"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding Order.RevisioneID}" />

            <TextBlock Grid.Row="6"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Quantita' confermata"
                       TextAlignment="Right" />
            <StackPanel Grid.Row="6"
                        Grid.Column="1"
                        Grid.ColumnSpan="3"
                        Orientation="Horizontal">
                <TextBlock Style="{StaticResource VulpesXData}" Text="{Binding Order.Quantita, StringFormat=N6}" />
                <TextBlock Style="{StaticResource VulpesXData}" Text="{Binding Order.UM}" />
            </StackPanel>

            <TextBlock Grid.Row="7"
                       Grid.Column="0"
                       Grid.ColumnSpan="4"
                       Margin="0,0,10,0"
                       HorizontalAlignment="Stretch"
                       Style="{StaticResource VulpesXSubtitle}"
                       Text="Materie prime necessarie"
                       TextAlignment="Center"
                       Typography.Capitals="AllSmallCaps" />

            <telerik:RadGridView x:Name="rgvRaws"
                                 Grid.Row="9"
                                 Grid.Column="0"
                                 Grid.ColumnSpan="4"
                                 Margin="10,5,10,5"
                                 AutoGenerateColumns="False"
                                 CanUserDeleteRows="False"
                                 CanUserFreezeColumns="False"
                                 CanUserInsertRows="False"
                                 ColumnAggregatesAlignment="NextToGroupKey"
                                 IsSearchingDeferred="True"
                                 IsSynchronizedWithCurrentItem="False"
                                 ItemsSource="{Binding RawsList}"
                                 RowIndicatorVisibility="Collapsed"
                                 RowStyleSelector="{StaticResource LaunchRawListSelector}"
                                 ShowGroupFooters="True"
                                 ShowGroupPanel="False"
                                 ShowSearchPanel="False">
                <telerik:RadGridView.ChildTableDefinitions>
                    <telerik:GridViewTableDefinition>
                        <telerik:GridViewTableDefinition.Relation>
                            <telerik:PropertyRelation />
                        </telerik:GridViewTableDefinition.Relation>
                    </telerik:GridViewTableDefinition>
                </telerik:RadGridView.ChildTableDefinitions>
                <telerik:RadGridView.HierarchyChildTemplate>
                    <DataTemplate>
                        <telerik:RadGridView Margin="30,0,10,0"
                                             AutoGenerateColumns="False"
                                             ItemsSource="{Binding Availabilities, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             RowEditEnded="RadGridView_RowEditEnded"
                                             RowIndicatorVisibility="Collapsed"
                                             RowValidating="RadGridView_RowValidating"
                                             ShowGroupPanel="False">
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewDataColumn Width="170"
                                                            DataMemberBinding="{Binding Lot}"
                                                            Header="Lotto"
                                                            IsReadOnly="True" />
                                <telerik:GridViewDataColumn Width="120"
                                                            DataMemberBinding="{Binding Ubication}"
                                                            Header="Ubicazione"
                                                            HeaderTextAlignment="Center"
                                                            IsReadOnly="True"
                                                            TextAlignment="Center" />
                                <telerik:GridViewDataColumn Width="120"
                                                            DataMemberBinding="{Binding Expire, StringFormat='dd/MM/yyyy'}"
                                                            Header="Scadenza"
                                                            HeaderTextAlignment="Center"
                                                            IsReadOnly="True"
                                                            TextAlignment="Center" />
                                <telerik:GridViewDataColumn Width="270"
                                                            DataFormatString="N6"
                                                            DataMemberBinding="{Binding QuantityAvailableDisplay}"
                                                            Header="Quantità disponibile"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn Width="160"
                                                            DataFormatString="N6"
                                                            DataMemberBinding="{Binding QuantityToEngage}"
                                                            Header="Quantità da impegnare"
                                                            HeaderTextAlignment="Right"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn Width="160"
                                                            DataFormatString="N6"
                                                            DataMemberBinding="{Binding QuantityEngagedForOrder}"
                                                            Header="Q.tà già impegnata"
                                                            HeaderTextAlignment="Right"
                                                            IsReadOnly="True"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn Width="355"
                                                            DataMemberBinding="{Binding StoreFullDescriptionSearchable}"
                                                            Header="Magazzino"
                                                            IsReadOnly="True" />
                            </telerik:RadGridView.Columns>
                        </telerik:RadGridView>
                    </DataTemplate>
                </telerik:RadGridView.HierarchyChildTemplate>
                <telerik:RadGridView.Columns>
                    <telerik:GridViewDataColumn Width="400"
                                                DataMemberBinding="{Binding ComponenteArticoloDescrizione}"
                                                Header="Articolo"
                                                IsReadOnly="True" />
                    <telerik:GridViewDataColumn Width="150"
                                                DataMemberBinding="{Binding Quantita, StringFormat=N6}"
                                                Header="Q.ta' necessaria"
                                                HeaderTextAlignment="Right"
                                                IsReadOnly="True"
                                                TextAlignment="Right" />
                    <telerik:GridViewDataColumn Width="150"
                                                DataMemberBinding="{Binding QuantitaImpegnata, StringFormat=N6}"
                                                Header="Q.ta' da impegnare"
                                                HeaderTextAlignment="Right"
                                                IsReadOnly="True"
                                                TextAlignment="Right" />
                    <telerik:GridViewDataColumn Width="150"
                                                DataMemberBinding="{Binding QuantitaGiaImpegnata, StringFormat=N6}"
                                                Header="Q.ta' gia' impegnata"
                                                HeaderTextAlignment="Right"
                                                IsReadOnly="True"
                                                TextAlignment="Right" />
                </telerik:RadGridView.Columns>
            </telerik:RadGridView>

        </Grid>
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="CONFERMA E PROCEDI"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>

</sc:FluentDefaultWindow>
