<UserControl x:Class="VulpesX.Modules.Default.Production.GanttView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VulpesX.Shared.Controls.Converters;assembly=VulpesX.Shared.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:gantt="clr-namespace:VulpesX.Shared.Controls.Gantt;assembly=VulpesX.Shared.Controls"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Production"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:production="clr-namespace:VulpesX.Modules.Default.Production"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BoolToColorConverter x:Key="booleanColorConverter" FalseColor="{StaticResource VulpesXGreenBrush}" TrueColor="{StaticResource VulpesXRedBrush}" />
        <converters:LongToTimeSpanConverter x:Key="longToTimeSpanStringConverter" />
        <converters:TempoIDDescrizioneConverter x:Key="tempoIDDescrizioneConverter" />
        <converters:TempoIDColoreConverter x:Key="tempoIDColoreConverter"
                                           EndColor="{StaticResource VulpesXRedBrush}"
                                           NeutralColor="{StaticResource VulpesXBlueBrush}"
                                           StartColor="{StaticResource VulpesXGreenBrush}"
                                           StopColor="{StaticResource VulpesXYellowBrush}" />

        <Style TargetType="gantt:BaselineContainer">
            <Setter Property="telerik:ZIndexManager.ZIndex" Value="100" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="ToolTipService.ToolTip" Value="{Binding ToolTip}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Border Height="10" BorderBrush="Red" BorderThickness="1">
                            <Rectangle>
                                <Rectangle.Fill>
                                    <LinearGradientBrush Opacity="0.3" SpreadMethod="Reflect" StartPoint="0 0" EndPoint="0 0.1">
                                        <LinearGradientBrush.Transform>
                                            <RotateTransform Angle="-45" />
                                        </LinearGradientBrush.Transform>
                                        <GradientStop Offset="0.5" Color="OrangeRed" />
                                        <GradientStop Offset="0.5" Color="Red" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="gantt:BaselineContainerTime">
            <Setter Property="telerik:ZIndexManager.ZIndex" Value="100" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Height" Value="17" />
            <Setter Property="ToolTipService.ToolTip" Value="{Binding ToolTip}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Grid Background="Green">
                            <TextBlock Grid.Row="1"
                                       FontSize="10"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="{Binding Description}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style BasedOn="{StaticResource EventContainerStyle}" TargetType="telerik:EventContainer">
            <Setter Property="telerik:DragDropManager.AllowDrag" Value="True" />
            <Setter Property="Background" Value="{Binding OriginalEvent.UltimoTempoTipoID, Converter={StaticResource tempoIDColoreConverter}}" />
            <Setter Property="BorderBrush" Value="{x:Null}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="MinHeight" Value="17" />
            <Setter Property="Padding" Value="5,0" />
            <Setter Property="telerik:ZIndexManager.ZIndex" Value="101" />
            <Setter Property="Foreground" Value="{DynamicResource MainBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="telerik:EventContainer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <telerik:ToolTipManager.ToolTip>
                                <ToolTip>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Start}" TextTrimming="None" TextWrapping="NoWrap" />
                                    </StackPanel>
                                </ToolTip>
                            </telerik:ToolTipManager.ToolTip>

                            <Rectangle x:Name="Background"
                                       Fill="{TemplateBinding Background}"
                                       Opacity="0.8"
                                       Stroke="{TemplateBinding BorderBrush}"
                                       StrokeThickness="{TemplateBinding BorderThickness}" />

                            <Rectangle x:Name="CommonStatesVisual"
                                       Fill="{TemplateBinding BorderBrush}"
                                       Opacity="0.9"
                                       Stroke="{TemplateBinding BorderBrush}"
                                       StrokeThickness="{TemplateBinding BorderThickness}"
                                       Visibility="Collapsed" />

                            <Rectangle x:Name="HighlightVisual"
                                       Fill="White"
                                       Stroke="{TemplateBinding BorderBrush}"
                                       StrokeThickness="{TemplateBinding BorderThickness}"
                                       Visibility="Collapsed" />

                            <Rectangle x:Name="MouseOverVisual"
                                       Grid.Column="1"
                                       Fill="{DynamicResource MainBrush}"
                                       Opacity="0.4"
                                       Stroke="{TemplateBinding BorderBrush}"
                                       StrokeThickness="{TemplateBinding BorderThickness}"
                                       Visibility="Collapsed" />

                            <Rectangle x:Name="MouseOverHighlightedVisual"
                                       Fill="{DynamicResource MainBrush}"
                                       Opacity="0.4"
                                       Stroke="{TemplateBinding BorderBrush}"
                                       StrokeThickness="{TemplateBinding BorderThickness}"
                                       Visibility="Collapsed" />

                            <Grid Grid.Column="0" Margin="{TemplateBinding Padding}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="txtBlock" Text="{Binding Title}" />
                                <telerik:ProgressPresenter Grid.Row="1"
                                                           Height="2"
                                                           Margin="0,0,0,2"
                                                           HorizontalAlignment="Stretch"
                                                           Orientation="Horizontal"
                                                           Progress="{Binding Progress}">
                                    <Rectangle HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               Fill="{DynamicResource MainBrush}"
                                               Opacity="0.7" />
                                </telerik:ProgressPresenter>
                            </Grid>

                            <Path Grid.Column="1"
                                  MaxWidth="14"
                                  MaxHeight="14"
                                  Margin="13,0,-40,0"
                                  HorizontalAlignment="Left"
                                  Data="M14.4,6L14,4H5V21H7V14H12.6L13,16H20V6H14.4Z"
                                  Fill="{Binding OriginalEvent.ERitardo, Converter={StaticResource booleanColorConverter}}"
                                  Stretch="Fill">
                                <telerik:ToolTipManager.ToolTip>
                                    <ToolTip Background="Transparent"
                                             BorderThickness="0"
                                             HorizontalOffset="-4"
                                             Placement="Top"
                                             VerticalOffset="1">
                                        <StackPanel Height="25" Orientation="Vertical">
                                            <StackPanel VerticalAlignment="Center" Background="{Binding OriginalEvent.ERitardo, Converter={StaticResource booleanColorConverter}}">
                                                <TextBlock Margin="3,0"
                                                           Foreground="{DynamicResource MainBrush}"
                                                           Text="{Binding OriginalEvent.ToolTipText}"
                                                           TextTrimming="None"
                                                           TextWrapping="NoWrap" />
                                            </StackPanel>
                                            <Path Width="5"
                                                  Height="5"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Bottom"
                                                  Data="M0,0 L4,0 L4,4 z"
                                                  Fill="{DynamicResource DeadlineBrush}"
                                                  RenderTransformOrigin="0.5,0.5"
                                                  Stretch="Fill">
                                                <Path.RenderTransform>
                                                    <RotateTransform Angle="275" />
                                                </Path.RenderTransform>
                                            </Path>
                                        </StackPanel>
                                    </ToolTip>
                                </telerik:ToolTipManager.ToolTip>
                            </Path>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="MouseOverVisual" Storyboard.TargetProperty="Visibility" Duration="0:0:0">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Visible</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled" />
                                    <VisualState x:Name="MouseOverHighlighted">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="MouseOverHighlightedVisual" Storyboard.TargetProperty="Visibility" Duration="0:0:0">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Visible</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="SelectionStates">
                                    <VisualState x:Name="Unselected" />
                                    <VisualState x:Name="Selected">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CommonStatesVisual" Storyboard.TargetProperty="Visibility" Duration="0:0:0">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Visible</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="FocusStates">
                                    <VisualState x:Name="Focused" />
                                    <VisualState x:Name="Unfocused" />
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="HighlightStates">
                                    <VisualState x:Name="NotHighlighted" />
                                    <VisualState x:Name="Highlighted">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HighlightVisual" Storyboard.TargetProperty="Visibility" Duration="0:0:0">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Visible</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>

                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="gantt:TimeLineDeadlineContainer">
            <Setter Property="telerik:ZIndexManager.ZIndex" Value="100" />
            <Setter Property="Margin" Value="0,0,-4,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="gantt:TimeLineDeadlineContainer">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="3" Height="24" Margin="0,0,-1,0">
                                <Rectangle Width="2"
                                           Height="22"
                                           Margin="0,1,0,1"
                                           Fill="{DynamicResource GXRedBrush}" />
                                <Path Height="3"
                                      VerticalAlignment="Top"
                                      Data="M4,2 C4,3.1045694 3.1045694,4 2,4 C0.89543051,4 0,3.1045694 0,2 C0,0.89543051 0.89543051,0 2,0 C3.1045694,0 4,0.89543051 4,2 z"
                                      Fill="{DynamicResource GXRedBrush}"
                                      Stretch="Fill" />
                                <Path Height="3"
                                      VerticalAlignment="Bottom"
                                      Data="M4,2 C4,3.1045694 3.1045694,4 2,4 C0.89543051,4 0,3.1045694 0,2 C0,0.89543051 0.89543051,0 2,0 C3.1045694,0 4,0.89543051 4,2 z"
                                      Fill="{DynamicResource GXRedBrush}"
                                      Stretch="Fill" />
                            </Grid>
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ordineTooltipTemplate">
            <Grid Width="400">
                <Border Background="{DynamicResource VulpesXFirstBrush}"
                        BorderBrush="{DynamicResource VulpesXOrangeBrush}"
                        BorderThickness="2"
                        UseLayoutRounding="True">
                    <StackPanel Orientation="Vertical">
                        <DockPanel>
                            <TextBlock Width="200" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Cliente" />
                            <TextBlock Foreground="{DynamicResource VulpesXSecondBrush}" Text="{Binding UltimaComposizione.ClienteDescrizione}" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Width="200" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Articolo" />
                            <TextBlock Foreground="{DynamicResource VulpesXSecondBrush}" Text="{Binding UltimaComposizione.ArticoloDescrizione}" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Width="200" Foreground="{DynamicResource VulpesXSecondBrush}" Text="Quantita" />
                            <TextBlock Foreground="{DynamicResource VulpesXSecondBrush}" Text="{Binding UltimaComposizione.QuantitaOrdine}" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Width="200" Foreground="{DynamicResource VulpesXSecondBrush}" Text="DataConsegna" />
                            <TextBlock Foreground="{DynamicResource VulpesXSecondBrush}" Text="{Binding UltimaComposizione.DataConsegna}" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Width="200" Foreground="{DynamicResource VulpesXSecondBrush}" Text="TempoUtilizzato" />
                            <TextBlock Foreground="{DynamicResource VulpesXSecondBrush}" Text="{Binding UltimaComposizione.TempoUtilizzato, Converter={StaticResource longToTimeSpanStringConverter}}" />
                        </DockPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <telerik:RadTabControl x:Name="rtcMain" Align="Justify" TabStripPlacement="Left">
        <telerik:RadTabItem x:Name="rtiWorks" Height="25" Header="Ordini">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20*" />
                        <ColumnDefinition Width="50*" />
                        <ColumnDefinition Width="30*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,5,0"
                            BorderBrush="{DynamicResource VulpesXBlueBrush}"
                            BorderThickness="0,0,0,2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="18" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                                <TextBlock Margin="5,0,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource VulpesXLightBrush}"
                                           Text="Ricerca" />
                            </Grid>
                            <DockPanel Grid.Row="1" LastChildFill="True">
                                <telerik:RadButton Name="btnSearchDown"
                                                   Margin="5,10,0,10"
                                                   Click="btnSearchDown_Click"
                                                   DockPanel.Dock="Right"
                                                   Style="{StaticResource VulpesXGridButton}"
                                                   ToolTip="Prossimo">
                                    <telerik:RadButton.Content>
                                        <Path Data="{DynamicResource DownPath}" Fill="{DynamicResource VulpesXSecondBrush}" Stretch="Uniform" />
                                    </telerik:RadButton.Content>
                                </telerik:RadButton>
                                <telerik:RadButton Name="btnSearchUp"
                                                   Margin="5,10,0,10"
                                                   Click="btnSearchUp_Click"
                                                   DockPanel.Dock="Right"
                                                   Style="{StaticResource VulpesXGridButton}"
                                                   ToolTip="Precedente">
                                    <telerik:RadButton.Content>
                                        <Path Data="{DynamicResource UpPath}" Fill="{DynamicResource VulpesXSecondBrush}" Stretch="Uniform" />
                                    </telerik:RadButton.Content>
                                </telerik:RadButton>

                                <telerik:RadWatermarkTextBox Name="rwtSearch"
                                                             Grid.Row="1"
                                                             Height="30"
                                                             Margin="0,10,0,10"
                                                             HorizontalAlignment="Stretch"
                                                             VerticalAlignment="Top"
                                                             Background="Transparent"
                                                             BorderBrush="{DynamicResource VulpesXBlueBrush}"
                                                             CaretBrush="White"
                                                             IsEnabled="{Binding IsEnabledLoading}"
                                                             SelectionOpacity="0.8"
                                                             TextChanged="rwtSearch_TextChanged"
                                                             WatermarkContent="Cerca" />
                            </DockPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Margin="0,0,5,0"
                            BorderBrush="{DynamicResource VulpesXBlueBrush}"
                            BorderThickness="0,0,0,2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="18" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                                <TextBlock Margin="5,0,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource VulpesXLightBrush}"
                                           Text="Visualizzazione" />
                            </Grid>

                            <StackPanel Grid.Row="1" HorizontalAlignment="Left" Orientation="Horizontal">
                                <telerik:RadDatePicker Margin="0,10,5,10"
                                                       IsEnabled="{Binding IsEnabledLoading}"
                                                       SelectedValue="{Binding VisibleStartTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       ToolTip="Dal" />
                                <telerik:RadDatePicker Margin="0,10,5,10"
                                                       IsEnabled="{Binding IsEnabledLoading}"
                                                       SelectedValue="{Binding VisibleEndTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       ToolTip="Al" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" HorizontalAlignment="Right" Orientation="Horizontal">
                                <telerik:RadSlider x:Name="zoomSlider"
                                                   Width="200"
                                                   Height="30"
                                                   Margin="0,12,5,10"
                                                   IsEnabled="{Binding IsEnabledLoading}"
                                                   Maximum="30000000000"
                                                   Minimum="10000010"
                                                   ToolTip="Gantt zoom"
                                                   ValueChanged="zoomSlider_ValueChanged"
                                                   Value="15000000000" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Margin="0,0,5,0"
                            BorderBrush="{DynamicResource VulpesXBlueBrush}"
                            BorderThickness="0,0,0,2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="18" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Background="{DynamicResource VulpesXBlueBrush}">
                                <TextBlock Margin="5,0,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource VulpesXLightBrush}"
                                           Text="Dati" />
                            </Grid>
                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <telerik:RadButton Name="btnRefresh"
                                                   Margin="0,10,5,10"
                                                   Click="btnRefresh_Click"
                                                   IsEnabled="{Binding IsEnabledLoading}"
                                                   Style="{StaticResource VulpesXGridButton}"
                                                   ToolTip="Aggiorna">
                                    <telerik:RadButton.Content>
                                        <Path Data="{DynamicResource RefreshPath}" Fill="{DynamicResource VulpesXSecondBrush}" Stretch="Uniform" />
                                    </telerik:RadButton.Content>
                                </telerik:RadButton>
                                <telerik:RadButton x:Name="btnExpandAll"
                                                   Margin="0,10,5,10"
                                                   Click="btnExpandAll_Click"
                                                   IsEnabled="{Binding IsEnabledLoading}"
                                                   Style="{StaticResource VulpesXGridButton}"
                                                   ToolTip="Espandi">
                                    <telerik:RadButton.Content>
                                        <Path Data="{DynamicResource ExpandPath}" Fill="{DynamicResource VulpesXSecondBrush}" Stretch="Uniform" />
                                    </telerik:RadButton.Content>
                                </telerik:RadButton>
                                <telerik:RadButton x:Name="btnCollapseAll"
                                                   Margin="0,10,5,10"
                                                   Click="btnCollapseAll_Click"
                                                   IsEnabled="{Binding IsEnabledLoading}"
                                                   Style="{StaticResource VulpesXGridButton}"
                                                   ToolTip="Collassa">
                                    <telerik:RadButton.Content>
                                        <Path Data="{DynamicResource CollapsePath}" Fill="{DynamicResource VulpesXSecondBrush}" Stretch="Uniform" />
                                    </telerik:RadButton.Content>
                                </telerik:RadButton>

                                <telerik:RadButton x:Name="btnRecalculate"
                                                   Margin="0,10,5,10"
                                                   Click="btnRecalculate_Click"
                                                   IsEnabled="{Binding IsEnabledLoading}"
                                                   Style="{StaticResource VulpesXGridButton}"
                                                   ToolTip="Ricalcola">
                                    <telerik:RadButton.Content>
                                        <Path Data="{DynamicResource CollapsePath}" Fill="{DynamicResource VulpesXSecondBrush}" Stretch="Uniform" />
                                    </telerik:RadButton.Content>
                                </telerik:RadButton>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <telerik:RadGanttView Name="rgvOrders"
                                      Grid.Row="1"
                                      gantt:CustomDragDropBehavior.IsEnabled="True"
                                      gantt:CustomDragDropBehavior.TaskResources="{Binding TasksResources}"
                                      gantt:GanttExpanderHelper.IsEnabled="True"
                                      MouseRightButtonDown="rgvOrders_MouseRightButtonDown"
                                      PixelLength="{Binding PixelLength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedItem="{Binding SelectedTask, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      TimeLineVisualizationBehavior="{Binding TimeLineBaselineBehavior}"
                                      Visibility="{Binding IsVisible}"
                                      VisibleRange="{Binding VisibleTime}">
                    <telerik:RadGanttView.Resources>
                        <converters:TempoIDColoreConverter x:Key="statoIDColoreConverter"
                                                           EndColor="{StaticResource VulpesXRedBrush}"
                                                           NeutralColor="{StaticResource VulpesXBlueBrush}"
                                                           StartColor="{StaticResource VulpesXGreenBrush}"
                                                           StopColor="{StaticResource VulpesXYellowBrush}" />
                    </telerik:RadGanttView.Resources>
                    <telerik:RadGanttView.Columns>
                        <telerik:TreeColumnDefinition Width="300" Header="Descrizione" MemberBinding="{Binding Data.Description}" />
                        <telerik:ColumnDefinition Width="20" Header="" MemberBinding="{Binding Data.UltimoTempoTipoID}">
                            <telerik:ColumnDefinition.CellTemplate>
                                <DataTemplate>
                                    <Border Width="10"
                                            Height="10"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{Binding Data.FormattedValue, Converter={StaticResource statoIDColoreConverter}}"
                                            CornerRadius="10" />
                                </DataTemplate>
                            </telerik:ColumnDefinition.CellTemplate>
                        </telerik:ColumnDefinition>

                        <telerik:ColumnDefinition Width="140" Header="Consegna" MemberBinding="{Binding Data.DataConsegna}" />
                        <telerik:ColumnDefinition Width="140" Header="Inizio" MemberBinding="{Binding Data.Start}" />
                        <telerik:ColumnDefinition Width="140" Header="Fine" MemberBinding="{Binding Data.End}" />
                        <telerik:ColumnDefinition Width="140" Header="Durata" MemberBinding="{Binding Data.Duration}" />
                        <telerik:ColumnDefinition Width="140" Header="Effettiva" MemberBinding="{Binding Data.EffectiveDuration}" />
                    </telerik:RadGanttView.Columns>
                    <telerik:RadGanttView.TimelineContainerSelector>
                        <gantt:TimeLineBaselineContainerSelector />
                    </telerik:RadGanttView.TimelineContainerSelector>
                    <telerik:RadRadialMenu.RadialContextMenu>
                        <telerik:RadRadialMenu Name="rgvRadialMenu"
                                               HideEventName="LostFocus"
                                               InnerRadiusFactor="0.40"
                                               PopupPlacement="Relative"
                                               ShowToolTip="True"
                                               StartAngle="-40"
                                               StaysOpenOnShow="True">
                            <telerik:RadRadialMenuItem Name="btnEdit" ContentSectorBackground="{DynamicResource VulpesXYellowBrush}" ToolTip="F2">
                                <telerik:RadRadialMenuItem.IconContent>
                                    <Path Data="{DynamicResource EditPath}" Fill="{DynamicResource VulpesXSecondBrush}" Stretch="Fill" />
                                </telerik:RadRadialMenuItem.IconContent>
                            </telerik:RadRadialMenuItem>
                            <telerik:RadRadialMenuItem Name="btnComposition" ContentSectorBackground="{DynamicResource VulpesXBlueBrush}" ToolTip="F2">
                                <telerik:RadRadialMenuItem.IconContent>
                                    <Path Data="{DynamicResource CompositionPath}" Fill="{DynamicResource VulpesXSecondBrush}" Stretch="Fill" />
                                </telerik:RadRadialMenuItem.IconContent>
                            </telerik:RadRadialMenuItem>
                        </telerik:RadRadialMenu>
                    </telerik:RadRadialMenu.RadialContextMenu>
                </telerik:RadGanttView>
                <telerik:RadBusyIndicator Grid.Row="1" BusyContent="Caricamento" IsBusy="{Binding IsBusy}" />
            </Grid>
        </telerik:RadTabItem>
        <telerik:RadTabItem x:Name="rtiResources" Height="25" Header="Risorse">
            <Grid>
                <telerik:RadDocking x:Name="Docking" BorderThickness="0">
                    <telerik:RadDocking.DocumentHost>
                        <telerik:RadSplitContainer>
                            <telerik:RadPaneGroup x:Name="DocumentGroup">
                                <telerik:RadPane x:Name="LayoutXml"
                                                 telerik:RadDocking.FloatingSize="450, 400"
                                                 telerik:RadDocking.SerializationTag="LayoutXml"
                                                 CanUserClose="False"
                                                 Header="Gantt">
                                    <Grid>
                                        <ItemsControl x:Name="itmRisorseGantt"
                                                      ItemsSource="{Binding RisorseGantt}"
                                                      ScrollViewer.CanContentScroll="True"
                                                      VirtualizingStackPanel.IsVirtualizing="True">
                                            <ItemsControl.Template>
                                                <ControlTemplate>
                                                    <Border Padding="{TemplateBinding Control.Padding}"
                                                            Background="{TemplateBinding Panel.Background}"
                                                            BorderBrush="{TemplateBinding Border.BorderBrush}"
                                                            BorderThickness="{TemplateBinding Border.BorderThickness}"
                                                            SnapsToDevicePixels="True">
                                                        <ScrollViewer Padding="{TemplateBinding Control.Padding}" Focusable="False" HorizontalScrollBarVisibility="Disabled">
                                                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" />
                                                        </ScrollViewer>
                                                    </Border>
                                                </ControlTemplate>
                                            </ItemsControl.Template>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Top" Orientation="Vertical" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <production:GanttSingleView />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </telerik:RadPane>
                            </telerik:RadPaneGroup>
                        </telerik:RadSplitContainer>
                    </telerik:RadDocking.DocumentHost>
                    <telerik:RadSplitContainer Width="500" InitialPosition="DockedRight">
                        <telerik:RadPaneGroup>
                            <telerik:RadPane telerik:RadDocking.SerializationTag="PaneRight1" CanUserClose="False" Header="Risorse">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="34" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <telerik:RadWatermarkTextBox Name="rwtSearchResource"
                                                                 Grid.Row="0"
                                                                 Height="30"
                                                                 Margin="2"
                                                                 HorizontalAlignment="Stretch"
                                                                 VerticalAlignment="Top"
                                                                 Background="Transparent"
                                                                 BorderBrush="{DynamicResource VulpesXBlueBrush}"
                                                                 CaretBrush="White"
                                                                 SelectionOpacity="0.8"
                                                                 TextChanged="rwtSearchResource_TextChanged"
                                                                 WatermarkContent="Cerca" />

                                    <ItemsControl x:Name="itmRisorse"
                                                  Grid.Row="1"
                                                  ItemsSource="{Binding Risorse}"
                                                  ScrollViewer.CanContentScroll="False"
                                                  VirtualizingStackPanel.IsVirtualizing="True">
                                        <ItemsControl.Template>
                                            <ControlTemplate>
                                                <Border Padding="{TemplateBinding Control.Padding}"
                                                        Background="{TemplateBinding Panel.Background}"
                                                        BorderBrush="{TemplateBinding Border.BorderBrush}"
                                                        BorderThickness="{TemplateBinding Border.BorderThickness}"
                                                        SnapsToDevicePixels="True">
                                                    <ScrollViewer Padding="{TemplateBinding Control.Padding}" Focusable="False" HorizontalScrollBarVisibility="Auto">
                                                        <ItemsPresenter SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" />
                                                    </ScrollViewer>
                                                </Border>
                                            </ControlTemplate>
                                        </ItemsControl.Template>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Orientation="Vertical" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,2"
                                                        HorizontalAlignment="Stretch"
                                                        BorderBrush="{Binding UltimaComposizione.UltimoTempoTipoID, Converter={StaticResource tempoIDColoreConverter}, FallbackValue={StaticResource VulpesXRedBrush}}"
                                                        BorderThickness="2">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="30" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <DockPanel Grid.Row="0">
                                                            <TextBlock Width="300"
                                                                       VerticalAlignment="Top"
                                                                       Background="{Binding UltimaComposizione.UltimoTempoTipoID, Converter={StaticResource tempoIDColoreConverter}, FallbackValue={StaticResource VulpesXRedBrush}}"
                                                                       Tag="{Binding ID}"
                                                                       Text="{Binding Descrizione}" />
                                                            <telerik:RadToggleSwitchButton Name="chkRisorsa"
                                                                                           HorizontalAlignment="Right"
                                                                                           Checked="chkRisorsa_Checked"
                                                                                           IsChecked="{Binding EGanttAperto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                           Unchecked="chkRisorsa_Unchecked" />
                                                        </DockPanel>

                                                        <StackPanel Grid.Row="1" Margin="5" Orientation="Vertical">
                                                            <DockPanel>
                                                                <TextBlock Width="100" Text="Commessa" />
                                                                <TextBlock FontWeight="Bold" Text="{Binding UltimaComposizione.OrdineID}" />
                                                                <Path Width="12"
                                                                      Height="12"
                                                                      HorizontalAlignment="Right"
                                                                      telerik:RadToolTipService.Placement="Right"
                                                                      telerik:RadToolTipService.PlacementRectangle="20 20 0 0"
                                                                      telerik:RadToolTipService.ShowDuration="20000"
                                                                      telerik:RadToolTipService.ToolTipContent="{Binding}"
                                                                      telerik:RadToolTipService.ToolTipContentTemplate="{StaticResource ordineTooltipTemplate}"
                                                                      Data="{DynamicResource InfoPath}"
                                                                      Fill="{DynamicResource VulpesXSecondBrush}"
                                                                      Stretch="Fill" />
                                                            </DockPanel>
                                                            <DockPanel>
                                                                <TextBlock Width="100" Text="Composizione" />
                                                                <TextBlock HorizontalAlignment="Right" FontWeight="Bold" Text="{Binding UltimaComposizione.ComponenteDescrizione}" />
                                                            </DockPanel>
                                                            <DockPanel>
                                                                <TextBlock Width="100" Text="Reparto" />
                                                                <TextBlock HorizontalAlignment="Right" FontWeight="Bold" Text="{Binding UltimaComposizione.RepartoDescrizione}" />
                                                            </DockPanel>
                                                            <DockPanel LastChildFill="True">
                                                                <TextBlock Width="100" Text="UltimoTempo" />
                                                                <TextBlock HorizontalAlignment="Right"
                                                                           DockPanel.Dock="Right"
                                                                           FontWeight="Bold"
                                                                           Text="{Binding UltimaComposizione.UltimoTempoData}" />
                                                                <TextBlock DockPanel.Dock="Right" Text=" - " />
                                                                <TextBlock HorizontalAlignment="Right"
                                                                           DockPanel.Dock="Right"
                                                                           FontWeight="Bold"
                                                                           Text="{Binding UltimaComposizione.UltimoTempoTipoID, Converter={StaticResource tempoIDDescrizioneConverter}}" />
                                                            </DockPanel>
                                                            <DockPanel>
                                                                <TextBlock Width="100" Text="Progresso" />
                                                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                                                    <telerik:RadProgressBar Margin="0,0,5,0" Minimum="0" Value="{Binding UltimaComposizione.TempoPercentuale}" />
                                                                    <TextBlock FontWeight="Bold" Text="{Binding UltimaComposizione.TempoPercentuale, StringFormat=N2}" />
                                                                    <TextBlock Margin="5,0,0,0" Text="%" />
                                                                </StackPanel>
                                                            </DockPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <telerik:RadBusyIndicator Grid.Row="1" BusyContent="Caricamento" IsBusy="{Binding IsBusyComponenti}" />
                                </Grid>
                            </telerik:RadPane>
                        </telerik:RadPaneGroup>
                    </telerik:RadSplitContainer>
                </telerik:RadDocking>
            </Grid>
        </telerik:RadTabItem>
    </telerik:RadTabControl>
</UserControl>
