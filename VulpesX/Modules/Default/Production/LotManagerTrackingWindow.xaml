<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Production.LotManagerTrackingWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Production"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Tracciamento lotto"
                        Width="600"
                        Height="270"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="SingleBorderWindow"
                        mc:Ignorable="d">
    <Grid>
        <Grid.Resources>
            <!--  lot  -->
            <ControlTemplate x:Key="StandardContentTemplate">
                <Grid Margin="5">

                    <StackPanel Panel.ZIndex="0" Orientation="Vertical">

                        <Grid Width="350" Margin="-5,0,-5,-5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="25" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5*" />
                                <ColumnDefinition Width="5*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="5,0,0,0"
                                       VerticalAlignment="Top"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{Binding MainBrush, Converter={StaticResource stringToColorConverter}}"
                                       Text="{Binding TypeDescription}"
                                       TextAlignment="Left"
                                       Typography.Capitals="AllSmallCaps" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Margin="0,0,5,0"
                                       VerticalAlignment="Top"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{Binding MainBrush, Converter={StaticResource stringToColorConverter}}"
                                       Text="{Binding Lot}"
                                       TextAlignment="Right"
                                       Typography.Capitals="AllSmallCaps" />

                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical">
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="MediumVioletRed"
                                           Text="Creato il"
                                           TextAlignment="Left" />
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="White"
                                           Text="{Binding CreatedText}"
                                           TextAlignment="Left" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical">
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="MediumVioletRed"
                                           Text="Operatore"
                                           TextAlignment="Left" />
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="White"
                                           Text="{Binding OperatorDescription}"
                                           TextAlignment="Left" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Vertical">
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="MediumVioletRed"
                                           Text="Risorsa"
                                           TextAlignment="Left" />
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="White"
                                           Text="{Binding ResourceDescription}"
                                           TextAlignment="Left" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Vertical">
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="MediumVioletRed"
                                           Text="Durata"
                                           TextAlignment="Left" />
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="White"
                                           Text="{Binding DurationText}"
                                           TextAlignment="Left" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </ControlTemplate>
            <Style x:Key="LotShape" BasedOn="{StaticResource RadDiagramShapeStyle}" TargetType="telerik:RadDiagramShape">
                <Setter Property="Position" Value="{Binding Position, Mode=TwoWay}" />
                <Setter Property="Visibility" Value="{Binding Visibility, Mode=TwoWay}" />
                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Opacity" Value="1" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="telerik:RadDiagramShape">
                            <Border Height="Auto"
                                    MinWidth="200"
                                    Padding="0"
                                    BorderBrush="{Binding MainBrush, Converter={StaticResource stringToColorConverter}}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ContentControl}, Path=DataContext}">
                                <Grid>
                                    <ContentControl Template="{StaticResource StandardContentTemplate}" />
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!--  production order launch history  -->
            <ControlTemplate x:Key="HistoryContentTemplate">
                <Grid Margin="5">

                    <StackPanel Panel.ZIndex="0" Orientation="Vertical">

                        <Grid Width="350" Margin="-5,0,-5,-5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="25" />
                                <RowDefinition Height="30" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5*" />
                                <ColumnDefinition Width="5*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="5,0,0,0"
                                       VerticalAlignment="Top"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{Binding MainBrush, Converter={StaticResource stringToColorConverter}}"
                                       Text="{Binding TypeDescription}"
                                       TextAlignment="Left"
                                       Typography.Capitals="AllSmallCaps" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Margin="0,0,5,0"
                                       VerticalAlignment="Top"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{Binding MainBrush, Converter={StaticResource stringToColorConverter}}"
                                       Text="{Binding Lot}"
                                       TextAlignment="Right"
                                       Typography.Capitals="AllSmallCaps" />

                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical">
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="MediumVioletRed"
                                           Text="Creato il"
                                           TextAlignment="Left" />
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="White"
                                           Text="{Binding CreatedText}"
                                           TextAlignment="Left" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical">
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="MediumVioletRed"
                                           Text="Operatore"
                                           TextAlignment="Left" />
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="White"
                                           Text="{Binding OperatorDescription}"
                                           TextAlignment="Left" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Vertical">
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="MediumVioletRed"
                                           Text="Risorsa"
                                           TextAlignment="Left" />
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="White"
                                           Text="{Binding ResourceDescription}"
                                           TextAlignment="Left" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Vertical">
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="MediumVioletRed"
                                           Text="Durata"
                                           TextAlignment="Left" />
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Top"
                                           FontSize="8"
                                           Foreground="White"
                                           Text="{Binding DurationText}"
                                           TextAlignment="Left" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </ControlTemplate>
            <Style x:Key="HistoryShape" BasedOn="{StaticResource RadDiagramShapeStyle}" TargetType="telerik:RadDiagramShape">
                <Setter Property="Position" Value="{Binding Position, Mode=TwoWay}" />
                <Setter Property="Visibility" Value="{Binding Visibility, Mode=TwoWay}" />
                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Opacity" Value="1" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="telerik:RadDiagramShape">
                            <Border Height="Auto"
                                    MinWidth="200"
                                    Padding="0"
                                    BorderBrush="{Binding MainBrush, Converter={StaticResource stringToColorConverter}}"
                                    BorderThickness="1"
                                    CornerRadius="0"
                                    DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ContentControl}, Path=DataContext}">
                                <Grid>
                                    <ContentControl Template="{StaticResource StandardContentTemplate}" />
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" />
                <ColumnDefinition Width="5*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="TRACCIABILITA' DEL LOTTO" />
            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <TextBlock FontSize="16" Style="{StaticResource VulpesXData}" Text="LOTTO" />
                <TextBlock Margin="10,0,10,0"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Foreground="White"
                           Text="{Binding LotTracking.Lot.ID}" />
            </StackPanel>
        </Grid>

        <telerik:RadDiagram x:Name="diaTracking"
                            Grid.Row="2"
                            ActiveTool="PanTool"
                            BorderThickness="3"
                            IsBackgroundSurfaceVisible="False"
                            IsConnectorsManipulationEnabled="False"
                            IsDraggingEnabled="False"
                            IsEditable="False"
                            IsManipulationEnabled="False"
                            IsResizingEnabled="False"
                            IsRotationEnabled="False"
                            ShapeStyle="{StaticResource LotShape}">
            <telerik:RadDiagram.ConnectionTemplate>
                <DataTemplate>
                    <telerik:RadDiagramConnection />
                </DataTemplate>
            </telerik:RadDiagram.ConnectionTemplate>
        </telerik:RadDiagram>

        <StackPanel Grid.Row="4"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Width="200"
                    Margin="5"
                    BorderBrush="{DynamicResource VulpesXYellowBrush}"
                    Content="USCIRE"
                    IsCancel="True"
                    Style="{StaticResource VulpesXButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
