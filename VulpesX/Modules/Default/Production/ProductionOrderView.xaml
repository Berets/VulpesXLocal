<UserControl x:Class="VulpesX.Modules.Default.Production.ProductionOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Production"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30*" />
                <ColumnDefinition Width="70*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="GESTIONE ORDINI DI PRODUZIONE" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <telerik:RadComboBox x:Name="cmbStatus"
                                     Margin="5"
                                     HorizontalAlignment="Stretch"
                                     DisplayMemberPath="Description"
                                     SelectedValuePath="ID"
                                     SelectionChanged="cmbStatus_SelectionChanged" />

                <telerik:RadDatePicker x:Name="dtpYear"
                                       Margin="5"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Right"
                                       DateSelectionMode="Year"
                                       DisplayFormat="Short"
                                       SelectionChanged="dtpYear_SelectionChanged" />
                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />

            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Margin="5"
                                         TextChanged="txtSearch_TextChanged"
                                         WatermarkContent="Cerca..." />
        </Grid>

        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     RowIndicatorVisibility="Collapsed"
                                     ShowGroupPanel="True">
                    <telerik:RadGridView.Columns>

                        <telerik:GridViewColumn Width="90">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadButton x:Name="cmdDelete"
                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                       Click="cmdDelete_Click"
                                                       Content="Elimina"
                                                       Style="{StaticResource VulpesXButton}"
                                                       Visibility="{Binding CanDeleteVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn Width="30">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgUnlock"
                                                      Cursor="Hand"
                                                      FontSize="18"
                                                      Foreground="{DynamicResource VulpesXBrush}"
                                                      Glyph="&#xe114;"
                                                      MouseDown="rgUnlock_MouseDown"
                                                      ToolTip="Sblocca arrivo materiale" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn Width="30">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgPrint"
                                                      Cursor="Hand"
                                                      FontSize="18"
                                                      Foreground="{DynamicResource VulpesXGreenBrush}"
                                                      Glyph="&#xe90e;"
                                                      MouseDown="rgPrint_MouseDown"
                                                      ToolTip="Stampa ODP" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn Width="30">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgView"
                                                      Cursor="Hand"
                                                      FontSize="18"
                                                      Foreground="{DynamicResource VulpesXBlueBrush}"
                                                      Glyph="&#xe13d;"
                                                      MouseDown="rgView_MouseDown"
                                                      ToolTip="Visualizza ODP" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>

                        <telerik:GridViewDataColumn Width="100"
                                                    DataMemberBinding="{Binding ID}"
                                                    Header="Codice"
                                                    HeaderTextAlignment="Center">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Center"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEdit_Click"
                                            Content="{Binding Path=ID}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="120"
                                                    DataMemberBinding="{Binding OrdineClienteFullID}"
                                                    Header="Rif. ord. cliente"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="140" DataMemberBinding="{Binding ArticoloID}" Header="Articolo" />
                        <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding ArticoloDescrizione}" Header="" />
                        <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding RevisioneID}" Header="Revisione" />
                        <telerik:GridViewDataColumn Width="140"
                                                    DataMemberBinding="{Binding Quantita, StringFormat=#.00}"
                                                    Header="Quantità"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="60"
                                                    DataMemberBinding="{Binding UM}"
                                                    Header=""
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="110"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding DataConsegna}"
                                                    Header="Consegna"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="80" DataMemberBinding="{Binding ClienteID}" Header="Cliente" />
                        <telerik:GridViewDataColumn Width="280" DataMemberBinding="{Binding ClienteDescrizione}" Header="" />
                        <telerik:GridViewDataColumn Width="110"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding DataOrdine}"
                                                    Header="Data ordine"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="180" DataMemberBinding="{Binding StatoDescrizione}" Header="Stato" />
                    </telerik:RadGridView.Columns>
                    <telerik:RadContextMenu.ContextMenu>
                        <telerik:RadContextMenu x:Name="cmGrid" Opening="cmGrid_Opening">
                            <telerik:RadMenuItem x:Name="rmiLaunch"
                                                 Click="rmiLaunch_Click"
                                                 Header="Lancia produzione"
                                                 Typography.Capitals="AllSmallCaps">
                                <telerik:RadMenuItem.Icon>
                                    <telerik:RadGlyph Width="16" Height="16" Glyph="&#xe659;" />
                                </telerik:RadMenuItem.Icon>
                            </telerik:RadMenuItem>
                            <telerik:RadMenuItem x:Name="rmiStatus" Header="Stato" Typography.Capitals="AllSmallCaps">
                                <telerik:RadMenuItem.Icon>
                                    <telerik:RadGlyph Width="16" Height="16" Glyph="&#xe648;" />
                                </telerik:RadMenuItem.Icon>
                            </telerik:RadMenuItem>
                            <telerik:RadMenuItem x:Name="rmiStoreMovs" Header="Movimenti di magazzino" Typography.Capitals="AllSmallCaps">
                                <telerik:RadMenuItem.Icon>
                                    <telerik:RadGlyph Width="16" Height="16" Glyph="&#xe92d;" />
                                </telerik:RadMenuItem.Icon>
                            </telerik:RadMenuItem>
                        </telerik:RadContextMenu>
                    </telerik:RadContextMenu.ContextMenu>

                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding Items}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>
</UserControl>
