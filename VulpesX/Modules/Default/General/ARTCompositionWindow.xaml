                                             FontSize="11"
                                             IsReadOnly="True"
                                             ItemsSource="{Binding Componenti}"
                                             RowIndicatorVisibility="Collapsed"
                                             SelectionMode="Extended"
                                             ShowGroupPanel="False"
                                             ShowSearchPanel="True"
                                             Tag="{Binding User}"
                                             UseLayoutRounding="False">
                            <telerik:RadGridView.Resources>
                                <converters:BoolToColorConverter x:Key="booleanColorConverter" FalseColor="{StaticResource VulpesXSecondBrush}" TrueColor="{StaticResource VulpesXGreenBrush}" />
                                <converters:ArticleDropIndicationConverter x:Key="dropIndicationDetailsConverter" />
                                <DataTemplate x:Key="DraggedItemTemplate">
                                    <StackPanel Margin="5">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Sposta" />
                                            <TextBlock Margin="2,0,0,0" FontWeight="Bold" Text="{Binding CurrentDraggedItem.Descrizione}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding CurrentDropPosition, Converter={StaticResource dropIndicationDetailsConverter}}" />
                                            <TextBlock Foreground="Gray" Text=", (" />
                                            <TextBlock FontWeight="Bold" Text="{Binding CurrentDraggedOverItem.Descrizione}" />
                                            <TextBlock Foreground="Gray" Text=")" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </telerik:RadGridView.Resources>
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewDataColumn>
                                    <telerik:GridViewDataColumn.CellTemplate>
                                        <DataTemplate>
                                            <Path Name="patComposizione"
                                                  Width="{Binding Path=FontSize, RelativeSource={RelativeSource AncestorType={x:Type telerik:RadGridView}}}"
                                                  Height="{Binding Path=FontSize, RelativeSource={RelativeSource AncestorType={x:Type telerik:RadGridView}}}"
                                                  telerik:RadToolTipService.IsEnabled="{Binding HaComposizione}"
                                                  telerik:RadToolTipService.Placement="RelativePoint"
                                                  telerik:RadToolTipService.PlacementRectangle="-39 0 0 0"
                                                  telerik:RadToolTipService.ShowDuration="20000"
                                                  telerik:RadToolTipService.ToolTipContent="{Binding}"
                                                  telerik:RadToolTipService.ToolTipContentTemplate="{StaticResource compositionTooltipTemplateRead}"
                                                  telerik:RadToolTipService.ToolTipOpening="patComposizione_ToolTipOpening"
                                                  Data="{DynamicResource CompositionPath}"
                                                  Fill="{Binding HaComposizione, Converter={StaticResource booleanColorConverter}}"
                                                  Stretch="Fill" />
                                        </DataTemplate>
                                    </telerik:GridViewDataColumn.CellTemplate>
                                </telerik:GridViewDataColumn>
                                <telerik:GridViewDataColumn>
                                    <telerik:GridViewDataColumn.CellTemplate>
                                        <DataTemplate>
                                            <Path Name="patDipendenze"
                                                  Width="{Binding Path=FontSize, RelativeSource={RelativeSource AncestorType={x:Type telerik:RadGridView}}}"
                                                  Height="{Binding Path=FontSize, RelativeSource={RelativeSource AncestorType={x:Type telerik:RadGridView}}}"
                                                  telerik:RadToolTipService.IsEnabled="{Binding HaDipendenze}"
                                                  telerik:RadToolTipService.Placement="RelativePoint"
                                                  telerik:RadToolTipService.PlacementRectangle="-39 0 0 0"
                                                  telerik:RadToolTipService.ShowDuration="20000"
                                                  telerik:RadToolTipService.ToolTipContent="{Binding}"
                                                  telerik:RadToolTipService.ToolTipContentTemplate="{StaticResource dependenciesTooltipTemplate}"
                                                  telerik:RadToolTipService.ToolTipOpening="patDipendenze_ToolTipOpening"
                                                  Data="{DynamicResource DependenciesPath}"
                                                  Fill="{Binding HaDipendenze, Converter={StaticResource booleanColorConverter}}"
                                                  Stretch="Fill" />
                                        </DataTemplate>
                                    </telerik:GridViewDataColumn.CellTemplate>
                                </telerik:GridViewDataColumn>
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding ID}" IsReadOnly="True">
                                    <telerik:GridViewDataColumn.AggregateFunctions>
                                        <telerik:CountFunction />
                                    </telerik:GridViewDataColumn.AggregateFunctions>
                                </telerik:GridViewDataColumn>
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding RevisioneID}" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding Descrizione}" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding DescrizioneEstesa}" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding TipoDescrizione}" IsReadOnly="True" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding CategoriaDescrizione}" IsReadOnly="True" />
                            </telerik:RadGridView.Columns>
                            <telerik:RadRadialMenu.RadialContextMenu>
                                <telerik:RadRadialMenu Name="rgvRadialMenuArticoli"
                                                       HideEventName="LostFocus"
                                                       InnerRadiusFactor="0.40"
                                                       PopupPlacement="Relative"
                                                       ShowToolTip="True"
                                                       StartAngle="-40"
                                                       StaysOpenOnShow="True">
                                    <telerik:RadRadialMenuItem Name="btnEditArticolo" ContentSectorBackground="{DynamicResource VulpesXYellowBrush}" ToolTip="F2">
                                        <telerik:RadRadialMenuItem.IconContent>
                                            <Path Data="{DynamicResource EditPath}" Fill="{DynamicResource VulpesXSecondBrush}" Stretch="Fill" />
                                        </telerik:RadRadialMenuItem.IconContent>
                                    </telerik:RadRadialMenuItem>
                                </telerik:RadRadialMenu>
                            </telerik:RadRadialMenu.RadialContextMenu>
                        </telerik:RadGridView>
                        <telerik:RadBusyIndicator Grid.Row="1" BusyContent="Caricamento" IsBusy="{Binding IsBusyComponenti}" />
                    </Grid>
                </telerik:RadPane>
                <telerik:RadPane telerik:RadDocking.SerializationTag="PaneReparti"
                                 CanUserClose="False"
                                 Header="Reparti"
                                 IsPinned="False">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Button Name="cmdInsertWard"
                                Grid.Row="0"
                                Width="200"
                                Margin="2"
                                HorizontalAlignment="Left"
                                BorderBrush="LightSkyBlue"
                                BorderThickness="5,0,0,0"
                                Click="cmdInsertWard_Click"
                                Content="INSERISCI"
                                FontSize="10" />

                        <telerik:RadGridView x:Name="rgvStages"
                                             Grid.Row="1"
                                             dragdrop:ArticleGridViewDragDropBehavior.IsEnabled="True"
                                             telerik:DragDropManager.AllowDrag="True"
                                             AutoGenerateColumns="False"
                                             IsReadOnly="True"
                                             ItemsSource="{Binding Reparti}"
                                             RowIndicatorVisibility="Collapsed"
                                             SelectionMode="Extended"
                                             ShowGroupPanel="False"
                                             ShowSearchPanel="True"
                                             UseLayoutRounding="False">
                            <telerik:RadGridView.ControlPanelItems>
                                <telerik:ControlPanelItem>
                                    <telerik:ControlPanelItem.Content>
                                        <telerik:RadButton IsEnabled="True" Style="{StaticResource VulpesXGridButton}" ToolTip="Aggiungi">
                                            <telerik:RadButton.Content>
                                                <Path Data="{DynamicResource AddPath}" Fill="{DynamicResource VulpesXGreenBrush}" Stretch="Uniform" />
                                            </telerik:RadButton.Content>
                                        </telerik:RadButton>
                                    </telerik:ControlPanelItem.Content>
                                </telerik:ControlPanelItem>

                                <telerik:ControlPanelItem>
                                    <telerik:ControlPanelItem.Content>
                                        <telerik:RadButton Style="{StaticResource VulpesXGridButton}" ToolTip="Ricarica">
                                            <telerik:RadButton.Content>
                                                <Path Data="{DynamicResource RefreshPath}" Fill="{DynamicResource VulpesXSecondBrush}" Stretch="Uniform" />
                                            </telerik:RadButton.Content>
                                        </telerik:RadButton>
                                    </telerik:ControlPanelItem.Content>
                                </telerik:ControlPanelItem>
                            </telerik:RadGridView.ControlPanelItems>
                            <telerik:RadGridView.Resources>
                                <converters:LongToTimeSpanConverter x:Key="longToTimeSpanConverter" />
                                <converters:ArticleDropIndicationConverter x:Key="dropIndicationDetailsConverter" />
                                <DataTemplate x:Key="DraggedItemTemplate">
                                    <StackPanel Margin="5">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Sposta" />
                                            <TextBlock Margin="2,0,0,0" FontWeight="Bold" Text="{Binding CurrentDraggedItem.Descrizione}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontWeight="Bold" Text="{Binding CurrentDropPosition, Converter={StaticResource dropIndicationDetailsConverter}}" />
                                            <TextBlock Foreground="Gray" Text=", (" />
                                            <TextBlock Text="{Binding CurrentDraggedOverItem.Descrizione}" />
                                            <TextBlock Foreground="Gray" Text=")" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </telerik:RadGridView.Resources>
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding ID}">
                                    <telerik:GridViewDataColumn.AggregateFunctions>
                                        <telerik:CountFunction />
                                    </telerik:GridViewDataColumn.AggregateFunctions>
                                </telerik:GridViewDataColumn>
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding Descrizione}" />
                                <telerik:GridViewDataColumn DataMemberBinding="{Binding TempoDefault, Converter={StaticResource longToTimeSpanConverter}}" IsReadOnly="True" />
                            </telerik:RadGridView.Columns>
                            <telerik:RadRadialMenu.RadialContextMenu>
                                <telerik:RadRadialMenu Name="rgvRadialMenuReparti"
                                                       HideEventName="LostFocus"
                                                       InnerRadiusFactor="0.40"
                                                       PopupPlacement="Relative"
                                                       ShowToolTip="True"
                                                       StartAngle="-40"
                                                       StaysOpenOnShow="True">
                                    <telerik:RadRadialMenuItem Name="btnEditReparto" ContentSectorBackground="{DynamicResource VulpesXYellowBrush}" ToolTip="F2">
                                        <telerik:RadRadialMenuItem.IconContent>
                                            <Path Data="{DynamicResource EditPath}" Fill="{DynamicResource VulpesXSecondBrush}" Stretch="Fill" />
                                        </telerik:RadRadialMenuItem.IconContent>
                                    </telerik:RadRadialMenuItem>
                                </telerik:RadRadialMenu>
                            </telerik:RadRadialMenu.RadialContextMenu>
                        </telerik:RadGridView>
                        <telerik:RadBusyIndicator Grid.Row="1" BusyContent="Caricamento" IsBusy="{Binding IsBusyReparti}" />
                    </Grid>
                </telerik:RadPane>
                <telerik:RadPane telerik:RadDocking.SerializationTag="PaneNote"
                                 CanUserClose="False"
                                 Header="Note"
                                 IsPinned="False">
                    <Grid DataContext="{Binding SelectedDistinta}">
                        <TextBox Height="300"
                                 Margin="2"
                                 VerticalAlignment="Top"
                                 VerticalContentAlignment="Top"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" />
                    </Grid>
                </telerik:RadPane>
            </telerik:RadPaneGroup>
        </telerik:RadSplitContainer>

    </telerik:RadDocking>
</sc:FluentDefaultWindow>
