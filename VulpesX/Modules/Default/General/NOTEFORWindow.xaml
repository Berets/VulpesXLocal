<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.General.NOTEFORWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.General"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli nota fornitore"
                        Width="800"
                        Height="500"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,15,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="5" />
                <RowDefinition Height="*" />
                <RowDefinition Height="35" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="7*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       VerticalAlignment="Top"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Nota" />
            <TextBox Grid.Row="1"
                     Grid.Column="1"
                     Margin="5,0,15,15"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"
                     VerticalContentAlignment="Top"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     MaxLength="255"
                     MaxLines="23"
                     Text="{Binding Data.Nofnot}"
                     TextWrapping="Wrap" />

            <StackPanel Grid.Row="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                <Button Name="cmdCancel"
                        Width="200"
                        Margin="2"
                        BorderBrush="Gold"
                        BorderThickness="5,0,0,0"
                        Click="cmdCancel_Click"
                        Content="USCIRE"
                        FontSize="10" />
                <Button Name="cmdSave"
                        Width="200"
                        Margin="2"
                        BorderBrush="ForestGreen"
                        BorderThickness="5,0,0,0"
                        Click="cmdSave_Click"
                        Content="SALVA"
                        FontSize="10" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</sc:FluentDefaultWindow>
