<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.General.ARTImageWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.General"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Immagini ARTICOLO"
                        Width="1024"
                        Height="400"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,5,0,0">
                <Button Name="cmdInsert"
                        Margin="5"
                        HorizontalAlignment="Right"
                        Click="cmdInsert_Click"
                        Content="UPLOAD"
                        Style="{StaticResource VulpesXInsertButton}" />
            </Grid>

            <telerik:RadBusyIndicator Name="bsyGrid"
                                      Grid.Row="1"
                                      Margin="5"
                                      BusyContent="Caricamento dati in corso..."
                                      DisplayAfter="0"
                                      Foreground="{DynamicResource VulpesXBrush}"
                                      IsBusy="{Binding IsBusy}"
                                      OverlayStyle="{StaticResource WaitOverlayStyle}">
                <telerik:RadGridView x:Name="rgvList"
                                     AutoGenerateColumns="False"
                                     CanUserDeleteRows="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Items}"
                                     SelectedItem="{Binding SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectionMode="Extended"
                                     ShowColumnFooters="True"
                                     ShowSearchPanel="False">

                    <telerik:RadGridView.Columns>
                        <telerik:GridViewColumn Width="110">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadButton x:Name="cmdDelete"
                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                       Click="cmdDelete_Click"
                                                       Content="Elimina"
                                                       Style="{StaticResource VulpesXButton}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>

                        <telerik:GridViewDataColumn DataMemberBinding="{Binding Estensione}" IsReadOnly="True">
                            <telerik:GridViewDataColumn.AggregateFunctions>
                                <telerik:CountFunction />
                            </telerik:GridViewDataColumn.AggregateFunctions>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding File}" IsReadOnly="True">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Left"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEdit_Click"
                                            Content="{Binding Path=File}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}"
                                            ToolTip="Modifica" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding Cartella}" IsReadOnly="True" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding Url}">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdOpen"
                                            Margin="3"
                                            HorizontalContentAlignment="Left"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdOpen_Click"
                                            Content="{Binding Path=Url}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBlueBrush}"
                                            ToolTip="Apri" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn IsReadOnly="True">
                            <telerik:GridViewDataColumn.CellTemplate>
                                <DataTemplate>
                                    <Path Name="patAllegati"
                                          Width="{Binding Path=FontSize, RelativeSource={RelativeSource AncestorType={x:Type telerik:RadGridView}}}"
                                          Height="{Binding Path=FontSize, RelativeSource={RelativeSource AncestorType={x:Type telerik:RadGridView}}}"
                                          telerik:RadToolTipService.Placement="RelativePoint"
                                          telerik:RadToolTipService.PlacementRectangle="20 20 0 0"
                                          telerik:RadToolTipService.ShowDuration="20000"
                                          telerik:RadToolTipService.ToolTipContent="{Binding}"
                                          telerik:RadToolTipService.ToolTipContentTemplate="{DynamicResource logTooltipTemplate}"
                                          Data="{DynamicResource LogUserPath}"
                                          Fill="{DynamicResource VulpesXSecondBrush}"
                                          Stretch="Uniform" />
                                </DataTemplate>
                            </telerik:GridViewDataColumn.CellTemplate>
                        </telerik:GridViewDataColumn>

                    </telerik:RadGridView.Columns>

                    <telerik:RadContextMenu.ContextMenu>
                        <telerik:RadContextMenu Background="#2C2D33">
                            <telerik:RadMenuItem x:Name="btnOpen"
                                                 Click="btnOpen_Click"
                                                 Foreground="{DynamicResource VulpesXSecondBrush}"
                                                 Header="Apri"
                                                 Typography.Capitals="AllSmallCaps">
                                <telerik:RadMenuItem.Icon>
                                    <Path Width="16"
                                          Height="16"
                                          Data="{DynamicResource OpenPath}"
                                          Fill="{DynamicResource VulpesXSecondBrush}"
                                          Stretch="Uniform" />
                                </telerik:RadMenuItem.Icon>
                            </telerik:RadMenuItem>
                        </telerik:RadContextMenu>

                    </telerik:RadContextMenu.ContextMenu>
                </telerik:RadGridView>
            </telerik:RadBusyIndicator>
        </Grid>
    </ScrollViewer>
</sc:FluentDefaultWindow>
