<UserControl x:Class="VulpesX.Modules.Default.General.ABEView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.General"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">

    <UserControl.Resources>
        <selectors:ABEListSelector x:Key="ABEListSelector">
            <selectors:ABEListSelector.DefaultRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </selectors:ABEListSelector.DefaultRowStyle>
            <selectors:ABEListSelector.ProspectRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="RoyalBlue" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="ToolTip" Value="Prospect" />
                </Style>
            </selectors:ABEListSelector.ProspectRowStyle>
            <selectors:ABEListSelector.ObsoleteRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="OrangeRed" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="ToolTip" Value="Obsoleto" />
                </Style>
            </selectors:ABEListSelector.ObsoleteRowStyle>
        </selectors:ABEListSelector>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="ANAGRAFICA BASE" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Margin="5"
                                         TextChanged="txtSearch_TextChanged"
                                         WatermarkContent="Cerca..." />
        </Grid>

        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     LoadingRowDetails="GridView_LoadingRowDetails"
                                     RowIndicatorVisibility="Collapsed"
                                     RowStyleSelector="{StaticResource ABEListSelector}"
                                     ShowGroupPanel="True">
                    <telerik:RadContextMenu.ContextMenu>
                        <telerik:RadContextMenu x:Name="cmGrid" Background="#2C2D33" Opening="cmGrid_Opening">
                            <telerik:RadMenuItem x:Name="rmiFinancials"
                                                 Background="{DynamicResource VulpesXBrush}"
                                                 Foreground="Black"
                                                 Header="Informazioni finanziarie"
                                                 Typography.Capitals="AllSmallCaps">
                                <telerik:RadMenuItem.Icon>
                                    <Image Width="16"
                                           Height="16"
                                           Source="{telerik:RadGlyph Glyph={StaticResource GlyphStarOutline}}"
                                           Stretch="Uniform" />
                                </telerik:RadMenuItem.Icon>
                                <telerik:RadMenuItem x:Name="rmiCreditScore"
                                                     Background="{DynamicResource VulpesXBrush}"
                                                     Click="rmiCreditScore_Click"
                                                     Foreground="Black"
                                                     Header="Credit score"
                                                     Typography.Capitals="AllSmallCaps">
                                    <telerik:RadMenuItem.Icon>
                                        <Image Width="16"
                                               Height="16"
                                               Source="{telerik:RadGlyph Glyph={StaticResource GlyphPreview}}"
                                               Stretch="Uniform" />
                                    </telerik:RadMenuItem.Icon>
                                </telerik:RadMenuItem>
                                <telerik:RadMenuItem x:Name="rmiReport"
                                                     Background="{DynamicResource VulpesXBrush}"
                                                     Click="rmiReport_Click"
                                                     Foreground="Black"
                                                     Header="Report finanziario"
                                                     Typography.Capitals="AllSmallCaps">
                                    <telerik:RadMenuItem.Icon>
                                        <Image Width="16"
                                               Height="16"
                                               Source="{telerik:RadGlyph Glyph={StaticResource GlyphPastePlainText}}"
                                               Stretch="Uniform" />
                                    </telerik:RadMenuItem.Icon>
                                </telerik:RadMenuItem>
                                <Separator Background="{DynamicResource VulpesXBrush}" Foreground="Black" />
                                <telerik:RadMenuItem x:Name="rmiBalance"
                                                     Background="{DynamicResource VulpesXBrush}"
                                                     Click="rmiBalance_Click"
                                                     Foreground="Black"
                                                     Header="Bilancio"
                                                     Typography.Capitals="AllSmallCaps">
                                    <telerik:RadMenuItem.Icon>
                                        <Image Width="16"
                                               Height="16"
                                               Source="{telerik:RadGlyph Glyph={StaticResource GlyphTable}}"
                                               Stretch="Uniform" />
                                    </telerik:RadMenuItem.Icon>
                                </telerik:RadMenuItem>
                            </telerik:RadMenuItem>
                        </telerik:RadContextMenu>
                    </telerik:RadContextMenu.ContextMenu>
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewToggleRowDetailsColumn />
                        <telerik:GridViewColumn Width="110">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadButton x:Name="cmdDelete"
                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                       Click="cmdDelete_Click"
                                                       Content="Elimina"
                                                       Style="{StaticResource VulpesXButton}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn x:Name="gvcActivities" Width="30">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgActivities"
                                                      Cursor="Hand"
                                                      FontSize="18"
                                                      Foreground="{DynamicResource VulpesXGreenBrush}"
                                                      Glyph="&#xe665;"
                                                      MouseDown="rgActivities_MouseDown"
                                                      ToolTip="Visualizza lo storico delle attivita'" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewDataColumn Width="100"
                                                    DataMemberBinding="{Binding abecod}"
                                                    Header="Codice"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataMemberBinding="{Binding abepiv}"
                                                    Header="Partita IVA"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="130"
                                                    DataMemberBinding="{Binding abecfi}"
                                                    Header="Codice fiscale"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding abers1}" Header="Ragione sociale">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Left"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEdit_Click"
                                            Content="{Binding Path=abers1}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding abers2}" Header="" />
                        <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding ItemTypeDescription}" Header="Tipo">
                            <telerik:GridViewDataColumn.AggregateFunctions>
                                <telerik:CountFunction ResultFormatString="{}{0:N0}" />
                            </telerik:GridViewDataColumn.AggregateFunctions>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="120" DataMemberBinding="{Binding abeloc}" Header="Localita'">
                            <telerik:GridViewDataColumn.AggregateFunctions>
                                <telerik:CountFunction ResultFormatString="{}{0:N0}" />
                            </telerik:GridViewDataColumn.AggregateFunctions>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding abepro}"
                                                    Header="Prov."
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center">
                            <telerik:GridViewDataColumn.AggregateFunctions>
                                <telerik:CountFunction ResultFormatString="{}{0:N0}" />
                            </telerik:GridViewDataColumn.AggregateFunctions>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding abeind}" Header="Indirizzo" />
                    </telerik:RadGridView.Columns>
                    <telerik:RadGridView.RowDetailsTemplate>
                        <DataTemplate>
                            <ContentControl x:Name="UserControlContainer" />
                        </DataTemplate>
                    </telerik:RadGridView.RowDetailsTemplate>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding Items}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>
</UserControl>
