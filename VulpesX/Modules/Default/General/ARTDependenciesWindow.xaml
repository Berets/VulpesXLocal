<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.General.ARTDependenciesWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.General"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Articoli dipendenti"
                        Width="1024"
                        Height="768"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Style="{StaticResource VulpesXTitle}" Text="ARTICOLI DIPENDENTI DA" />
                <TextBlock Margin="5"
                           VerticalAlignment="Center"
                           FontSize="20"
                           Foreground="White"
                           Text="{Binding ProductFullDescription}" />
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button x:Name="cmdFirst"
                        Width="50"
                        Margin="5"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderBrush="{DynamicResource VulpesXDataBrush}"
                        BorderThickness="2"
                        Click="cmdFirst_Click"
                        FontSize="20"
                        Foreground="{StaticResource VulpesXDataBrush}"
                        ToolTip="Ritorna al primo articolo visualizzato ed azzera lo storico delle navigazioni">
                    <StackPanel Orientation="Horizontal">
                        <telerik:RadGlyph Margin="0,0,0,0" Glyph="&#xe034;" />
                    </StackPanel>
                </Button>

                <Button x:Name="cmdBack"
                        Width="50"
                        Margin="5"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderBrush="{DynamicResource VulpesXDataBrush}"
                        BorderThickness="2"
                        Click="cmdBack_Click"
                        FontSize="20"
                        Foreground="{StaticResource VulpesXDataBrush}"
                        ToolTip="Articolo precedente">
                    <StackPanel Orientation="Horizontal">
                        <telerik:RadGlyph Margin="0,0,0,0" Glyph="&#xe01a;" />
                    </StackPanel>
                </Button>

                <Button x:Name="cmdForward"
                        Width="50"
                        Margin="5"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderBrush="{DynamicResource VulpesXDataBrush}"
                        BorderThickness="2"
                        Click="cmdForward_Click"
                        FontSize="20"
                        Foreground="{StaticResource VulpesXDataBrush}"
                        ToolTip="Articolo successivo">
                    <StackPanel Orientation="Horizontal">
                        <telerik:RadGlyph Glyph="&#xe018;" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>
            <telerik:RadGridView x:Name="rgvList"
                                 Grid.Row="0"
                                 AutoGenerateColumns="False"
                                 CanUserFreezeColumns="False"
                                 CanUserResizeColumns="False"
                                 IsReadOnly="True"
                                 ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                 RowIndicatorVisibility="Visible"
                                 ShowGroupPanel="False">
                <telerik:RadGridView.Columns>
                    <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding ArticoloID}" Header="Codice articolo">
                        <telerik:GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button x:Name="cmdDrill"
                                        Margin="3"
                                        HorizontalContentAlignment="Left"
                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                        Click="cmdDrill_Click"
                                        Content="{Binding Path=ArticoloID}"
                                        Cursor="Hand"
                                        Foreground="{DynamicResource VulpesXBrush}"
                                        ToolTip="Mostra i prodotti dipendenti da questo articolo" />
                            </DataTemplate>
                        </telerik:GridViewColumn.CellTemplate>
                    </telerik:GridViewDataColumn>
                    <telerik:GridViewDataColumn Width="450" DataMemberBinding="{Binding Descrizione}">
                        <telerik:GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button x:Name="cmdEditProduct"
                                        Margin="3"
                                        HorizontalContentAlignment="Left"
                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                        Click="cmdEditProduct_Click"
                                        Content="{Binding Path=Descrizione}"
                                        Cursor="Hand"
                                        Foreground="{DynamicResource VulpesXBrush}"
                                        ToolTip="Modifica l'articolo selezionato" />
                            </DataTemplate>
                        </telerik:GridViewColumn.CellTemplate>
                    </telerik:GridViewDataColumn>
                    <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding RevisioneID}" Header="Revisione" />
                    <telerik:GridViewDataColumn DataMemberBinding="{Binding Quantita}"
                                                Header="Quantità necessaria"
                                                HeaderTextAlignment="Right"
                                                TextAlignment="Right">
                        <telerik:GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button x:Name="cmdComposition"
                                        Margin="3"
                                        HorizontalContentAlignment="Right"
                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                        Click="cmdComposition_Click"
                                        Content="{Binding Path=Quantita}"
                                        Cursor="Hand"
                                        Foreground="{DynamicResource VulpesXBrush}"
                                        ToolTip="Apri il ciclo di produzione di questo articolo" />
                            </DataTemplate>
                        </telerik:GridViewColumn.CellTemplate>
                    </telerik:GridViewDataColumn>
                    <telerik:GridViewDataColumn Width="350" DataMemberBinding="{Binding Note}" Header="Note" />
                </telerik:RadGridView.Columns>
            </telerik:RadGridView>
            <telerik:RadDataPager x:Name="rdpGrid"
                                  Grid.Row="1"
                                  Margin="0,-1,0,0"
                                  DisplayMode="FirstLastPreviousNextNumeric, Text"
                                  FontSize="12"
                                  IsTotalItemCountFixed="True"
                                  PageSize="20"
                                  Source="{Binding Dependencies}" />
        </Grid>

        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />

        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
