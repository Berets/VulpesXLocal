<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.General.ARTCompositionReplaceWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.General"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Sostituzione ARTICOLO"
                        Width="1280"
                        Height="700"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">

    <telerik:RadBusyIndicator Name="bsyGrid"
                              BusyContent="Caricamento dati in corso..."
                              DisplayAfter="0"
                              Foreground="{DynamicResource VulpesXBrush}"
                              IsBusy="{Binding IsBusy}"
                              OverlayStyle="{StaticResource WaitOverlayStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="70*" />
                <RowDefinition Height="30" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50*" />
                    <ColumnDefinition Width="50*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBrush}">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{DynamicResource VulpesXDarkBrush}"
                                   Text="Articolo da sostituire" />
                    </Grid>
                    <StackPanel Grid.Row="1" Orientation="Vertical">
                        <DockPanel Margin="5">
                            <TextBlock Width="150"
                                       Margin="0,0,10,0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Articolo"
                                       TextAlignment="Right" />
                            <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                        ItemsSource="{Binding Products}"
                                                        NoResultsContent="Nessun articolo trovato"
                                                        SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable" />
                        </DockPanel>
                        <DockPanel Margin="5">
                            <TextBlock Width="150"
                                       Margin="0,0,10,0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Revisione"
                                       TextAlignment="Right" />
                            <telerik:RadComboBox ItemsSource="{Binding Revisions}" SelectedItem="{Binding SelectedRevision}" />
                        </DockPanel>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="{DynamicResource VulpesXBrush}">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="{DynamicResource VulpesXDarkBrush}"
                                   Text="Articolo nuovo" />
                    </Grid>
                    <StackPanel Grid.Row="1" Orientation="Vertical">
                        <DockPanel Margin="5">
                            <TextBlock Width="150"
                                       Margin="0,0,10,0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Articolo"
                                       TextAlignment="Right" />
                            <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                        ItemsSource="{Binding ProductsNew}"
                                                        NoResultsContent="Nessun articolo trovato"
                                                        SelectedItem="{Binding SelectedProductNew, Mode=TwoWay}"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable" />
                        </DockPanel>
                        <DockPanel Margin="5">
                            <TextBlock Width="150"
                                       Margin="0,0,10,0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Revisione"
                                       TextAlignment="Right" />
                            <telerik:RadComboBox ItemsSource="{Binding RevisionsNew}" SelectedItem="{Binding SelectedRevisionNew}" />
                        </DockPanel>

                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="{DynamicResource VulpesXBrush}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="{DynamicResource VulpesXDarkBrush}"
                               Text="Dipendenze" />
                </Grid>
                <telerik:RadTreeListView x:Name="rgvList"
                                         Grid.Row="1"
                                         AutoExpandItems="True"
                                         AutoGenerateColumns="False"
                                         CanUserFreezeColumns="False"
                                         ColumnWidth="*"
                                         IsReadOnly="False"
                                         ItemsSource="{Binding Dependencies}"
                                         RowIndicatorVisibility="Collapsed"
                                         SelectionMode="Extended">

                    <telerik:RadTreeListView.Columns>
                        <telerik:GridViewSelectColumn />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding ArticoloID}" Header="Codice articolo" IsReadOnly="True" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding Descrizione}" IsReadOnly="True" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding RevisioneID}" Header="Revisione" IsReadOnly="True" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding Quantita}"
                                                    Header="Quantità necessaria"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />

                        <telerik:GridViewDataColumn DataMemberBinding="{Binding RevisioneNuova}"
                                                    Header="Nuova revisione"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding QuantitaNuova}"
                                                    Header="Nuova quantità"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                    </telerik:RadTreeListView.Columns>
                    <telerik:RadTreeListView.ChildTableDefinitions>
                        <telerik:TreeListViewTableDefinition ItemsSource="{Binding Dipendenze}" />
                    </telerik:RadTreeListView.ChildTableDefinitions>
                </telerik:RadTreeListView>

            </Grid>

            <Grid Grid.Row="2" Background="{DynamicResource VulpesXBlueBrush}">
                <StackPanel Orientation="Horizontal">
                    <DockPanel>
                        <TextBlock Width="150"
                                   Margin="0,0,10,0"
                                   Style="{StaticResource VulpesXLabel}"
                                   Text="Revisione"
                                   TextAlignment="Right" />
                        <TextBox x:Name="txtRevisioneNuova" Width="200" />
                        <Button x:Name="btnSetRevision"
                                Margin="20,0,0,0"
                                Click="btnSetRevision_Click"
                                Content="IMPOSTA REVISIONE" />
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Width="150"
                                   Margin="0,0,10,0"
                                   Style="{StaticResource VulpesXLabel}"
                                   Text="Quantità"
                                   TextAlignment="Right" />
                        <telerik:RadNumericUpDown Name="nuQuantitaNuova"
                                                  Width="200"
                                                  Minimum="0.000001"
                                                  NumberDecimalDigits="6" />
                        <Button x:Name="btnSetQuantity"
                                Margin="20,0,0,0"
                                Click="btnSetQuantity_Click"
                                Content="IMPOSTA QUANTITA'" />

                    </DockPanel>

                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="3"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
                <Button Name="cmdSave"
                        Click="cmdSave_Click"
                        Content="SALVA"
                        Style="{StaticResource VulpesXConfirmButton}" />
            </StackPanel>
        </Grid>
    </telerik:RadBusyIndicator>
</sc:FluentDefaultWindow>
