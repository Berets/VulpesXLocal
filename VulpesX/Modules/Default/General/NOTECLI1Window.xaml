<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.General.NOTECLI1Window"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.General"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli nota cliente"
                        Width="800"
                        Height="500"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,15,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="35" />
                <RowDefinition Height="*" />
                <RowDefinition Height="35" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="7*" />
            </Grid.ColumnDefinitions>


            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Tipo nota" />
            <telerik:RadComboBox Grid.Row="0"
                                 Grid.Column="1"
                                 Width="200"
                                 Margin="5,2,15,2"
                                 HorizontalAlignment="Left"
                                 HorizontalContentAlignment="Left"
                                 DisplayMemberPath="Description"
                                 IsEditable="True"
                                 IsReadOnly="True"
                                 ItemsSource="{Binding NoteTypes}"
                                 SelectedValue="{Binding Data.NOTETI}"
                                 SelectedValuePath="ID" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       VerticalAlignment="Top"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Nota" />
            <TextBox Grid.Row="1"
                     Grid.Column="1"
                     Margin="5,0,15,15"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"
                     VerticalContentAlignment="Top"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     MaxLength="255"
                     MaxLines="21"
                     Text="{Binding Data.notdes}"
                     TextWrapping="Wrap" />

            <StackPanel Grid.Row="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                <Button Name="cmdCancel"
                        BorderBrush="{DynamicResource VulpesXYellowBrush}"
                        Click="cmdCancel_Click"
                        Content="USCIRE"
                        IsCancel="True"
                        Style="{StaticResource VulpesXButton}" />
                <Button Name="cmdSave"
                        BorderBrush="{DynamicResource VulpesXGreenBrush}"
                        Click="cmdSave_Click"
                        Content="SALVA"
                        Style="{StaticResource VulpesXButton}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</sc:FluentDefaultWindow>
