<UserControl x:Class="VulpesX.Modules.Default.CRM.FATTT00FView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:aggregates="clr-namespace:VulpesX.Shared.Controls.Aggregators;assembly=VulpesX.Shared.Controls"
             xmlns:chart="clr-namespace:Telerik.Windows.Controls;assembly=Telerik.Windows.Controls.Chart"
             xmlns:chartView="clr-namespace:Telerik.Windows.Controls.ChartView;assembly=Telerik.Windows.Controls.Chart"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource VulpesXTitle}" Text="GESTIONE FATTURE" />
        <telerik:RadTabControl Grid.Row="1"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">

            <telerik:RadTabItem DropDownContent="LISTA" Header="LISTA">
                <telerik:RadTabItem.Content>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40" />
                            <RowDefinition Height="40" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,5,0,0">
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="Fatture dal" />
                                <telerik:RadDateTimePicker x:Name="rdpFromDate"
                                                           Width="150"
                                                           Margin="5"
                                                           VerticalAlignment="Stretch"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           ParseExact="False"
                                                           SelectionChanged="rdpFromDate_SelectionChanged" />
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                           Text="al" />
                                <telerik:RadDateTimePicker x:Name="rdpToDate"
                                                           Width="150"
                                                           Margin="5"
                                                           VerticalAlignment="Stretch"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           ParseExact="False"
                                                           SelectionChanged="rdpToDate_SelectionChanged" />

                                <Button Name="cmdInsert"
                                        Margin="5"
                                        Click="cmdInsert_Click"
                                        Content="INSERISCI"
                                        Style="{StaticResource VulpesXInsertButton}" />
                                <Button Name="cmdPrintFinal"
                                        Width="170"
                                        Margin="5"
                                        BorderBrush="{DynamicResource VulpesXGreenBrush}"
                                        Click="cmdPrintFinal_Click"
                                        Content="STAMPA DEFINITIVA"
                                        IsEnabled="False"
                                        Style="{StaticResource VulpesXButton}" />
                                <Button Name="cmdGenerateFile"
                                        Width="170"
                                        Margin="5"
                                        BorderBrush="{DynamicResource VulpesXVioletBrush}"
                                        Click="cmdGenerateFile_Click"
                                        Content="GENERA FILE FATTURAZIONE"
                                        IsEnabled="True"
                                        Style="{StaticResource VulpesXButton}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal" />
                        </Grid>

                        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
                            <telerik:RadWatermarkTextBox Name="txtSearch"
                                                         Margin="5"
                                                         TextChanged="txtSearch_TextChanged"
                                                         WatermarkContent="Cerca..." />
                        </Grid>

                        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                                  Grid.Row="4"
                                                  BusyContent="Caricamento dati in corso..."
                                                  Foreground="{DynamicResource VulpesXBrush}"
                                                  IsBusy="{Binding IsBusy}"
                                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="35" />
                                </Grid.RowDefinitions>
                                <Grid.Resources>
                                    <DataTemplate x:Key="FEStatus">
                                        <Border BorderBrush="{Binding FEStatusColor, Converter={StaticResource stringToColorConverter}}" Cursor="{Binding FEStatusCursor}">
                                            <StackPanel Orientation="Horizontal">
                                                <Label x:Name="label" ToolTip="{Binding FEStatusText}">
                                                    <telerik:RadGlyph x:Name="rgFE"
                                                                      FontSize="14"
                                                                      Foreground="{Binding FEStatusColor, Converter={StaticResource stringToColorConverter}}"
                                                                      Glyph="&#xe809;"
                                                                      MouseDown="rgFE_MouseDown" />
                                                </Label>
                                                <Label Margin="5,0,0,0" Content="{Binding SDISentStatusDescription}" Foreground="{Binding FEStatusColor, Converter={StaticResource stringToColorConverter}}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                    <DataTemplate x:Key="SelfInvoiceIcon">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="35" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    BorderBrush="{Binding SelfInvoiceStatusColor, Converter={StaticResource stringToColorConverter}}"
                                                    Cursor="Hand"
                                                    Visibility="{Binding SelfInvoiceStatusVisibility, Converter={StaticResource boolToVisibilityConverter}}">
                                                <telerik:RadGlyph x:Name="rgSelfInvoiceIcon"
                                                                  FontSize="14"
                                                                  Foreground="{Binding SelfInvoiceStatusColor, Converter={StaticResource stringToColorConverter}}"
                                                                  Glyph="&#xe102;"
                                                                  MouseDown="rgSelfInvoiceIcon_MouseDown" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                    <DataTemplate x:Key="InvoiceAttachmentsIcon">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="35" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" BorderBrush="{Binding InvoiceAttachmentsStatusColor, Converter={StaticResource stringToColorConverter}}" Cursor="Hand">
                                                <Label x:Name="label" ToolTip="{Binding InvoiceAttachmentsStatusText}">
                                                    <telerik:RadGlyph x:Name="rgInvoiceAttachmentsIcon"
                                                                      FontSize="16"
                                                                      Foreground="{Binding InvoiceAttachmentsStatusColor, Converter={StaticResource stringToColorConverter}}"
                                                                      Glyph="&#xe10e;"
                                                                      MouseDown="rgInvoiceAttachmentsIcon_MouseDown" />
                                                </Label>
                                            </Border>
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding InvoiceAttachmentsText}" />
                                        </Grid>
                                    </DataTemplate>
                                </Grid.Resources>
                                <telerik:RadGridView x:Name="GridView"
                                                     Grid.Row="0"
                                                     AutoGenerateColumns="False"
                                                     CanUserFreezeColumns="False"
                                                     CanUserResizeColumns="False"
                                                     ColumnAggregatesAlignment="NoAlignment"
                                                     GroupRenderMode="Flat"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                                     RowIndicatorVisibility="Collapsed"
                                                     SelectionMode="Extended"
                                                     ShowColumnFooters="True"
                                                     ShowGroupFooters="True"
                                                     ShowGroupPanel="True">
                                    <telerik:RadContextMenu.ContextMenu>
                                        <telerik:RadContextMenu x:Name="cmGrid" Background="#2C2D33" Opening="cmGrid_Opening">
                                            <telerik:RadMenuItem x:Name="rmiAccounting"
                                                                 Click="rmiAccounting_Click"
                                                                 Foreground="{DynamicResource VulpesXSecondBrush}"
                                                                 Header="Contabilizzazione"
                                                                 Typography.Capitals="AllSmallCaps">
                                                <telerik:RadMenuItem.Icon>
                                                    <Image Width="16"
                                                           Height="16"
                                                           Source="{telerik:RadGlyph Glyph={StaticResource GlyphLinkHorizontal}}"
                                                           Stretch="Uniform" />
                                                </telerik:RadMenuItem.Icon>
                                            </telerik:RadMenuItem>
                                            <telerik:RadMenuItem x:Name="rmiSendable"
                                                                 Click="rmiSendable_Click"
                                                                 Foreground="{DynamicResource VulpesXSecondBrush}"
                                                                 Header=""
                                                                 Typography.Capitals="AllSmallCaps">
                                                <telerik:RadMenuItem.Icon>
                                                    <Image Width="16"
                                                           Height="16"
                                                           Source="{telerik:RadGlyph Glyph={StaticResource GlyphBac}}"
                                                           Stretch="Uniform" />
                                                </telerik:RadMenuItem.Icon>
                                            </telerik:RadMenuItem>
                                        </telerik:RadContextMenu>
                                    </telerik:RadContextMenu.ContextMenu>
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewColumn Width="70">
                                            <telerik:GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <telerik:RadButton x:Name="cmdDelete"
                                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                                       Click="cmdDelete_Click"
                                                                       Content="Elimina"
                                                                       Style="{StaticResource VulpesXButton}"
                                                                       Visibility="{Binding CanDeleteVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                                </DataTemplate>
                                            </telerik:GridViewColumn.CellTemplate>
                                        </telerik:GridViewColumn>
                                        <telerik:GridViewColumn Width="30">
                                            <telerik:GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <telerik:RadGlyph x:Name="rgPrint"
                                                                      Cursor="Hand"
                                                                      FontSize="18"
                                                                      Foreground="{DynamicResource VulpesXGreenBrush}"
                                                                      Glyph="&#xe90e;"
                                                                      MouseDown="rgPrint_MouseDown"
                                                                      ToolTip="Apri il PDF della fattura" />
                                                </DataTemplate>
                                            </telerik:GridViewColumn.CellTemplate>
                                        </telerik:GridViewColumn>
                                        <telerik:GridViewDataColumn Width="80" CellTemplate="{StaticResource InvoiceAttachmentsIcon}" Header="Allegati" />
                                        <telerik:GridViewDataColumn CellTemplate="{StaticResource FEStatus}" FilterMemberPath="SDISentStatusDescription" Header="Fattura elettronica" />
                                        <telerik:GridViewDataColumn Width="50" CellTemplate="{StaticResource SelfInvoiceIcon}" Header="" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding FTTIPODescription}" Header="Tipo" />
                                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding Causal.FullDescriptionSearchable}" Header="Causale" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding FTNUOR}"
                                                                    Header="N. provvisorio"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button x:Name="cmdEdit"
                                                            Margin="3"
                                                            HorizontalContentAlignment="Right"
                                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                                            Click="cmdEdit_Click"
                                                            Content="{Binding Path=FTNUOR}"
                                                            Cursor="Hand"
                                                            Foreground="{DynamicResource VulpesXBrush}" />
                                                </DataTemplate>
                                            </telerik:GridViewColumn.CellTemplate>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding DefinitiveID}" Header="N. definitivo" />
                                        <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy"
                                                                    DataMemberBinding="{Binding FTDAOR}"
                                                                    Header="Data"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="380" DataMemberBinding="{Binding CustomerFullDescriptionSearchable}" Header="Cliente">
                                            <telerik:GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button x:Name="cmdEdit"
                                                            Margin="3"
                                                            HorizontalContentAlignment="Left"
                                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                                            Click="cmdEditCustomer_Click"
                                                            Content="{Binding Path=CustomerFullDescriptionSearchable}"
                                                            Cursor="Hand"
                                                            Foreground="{DynamicResource VulpesXBrush}" />
                                                </DataTemplate>
                                            </telerik:GridViewColumn.CellTemplate>
                                            <telerik:GridViewColumn.AggregateFunctions>
                                                <telerik:CountFunction Caption="NUMERO : " ResultFormatString="{}{0:N0}" />
                                                <aggregates:InvoicesCustomSum />
                                            </telerik:GridViewColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Imponibile, StringFormat=N2}"
                                                                    Header="Imponibile"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button x:Name="cmdEditRows"
                                                            Margin="3"
                                                            HorizontalContentAlignment="Right"
                                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                                            Click="cmdEditRows_Click"
                                                            Content="{Binding Path=Imponibile, StringFormat=N2}"
                                                            ContentStringFormat="N2"
                                                            Cursor="Hand"
                                                            Foreground="{DynamicResource VulpesXBrush}" />
                                                </DataTemplate>
                                            </telerik:GridViewColumn.CellTemplate>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding StatusDescription}" Header="Stato" />
                                    </telerik:RadGridView.Columns>
                                </telerik:RadGridView>
                                <telerik:RadDataPager x:Name="rdpGrid"
                                                      Grid.Row="1"
                                                      Margin="0,-1,0,0"
                                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                                      FontSize="12"
                                                      IsTotalItemCountFixed="True"
                                                      PageSize="20"
                                                      Source="{Binding Items}" />
                            </Grid>
                        </telerik:RadBusyIndicator>
                    </Grid>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="ANDAMENTO" Header="ANDAMENTO">
                <telerik:RadTabItem.Content>
                    <Grid>
                        <telerik:RadBusyIndicator x:Name="bsyGridTrend"
                                                  BusyContent="Caricamento dati in corso..."
                                                  Foreground="{DynamicResource VulpesXBrush}"
                                                  IsBusy="{Binding IsBusy}"
                                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="5*" />
                                        <RowDefinition Height="5*" />
                                    </Grid.RowDefinitions>

                                    <telerik:RadCartesianChart x:Name="rccTrend"
                                                               Grid.Row="0"
                                                               Height="250"
                                                               HoverMode="FadeOtherSeries"
                                                               Palette="Fluent">
                                        <telerik:RadCartesianChart.Behaviors>
                                            <telerik:ChartPanAndZoomBehavior DragMode="Zoom" ZoomMode="Both" />
                                        </telerik:RadCartesianChart.Behaviors>
                                        <telerik:RadCartesianChart.HorizontalAxis>
                                            <telerik:CategoricalAxis />
                                        </telerik:RadCartesianChart.HorizontalAxis>
                                        <telerik:RadCartesianChart.VerticalAxis>
                                            <telerik:LinearAxis />
                                        </telerik:RadCartesianChart.VerticalAxis>
                                    </telerik:RadCartesianChart>
                                    <telerik:RadLegend Margin="5"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Top"
                                                       BorderThickness="1"
                                                       Items="{Binding ElementName=rccTrend, Path=LegendItems}" />

                                    <Grid Grid.Row="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="9*" />
                                            <RowDefinition Height="1*" />
                                        </Grid.RowDefinitions>
                                        <Grid.Resources>
                                            <selectors:FATTT00FTrendCellSelector x:Key="TrendCellSelector">
                                                <selectors:FATTT00FTrendCellSelector.PositiveRowStyle>
                                                    <DataTemplate>
                                                        <TextBlock Foreground="{DynamicResource VulpesXGreenBrush}" Text="{Binding TrendPercentage, StringFormat='{}{0:N2} %'}" TextAlignment="Right" />
                                                    </DataTemplate>
                                                </selectors:FATTT00FTrendCellSelector.PositiveRowStyle>
                                                <selectors:FATTT00FTrendCellSelector.NegativeRowStyle>
                                                    <DataTemplate>
                                                        <TextBlock Foreground="{DynamicResource VulpesXRedBrush}" Text="{Binding TrendPercentage, StringFormat='{}{0:N2} %'}" TextAlignment="Right" />
                                                    </DataTemplate>
                                                </selectors:FATTT00FTrendCellSelector.NegativeRowStyle>
                                                <selectors:FATTT00FTrendCellSelector.NeutroRowStyle>
                                                    <DataTemplate>
                                                        <TextBlock Foreground="{DynamicResource VulpesXYellowBrush}" Text="{Binding TrendPercentage, StringFormat='{}{0:N2} %'}" TextAlignment="Right" />
                                                    </DataTemplate>
                                                </selectors:FATTT00FTrendCellSelector.NeutroRowStyle>
                                            </selectors:FATTT00FTrendCellSelector>
                                        </Grid.Resources>
                                        <telerik:RadGridView x:Name="gvTrend"
                                                             Grid.Row="0"
                                                             AutoGenerateColumns="False"
                                                             CanUserFreezeColumns="False"
                                                             CanUserResizeColumns="False"
                                                             ColumnAggregatesAlignment="NextToGroupKey"
                                                             GroupRenderMode="Flat"
                                                             IsReadOnly="True"
                                                             ItemsSource="{Binding PagedSource, ElementName=rdpTrend}"
                                                             RowIndicatorVisibility="Collapsed"
                                                             SelectionMode="Single"
                                                             ShowGroupFooters="True"
                                                             ShowGroupPanel="True">
                                            <telerik:RadGridView.GroupDescriptors>
                                                <telerik:GroupDescriptor Member="Year" SortDirection="Descending" />
                                            </telerik:RadGridView.GroupDescriptors>
                                            <telerik:RadGridView.Columns>
                                                <telerik:GridViewDataColumn Width="100"
                                                                            ColumnGroupName="Year"
                                                                            DataMemberBinding="{Binding Year}"
                                                                            Header="Anno" />
                                                <telerik:GridViewDataColumn Width="100" DataMemberBinding="{Binding Month}" Header="Mese" />
                                                <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding Amount, StringFormat=N2}" Header="Fatturato" />
                                                <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding CreditAmount, StringFormat=N2}" Header="Note credito">
                                                    <telerik:GridViewColumn.AggregateFunctions>
                                                        <telerik:SumFunction Caption="TOTALE FATTURATO: " ResultFormatString="{}{0:N2}" SourceField="Amount" />
                                                        <telerik:SumFunction Caption="TOTALE NOTE CREDITO: " ResultFormatString="{}{0:N2}" SourceField="CreditAmount" />
                                                    </telerik:GridViewColumn.AggregateFunctions>
                                                </telerik:GridViewDataColumn>
                                                <telerik:GridViewDataColumn Width="150"
                                                                            CellTemplateSelector="{StaticResource TrendCellSelector}"
                                                                            DataMemberBinding="{Binding TrendPercentage}"
                                                                            Header="Trend (%)"
                                                                            HeaderTextAlignment="Right"
                                                                            TextAlignment="Right" />
                                            </telerik:RadGridView.Columns>
                                        </telerik:RadGridView>
                                        <telerik:RadDataPager x:Name="rdpTrend"
                                                              Grid.Row="1"
                                                              Margin="0,-1,0,0"
                                                              DisplayMode="FirstLastPreviousNextNumeric, Text"
                                                              FontSize="12"
                                                              IsTotalItemCountFixed="True"
                                                              PageSize="20"
                                                              Source="{Binding Trend.Months}" />

                                    </Grid>
                                </Grid>
                            </ScrollViewer>
                        </telerik:RadBusyIndicator>
                    </Grid>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>
    </Grid>

</UserControl>
