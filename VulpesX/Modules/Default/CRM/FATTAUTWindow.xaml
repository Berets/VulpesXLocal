<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.CRM.FATTAUTWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli autofattura"
                        Width="650"
                        Height="500"
                        Background="{DynamicResource VulpesXDarkWindowsBackgroundBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid Margin="0,15,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="35" />
                <RowDefinition Height="35" />
                <RowDefinition Height="35" />
                <RowDefinition Height="35" />
                <RowDefinition Height="35" />
                <RowDefinition Height="35" />
                <RowDefinition Height="35" />
                <RowDefinition Height="35" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="7*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Autofattura n." />
            <TextBlock Grid.Row="0"
                       Grid.Column="1"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding Data.FullIDText}" />
            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Fornitore" />
            <telerik:RadAutoCompleteBox x:Name="acSupplier"
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="5,2,15,2"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        DisplayMemberPath="FullDescriptionSearchable"
                                        ItemsSource="{Binding Suppliers}"
                                        LostFocus="ac_LostFocus"
                                        NoResultsContent="Nessun codice trovato"
                                        SelectedItem="{Binding SelectedSupplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectionChanged="acSupplier_SelectionChanged"
                                        SelectionMode="Single"
                                        TextSearchMode="Contains"
                                        TextSearchPath="FullDescriptionSearchable"
                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Data ricezione SDI" />
            <telerik:RadDateTimePicker Grid.Row="3"
                                       Grid.Column="1"
                                       Width="200"
                                       Margin="5,0,15,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       DateSelectionMode="Day"
                                       DateTimeWatermarkContent="Scegliere la data"
                                       DisplayFormat="Short"
                                       InputMode="DatePicker"
                                       SelectedValue="{Binding Data.FTAUDATRIC, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Identificativo SDI" />
            <TextBox Grid.Row="4"
                     Grid.Column="1"
                     Margin="5,0,15,0"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"
                     MaxLength="15"
                     Text="{Binding Data.FTAUINDSDI, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Row="5"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Numero fattura fornitore" />
            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                <TextBox Width="150"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         MaxLength="20"
                         Text="{Binding Data.FTAUNUMFAT, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Style="{StaticResource VulpesXLabel}" Text="del" />
                <telerik:RadDateTimePicker Width="200"
                                           Margin="5,0,15,0"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent="Scegliere la data"
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           SelectedValue="{Binding Data.FTAUDATFAT, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            </StackPanel>

            <TextBlock Grid.Row="7"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Registrazione di origine" />
            <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
                <TextBlock Margin="5,0,5,0" Style="{StaticResource VulpesXData}" Text="{Binding Data.FTAPNAN}" />
                <TextBlock Style="{StaticResource VulpesXLabel}" Text="/" />
                <TextBlock Margin="5,0,5,0" Style="{StaticResource VulpesXData}" Text="{Binding Data.FTAPNRE, StringFormat=N0}" />
            </StackPanel>

            <StackPanel Grid.Row="8"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                <Button Name="cmdCancel"
                        Width="200"
                        Margin="2"
                        BorderBrush="Gold"
                        BorderThickness="5,0,0,0"
                        Content="USCIRE"
                        FontSize="10"
                        IsCancel="True" />
                <Button Name="cmdSave"
                        Width="200"
                        Margin="2"
                        BorderBrush="ForestGreen"
                        BorderThickness="5,0,0,0"
                        Click="cmdSave_Click"
                        Content="SALVA"
                        FontSize="10"
                        IsDefault="True" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</sc:FluentDefaultWindow>
