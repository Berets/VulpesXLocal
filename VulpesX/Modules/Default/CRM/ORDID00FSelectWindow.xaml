<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.CRM.ORDID00FSelectWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Seleziona le righe degli ordini"
                        Width="1400"
                        Height="750"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Margin="10,0,0,0" Style="{DynamicResource VulpesXLabel}" Text="Cliente" />
            <TextBlock Margin="10,0,0,0" Style="{DynamicResource VulpesXData}" Text="{Binding FirstHead.Customer.FullDescriptionSearchable}" />
            <TextBlock Margin="10,0,0,0" Style="{DynamicResource VulpesXLabel}" Text="Destinazione" />
            <TextBlock Margin="10,0,0,0" Style="{DynamicResource VulpesXData}" Text="{Binding FirstHead.Recipient.FullDescriptionSearchable}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="35" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Style="{DynamicResource VulpesXTitle}" Text="RIGHE DA ORDINI" />
            <Grid Grid.Row="1" Margin="5,5,5,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="rgvRows"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserDeleteRows="False"
                                     CanUserFreezeColumns="False"
                                     CanUserInsertRows="False"
                                     CanUserResizeColumns="False"
                                     GroupRenderMode="Flat"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     RowIndicatorVisibility="Collapsed"
                                     SelectionMode="Extended"
                                     ShowGroupPanel="False">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewSelectColumn IsSelected="False" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding OTNUOR}"
                                                    Header="Ordine n."
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="60"
                                                    DataMemberBinding="{Binding ODRIGA}"
                                                    Header="Riga"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="300"
                                                    DataMemberBinding="{Binding SelectedProduct.FullDescriptionSearchable}"
                                                    Header="Prodotto"
                                                    IsReadOnly="True" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataMemberBinding="{Binding ODQTAV}"
                                                    Header="Quantita'"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="60"
                                                    DataMemberBinding="{Binding odunit}"
                                                    Header="UM"
                                                    HeaderTextAlignment="Center"
                                                    IsReadOnly="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="150"
                                                    DataMemberBinding="{Binding QuantityToSend}"
                                                    Header="Quantita da evadere"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="60"
                                                    DataMemberBinding="{Binding odunit}"
                                                    Header="UM"
                                                    HeaderTextAlignment="Center"
                                                    IsReadOnly="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="150"
                                                    DataMemberBinding="{Binding ODQTAEV}"
                                                    Header="Quantita gia' evasa"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="60"
                                                    DataMemberBinding="{Binding odunit}"
                                                    Header="UM"
                                                    HeaderTextAlignment="Center"
                                                    IsReadOnly="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding ODDACO}"
                                                    Header="Data consegna"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewComboBoxColumn Width="120"
                                                        DataMemberBinding="{Binding FulfillmentID}"
                                                        DisplayMemberPath="Description"
                                                        Header="S/A"
                                                        IsLightweightModeEnabled="True"
                                                        ItemsSourceBinding="{Binding Fulfillments}"
                                                        SelectedValueMemberPath="ID" />
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding AvailableRows}" />
            </Grid>
        </Grid>

        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
