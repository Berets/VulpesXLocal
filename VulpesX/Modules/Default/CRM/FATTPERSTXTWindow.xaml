<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.CRM.FATTPERSTXTWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Generazione file fatturazione"
                        Width="800"
                        Height="450"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">

    <telerik:RadBusyIndicator x:Name="bsyGrid"
                              Grid.Row="4"
                              BusyContent="Caricamento dati in corso..."
                              Foreground="{DynamicResource VulpesXBrush}"
                              IsBusy="{Binding IsBusy}"
                              OverlayStyle="{StaticResource WaitOverlayStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35" />
                <RowDefinition Height="35" />
                <RowDefinition Height="35" />
                <RowDefinition Height="35" />
                <RowDefinition Height="35" />
                <RowDefinition Height="*" />
                <RowDefinition Height="35" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="7*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Tipo file" />
            <telerik:RadComboBox x:Name="rcbTypes"
                                 Grid.Row="0"
                                 Grid.Column="1"
                                 Width="200"
                                 Margin="5,2,15,2"
                                 HorizontalAlignment="Left"
                                 HorizontalContentAlignment="Left"
                                 DisplayMemberPath="txtdes"
                                 ItemsSource="{Binding Types}"
                                 SelectedValue="{Binding SelectedType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 SelectionChanged="rcbTypes_SelectionChanged" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Cliente" />
            <telerik:RadAutoCompleteBox x:Name="acCustomer"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="5,2,15,2"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        DisplayMemberPath="FullDescriptionSearchable"
                                        ItemsSource="{Binding Customers}"
                                        LostFocus="acCustomer_LostFocus"
                                        NoResultsContent="Nessun codice trovato"
                                        SelectedItem="{Binding SelectedCustomer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectionMode="Single"
                                        TextSearchMode="Contains"
                                        TextSearchPath="FullDescriptionSearchable"
                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Dal" />
            <telerik:RadDatePicker Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="5,2,15,2"
                                   SelectedValue="{Binding From, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Al" />
            <telerik:RadDatePicker Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="5,2,15,2"
                                   SelectedValue="{Binding To, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Percorso" />
            <Grid Grid.Row="4" Grid.Column="1" Margin="5,2,15,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="8*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Text="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button x:Name="btnBrowse" Grid.Column="1" Content="..." />
            </Grid>

            <StackPanel Grid.Row="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
                <Button Name="cmdSave"
                        Click="cmdSave_Click"
                        Content="SALVA"
                        Style="{StaticResource VulpesXConfirmButton}" />
            </StackPanel>
        </Grid>
    </telerik:RadBusyIndicator>
</sc:FluentDefaultWindow>
