<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.CRM.ORDIT00FInvoicesWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Fatture collegate all'ordine"
                        Width="1000"
                        Height="650"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <telerik:RadBusyIndicator x:Name="bsyWait"
                                  Grid.Row="0"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">

            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Grid Margin="5,5,5,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="35" />
                    </Grid.RowDefinitions>
                    <Grid.Resources>
                        <DataTemplate x:Key="SelfInvoiceIcon">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        BorderBrush="{Binding SelfInvoiceStatusColor}"
                                        Cursor="Hand"
                                        Visibility="{Binding SelfInvoiceStatusVisibility}">
                                    <telerik:RadGlyph x:Name="rgSelfInvoiceIcon"
                                                      FontSize="14"
                                                      Foreground="{Binding SelfInvoiceStatusColor, Converter={StaticResource stringToColorConverter}}"
                                                      Glyph="&#xe102;"
                                                      MouseDown="rgSelfInvoiceIcon_MouseDown" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                        <DataTemplate x:Key="InvoiceAttachmentsIcon">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="{Binding InvoiceAttachmentsStatusColor, Converter={StaticResource stringToColorConverter}}" Cursor="Hand">
                                    <Label x:Name="label" ToolTip="{Binding InvoiceAttachmentsStatusText}">
                                        <telerik:RadGlyph x:Name="rgInvoiceAttachmentsIcon"
                                                          FontSize="14"
                                                          Foreground="{Binding InvoiceAttachmentsStatusColor, Converter={StaticResource stringToColorConverter}}"
                                                          Glyph="&#xe10e;"
                                                          MouseDown="rgInvoiceAttachmentsIcon_MouseDown" />
                                    </Label>
                                </Border>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding InvoiceAttachmentsText}" />
                            </Grid>
                        </DataTemplate>
                    </Grid.Resources>
                    <telerik:RadGridView x:Name="GridView"
                                         Grid.Row="0"
                                         AutoGenerateColumns="False"
                                         CanUserFreezeColumns="False"
                                         CanUserResizeColumns="False"
                                         ColumnAggregatesAlignment="NextToGroupKey"
                                         GroupRenderMode="Flat"
                                         IsReadOnly="True"
                                         ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                         RowIndicatorVisibility="Collapsed"
                                         ShowColumnFooters="True"
                                         ShowGroupFooters="True"
                                         ShowGroupPanel="True">
                        <telerik:RadGridView.Columns>
                            <telerik:GridViewColumn Width="110">
                                <telerik:GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <telerik:RadButton x:Name="cmdDelete"
                                                           telerik:TouchManager.TouchMode="HitTestHidden"
                                                           BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                           Click="cmdDelete_Click"
                                                           Content="Elimina"
                                                           Style="{StaticResource VulpesXButton}"
                                                           Visibility="{Binding CanDeleteVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                    </DataTemplate>
                                </telerik:GridViewColumn.CellTemplate>
                            </telerik:GridViewColumn>
                            <telerik:GridViewDataColumn Width="80" CellTemplate="{StaticResource InvoiceAttachmentsIcon}" Header="Allegati" />
                            <telerik:GridViewDataColumn Width="50" CellTemplate="{StaticResource SelfInvoiceIcon}" Header="" />
                            <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding FTTIPODescription}" Header="Tipo" />
                            <telerik:GridViewDataColumn Width="120"
                                                        DataMemberBinding="{Binding FTNUOR}"
                                                        Header="N. provvisorio"
                                                        HeaderTextAlignment="Right"
                                                        TextAlignment="Right">
                                <telerik:GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button x:Name="cmdEdit"
                                                Margin="3"
                                                HorizontalContentAlignment="Right"
                                                BorderBrush="{DynamicResource VulpesXBrush}"
                                                Click="cmdEdit_Click"
                                                Content="{Binding Path=FTNUOR}"
                                                Cursor="Hand"
                                                Foreground="{DynamicResource VulpesXBrush}" />
                                    </DataTemplate>
                                </telerik:GridViewColumn.CellTemplate>
                            </telerik:GridViewDataColumn>
                            <telerik:GridViewDataColumn Width="120"
                                                        DataMemberBinding="{Binding FTNUFD}"
                                                        Header="N. definitivo"
                                                        HeaderTextAlignment="Right"
                                                        TextAlignment="Right" />
                            <telerik:GridViewDataColumn Width="120"
                                                        DataFormatString="dd/MM/yyyy"
                                                        DataMemberBinding="{Binding FTDAOR}"
                                                        Header="Data"
                                                        HeaderTextAlignment="Center"
                                                        TextAlignment="Center" />
                            <telerik:GridViewDataColumn Width="350" DataMemberBinding="{Binding Customer.FullDescriptionSearchable}" Header="Cliente">
                                <telerik:GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button x:Name="cmdEdit"
                                                Margin="3"
                                                HorizontalContentAlignment="Left"
                                                BorderBrush="{DynamicResource VulpesXBrush}"
                                                Click="cmdEditCustomer_Click"
                                                Content="{Binding Path=Customer.FullDescriptionSearchable}"
                                                Cursor="Hand"
                                                Foreground="{DynamicResource VulpesXBrush}" />
                                    </DataTemplate>
                                </telerik:GridViewColumn.CellTemplate>
                            </telerik:GridViewDataColumn>
                            <telerik:GridViewDataColumn Width="250"
                                                        DataFormatString="N2"
                                                        DataMemberBinding="{Binding Imponibile, StringFormat=N2}"
                                                        Header="Imponibile"
                                                        HeaderTextAlignment="Right"
                                                        TextAlignment="Right">
                                <telerik:GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button x:Name="cmdEditRows"
                                                Margin="3"
                                                HorizontalContentAlignment="Right"
                                                BorderBrush="{DynamicResource VulpesXBrush}"
                                                Click="cmdEditRows_Click"
                                                Content="{Binding Path=Imponibile, StringFormat=N2}"
                                                ContentStringFormat="N2"
                                                Cursor="Hand"
                                                Foreground="{DynamicResource VulpesXBrush}" />
                                    </DataTemplate>
                                </telerik:GridViewColumn.CellTemplate>
                                <telerik:GridViewColumn.AggregateFunctions>
                                    <telerik:CountFunction Caption="NUMERO FATTURE: " ResultFormatString="{}{0:N0}" />
                                    <telerik:SumFunction Caption="TOTALE IMPONIBILE: " ResultFormatString="{}{0:N2}" SourceField="Imponibile" />
                                </telerik:GridViewColumn.AggregateFunctions>
                            </telerik:GridViewDataColumn>
                        </telerik:RadGridView.Columns>
                    </telerik:RadGridView>
                    <telerik:RadDataPager x:Name="rdpGrid"
                                          Grid.Row="1"
                                          Margin="0,-1,0,0"
                                          DisplayMode="FirstLastPreviousNextNumeric, Text"
                                          FontSize="12"
                                          IsTotalItemCountFixed="True"
                                          PageSize="20"
                                          Source="{Binding Heads}" />
                </Grid>
            </ScrollViewer>
        </telerik:RadBusyIndicator>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
