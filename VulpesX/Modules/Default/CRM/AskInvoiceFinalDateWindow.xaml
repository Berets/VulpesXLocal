<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.CRM.AskInvoiceFinalDateWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Stampa definitiva fattura, selezione della data"
                        Width="500"
                        Height="150"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="None"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="7*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Data" />
        <telerik:RadDateTimePicker x:Name="rdpDate"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   Width="200"
                                   Margin="5,0,15,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   DateSelectionMode="Day"
                                   DateTimeWatermarkContent="Scegliere la data"
                                   DisplayFormat="Short"
                                   InputMode="DatePicker"
                                   SelectedValue="{Binding Data.OTDAOR, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Width="200"
                    Margin="2"
                    BorderBrush="Gold"
                    BorderThickness="5,0,0,0"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    FontSize="10"
                    IsCancel="True" />
            <Button Name="cmdSave"
                    Width="200"
                    Margin="2"
                    BorderBrush="ForestGreen"
                    BorderThickness="5,0,0,0"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    FontSize="10"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
