<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.CRM.ORDITALEWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Promeoria sull'ordine cliente"
                        Width="900"
                        Height="500"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid>
                <telerik:RadBusyIndicator x:Name="bsyGrid"
                                          Grid.Row="2"
                                          BusyContent="Caricamento dati in corso..."
                                          Foreground="{DynamicResource VulpesXBrush}"
                                          IsBusy="{Binding IsBusy}"
                                          OverlayStyle="{StaticResource WaitOverlayStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="35" />
                        </Grid.RowDefinitions>
                        <telerik:RadGridView x:Name="GridView"
                                             Grid.Row="0"
                                             AddingNewDataItem="GridView_AddingNewDataItem"
                                             AutoGenerateColumns="False"
                                             CanUserFreezeColumns="False"
                                             CanUserInsertRows="True"
                                             CanUserResizeColumns="False"
                                             GroupRenderMode="Flat"
                                             ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                             NewRowPosition="Top"
                                             RowEditEnded="GridView_RowEditEnded"
                                             RowIndicatorVisibility="Visible"
                                             RowValidating="GridView_RowValidating"
                                             ShowGroupPanel="False"
                                             Tag="{Binding IsEnabled}">
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewDataColumn Width="750" DataMemberBinding="{Binding OTADESC}" Header="Promemoria" />
                                <telerik:GridViewCheckBoxColumn DataMemberBinding="{Binding OTAATTI}"
                                                                Header="Attivo"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                            </telerik:RadGridView.Columns>
                        </telerik:RadGridView>
                        <telerik:RadDataPager x:Name="rdpGrid"
                                              Grid.Row="1"
                                              Margin="0,-1,0,0"
                                              DisplayMode="FirstLastPreviousNextNumeric, Text"
                                              FontSize="12"
                                              IsTotalItemCountFixed="True"
                                              PageSize="20"
                                              Source="{Binding Alerts}" />
                    </Grid>
                </telerik:RadBusyIndicator>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>

    </Grid>
</sc:FluentDefaultWindow>
