<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.CRM.OFFETAL00FWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Allegati all'offerta"
                        Width="1000"
                        Height="500"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid>
                <telerik:RadBusyIndicator x:Name="bsyGrid"
                                          BusyContent="Caricamento dati in corso..."
                                          Foreground="{DynamicResource VulpesXBrush}"
                                          IsBusy="{Binding IsBusy}"
                                          OverlayStyle="{StaticResource WaitOverlayStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="35" />
                        </Grid.RowDefinitions>
                        <Grid.Resources>
                            <DataTemplate x:Key="DownloadIcon">
                                <Border x:Name="boDownload"
                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                        Cursor="Hand"
                                        MouseDown="boDownload_MouseDown"
                                        Visibility="{Binding DownloadsVisibility, Converter={StaticResource boolToVisibilityConverter}}">
                                    <Label x:Name="label" ToolTip="Download dell'allegato">
                                        <telerik:RadGlyph FontSize="14" Foreground="{DynamicResource VulpesXBrush}" Glyph="&#xe132;" />
                                    </Label>
                                </Border>
                            </DataTemplate>
                            <DataTemplate x:Key="OpenIcon">
                                <Border x:Name="boOpen"
                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                        Cursor="Hand"
                                        MouseDown="boOpen_MouseDown"
                                        Visibility="{Binding DownloadsVisibility, Converter={StaticResource boolToVisibilityConverter}}">
                                    <Label x:Name="label" ToolTip="Apri l'allegato (il dispositivo deve avere il software necessario all'apertura del tipo di file selezionato)">
                                        <telerik:RadGlyph FontSize="14" Foreground="{DynamicResource VulpesXBrush}" Glyph="&#xe134;" />
                                    </Label>
                                </Border>
                            </DataTemplate>
                        </Grid.Resources>
                        <telerik:RadGridView x:Name="GridView"
                                             Grid.Row="0"
                                             AddingNewDataItem="GridView_AddingNewDataItem"
                                             AutoGenerateColumns="False"
                                             CanUserFreezeColumns="False"
                                             CanUserInsertRows="True"
                                             CanUserResizeColumns="False"
                                             Deleting="GridView_Deleting"
                                             GroupRenderMode="Flat"
                                             IsReadOnly="{Binding IsReadonly}"
                                             ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                             NewRowPosition="Top"
                                             RowEditEnded="GridView_RowEditEnded"
                                             RowIndicatorVisibility="Visible"
                                             RowValidating="GridView_RowValidating"
                                             SelectionMode="Extended"
                                             ShowGroupPanel="False"
                                             Tag="{Binding IsEnabled}">
                            <telerik:RadGridView.Columns>
                                <telerik:GridViewColumn Width="110">
                                    <telerik:GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <telerik:RadButton x:Name="cmdSelect"
                                                               telerik:TouchManager.TouchMode="HitTestHidden"
                                                               BorderBrush="{DynamicResource VulpesXBrush}"
                                                               Click="cmdSelect_Click"
                                                               Content="Seleziona file"
                                                               IsEnabled="{Binding Tag, RelativeSource={RelativeSource AncestorType=telerik:RadGridView}}"
                                                               Style="{StaticResource VulpesXButton}" />
                                        </DataTemplate>
                                    </telerik:GridViewColumn.CellTemplate>
                                </telerik:GridViewColumn>
                                <telerik:GridViewDataColumn Width="350"
                                                            DataMemberBinding="{Binding OFTANAME}"
                                                            Header="Nome file"
                                                            IsReadOnly="True" />
                                <telerik:GridViewDataColumn Width="120"
                                                            DataMemberBinding="{Binding OFTASIZEText}"
                                                            Header="Dimensione"
                                                            HeaderTextAlignment="Right"
                                                            IsReadOnly="True"
                                                            TextAlignment="Right" />
                                <telerik:GridViewDataColumn Width="40"
                                                            CellTemplate="{StaticResource DownloadIcon}"
                                                            Header="{x:Null}"
                                                            IsFilterable="False"
                                                            IsReadOnly="True"
                                                            IsSearchable="False"
                                                            IsSortable="False"
                                                            TextAlignment="Center" />
                                <telerik:GridViewDataColumn Width="40"
                                                            CellTemplate="{StaticResource OpenIcon}"
                                                            Header="{x:Null}"
                                                            IsFilterable="False"
                                                            IsReadOnly="True"
                                                            IsSearchable="False"
                                                            IsSortable="False"
                                                            TextAlignment="Center" />
                                <telerik:GridViewDataColumn Width="140"
                                                            DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                            DataMemberBinding="{Binding added}"
                                                            Header="Aggiunto il"
                                                            HeaderTextAlignment="Center"
                                                            IsReadOnly="True"
                                                            TextAlignment="Center" />
                                <telerik:GridViewDataColumn Width="250"
                                                            DataMemberBinding="{Binding add_user}"
                                                            Header="da"
                                                            IsReadOnly="True" />

                            </telerik:RadGridView.Columns>
                        </telerik:RadGridView>
                        <telerik:RadDataPager x:Name="rdpGrid"
                                              Grid.Row="1"
                                              Margin="0,-1,0,0"
                                              DisplayMode="FirstLastPreviousNextNumeric, Text"
                                              FontSize="12"
                                              IsTotalItemCountFixed="True"
                                              PageSize="20"
                                              Source="{Binding Head.Attachments}" />
                    </Grid>
                </telerik:RadBusyIndicator>
            </Grid>
        </ScrollViewer>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>

</sc:FluentDefaultWindow>
