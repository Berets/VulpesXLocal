<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.CRM.LISCLIWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli listino cliente"
                        Width="700"
                        Height="650"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="DATI GENERALI" Header="DATI GENERALI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Cliente" />
                            <telerik:RadAutoCompleteBox x:Name="acCustomer"
                                                        Grid.Row="0"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Customers}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding SelectedCustomer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acCustomer_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Destinatario" />
                            <telerik:RadAutoCompleteBox x:Name="acRecipient"
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescription"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Recipients}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding SelectedRecipient, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acRecipient_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescription"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Prodotto" />
                            <telerik:RadAutoCompleteBox Grid.Row="2"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Data.Products}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding Data.Product, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Codifica del cliente" />
                            <DockPanel Grid.Row="3" Grid.Column="1" HorizontalAlignment="Stretch">
                                <TextBox Width="120"
                                         Margin="5,2,2,2"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         DockPanel.Dock="Left"
                                         MaxLength="50"
                                         Text="{Binding Data.customerProductID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="5,2,15,2"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         DockPanel.Dock="Right"
                                         MaxLength="255"
                                         Text="{Binding Data.customerProductDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Dal" />
                            <telerik:RadDateTimePicker Grid.Row="5"
                                                       Grid.Column="1"
                                                       Width="200"
                                                       Margin="5,0,15,0"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       DateSelectionMode="Day"
                                                       DateTimeWatermarkContent="Scegliere la data"
                                                       DisplayFormat="Short"
                                                       InputMode="DatePicker"
                                                       SelectedValue="{Binding Data.fromDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Al" />
                            <telerik:RadDateTimePicker Grid.Row="6"
                                                       Grid.Column="1"
                                                       Width="200"
                                                       Margin="5,0,15,0"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       DateSelectionMode="Day"
                                                       DateTimeWatermarkContent="Scegliere la data"
                                                       DisplayFormat="Short"
                                                       InputMode="DatePicker"
                                                       SelectedValue="{Binding Data.toDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Da" />
                            <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadNumericUpDown Width="200"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          NumberDecimalDigits="6"
                                                          Value="{Binding Data.fromQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <telerik:RadComboBox Width="100"
                                                     Margin="2,1,5,1"
                                                     HorizontalAlignment="Left"
                                                     HorizontalContentAlignment="Left"
                                                     DisplayMemberPath="Description"
                                                     FontSize="10"
                                                     IsEditable="True"
                                                     ItemsSource="{Binding Data.UMs}"
                                                     SelectedValue="{Binding Data.unit_id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     SelectedValuePath="ID" />
                            </StackPanel>
                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="A" />
                            <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadNumericUpDown Width="200"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          NumberDecimalDigits="6"
                                                          Value="{Binding Data.toQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{DynamicResource VulpesXData}" Text="{Binding Data.unit_id, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Grid.Row="9"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Prezzo" />
                            <telerik:RadNumericUpDown Grid.Row="9"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      Minimum="0"
                                                      NumberDecimalDigits="6"
                                                      Value="{Binding Data.price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="10"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Nota" />
                            <TextBox Grid.Row="10"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="255"
                                     Text="{Binding Data.description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="11"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Sconto 1" />
                            <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadNumericUpDown Width="200"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.discount1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <telerik:RadComboBox Grid.Row="0"
                                                     Grid.Column="0"
                                                     Width="200"
                                                     Margin="5,2,15,2"
                                                     HorizontalAlignment="Left"
                                                     HorizontalContentAlignment="Left"
                                                     DisplayMemberPath="Description"
                                                     IsEditable="True"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding ValueTypes}"
                                                     SelectedValue="{Binding Data.discountType1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     SelectedValuePath="ID" />
                            </StackPanel>
                            <TextBlock Grid.Row="12"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Sconto 2" />
                            <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadNumericUpDown Width="200"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.discount2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <telerik:RadComboBox Grid.Row="0"
                                                     Grid.Column="0"
                                                     Width="200"
                                                     Margin="5,2,15,2"
                                                     HorizontalAlignment="Left"
                                                     HorizontalContentAlignment="Left"
                                                     DisplayMemberPath="Description"
                                                     IsEditable="True"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding ValueTypes}"
                                                     SelectedValue="{Binding Data.discountType2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     SelectedValuePath="ID" />
                            </StackPanel>
                            <TextBlock Grid.Row="13"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Sconto 3" />
                            <StackPanel Grid.Row="13" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadNumericUpDown Width="200"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.discount3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <telerik:RadComboBox Grid.Row="0"
                                                     Grid.Column="0"
                                                     Width="200"
                                                     Margin="5,2,15,2"
                                                     HorizontalAlignment="Left"
                                                     HorizontalContentAlignment="Left"
                                                     DisplayMemberPath="Description"
                                                     IsEditable="True"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding ValueTypes}"
                                                     SelectedValue="{Binding Data.discountType3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     SelectedValuePath="ID" />
                            </StackPanel>
                            <TextBlock Grid.Row="14"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Maggiorazione" />
                            <StackPanel Grid.Row="14" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadNumericUpDown Width="200"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.surcharge, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <telerik:RadComboBox Grid.Row="0"
                                                     Grid.Column="0"
                                                     Width="200"
                                                     Margin="5,2,15,2"
                                                     HorizontalAlignment="Left"
                                                     HorizontalContentAlignment="Left"
                                                     DisplayMemberPath="Description"
                                                     IsEditable="True"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding ValueTypes}"
                                                     SelectedValue="{Binding Data.surchargeType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     SelectedValuePath="ID" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Inserito il" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultimo aggiornamento il" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Annullato il" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Motivo annullamento" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Margin="5,2,2,2"
                                       Style="{StaticResource VulpesXData}"
                                       Text="{Binding Data.canceledNote}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>

    </Grid>
</sc:FluentDefaultWindow>
