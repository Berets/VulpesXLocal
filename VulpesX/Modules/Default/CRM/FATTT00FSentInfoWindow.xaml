<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.CRM.FATTT00FSentInfoWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli sull'invio del file"
                        Width="800"
                        Height="450"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <telerik:RadBusyIndicator x:Name="bsyWait"
                              Grid.Row="5"
                              BusyContent="Caricamento dati in corso..."
                              Foreground="{DynamicResource VulpesXBrush}"
                              IsBusy="{Binding IsBusy}"
                              OverlayStyle="{StaticResource WaitOverlayStyle}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,15,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Codice SDI" />
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Style="{StaticResource VulpesXData}"
                           Text="{Binding Result.SdiID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Padding="50,0,0,0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Formato invio" />
                <TextBlock Grid.Row="0"
                           Grid.Column="3"
                           Style="{StaticResource VulpesXData}"
                           Text="{Binding Result.SendFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Data ed ora invio" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Style="{StaticResource VulpesXData}"
                           Text="{Binding Result.Sent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Codice destinatario" />
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Style="{StaticResource VulpesXData}"
                           Text="{Binding Result.Code, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="PEC" />
                <TextBlock Grid.Row="3"
                           Grid.Column="1"
                           Grid.ColumnSpan="3"
                           Style="{StaticResource VulpesXData}"
                           Text="{Binding Result.PEC, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Allegati" />
                <CheckBox Grid.Row="4"
                          Grid.Column="1"
                          Margin="20,0,0,0"
                          IsChecked="{Binding Result.HasAttachments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          IsEnabled="False" />

                <TextBlock Grid.Row="4"
                           Grid.Column="2"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Copia cortesia" />
                <CheckBox Grid.Row="4"
                          Grid.Column="3"
                          Margin="20,0,0,0"
                          IsChecked="{Binding Result.HasPDF, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          IsEnabled="False" />

                <StackPanel Grid.Row="6"
                            Grid.RowSpan="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="4"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Orientation="Horizontal">
                    <Button Name="cmdRecreate"
                            Width="220"
                            Margin="2"
                            VerticalAlignment="Stretch"
                            BorderBrush="MediumVioletRed"
                            BorderThickness="5,0,0,0"
                            Click="cmdRecreate_Click"
                            Content="RIGENERA IL FILE XML (non inviabile)"
                            FontSize="10"
                            Foreground="White" />
                    <Button Name="cmdSave"
                            Width="220"
                            Margin="2"
                            VerticalAlignment="Stretch"
                            BorderBrush="SteelBlue"
                            BorderThickness="5,0,0,0"
                            Click="cmdSave_Click"
                            Content="SALVA IL FILE XML INVIATO"
                            FontSize="10"
                            Foreground="White" />
                    <Button Name="cmdOpen"
                            Width="220"
                            Margin="2"
                            VerticalAlignment="Stretch"
                            BorderBrush="SteelBlue"
                            BorderThickness="5,0,0,0"
                            Click="cmdOpen_Click"
                            Content="APRI IL FILE XML INVIATO"
                            FontSize="10"
                            Foreground="White" />
                </StackPanel>

                <StackPanel Grid.Row="8"
                            Grid.Column="0"
                            Grid.ColumnSpan="4"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Orientation="Horizontal">
                    <Button Name="cmdPrint"
                            Width="220"
                            Margin="2"
                            VerticalAlignment="Stretch"
                            BorderBrush="SteelBlue"
                            BorderThickness="5,0,0,0"
                            Click="cmdPrint_Click"
                            Content="STAMPA IL FILE XML INVIATO"
                            FontSize="10"
                            Foreground="White" />
                </StackPanel>


                <Button Name="cmdCancel"
                        Grid.Row="10"
                        Grid.Column="2"
                        Grid.ColumnSpan="2"
                        Width="220"
                        Height="40"
                        Margin="2,2,12,5"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        BorderBrush="Gold"
                        BorderThickness="5,0,0,0"
                        Content="CHIUDI"
                        FontSize="10"
                        Foreground="White"
                        IsCancel="True" />
            </Grid>
        </ScrollViewer>
    </telerik:RadBusyIndicator>
</sc:FluentDefaultWindow>
