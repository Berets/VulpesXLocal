<UserControl x:Class="VulpesX.Modules.Default.CRM.ORDIT00FView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <UserControl.Resources>
        <selectors:OrdersListSelector x:Key="OrdersListSelector">
            <selectors:OrdersListSelector.DefaultRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </selectors:OrdersListSelector.DefaultRowStyle>
            <selectors:OrdersListSelector.CanceledRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="OrangeRed" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="ToolTip" Value="Elemento annullato" />
                </Style>
            </selectors:OrdersListSelector.CanceledRowStyle>
            <selectors:OrdersListSelector.PartialRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="DarkGoldenrod" />
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="ToolTip" Value="Ordine completo parzialmente, evadibile in parte" />
                </Style>
            </selectors:OrdersListSelector.PartialRowStyle>
            <selectors:OrdersListSelector.NotReadyRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="Firebrick" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="ToolTip" Value="Ordine incompleto, non disponibile per l'evasione" />
                </Style>
            </selectors:OrdersListSelector.NotReadyRowStyle>
            <selectors:OrdersListSelector.ReadyRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="SeaGreen" />
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="ToolTip" Value="Ordine completo, pronto per l'evasione totale" />
                </Style>
            </selectors:OrdersListSelector.ReadyRowStyle>
        </selectors:OrdersListSelector>

        <selectors:OrdersDetalListSelector x:Key="OrdersListDetailsSelector">
            <selectors:OrdersDetalListSelector.DefaultRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </selectors:OrdersDetalListSelector.DefaultRowStyle>
            <selectors:OrdersDetalListSelector.CanceledRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="OrangeRed" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="ToolTip" Value="Elemento annullato" />
                </Style>
            </selectors:OrdersDetalListSelector.CanceledRowStyle>
            <selectors:OrdersDetalListSelector.PartialRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="DarkGoldenrod" />
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="ToolTip" Value="Ordine attualmente in produzione o in attesa di materiale ordinato" />
                </Style>
            </selectors:OrdersDetalListSelector.PartialRowStyle>
            <selectors:OrdersDetalListSelector.WaitingRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="MediumVioletRed" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="ToolTip" Value="Ordine in attesa di materia prima" />
                </Style>
            </selectors:OrdersDetalListSelector.WaitingRowStyle>
            <selectors:OrdersDetalListSelector.NotReadyRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="Firebrick" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="ToolTip" Value="Ordine non in produzione" />
                </Style>
            </selectors:OrdersDetalListSelector.NotReadyRowStyle>
            <selectors:OrdersDetalListSelector.ReadyRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="SeaGreen" />
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="ToolTip" Value="Ordine di produzione terminato" />
                </Style>
            </selectors:OrdersDetalListSelector.ReadyRowStyle>
        </selectors:OrdersDetalListSelector>

        <DataTemplate x:Key="OrderAttachmentsIcon">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="{Binding OrderAttachmentsStatusColor, Converter={StaticResource stringToColorConverter}}" Cursor="Hand">
                    <Label x:Name="label" ToolTip="{Binding OrderAttachmentsStatusText}">
                        <telerik:RadGlyph x:Name="rgOrderAttachmentsIcon"
                                          FontSize="14"
                                          Foreground="{Binding OrderAttachmentsStatusColor, Converter={StaticResource stringToColorConverter}}"
                                          Glyph="&#xe10e;"
                                          MouseDown="rgOrderAttachmentsIcon_MouseDown" />
                    </Label>
                </Border>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding OrderAttachmentsText}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="DDTIcon">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="{Binding DDTStatusColor, Converter={StaticResource stringToColorConverter}}" Cursor="Hand">
                    <Label x:Name="label" ToolTip="{Binding DDTStatusText}">
                        <telerik:RadGlyph x:Name="rgDDTIcon"
                                          FontSize="14"
                                          Foreground="{Binding DDTStatusColor, Converter={StaticResource stringToColorConverter}}"
                                          Glyph="&#xe700;"
                                          MouseDown="rgDDTIcon_MouseDown" />
                    </Label>
                </Border>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding DDTText}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="InvoiceIcon">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="{Binding InvoicesStatusColor, Converter={StaticResource stringToColorConverter}}" Cursor="Hand">
                    <Label x:Name="label" ToolTip="{Binding InvoicesStatusText}">
                        <telerik:RadGlyph x:Name="rgInvoicesIcon"
                                          FontSize="14"
                                          Foreground="{Binding InvoicesStatusColor, Converter={StaticResource stringToColorConverter}}"
                                          Glyph="&#xe906;"
                                          MouseDown="rgInvoicesIcon_MouseDown" />
                    </Label>
                </Border>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding InvoicesText}" />
            </Grid>
        </DataTemplate>

    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource VulpesXTitle}" Text="GESTIONE ORDINI CLIENTI" />

        <telerik:RadTabControl Grid.Row="2"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="GESTIONE" Header="GESTIONE">
                <telerik:RadTabItem.Content>
                    <telerik:RadBusyIndicator x:Name="bsyGrid"
                                              BusyContent="Caricamento dati in corso..."
                                              Foreground="{DynamicResource VulpesXBrush}"
                                              IsBusy="{Binding IsBusy}"
                                              OverlayStyle="{StaticResource WaitOverlayStyle}">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="35" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,5,0,0">
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                                    <telerik:RadComboBox x:Name="cmbStatus"
                                                         Margin="5"
                                                         HorizontalAlignment="Stretch"
                                                         DisplayMemberPath="Description"
                                                         SelectedValuePath="ID"
                                                         SelectionChanged="cmbStatus_SelectionChanged" />

                                    <telerik:RadDatePicker x:Name="dtpYear"
                                                           Grid.Column="3"
                                                           Margin="5"
                                                           HorizontalAlignment="Stretch"
                                                           HorizontalContentAlignment="Right"
                                                           DateSelectionMode="Year"
                                                           DisplayFormat="Short"
                                                           SelectionChanged="dtpYear_SelectionChanged" />
                                    <Button Name="cmdInsert"
                                            Margin="5"
                                            Click="cmdInsert_Click"
                                            Content="INSERISCI"
                                            Style="{StaticResource VulpesXInsertButton}" />

                                    <Button Name="cmdDDT"
                                            Width="150"
                                            Margin="5"
                                            BorderBrush="{DynamicResource VulpesXYellowBrush}"
                                            Click="cmdDDT_Click"
                                            Content="CREA DDT"
                                            Style="{StaticResource VulpesXButton}"
                                            ToolTip="Crea i DDT per gli ordini selezionati"
                                            ToolTipService.ShowOnDisabled="True" />
                                    <Button Name="cmdInvoice"
                                            Width="150"
                                            Margin="5"
                                            BorderBrush="{DynamicResource VulpesXVioletBrush}"
                                            Click="cmdInvoice_Click"
                                            Content="CREA FATTURA"
                                            Style="{StaticResource VulpesXButton}"
                                            ToolTip="Crea le fatture per gli ordini selezionati"
                                            ToolTipService.ShowOnDisabled="True" />

                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" HorizontalAlignment="Stretch">

                                <telerik:RadWatermarkTextBox Name="txtSearch"
                                                             Margin="5"
                                                             TextChanged="txtSearch_TextChanged"
                                                             WatermarkContent="Cerca..." />
                            </Grid>



                            <telerik:RadGridView x:Name="GridView"
                                                 Grid.Row="2"
                                                 AutoGenerateColumns="False"
                                                 CanUserFreezeColumns="False"
                                                 CanUserResizeColumns="False"
                                                 ColumnAggregatesAlignment="NextToGroupKey"
                                                 GroupRenderMode="Flat"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                                 RowIndicatorVisibility="Collapsed"
                                                 RowStyleSelector="{StaticResource OrdersListSelector}"
                                                 SelectionChanged="GridView_SelectionChanged"
                                                 SelectionMode="Extended"
                                                 ShowColumnFooters="True"
                                                 ShowGroupFooters="True"
                                                 ShowGroupPanel="True">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewColumn Width="70">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadButton x:Name="cmdDelete"
                                                                   telerik:TouchManager.TouchMode="HitTestHidden"
                                                                   BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                                   Click="cmdDelete_Click"
                                                                   Content="Elimina"
                                                                   Style="{StaticResource VulpesXButton}"
                                                                   Visibility="{Binding CanDeleteVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewColumn Width="30">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadGlyph x:Name="rgAlert"
                                                                  Cursor="Hand"
                                                                  FontSize="14"
                                                                  Foreground="{Binding AlertColor, Converter={StaticResource stringToColorConverter}}"
                                                                  Glyph="&#xe400;"
                                                                  MouseDown="rgAlert_MouseDown"
                                                                  ToolTip="{Binding AlertToolTip}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewDataColumn Width="80" CellTemplate="{StaticResource OrderAttachmentsIcon}" Header="Allegati" />
                                    <telerik:GridViewColumn Width="30">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadGlyph x:Name="rgPrint"
                                                                  Cursor="Hand"
                                                                  FontSize="14"
                                                                  Foreground="{Binding CanPrintColor, Converter={StaticResource stringToColorConverter}}"
                                                                  Glyph="&#xe90e;"
                                                                  MouseDown="rgPrint_MouseDown"
                                                                  ToolTip="{Binding PrintToolTip}"
                                                                  Visibility="{Binding CanTasksVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewColumn Width="30">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadGlyph x:Name="rgSendEmail"
                                                                  Cursor="Hand"
                                                                  FontSize="14"
                                                                  Foreground="{Binding CanSendColor, Converter={StaticResource stringToColorConverter}}"
                                                                  Glyph="&#xe809;"
                                                                  MouseDown="rgSendEmail_MouseDown"
                                                                  ToolTip="{Binding SendToolTip}"
                                                                  Visibility="{Binding CanTasksVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewColumn Width="30">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadGlyph x:Name="rgSign"
                                                                  Cursor="Hand"
                                                                  FontSize="14"
                                                                  Foreground="{Binding SignColor, Converter={StaticResource stringToColorConverter}}"
                                                                  Glyph="&#xe157;"
                                                                  MouseDown="rgSign_MouseDown"
                                                                  ToolTip="{Binding SignToolTip}"
                                                                  Visibility="{Binding CanTasksVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewColumn Width="30">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadGlyph x:Name="rgProduction"
                                                                  Cursor="Hand"
                                                                  FontSize="14"
                                                                  Foreground="{Binding ProductionColor, Converter={StaticResource stringToColorConverter}}"
                                                                  Glyph="&#xe13c;"
                                                                  MouseDown="rgProduction_MouseDown"
                                                                  ToolTip="{Binding ProductionToolTip}"
                                                                  Visibility="{Binding CanProductionTasksVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding OTNUOR}"
                                                                Header="Numero"
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button x:Name="cmdEdit"
                                                        Margin="3"
                                                        HorizontalContentAlignment="Right"
                                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                                        Click="cmdEdit_Click"
                                                        Content="{Binding Path=OTNUOR}"
                                                        Cursor="Hand"
                                                        Foreground="{DynamicResource VulpesXBrush}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewDataColumn>
                                    <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy"
                                                                DataMemberBinding="{Binding OTDAOR}"
                                                                Header="Data"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding CustomerFullDescriptionSearchable}" Header="Cliente" />
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding RecipientFullDescriptionSearchable}" Header="Destinatario" />
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding Causal.FullDescriptionSearchable}" Header="Causale" />
                                    <telerik:GridViewDataColumn DataFormatString="N2"
                                                                DataMemberBinding="{Binding Imponibile, StringFormat=N2}"
                                                                Header="Imponibile"
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button x:Name="cmdEditRows"
                                                        Margin="3"
                                                        HorizontalContentAlignment="Right"
                                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                                        Click="cmdEditRows_Click"
                                                        Content="{Binding Path=Imponibile, StringFormat=N2}"
                                                        ContentStringFormat="N2"
                                                        Cursor="Hand"
                                                        Foreground="{DynamicResource VulpesXBrush}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                        <telerik:GridViewColumn.AggregateFunctions>
                                            <telerik:CountFunction Caption="NUMERO ORDINI: " ResultFormatString="{}{0:N0}" />
                                            <telerik:SumFunction Caption="TOTALE IMPONIBILE: " ResultFormatString="{}{0:N2}" SourceField="Imponibile" />
                                        </telerik:GridViewColumn.AggregateFunctions>
                                    </telerik:GridViewDataColumn>
                                    <telerik:GridViewDataColumn Width="70" CellTemplate="{StaticResource DDTIcon}" Header="DDT" />
                                    <telerik:GridViewDataColumn Width="70" CellTemplate="{StaticResource InvoiceIcon}" Header="Fatture" />
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding flgchiDescription}" Header="Stato" />
                                    <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy"
                                                                DataMemberBinding="{Binding OTDARI}"
                                                                Header="Data richiesta"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy"
                                                                DataMemberBinding="{Binding OTDATC}"
                                                                Header="Data consegna"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy"
                                                                DataMemberBinding="{Binding OTDAPA}"
                                                                Header="Data partenza"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>
                            <telerik:RadDataPager x:Name="rdpGrid"
                                                  Grid.Row="3"
                                                  Margin="0,-1,0,0"
                                                  DisplayMode="FirstLastPreviousNextNumeric, Text"
                                                  FontSize="12"
                                                  IsTotalItemCountFixed="True"
                                                  PageSize="20"
                                                  Source="{Binding Items}" />
                        </Grid>
                    </telerik:RadBusyIndicator>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="EVASIONE" Header="EVASIONE">
                <telerik:RadTabItem.Content>
                    <telerik:RadBusyIndicator x:Name="bsyGridDetails"
                                              BusyContent="Caricamento dati in corso..."
                                              Foreground="{DynamicResource VulpesXBrush}"
                                              IsBusy="{Binding IsBusyDetails}"
                                              OverlayStyle="{StaticResource WaitOverlayStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="35" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,5,0,0">
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">

                                    <Button Name="cmdDDTDetails"
                                            Width="150"
                                            Margin="5"
                                            BorderBrush="{DynamicResource VulpesXYellowBrush}"
                                            Click="cmdDDTDetails_Click"
                                            Content="CREA DDT"
                                            Style="{StaticResource VulpesXButton}"
                                            ToolTip="Crea i DDT per gli ordini selezionati"
                                            ToolTipService.ShowOnDisabled="True" />
                                    <Button Name="cmdInvoiceDetails"
                                            Width="150"
                                            Margin="5"
                                            BorderBrush="{DynamicResource VulpesXVioletBrush}"
                                            Click="cmdInvoiceDetails_Click"
                                            Content="CREA FATTURA"
                                            Style="{StaticResource VulpesXButton}"
                                            ToolTip="Crea le fatture per gli ordini selezionati"
                                            ToolTipService.ShowOnDisabled="True" />

                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" HorizontalAlignment="Stretch">

                                <telerik:RadWatermarkTextBox Name="txtSearchDetails"
                                                             Margin="5"
                                                             TextChanged="txtSearchDetails_TextChanged"
                                                             WatermarkContent="Cerca..." />
                            </Grid>

                            <telerik:RadGridView x:Name="GridViewDetails"
                                                 Grid.Row="2"
                                                 AutoGenerateColumns="False"
                                                 CanUserFreezeColumns="False"
                                                 CanUserResizeColumns="False"
                                                 ColumnAggregatesAlignment="NextToGroupKey"
                                                 GroupRenderMode="Flat"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding PagedSource, ElementName=rdpGridDetails}"
                                                 RowIndicatorVisibility="Collapsed"
                                                 RowStyleSelector="{StaticResource OrdersListDetailsSelector}"
                                                 SelectionChanged="GridViewDetails_SelectionChanged"
                                                 SelectionMode="Extended"
                                                 ShowColumnFooters="True"
                                                 ShowGroupFooters="True"
                                                 ShowGroupPanel="True">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewDataColumn Width="65"
                                                                DataMemberBinding="{Binding OTANNO}"
                                                                Header="Anno"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="70"
                                                                DataMemberBinding="{Binding OTNUOR}"
                                                                Header="Ord. n."
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="70"
                                                                DataMemberBinding="{Binding ODRIGA}"
                                                                Header="Pos."
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding Product.FullDescriptionSearchable}" Header="Prodotto" />
                                    <telerik:GridViewDataColumn Width="140"
                                                                DataMemberBinding="{Binding ODQTAV}"
                                                                Header="Q.tà"
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="30"
                                                                DataMemberBinding="{Binding odunit}"
                                                                Header=""
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="140"
                                                                DataMemberBinding="{Binding ODQTAEV}"
                                                                Header="Q.tà evasa"
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="30"
                                                                DataMemberBinding="{Binding odunit}"
                                                                Header=""
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="120"
                                                                DataFormatString="dd/MM/yyyy"
                                                                DataMemberBinding="{Binding OrderDate}"
                                                                Header="Data ordine"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="120"
                                                                DataFormatString="dd/MM/yyyy"
                                                                DataMemberBinding="{Binding ODDACO}"
                                                                Header="Data consegna"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="120"
                                                                DataFormatString="dd/MM/yyyy"
                                                                DataMemberBinding="{Binding ODDAPA}"
                                                                Header="Data partenza"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding Customer.FullDescriptionSearchable}" Header="Cliente" />
                                    <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding Recipient.FullDescriptionSearchable}" Header="Destinatario" />
                                    <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding Causal.FullDescriptionSearchable}" Header="Causale" />
                                    <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding HeadStatusDescription}" Header="Stato" />
                                    <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding LinkedProductionOrder.ID}" Header="Ordine di prod." />
                                    <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding LinkedProductionOrder.StatoDescrizione}" Header="Stato ord. prod." />
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>
                            <telerik:RadDataPager x:Name="rdpGridDetails"
                                                  Grid.Row="3"
                                                  Margin="0,-1,0,0"
                                                  DisplayMode="FirstLastPreviousNextNumeric, Text"
                                                  FontSize="12"
                                                  IsTotalItemCountFixed="True"
                                                  PageSize="20"
                                                  Source="{Binding DetailsItems}" />
                        </Grid>
                    </telerik:RadBusyIndicator>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>
    </Grid>

</UserControl>
