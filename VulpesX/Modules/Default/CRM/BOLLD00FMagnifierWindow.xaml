<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.CRM.BOLLD00FMagnifierWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="{Binding Title}"
                        Width="980"
                        Height="440"
                        ResizeMode="NoResize"
                        ShowInTaskbar="False"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterOwner"
                        WindowStyle="None"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="30" />
                <RowDefinition Height="50" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Margin="0,0,3,0"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Style="{DynamicResource VulpesXLabel}"
                       Text="Articolo"
                       TextAlignment="Right" />
            <StackPanel Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                <telerik:RadAutoCompleteBox Width="350"
                                            Margin="1"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Stretch"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            IsEnabled="{Binding IsEnabled}"
                                            ItemsSource="{Binding Row.Products}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun articolo trovato"
                                            SelectedItem="{Binding Row.Product, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable" />
                <TextBlock Width="90"
                           Margin="0,0,3,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Q.tà"
                           TextAlignment="Right" />
                <telerik:RadComboBox Width="100"
                                     Margin="2,1,5,1"
                                     HorizontalAlignment="Left"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     FontSize="10"
                                     IsEditable="True"
                                     IsEnabled="{Binding IsEnabled}"
                                     ItemsSource="{Binding Row.UMs}"
                                     SelectedValue="{Binding Row.BOUNIM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
                <telerik:RadNumericUpDown Width="100"
                                          Margin="2"
                                          FontSize="10"
                                          IsEnabled="{Binding IsEnabled}"
                                          Minimum="0"
                                          NumberDecimalDigits="6"
                                          ShowButtons="False"
                                          Value="{Binding Row.QuantityValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button x:Name="cmdAvailability"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="cmdAvailability_Click"
                        Cursor="Hand"
                        Style="{DynamicResource CalloutButtonStyle}"
                        ToolTip="Mostra le giacenze per l'articolo selezionato">
                    <telerik:RadGlyph Margin="3,0,3,0"
                                      FontSize="18"
                                      Foreground="{DynamicResource VulpesXGreenBrush}"
                                      Glyph="&#xe134;" />
                </Button>
                <telerik:RadComboBox Width="100"
                                     Margin="1"
                                     HorizontalAlignment="Left"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     FontSize="10"
                                     IsEditable="True"
                                     IsEnabled="{Binding IsEnabled}"
                                     ItemsSource="{Binding Row.QuantityTypes}"
                                     SelectedValue="{Binding Row.BOTQTA, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Margin="0,0,3,0"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Style="{DynamicResource VulpesXLabel}"
                       Text="Prezzo"
                       TextAlignment="Right" />
            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                <telerik:RadNumericUpDown Width="100"
                                          Margin="2"
                                          FontSize="10"
                                          IsEnabled="{Binding IsEnabled}"
                                          Minimum="0"
                                          NumberDecimalDigits="6"
                                          ShowButtons="False"
                                          Value="{Binding Row.boprez, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button x:Name="cmdPrices"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="cmdPrices_Click"
                        Cursor="Hand"
                        Style="{DynamicResource CalloutButtonStyle}"
                        ToolTip="Mostra i listini per l'articolo selezionato">
                    <telerik:RadGlyph Margin="3,0,5,0"
                                      FontSize="18"
                                      Foreground="{DynamicResource VulpesXGreenBrush}"
                                      Glyph="&#xe134;" />
                </Button>
                <telerik:RadComboBox Width="100"
                                     Margin="1"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     FontSize="10"
                                     IsEditable="True"
                                     IsEnabled="{Binding IsEnabled}"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Row.PriceTypes}"
                                     SelectedValue="{Binding Row.botpre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
                <TextBlock Width="90"
                           Margin="0,0,3,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Sconti"
                           TextAlignment="Right" />
                <telerik:RadNumericUpDown Width="50"
                                          Margin="2"
                                          FontSize="10"
                                          IsEnabled="{Binding IsEnabled}"
                                          Minimum="0"
                                          NumberDecimalDigits="2"
                                          ShowButtons="False"
                                          Value="{Binding Row.bosco1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <telerik:RadComboBox Width="100"
                                     Margin="1"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     FontSize="10"
                                     IsEditable="True"
                                     IsEnabled="{Binding IsEnabled}"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Row.DiscountTypes}"
                                     SelectedValue="{Binding Row.botsc1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
                <telerik:RadNumericUpDown Width="50"
                                          Margin="2"
                                          FontSize="10"
                                          IsEnabled="{Binding IsEnabled}"
                                          Minimum="0"
                                          NumberDecimalDigits="2"
                                          ShowButtons="False"
                                          Value="{Binding Row.bosco2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <telerik:RadComboBox Width="100"
                                     Margin="1"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     FontSize="10"
                                     IsEditable="True"
                                     IsEnabled="{Binding IsEnabled}"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Row.DiscountTypes}"
                                     SelectedValue="{Binding Row.botsc2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
                <telerik:RadNumericUpDown Width="50"
                                          Margin="2"
                                          FontSize="10"
                                          IsEnabled="{Binding IsEnabled}"
                                          Minimum="0"
                                          NumberDecimalDigits="2"
                                          ShowButtons="False"
                                          Value="{Binding Row.bosco3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <telerik:RadComboBox Width="100"
                                     Margin="1"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     FontSize="10"
                                     IsEditable="True"
                                     IsEnabled="{Binding IsEnabled}"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Row.DiscountTypes}"
                                     SelectedValue="{Binding Row.botsc3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Grid.Column="1"
                        Margin="233,0,0,0"
                        Orientation="Horizontal">
                <TextBlock Width="90"
                           Margin="0,0,3,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Maggiorazione"
                           TextAlignment="Right" />
                <telerik:RadNumericUpDown Width="50"
                                          Margin="2"
                                          FontSize="10"
                                          IsEnabled="{Binding IsEnabled}"
                                          Minimum="0"
                                          NumberDecimalDigits="2"
                                          ShowButtons="False"
                                          Value="{Binding Row.bomagg, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <telerik:RadComboBox Width="100"
                                     Margin="1"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     FontSize="10"
                                     IsEditable="True"
                                     IsEnabled="{Binding IsEnabled}"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Row.DiscountTypes}"
                                     SelectedValue="{Binding Row.botmag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
                <Button x:Name="cmdAddToPriceList"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="cmdAddToPriceList_Click"
                        Cursor="Hand"
                        Style="{DynamicResource CalloutButtonStyle}"
                        ToolTip="Crea una nuova voce nel listino cliente/destinatari con i dati attuali">
                    <telerik:RadGlyph Margin="3,0,5,0"
                                      FontSize="18"
                                      Foreground="{DynamicResource VulpesXGreenBrush}"
                                      Glyph="&#xe11f;" />
                </Button>
            </StackPanel>

            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Margin="0,0,3,0"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Style="{DynamicResource VulpesXLabel}"
                       Text="Aliquota"
                       TextAlignment="Right" />
            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                <telerik:RadAutoCompleteBox Width="325"
                                            Margin="1"
                                            HorizontalAlignment="Left"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            IsEnabled="{Binding IsEnabled}"
                                            ItemsSource="{Binding Row.Rates}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessuna aliquota trovata"
                                            SelectedItem="{Binding Row.Rate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable" />
                <TextBlock Width="160"
                           Margin="0,0,3,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Riferimenti cliente"
                           TextAlignment="Right" />
                <TextBox Width="350"
                         Margin="1"
                         HorizontalAlignment="Left"
                         FontSize="10"
                         IsEnabled="{Binding IsEnabled}"
                         MaxLength="100"
                         Text="{Binding Row.BORIFC, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Margin="0,0,3,0"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Style="{DynamicResource VulpesXLabel}"
                       Text="Gruppo"
                       TextAlignment="Right" />
            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                <telerik:RadAutoCompleteBox Width="150"
                                            Margin="1"
                                            HorizontalAlignment="Left"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            IsEnabled="{Binding IsEnabled}"
                                            ItemsSource="{Binding Row.Groups}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun gruppo trovato"
                                            SelectedItem="{Binding Row.Group, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable" />
                <TextBlock Width="50"
                           Margin="0,0,3,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Conto"
                           TextAlignment="Right" />
                <telerik:RadAutoCompleteBox Width="240"
                                            Margin="1"
                                            HorizontalAlignment="Left"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            IsEnabled="{Binding IsEnabled}"
                                            ItemsSource="{Binding Row.Accounts}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun conto trovato"
                                            SelectedItem="{Binding Row.Account, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable" />
                <TextBlock Width="90"
                           Margin="0,0,3,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Sottoconto"
                           TextAlignment="Right" />
                <telerik:RadAutoCompleteBox Width="300"
                                            Margin="1"
                                            HorizontalAlignment="Left"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            IsEnabled="{Binding IsEnabled}"
                                            ItemsSource="{Binding Row.Subaccounts}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun sottoconto trovato"
                                            SelectedItem="{Binding Row.Subaccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable" />
            </StackPanel>

            <TextBlock Grid.Row="5"
                       Grid.Column="0"
                       Margin="0,0,3,0"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Style="{DynamicResource VulpesXLabel}"
                       Text="Agente I"
                       TextAlignment="Right" />
            <StackPanel Grid.Row="5"
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                <telerik:RadAutoCompleteBox x:Name="acFirstAgent"
                                            Width="300"
                                            Margin="1"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            IsEnabled="{Binding IsEnabled}"
                                            ItemsSource="{Binding Row.Agents}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun codice trovato"
                                            SelectedItem="{Binding Row.FirstAgent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                <TextBlock Width="90"
                           Margin="0,0,3,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Provvigione"
                           TextAlignment="Right" />
                <telerik:RadNumericUpDown Width="150"
                                          Margin="2"
                                          FontSize="10"
                                          IsEnabled="{Binding IsEnabled}"
                                          Minimum="0"
                                          NumberDecimalDigits="2"
                                          ShowButtons="False"
                                          Value="{Binding Row.BOCOA1P, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <telerik:RadComboBox Width="200"
                                     Margin="1"
                                     HorizontalAlignment="Left"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     IsEditable="True"
                                     IsEnabled="{Binding IsEnabled}"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Row.DiscountTypes}"
                                     SelectedValue="{Binding Row.BOCOA1PT, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
            </StackPanel>

            <TextBlock Grid.Row="6"
                       Grid.Column="0"
                       Margin="0,0,3,0"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Style="{DynamicResource VulpesXLabel}"
                       Text="Agente II"
                       TextAlignment="Right" />
            <StackPanel Grid.Row="6"
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                <telerik:RadAutoCompleteBox x:Name="acSecondAgent"
                                            Width="300"
                                            Margin="1"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            IsEnabled="{Binding IsEnabled}"
                                            ItemsSource="{Binding Row.Agents}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun codice trovato"
                                            SelectedItem="{Binding Row.SecondAgent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                <TextBlock Width="90"
                           Margin="0,0,3,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Provvigione"
                           TextAlignment="Right" />
                <telerik:RadNumericUpDown Width="150"
                                          Margin="2"
                                          FontSize="10"
                                          IsEnabled="{Binding IsEnabled}"
                                          Minimum="0"
                                          NumberDecimalDigits="2"
                                          ShowButtons="False"
                                          Value="{Binding Row.BOCOA2P, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <telerik:RadComboBox Width="200"
                                     Margin="1"
                                     HorizontalAlignment="Left"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     IsEditable="True"
                                     IsEnabled="{Binding IsEnabled}"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Row.DiscountTypes}"
                                     SelectedValue="{Binding Row.BOCOA2PT, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
            </StackPanel>

            <TextBlock Grid.Row="7"
                       Grid.Column="0"
                       Margin="0,0,3,0"
                       VerticalAlignment="Top"
                       FontWeight="Bold"
                       Style="{DynamicResource VulpesXLabel}"
                       Text="Nota"
                       TextAlignment="Right" />
            <StackPanel Grid.Row="7"
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                <TextBox Width="650"
                         Height="40"
                         Margin="1"
                         VerticalAlignment="Top"
                         VerticalContentAlignment="Top"
                         AcceptsReturn="True"
                         FontSize="10"
                         IsEnabled="{Binding IsEnabled}"
                         IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType=telerik:RadGridView}}"
                         PreviewMouseRightButtonDown="txtNote_PreviewMouseRightButtonDown"
                         PreviewMouseRightButtonUp="txtNote_PreviewMouseRightButtonUp"
                         Text="{Binding Model.Row.BONOTE, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Width="90"
                           Margin="0,0,3,0"
                           VerticalAlignment="Top"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Stampa nota"
                           TextAlignment="Right" />
                <telerik:RadToggleSwitchButton Margin="1"
                                               VerticalAlignment="Top"
                                               CheckedContent="Sì"
                                               Content="{Binding Row.BOSHOW, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                               IsChecked="{Binding Row.BOSHOW, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                               IsEnabled="{Binding IsEnabled}"
                                               UncheckedContent="No" />
            </StackPanel>

            <StackPanel Grid.Row="8"
                        Grid.Column="1"
                        Margin="0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <TextBlock Margin="0,0,3,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Totale riga"
                           TextAlignment="Right" />
                <TextBlock Margin="10,0,10,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXData}"
                           Text="{Binding Row.AmountDisplay, StringFormat=N2}"
                           TextAlignment="Right" />
                <TextBlock Margin="0,0,3,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Totale sconti riga"
                           TextAlignment="Right" />
                <TextBlock Margin="10,0,10,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXData}"
                           Text="{Binding Row.Discount, StringFormat=N2}"
                           TextAlignment="Right" />
                <TextBlock Margin="0,0,3,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Totale maggiorazione riga"
                           TextAlignment="Right" />
                <TextBlock Margin="10,0,10,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXData}"
                           Text="{Binding Row.Surcharge, StringFormat=N2}"
                           TextAlignment="Right" />
            </StackPanel>
        </Grid>


        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
