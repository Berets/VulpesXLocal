<UserControl x:Class="VulpesX.Modules.Default.CRM.OFFET00FView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">

    <UserControl.Resources>
        <selectors:OFFET00FCanceledListSelector x:Key="CanceledListSelector">
            <selectors:OFFET00FCanceledListSelector.DefaultRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="ToolTip" Value="{Binding OFTOGG, StringFormat={}Oggetto: {0}}" />
                </Style>
            </selectors:OFFET00FCanceledListSelector.DefaultRowStyle>
            <selectors:OFFET00FCanceledListSelector.CanceledRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="{DynamicResource VulpesXRedBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource VulpesXLightBrush}" />
                    <Setter Property="ToolTip" Value="Elemento annullato" />
                </Style>
            </selectors:OFFET00FCanceledListSelector.CanceledRowStyle>
        </selectors:OFFET00FCanceledListSelector>

        <DataTemplate x:Key="OfferAttachmentsIcon">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="{Binding OfferAttachmentsStatusColor, Converter={StaticResource stringToColorConverter}}" Cursor="Hand">
                    <Label x:Name="label" ToolTip="{Binding OfferAttachmentsStatusText}">
                        <telerik:RadGlyph x:Name="rgOfferAttachmentsIcon"
                                          FontSize="14"
                                          Foreground="{Binding OfferAttachmentsStatusColor, Converter={StaticResource stringToColorConverter}}"
                                          Glyph="&#xe10e;"
                                          MouseDown="rgOfferAttachmentsIcon_MouseDown" />
                    </Label>
                </Border>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding OfferAttachmentsText}" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30*" />
                <ColumnDefinition Width="70*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="GESTIONE OFFERTE" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <telerik:RadComboBox x:Name="cmbStatus"
                                     Grid.Column="2"
                                     Margin="5"
                                     HorizontalAlignment="Stretch"
                                     DisplayMemberPath="Description"
                                     SelectedValuePath="ID"
                                     SelectionChanged="cmbStatus_SelectionChanged" />

                <telerik:RadDatePicker x:Name="dtpYear"
                                       Grid.Column="3"
                                       Margin="5"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Right"
                                       DateSelectionMode="Year"
                                       DisplayFormat="Short"
                                       SelectionChanged="dtpYear_SelectionChanged" />
                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />

            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">

            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Margin="5"
                                         TextChanged="txtSearch_TextChanged"
                                         WatermarkContent="Cerca..." />
        </Grid>

        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     ColumnAggregatesAlignment="NextToGroupKey"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     RowIndicatorVisibility="Collapsed"
                                     RowStyleSelector="{StaticResource CanceledListSelector}"
                                     SelectionMode="Extended"
                                     ShowColumnFooters="True"
                                     ShowGroupFooters="True"
                                     ShowGroupPanel="True">
                    <telerik:RadContextMenu.ContextMenu>
                        <telerik:RadContextMenu x:Name="cmGrid" Opening="cmGrid_Opening">
                            <telerik:RadMenuItem x:Name="rmiTransform"
                                                 Click="rmiTransform_Click"
                                                 Header="Transforma in ordine"
                                                 Typography.Capitals="AllSmallCaps">
                                <telerik:RadMenuItem.Icon>
                                    <telerik:RadGlyph Width="18"
                                                      Height="18"
                                                      Foreground="{DynamicResource VulpesXYellowBrush}"
                                                      Glyph="&#xe10f;" />
                                </telerik:RadMenuItem.Icon>
                            </telerik:RadMenuItem>
                            <telerik:RadMenuItem x:Name="rmiClose"
                                                 Click="rmiClose_Click"
                                                 Header="Chiudi offerta"
                                                 Typography.Capitals="AllSmallCaps">
                                <telerik:RadMenuItem.Icon>
                                    <telerik:RadGlyph Width="18"
                                                      Height="18"
                                                      Foreground="{DynamicResource VulpesXRedBrush}"
                                                      Glyph="&#xe11d;" />
                                </telerik:RadMenuItem.Icon>
                            </telerik:RadMenuItem>
                        </telerik:RadContextMenu>
                    </telerik:RadContextMenu.ContextMenu>
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewColumn Width="110">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadButton x:Name="cmdDelete"
                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                       Click="cmdDelete_Click"
                                                       Content="Elimina"
                                                       Style="{StaticResource VulpesXButton}"
                                                       Visibility="{Binding CanDeleteVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewDataColumn Width="80" CellTemplate="{StaticResource OfferAttachmentsIcon}" Header="Allegati" />
                        <telerik:GridViewColumn Width="30">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgPrint"
                                                      Cursor="Hand"
                                                      FontSize="14"
                                                      Foreground="{Binding CanPrintColor, Converter={StaticResource stringToColorConverter}}"
                                                      Glyph="&#xe90e;"
                                                      MouseDown="rgPrint_MouseDown"
                                                      ToolTip="{Binding PrintToolTip}"
                                                      Visibility="{Binding CanTasksVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn Width="30">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgSendEmail"
                                                      Cursor="Hand"
                                                      FontSize="14"
                                                      Foreground="{Binding CanSendColor, Converter={StaticResource stringToColorConverter}}"
                                                      Glyph="&#xe809;"
                                                      MouseDown="rgSendEmail_MouseDown"
                                                      ToolTip="{Binding SendToolTip}"
                                                      Visibility="{Binding CanTasksVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn Width="30">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgSign"
                                                      Cursor="{Binding SignCursor}"
                                                      FontSize="14"
                                                      Foreground="{Binding SignColor, Converter={StaticResource stringToColorConverter}}"
                                                      Glyph="&#xe157;"
                                                      MouseDown="rgSign_MouseDown"
                                                      ToolTip="{Binding SignToolTip}"
                                                      Visibility="{Binding CanTasksVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewDataColumn Width="100"
                                                    DataMemberBinding="{Binding OFTNUOR}"
                                                    Header="Numero"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Right"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEdit_Click"
                                            Content="{Binding Path=OFTNUOR}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding OFTDAOR}"
                                                    Header="Data"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding Customer.FullDescriptionSearchable}" Header="Cliente/Prospect">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               Background="{Binding EntityBackground, Converter={StaticResource stringToColorConverter}}"
                                               Text="{Binding Customer.FullDescriptionSearchable}"
                                               ToolTip="{Binding EntityTooltip}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding Recipient.FullDescriptionSearchable}" Header="Destinatario" />
                        <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding Causal.FullDescriptionSearchable}" Header="Causale" />
                        <telerik:GridViewDataColumn Width="250"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding Imponibile, StringFormat=N2}"
                                                    Header="Imponibile"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEditRows"
                                            Margin="3"
                                            HorizontalContentAlignment="Right"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEditRows_Click"
                                            Content="{Binding Path=Imponibile, StringFormat=N2}"
                                            ContentStringFormat="N2"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                            <telerik:GridViewColumn.AggregateFunctions>
                                <telerik:CountFunction Caption="NUMERO OFFERTE: " ResultFormatString="{}{0:N0}" />
                                <telerik:SumFunction Caption="TOTALE IMPONIBILE: " ResultFormatString="{}{0:N2}" SourceField="Imponibile" />
                            </telerik:GridViewColumn.AggregateFunctions>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding OFTOGG}" Header="Oggetto" />
                        <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding oflgchiDescription}" Header="Stato" />
                        <telerik:GridViewDataColumn Width="140"
                                                    DataFormatString="dd/MM/yyyy HH.mm.ss"
                                                    DataMemberBinding="{Binding OFTINFI}"
                                                    Header="Invio a firma"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding OFTINFIUSR}" Header="Da" />
                        <telerik:GridViewDataColumn Width="140"
                                                    DataFormatString="dd/MM/yyyy HH.mm.ss"
                                                    DataMemberBinding="{Binding OFTFITE}"
                                                    Header="Firma tecnica"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding OFTFITEUSR}" Header="Da" />
                        <telerik:GridViewDataColumn Width="140"
                                                    DataFormatString="dd/MM/yyyy HH.mm.ss"
                                                    DataMemberBinding="{Binding OFTFITE}"
                                                    Header="Firma commerciale"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding OFTFITEUSR}" Header="Da" />
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding Items}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>

</UserControl>
