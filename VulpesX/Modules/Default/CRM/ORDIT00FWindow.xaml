<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.CRM.ORDIT00FWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli testata ordine cliente"
                        Width="1000"
                        Height="690"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <StackPanel x:Name="spInsertInfo"
                    Grid.Row="0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <TextBlock Style="{StaticResource VulpesXLabel}" Text="Nuovo ordine" />
            <TextBlock Margin="5,2,2,2" Style="{StaticResource VulpesXLabel}" Text="del" />
            <telerik:RadDateTimePicker Width="120"
                                       Margin="5,0,15,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       DateSelectionMode="Day"
                                       DateTimeWatermarkContent="Scegliere la data"
                                       DisplayFormat="Short"
                                       InputMode="DatePicker"
                                       IsEnabled="{Binding IsEnabled}"
                                       SelectedValue="{Binding Data.OTDAOR, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
        <StackPanel x:Name="spEditInfo"
                    Grid.Row="0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <TextBlock Style="{StaticResource VulpesXLabel}" Text="Ordine n." />
            <TextBlock Margin="5,2,1,2"
                       HorizontalAlignment="Left"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding Data.OTANNO}" />
            <TextBlock Margin="1"
                       HorizontalAlignment="Left"
                       Style="{StaticResource VulpesXData}"
                       Text="/" />
            <TextBlock Margin="1,2,2,2"
                       HorizontalAlignment="Left"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding Data.OTNUOR}" />
            <TextBlock Margin="5,2,2,2" Style="{StaticResource VulpesXLabel}" Text="del" />
            <telerik:RadDateTimePicker Width="120"
                                       Margin="5,0,15,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       DateSelectionMode="Day"
                                       DateTimeWatermarkContent="Scegliere la data"
                                       DisplayFormat="Short"
                                       InputMode="DatePicker"
                                       IsEnabled="{Binding IsEnabled}"
                                       SelectedValue="{Binding Data.OTDAOR, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <telerik:RadTabControl Grid.Row="1"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="GENERALI" Header="GENERALI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="15" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="8*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Margin="5,2,225,2"
                                       HorizontalAlignment="Right"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Stato" />
                            <telerik:RadComboBox Grid.Row="0"
                                                 Grid.Column="1"
                                                 Width="200"
                                                 Margin="5,2,15,2"
                                                 HorizontalAlignment="Right"
                                                 HorizontalContentAlignment="Left"
                                                 DisplayMemberPath="Description"
                                                 IsEditable="True"
                                                 IsEnabled="False"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding Data.OrderStatus}"
                                                 SelectedValue="{Binding Data.flgchi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 SelectedValuePath="ID" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Causale" />
                            <telerik:RadAutoCompleteBox x:Name="acCausal"
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        IsEnabled="{Binding IsEnabled}"
                                                        ItemsSource="{Binding Causals}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding SelectedCausal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acCausal_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Data richiesta dal cliente" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadDateTimePicker Width="150"
                                                           Margin="5,0,15,0"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           IsEnabled="{Binding IsEnabled}"
                                                           SelectedValue="{Binding Data.OTDARI, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Data consegna" />
                                <telerik:RadDateTimePicker Width="150"
                                                           Margin="5,0,15,0"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           IsEnabled="{Binding IsEnabled}"
                                                           SelectedValue="{Binding Data.OTDATC, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Data partenza" />
                                <telerik:RadDateTimePicker Width="150"
                                                           Margin="5,0,15,0"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           IsEnabled="{Binding IsEnabled}"
                                                           SelectedValue="{Binding Data.OTDAPA, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Cliente" />
                            <telerik:RadAutoCompleteBox x:Name="acCustomer"
                                                        Grid.Row="4"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        IsEnabled="{Binding IsEnabled}"
                                                        ItemsSource="{Binding Customers}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding SelectedCustomer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acCustomer_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <Grid x:Name="grdExpired"
                                  Grid.Row="5"
                                  Grid.Column="1"
                                  Margin="5,2,15,2"
                                  Background="{DynamicResource VulpesXRedBrush}"
                                  Cursor="Hand"
                                  MouseDown="grdExpired_MouseDown"
                                  ToolTip="Clicca per vedere EC"
                                  Visibility="{Binding ExpiredVisibility}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="SCOPERTO : " />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"
                                           Text="{Binding Expired, StringFormat=C2, ConverterCulture=it-IT}" />
                            </Grid>

                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Destinatario" />
                            <telerik:RadAutoCompleteBox x:Name="acRecipient"
                                                        Grid.Row="6"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        IsEnabled="{Binding IsEnabled}"
                                                        ItemsSource="{Binding Recipients}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding SelectedRecipient, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acRecipient_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />


                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Indirizzo" />
                            <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Width="350"
                                           Margin="5,2,1,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding SelectedCustomer.abeind, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Width="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="C.a.p."
                                           TextAlignment="Right" />
                                <TextBlock Margin="5,2,1,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding SelectedCustomer.abecap, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Comune" />
                            <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Width="350"
                                           Margin="5,2,1,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding SelectedCustomer.abeloc, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Width="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Provincia"
                                           TextAlignment="Right" />
                                <TextBlock Margin="5,2,1,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding SelectedCustomer.abepro, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Grid.Row="9"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Partita IVA" />
                            <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Width="200"
                                           Margin="5,2,1,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding SelectedCustomer.abepiv, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Width="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Codice fiscale"
                                           TextAlignment="Right" />
                                <TextBlock Width="200"
                                           Margin="5,2,1,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding SelectedCustomer.abecfi, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Grid.Row="10"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Telefono" />
                            <StackPanel Grid.Row="10"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="3"
                                        Orientation="Horizontal">
                                <TextBlock Width="150"
                                           Margin="5,2,1,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding SelectedCustomerContacts.CLNUTE, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock MinWidth="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Cellulare"
                                           TextAlignment="Right" />
                                <TextBlock Width="150"
                                           Margin="5,2,1,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding SelectedCustomerContacts.clicel, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock MinWidth="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Fax"
                                           TextAlignment="Right" />
                                <TextBlock Width="150"
                                           Margin="5,2,1,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding SelectedCustomerContacts.CLNUFA, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Grid.Row="11"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Email" />
                            <TextBlock Grid.Row="11"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="3"
                                       Margin="5,2,1,2"
                                       HorizontalAlignment="Left"
                                       Style="{StaticResource VulpesXData}"
                                       Text="{Binding SelectedCustomerContacts.climail, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Border Grid.Row="12"
                                    Grid.RowSpan="2"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Margin="5,0,5,0"
                                    Background="DarkGoldenrod"
                                    BorderBrush="{DynamicResource VulpesXBrush}"
                                    BorderThickness="1">
                                <TextBlock Padding="0"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXBrush}"
                                           Opacity=".8"
                                           Text="CLIENTE"
                                           TextAlignment="Center"
                                           Typography.Capitals="AllSmallCaps">
                                    <TextBlock.LayoutTransform>
                                        <RotateTransform Angle="270" />
                                    </TextBlock.LayoutTransform>
                                </TextBlock>
                            </Border>
                            <TextBlock Grid.Row="12"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Riferimenti" />
                            <TextBox Grid.Row="12"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="100"
                                     Text="{Binding Data.OTDE25, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="13"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Numero ordine" />
                            <StackPanel Grid.Row="13" Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="350"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         MaxLength="50"
                                         Text="{Binding Data.OTCUNO, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock MinWidth="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Data ordine"
                                           TextAlignment="Right" />
                                <telerik:RadDateTimePicker Width="150"
                                                           Margin="5,0,15,0"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           SelectedValue="{Binding Data.OTCUDO, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <TextBlock Grid.Row="14"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Lingua" />
                            <telerik:RadAutoCompleteBox x:Name="acLanguage"
                                                        Grid.Row="14"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        IsEnabled="{Binding IsEnabled}"
                                                        ItemsSource="{Binding Languages}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding SelectedLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acLanguage_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="PAGAMENTO" Header="PAGAMENTO">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="15" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Pagamento" />
                            <telerik:RadAutoCompleteBox x:Name="acPayment"
                                                        Grid.Row="0"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        IsEnabled="{Binding IsEnabled}"
                                                        ItemsSource="{Binding Payments}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding SelectedPayment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acPayment_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Banca" />
                            <telerik:RadAutoCompleteBox x:Name="acCustomerBank"
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        IsEnabled="{Binding IsEnabled}"
                                                        ItemsSource="{Binding Banks}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessuna banca trovata"
                                                        SelectedItem="{Binding SelectedCustomerBank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acCustomerBank_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="TRASPORTO" Header="TRASPORTO">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="15" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="15" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Imballo" />
                            <telerik:RadAutoCompleteBox x:Name="acPacking"
                                                        Grid.Row="0"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        IsEnabled="{Binding IsEnabled}"
                                                        ItemsSource="{Binding Packings}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding SelectedPacking, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acPacking_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Spedizione" />
                            <telerik:RadAutoCompleteBox x:Name="acShipment"
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        IsEnabled="{Binding IsEnabled}"
                                                        ItemsSource="{Binding Shipments}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding SelectedShipment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acShipment_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Consegna" />
                            <telerik:RadAutoCompleteBox x:Name="acDelivery"
                                                        Grid.Row="2"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        IsEnabled="{Binding IsEnabled}"
                                                        ItemsSource="{Binding Deliveries}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding SelectedDelivery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acDelivery_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Primo corriere" />
                            <telerik:RadAutoCompleteBox x:Name="acFirstCarrier"
                                                        Grid.Row="4"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        IsEnabled="{Binding IsEnabled}"
                                                        ItemsSource="{Binding Carriers}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
