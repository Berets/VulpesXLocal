<UserControl x:Class="VulpesX.Modules.Default.CRM.BOLLT00FView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:aggregates="clr-namespace:VulpesX.Shared.Controls.Aggregators;assembly=VulpesX.Shared.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">

    <UserControl.Resources>
        <selectors:DDTListSelector x:Key="DDTListSelector">
            <selectors:DDTListSelector.DefaultRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="ToolTip" Value="DDT stampato definitivamente" />
                </Style>
            </selectors:DDTListSelector.DefaultRowStyle>
            <selectors:DDTListSelector.CanceledRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="{DynamicResource VulpesXRedBrush}" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="ToolTip" Value="Elemento annullato" />
                </Style>
            </selectors:DDTListSelector.CanceledRowStyle>
            <selectors:DDTListSelector.PartialRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="{DynamicResource VulpesXYellowBrush}" />
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="ToolTip" Value="DDT completato parzialmente, manca l'assegnazione di alcuni articoli" />
                </Style>
            </selectors:DDTListSelector.PartialRowStyle>
            <selectors:DDTListSelector.NotReadyRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="{DynamicResource VulpesXRedBrush}" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="ToolTip" Value="DDT non completato, manca l'assegnazione degli articoli" />
                </Style>
            </selectors:DDTListSelector.NotReadyRowStyle>
            <selectors:DDTListSelector.NotSyncRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="{DynamicResource VulpesXVioletBrush}" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="ToolTip" Value="DDT non completato, c'e' una discrepanza tra il materiale realmente impegnato e quello assegnato" />
                </Style>
            </selectors:DDTListSelector.NotSyncRowStyle>
            <selectors:DDTListSelector.ReadyRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="{DynamicResource VulpesXGreenBrush}" />
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="ToolTip" Value="DDT completo, pronto per la stampa e l'evasione" />
                </Style>
            </selectors:DDTListSelector.ReadyRowStyle>
        </selectors:DDTListSelector>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="GESTIONE DDT" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <telerik:RadComboBox x:Name="cmbStatus"
                                     Margin="5"
                                     HorizontalAlignment="Stretch"
                                     DisplayMemberPath="Description"
                                     SelectedValue="{Binding SelectedStatusID}"
                                     SelectedValuePath="ID"
                                     SelectionChanged="cmbStatus_SelectionChanged" />

                <telerik:RadDatePicker x:Name="dtpYear"
                                       Margin="5"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Right"
                                       DateSelectionMode="Year"
                                       DisplayFormat="Short"
                                       SelectedValue="{Binding Year}"
                                       SelectionChanged="dtpYear_SelectionChanged" />

                <Button x:Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />

                <Button x:Name="cmdInvoice"
                        Width="150"
                        Margin="5"
                        BorderBrush="{DynamicResource VulpesXVioletBrush}"
                        Click="cmdInvoice_Click"
                        Content="CREA FATTURE"
                        IsEnabled="False"
                        Style="{StaticResource VulpesXButton}"
                        ToolTip="Crea le fatture per gli ordini selezionati" />

                <telerik:RadDropDownButton x:Name="rddbImport"
                                           Width="150"
                                           Margin="5"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Stretch"
                                           Content="Importazioni"
                                           IsEnabled="False">
                    <telerik:RadDropDownButton.DropDownContent>
                        <telerik:RadContextMenu>
                            <telerik:RadMenuItem x:Name="rmiImpGILAT"
                                                 Width="150"
                                                 Click="rmiImpGILAT_Click"
                                                 Cursor="Hand"
                                                 Foreground="{DynamicResource VulpesXBrush}"
                                                 Header="GILAT">
                                <telerik:RadMenuItem.Icon>
                                    <telerik:RadGlyph Cursor="Hand"
                                                      FontSize="14"
                                                      Foreground="{DynamicResource VulpesXBrush}"
                                                      Glyph="&#xe6a7;" />
                                </telerik:RadMenuItem.Icon>
                            </telerik:RadMenuItem>
                            <telerik:RadMenuItem x:Name="rmiImpBANCOLAT"
                                                 Width="150"
                                                 Click="rmiImpBANCOLAT_Click"
                                                 Cursor="Hand"
                                                 Foreground="{DynamicResource VulpesXBrush}"
                                                 Header="BANCOLAT">
                                <telerik:RadMenuItem.Icon>
                                    <telerik:RadGlyph Cursor="Hand"
                                                      FontSize="14"
                                                      Foreground="{DynamicResource VulpesXBrush}"
                                                      Glyph="&#xe6a7;" />
                                </telerik:RadMenuItem.Icon>
                            </telerik:RadMenuItem>
                        </telerik:RadContextMenu>
                    </telerik:RadDropDownButton.DropDownContent>
                </telerik:RadDropDownButton>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         HorizontalAlignment="Stretch"
                                         LostFocus="txtSearch_LostFocus"
                                         Text="{Binding TextFilter}"
                                         WatermarkContent="Cerca..." />
        </Grid>
        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>


                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     Grid.ColumnSpan="2"
                                     Margin="0,5,0,0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     ColumnAggregatesAlignment="NextToGroupKey"
                                     FilteringMode="FilterRow"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     IsSynchronizedWithCurrentItem="False"
                                     ItemsSource="{Binding Items}"
                                     RowIndicatorVisibility="Collapsed"
                                     RowStyleSelector="{StaticResource DDTListSelector}"
                                     SelectionMode="Extended"
                                     ShowColumnFooters="True"
                                     ShowColumnSortIndexes="True"
                                     ShowGroupFooters="True"
                                     ShowGroupPanel="False">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewSelectColumn IsSelected="False" IsVisible="{Binding IsSelectable}" />
                        <telerik:GridViewColumn Width="90">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadButton x:Name="cmdDelete"
                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                       Click="cmdDelete_Click"
                                                       Content="Elimina"
                                                       Style="{StaticResource VulpesXButton}"
                                                       Visibility="{Binding CanDeleteVisibility, Converter={StaticResource boolToVisibilityConverter}}" />

                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn Width="25">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgPrintPreview"
                                                      Cursor="Hand"
                                                      FontSize="18"
                                                      Foreground="{DynamicResource VulpesXGreenBrush}"
                                                      Glyph="&#xe13d;"
                                                      MouseDown="rgPrintPreview_MouseDown"
                                                      ToolTip="Apri il PDF con l'anteprima del DDT"
                                                      Visibility="{Binding CanPrintPreviewVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn Width="25">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgPrint"
                                                      Cursor="Hand"
                                                      FontSize="18"
                                                      Foreground="{DynamicResource VulpesXGreenBrush}"
                                                      Glyph="&#xe90e;"
                                                      MouseDown="rgPrint_MouseDown"
                                                      ToolTip="Apri il PDF del DDT" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding StatusDescription}" Header="Stato" IsFilterable="False" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding BTBOLLText}"
                                                    Header="N. provv."
                                                    HeaderTextAlignment="Right"
                                                    IsCustomSortingEnabled="True"
                                                    TextAlignment="Right">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Right"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEdit_Click"
                                            Content="{Binding Path=BTBOLLText}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}"
                                            ToolTip="Clicca per accedere alla testata del DDT" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="100"
                                                    DataMemberBinding="{Binding BTDATPText}"
                                                    Header="Data provv."
                                                    HeaderTextAlignment="Center"
                                                    IsCustomSortingEnabled="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding DefinitiveID}"
                                                    Header="Numero def."
                                                    IsFilterable="True"
                                                    IsSortable="False" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataMemberBinding="{Binding BTDATAText}"
                                                    Header="Data def."
                                                    HeaderTextAlignment="Center"
                                                    IsCustomSortingEnabled="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="60"
                                                    DataMemberBinding="{Binding BTCOLLText}"
                                                    Header="Colli"
                                                    HeaderTextAlignment="Right"
                                                    IsCustomSortingEnabled="True"
                                                    TextAlignment="Right">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEditRows"
                                            Margin="3"
                                            HorizontalContentAlignment="Right"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEditRows_Click"
                                            Content="{Binding Path=BTCOLLText}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}"
                                            ToolTip="Clicca per accedere alle righe del DDT" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="60"
                                                    DataMemberBinding="{Binding Causal.bolcod}"
                                                    Header="Causale"
                                                    IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding Causal.boldes}" Header="" IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="200"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding Imponibile, StringFormat=N2}"
                                                    Header="Imponibile"
                                                    HeaderTextAlignment="Right"
                                                    IsVisible="False"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="80"
                                                    DataMemberBinding="{Binding CustomerID}"
                                                    Header="Cliente"
                                                    IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding CustomerDescription}" Header="" IsCustomSortingEnabled="True">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Left"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEditCustomer_Click"
                                            Content="{Binding Path=CustomerDescription}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                            <telerik:GridViewColumn.AggregateFunctions>
                                <telerik:CountFunction Caption="NUMERO DDT: " ResultFormatString="{}{0:N0}" />
                                <telerik:SumFunction Caption="NUMERO COLLI: " ResultFormatString="{}{0:N2}" SourceField="BTCOLL" />
                                <telerik:SumFunction Caption="TOTALE IMPONIBILE: " ResultFormatString="{}{0:N2}" SourceField="Imponibile" />
                                <aggregates:DDTCustomSum ResultFormatString="{}{0:N2}" />
                            </telerik:GridViewColumn.AggregateFunctions>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="60"
                                                    DataMemberBinding="{Binding RecipientID}"
                                                    Header="Dest."
                                                    IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding RecipientDescription}" Header="" IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="200"
                                                    DataMemberBinding="{Binding BTDE25}"
                                                    Header="Riferimenti cliente"
                                                    IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="150"
                                                    DataMemberBinding="{Binding BTDASPText}"
                                                    Header="Data spedizione"
                                                    HeaderTextAlignment="Center"
                                                    IsCustomSortingEnabled="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding BTDEBE}" Header="Aspetto dei beni" IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataMemberBinding="{Binding FirstCarrier.vetdes}"
                                                    Header="Vettore1"
                                                    IsCustomSortingEnabled="True"
                                                    UniqueName="Vettore1" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataMemberBinding="{Binding SecondCarrier.vetdes}"
                                                    Header="Vettore2"
                                                    IsCustomSortingEnabled="True"
                                                    UniqueName="Vettore2" />
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>
                    <telerik:RadDataPager x:Name="rdpGrid"
                                          Grid.Row="1"
                                          Margin="0,-1,0,0"
                                          DisplayMode="FirstLastPreviousNextNumeric, Text"
                                          FontSize="12"
                                          IsTotalItemCountFixed="True"
                                          ItemCount="{Binding TotalCount}"
                                          PageSize="{Binding PageSize}"
                                          PageIndex="{Binding PageRequested, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <TextBlock Margin="0,0,10,0"
                                   HorizontalAlignment="Right"
                                   Style="{StaticResource VulpesXLabel}"
                                   Text="Righe"
                                   ToolTip="Imposta il numero di righe da mostrare nella lista" />
                        <telerik:RadNumericUpDown x:Name="rnudPageSize"
                                                  MinWidth="90"
                                                  Maximum="2000"
                                                  Minimum="1"
                                                  NumberDecimalDigits="0"
                                                  ShowButtons="False"
                                                  ValueChanged="rnudPageSize_ValueChanged"
                                                  Value="20" />
                    </StackPanel>
                </Grid>
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>
</UserControl>
