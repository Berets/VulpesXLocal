<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.CRM.AskDDTSendDateWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Selezionare data ed ora dell'invio"
                        Width="900"
                        Height="500"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="None"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="35" />
            <RowDefinition Height="35" />
            <RowDefinition Height="35" />
            <RowDefinition Height="35" />
            <RowDefinition Height="35" />
            <RowDefinition Height="10" />
            <RowDefinition Height="35" />
            <RowDefinition Height="35" />
            <RowDefinition Height="10" />
            <RowDefinition Height="35" />
            <RowDefinition Height="35" />
            <RowDefinition Height="35" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="7*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Data ed ora di stampa definitiva" />
        <telerik:RadDateTimePicker x:Name="rdpDateFinal"
                                   Grid.Row="1"
                                   Grid.Column="1"
                                   Width="250"
                                   Margin="5,0,15,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   DateSelectionMode="Day"
                                   DateTimeWatermarkContent="Scegliere la data e l'ora"
                                   DisplayFormat="Short"
                                   InputMode="DateTimePicker"
                                   SelectedValue="{Binding Data.BTDATA, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Data ed ora di spedizione" />
        <telerik:RadDateTimePicker x:Name="rdpDate"
                                   Grid.Row="2"
                                   Grid.Column="1"
                                   Width="250"
                                   Margin="5,0,15,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   DateSelectionMode="Day"
                                   DateTimeWatermarkContent="Scegliere la data e l'ora"
                                   DisplayFormat="Short"
                                   InputMode="DateTimePicker"
                                   SelectedValue="{Binding Data.BTDASP, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Imballo" />
        <telerik:RadAutoCompleteBox x:Name="acPacking"
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Margin="5,2,15,2"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    DisplayMemberPath="FullDescriptionSearchable"
                                    IsEnabled="{Binding IsReadonly}"
                                    ItemsSource="{Binding Packings}"
                                    LostFocus="ac_LostFocus"
                                    NoResultsContent="Nessun codice trovato"
                                    SelectedItem="{Binding SelectedPacking, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SelectionChanged="acPacking_SelectionChanged"
                                    SelectionMode="Single"
                                    TextSearchMode="Contains"
                                    TextSearchPath="FullDescriptionSearchable"
                                    WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
        <TextBlock Grid.Row="4"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Spedizione" />
        <telerik:RadAutoCompleteBox x:Name="acShipment"
                                    Grid.Row="4"
                                    Grid.Column="1"
                                    Margin="5,2,15,2"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    DisplayMemberPath="FullDescriptionSearchable"
                                    IsEnabled="{Binding IsReadonly}"
                                    ItemsSource="{Binding Shipments}"
                                    LostFocus="ac_LostFocus"
                                    NoResultsContent="Nessun codice trovato"
                                    SelectedItem="{Binding SelectedShipment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SelectionChanged="acShipment_SelectionChanged"
                                    SelectionMode="Single"
                                    TextSearchMode="Contains"
                                    TextSearchPath="FullDescriptionSearchable"
                                    WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
        <TextBlock Grid.Row="5"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Consegna" />
        <telerik:RadAutoCompleteBox x:Name="acDelivery"
                                    Grid.Row="5"
                                    Grid.Column="1"
                                    Margin="5,2,15,2"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    DisplayMemberPath="FullDescriptionSearchable"
                                    IsEnabled="{Binding IsReadonly}"
                                    ItemsSource="{Binding Deliveries}"
                                    LostFocus="ac_LostFocus"
                                    NoResultsContent="Nessun codice trovato"
                                    SelectedItem="{Binding SelectedDelivery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SelectionChanged="acDelivery_SelectionChanged"
                                    SelectionMode="Single"
                                    TextSearchMode="Contains"
                                    TextSearchPath="FullDescriptionSearchable"
                                    WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

        <TextBlock Grid.Row="7"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Primo corriere" />
        <telerik:RadAutoCompleteBox x:Name="acFirstCarrier"
                                    Grid.Row="7"
                                    Grid.Column="1"
                                    Margin="5,2,15,2"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    DisplayMemberPath="FullDescriptionSearchable"
                                    IsEnabled="{Binding IsReadonly}"
                                    ItemsSource="{Binding Carriers}"
                                    LostFocus="ac_LostFocus"
                                    NoResultsContent="Nessun codice trovato"
                                    SelectedItem="{Binding SelectedFirstCarrier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SelectionChanged="acFirstCarrier_SelectionChanged"
                                    SelectionMode="Single"
                                    TextSearchMode="Contains"
                                    TextSearchPath="FullDescriptionSearchable"
                                    WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
        <TextBlock Grid.Row="8"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Secondo corriere" />
        <telerik:RadAutoCompleteBox x:Name="acSecondCarrier"
                                    Grid.Row="8"
                                    Grid.Column="1"
                                    Margin="5,2,15,2"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    DisplayMemberPath="FullDescriptionSearchable"
                                    IsEnabled="{Binding IsReadonly}"
                                    ItemsSource="{Binding Carriers}"
                                    LostFocus="ac_LostFocus"
                                    NoResultsContent="Nessun codice trovato"
                                    SelectedItem="{Binding SelectedSecondCarrier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SelectionChanged="acSecondCarrier_SelectionChanged"
                                    SelectionMode="Single"
                                    TextSearchMode="Contains"
                                    TextSearchPath="FullDescriptionSearchable"
                                    WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

        <TextBlock Grid.Row="10"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Aspetto esteriore dei beni" />
        <TextBox Grid.Row="10"
                 Grid.Column="1"
                 Margin="5,0,15,0"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Center"
                 IsEnabled="{Binding IsReadonly}"
                 MaxLength="50"
                 Text="{Binding Data.BTDEBE, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock Grid.Row="11"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Peso lordo (Kg)" />
        <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal">
            <telerik:RadNumericUpDown Width="100"
                                      Margin="5,2,2,2"
                                      HorizontalAlignment="Left"
                                      Minimum="0"
                                      NumberDecimalDigits="2"
                                      ShowButtons="False"
                                      Value="{Binding Data.BTPESO, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Margin="15,0,0,0" Style="{StaticResource VulpesXLabel}" Text="Peso netto (Kg)" />
            <telerik:RadNumericUpDown Width="100"
                                      Margin="15,2,2,2"
                                      HorizontalAlignment="Left"
                                      Minimum="0"
                                      NumberDecimalDigits="2"
                                      ShowButtons="False"
                                      Value="{Binding Data.BTPES2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Margin="15,0,0,0" Style="{StaticResource VulpesXLabel}" Text="Tara (Kg)" />
            <TextBlock MinWidth="100"
                       Margin="10,2,2,2"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding Data.Tare, StringFormat=N2}"
                       TextAlignment="Right" />
        </StackPanel>
        <TextBlock Grid.Row="12"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Numero colli" />
        <telerik:RadNumericUpDown Grid.Row="12"
                                  Grid.Column="1"
                                  Width="100"
                                  Margin="5,2,2,2"
                                  HorizontalAlignment="Left"
                                  Minimum="0"
                                  NumberDecimalDigits="2"
                                  ShowButtons="False"
                                  Value="{Binding Data.BTCOLL, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Grid.Row="14"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Width="200"
                    Margin="2"
                    BorderBrush="Gold"
                    BorderThickness="5,0,0,0"
                    Content="USCIRE"
                    FontSize="10"
                    IsCancel="True" />
            <Button Name="cmdSave"
                    Width="200"
                    Margin="2"
                    BorderBrush="ForestGreen"
                    BorderThickness="5,0,0,0"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    FontSize="10"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
