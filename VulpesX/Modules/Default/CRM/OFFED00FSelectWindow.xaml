<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.CRM.OFFED00FSelectWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.CRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Seleziona le righe dagli ordini"
                        Width="1024"
                        Height="768"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="6*" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Margin="10,0,0,0" Style="{DynamicResource VulpesXLabel}" Text="Cliente" />
            <TextBlock Margin="10,0,0,0" Style="{DynamicResource VulpesXData}" Text="{Binding FirstHead.Customer.FullDescriptionSearchable}" />
            <TextBlock Margin="10,0,0,0" Style="{DynamicResource VulpesXLabel}" Text="Destinazione" />
            <TextBlock Margin="10,0,0,0" Style="{DynamicResource VulpesXData}" Text="{Binding FirstHead.Recipient.FullDescriptionSearchable}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="35" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Style="{DynamicResource VulpesXTitle}" Text="RIGHE DA OFFERTE" />
            <Grid Grid.Row="1" Margin="5,5,5,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="rgvRows"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     RowIndicatorVisibility="Collapsed"
                                     SelectionMode="Extended"
                                     ShowGroupPanel="False">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewSelectColumn IsSelected="False" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding OFTNUOR}"
                                                    Header="Ordine n."
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="60"
                                                    DataMemberBinding="{Binding OFDRIGA}"
                                                    Header="Riga"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding SelectedProduct.FullDescriptionSearchable}" Header="Prodotto" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataMemberBinding="{Binding OFDQTAV}"
                                                    Header="Quantita'"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="60"
                                                    DataMemberBinding="{Binding SelectedProduct.UnitaID}"
                                                    Header="UM"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding QuantityTypeDescription}" Header="Tipo q.ta'" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataMemberBinding="{Binding OFDPREZ}"
                                                    Header="Prezzo"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding PriceTypeDescription}" Header="Tipo prezzo" />

                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding AvailableRows}" />
            </Grid>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="35" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Style="{DynamicResource VulpesXTitle}" Text="ALLEGATI DA OFFERTE" />
            <Grid Grid.Row="1" Margin="5,5,5,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="rgvAttachments"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGridAtt}"
                                     RowIndicatorVisibility="Collapsed"
                                     SelectionMode="Extended"
                                     ShowGroupPanel="False">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewSelectColumn />
                        <telerik:GridViewDataColumn Width="600" DataMemberBinding="{Binding OFTANAME}" Header="Nome" />
                        <telerik:GridViewDataColumn Width="150"
                                                    DataMemberBinding="{Binding OFTASIZEText}"
                                                    Header="Dimensione"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGridAtt"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding AvailableAttachments}" />
            </Grid>
        </Grid>

        <StackPanel Grid.Row="3"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="CREA ORDINE CLIENTE"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
