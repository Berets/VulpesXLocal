<UserControl x:Class="VulpesX.Modules.Default.Treasury.MovementsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Treasury"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="90" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="MOVIMENTI E SALDI" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <telerik:RadComboBox x:Name="cmbYear"
                                     Grid.Row="0"
                                     Width="200"
                                     Margin="5"
                                     HorizontalAlignment="Right"
                                     HorizontalContentAlignment="Right"
                                     DisplayMemberPath="eseann"
                                     SelectionChanged="RadComboBox_SelectionChanged" />
            </StackPanel>
        </Grid>


        <telerik:RadBusyIndicator x:Name="bsyData"
                                  Grid.Row="1"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">

            <Border BorderBrush="{DynamicResource VulpesXBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30" />
                        <RowDefinition Height="30" />
                        <RowDefinition Height="30" />
                        <RowDefinition Height="30" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Disponibilita' al" />
                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Margin="1"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="DeepSkyBlue"
                               Text="{Binding TodayText, Mode=OneWay}" />
                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               Margin="1"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="DeepSkyBlue"
                               Text="{Binding TotaleDisponibilita, StringFormat={} {0:N2} €}" />

                    <TextBlock Grid.Row="0"
                               Grid.Column="3"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Disponibilita' portafoglio" />
                    <TextBlock Grid.Row="0"
                               Grid.Column="4"
                               Margin="1"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="DeepSkyBlue"
                               Text="{Binding TotaleDisponibilitaPortafoglio, StringFormat={} {0:N2} €}" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Disponibilita' fino al" />
                    <telerik:RadDateTimePicker x:Name="rdtLimitDate"
                                               Grid.Row="1"
                                               Grid.Column="1"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               DateSelectionMode="Day"
                                               DateTimeWatermarkContent="Scegliere la data limite"
                                               DisplayFormat="Short"
                                               InputMode="DatePicker"
                                               ParseExact="True"
                                               SelectionChanged="rdtLimitDate_SelectionChanged" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Margin="0,0,15,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXSecondBrush}"
                               Text="Mostra solo presentati in banca" />
                    <telerik:RadToggleSwitchButton Name="rtsOnlyAtBank"
                                                   Grid.Row="2"
                                                   Grid.Column="1"
                                                   Margin="5,0,0,0"
                                                   Checked="rtsOnlyAtBank_Checked"
                                                   IsThreeState="False"
                                                   Unchecked="rtsOnlyAtBank_Unchecked" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               Margin="1"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="DeepSkyBlue"
                               Text="{Binding TotaleDisponibilitaFutura, StringFormat={} {0:N2} €}" />


                </Grid>
            </Border>


        </telerik:RadBusyIndicator>
        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">

            <Grid>
                <Grid.Resources>
                    <selectors:TreasuryMovementAvailabilityCellSelector x:Key="TreasuryFutureAvailabilityCellSelector">
                        <selectors:TreasuryMovementAvailabilityCellSelector.DefaultCell>
                            <DataTemplate>
                                <TextBlock Foreground="{DynamicResource VulpesXSecondBrush}" Text="{Binding DisponibilitaFutura, StringFormat=N2}" TextAlignment="Right" />
                            </DataTemplate>
                        </selectors:TreasuryMovementAvailabilityCellSelector.DefaultCell>
                        <selectors:TreasuryMovementAvailabilityCellSelector.NegativeCell>
                            <DataTemplate>
                                <TextBlock Foreground="{DynamicResource VulpesXRedBrush}" Text="{Binding DisponibilitaFutura, StringFormat=N2}" TextAlignment="Right" />
                            </DataTemplate>
                        </selectors:TreasuryMovementAvailabilityCellSelector.NegativeCell>
                    </selectors:TreasuryMovementAvailabilityCellSelector>
                </Grid.Resources>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     CellEditEnded="GridView_CellEditEnded"
                                     EditTriggers="Default"
                                     GroupRenderMode="Flat"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     LeftFrozenColumnCount="2"
                                     RowIndicatorVisibility="Collapsed"
                                     ShowGroupPanel="True">
                    <telerik:RadContextMenu.ContextMenu>
                        <telerik:RadContextMenu x:Name="cmGrid" Background="#2C2D33" Opening="cmGrid_Opening">
                            <telerik:RadMenuItem x:Name="rmiBankFluxes"
                                                 Click="rmiBankFluxes_Click"
                                                 Header="Flussi bancari"
                                                 Typography.Capitals="AllSmallCaps">
                                <telerik:RadMenuItem.Icon>
                                    <Image Width="16"
                                           Height="16"
                                           Source="{telerik:RadGlyph Glyph={StaticResource GlyphStumbleUpon}}"
                                           Stretch="Uniform" />
                                </telerik:RadMenuItem.Icon>
                            </telerik:RadMenuItem>
                        </telerik:RadContextMenu>
                    </telerik:RadContextMenu.ContextMenu>
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewDataColumn Width="200"
                                                    DataMemberBinding="{Binding Bank.Bank.abiban}"
                                                    Header="Banca"
                                                    IsReadOnly="True" />
                        <telerik:GridViewDataColumn Width="200"
                                                    DataMemberBinding="{Binding Bank.Bank.abiage}"
                                                    Header="Filiale"
                                                    IsReadOnly="True" />
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding cnsl17}"
                                                    Header="Saldo banca"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right">
                            <telerik:GridViewDataColumn.CellEditTemplate>
                                <DataTemplate>
                                    <telerik:RadNumericUpDown Width="120"
                                                              Margin="1"
                                                              HorizontalAlignment="Left"
                                                              NumberDecimalDigits="2"
                                                              ShowButtons="False"
                                                              Tag="cnsl17"
                                                              Value="{Binding cnsl17, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </telerik:GridViewDataColumn.CellEditTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding Differenza}"
                                                    Header="Disponibilita'"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="130"
                                                    DataFormatString="{}{0:N2}"
                                                    DataMemberBinding="{Binding ImportoProvvisorio}"
                                                    Header="Imp. scaduti"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdDetails"
                                            Margin="3"
                                            HorizontalContentAlignment="Right"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdDetails_Click"
                                            Cursor="Hand"
                                            Foreground="{Binding ImportoProvvisorioBrush, Converter={StaticResource stringToColorConverter}}"
                                            ToolTip="Clicca qui per visualizzare i dettagli degli importi provvisori">
                                        <Button.Content>
                                            <TextBlock Text="{Binding Path=ImportoProvvisorio, StringFormat={}{0:N2}}" />
                                        </Button.Content>
                                    </Button>
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding SaldoAlGiorno}"
                                                    Header="Saldo al giorno"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="150"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding ImportoScadenza}"
                                                    Header="Imp. scadenza mese"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdDetailsExpire"
                                            Margin="3"
                                            HorizontalContentAlignment="Right"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdDetailsExpire_Click"
                                            Cursor="Hand"
                                            Foreground="{Binding ImportoScadenzaBrush, Converter={StaticResource stringToColorConverter}}"
                                            ToolTip="Clicca qui per visualizzare i dettagli degli importi in scadenza questo mese">

                                        <Button.Content>
                                            <TextBlock Text="{Binding Path=ImportoScadenza, StringFormat={}{0:N2}}" />
                                        </Button.Content>
                                    </Button>
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="140"
                                                    CellTemplateSelector="{StaticResource TreasuryFutureAvailabilityCellSelector}"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding DisponibilitaFutura}"
                                                    Header="Disp. fine mese"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="150"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding ImportoScadenzaSuccessiva}"
                                                    Header="Imp. scadenza succ."
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdDetailsExpireNext"
                                            Margin="3"
                                            HorizontalContentAlignment="Right"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdDetailsExpireNext_Click"
                                            ContentStringFormat="N2"
                                            Cursor="Hand"
                                            Foreground="{Binding ImportoScadenzaSuccessivaBrush, Converter={StaticResource stringToColorConverter}}"
                                            ToolTip="Clicca qui per visualizzare i dettagli degli importi in scadenza nei prossimi mesi">

                                        <Button.Content>
                                            <TextBlock Text="{Binding Path=ImportoScadenzaSuccessiva, StringFormat={}{0:N2}}" />
                                        </Button.Content>
                                    </Button>
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="140"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding ImpegnatoFornitori}"
                                                    Header="Disp. mesi succ."
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="3"
                                               Foreground="{Binding DisponibilitaMesiSuccessiviBrush, Converter={StaticResource stringToColorConverter}}"
                                               Text="{Binding Path=DisponibilitaMesiSuccessivi, StringFormat=N2}"
                                               TextAlignment="Right" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="140"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding Castelletto}"
                                                    Header="Castelletto"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdCastellettoDetails"
                                            Margin="3"
                                            HorizontalContentAlignment="Right"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdCastellettoDetails_Click"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}"
                                            ToolTip="Clicca qui per visualizzare i dettagli del castelletto">
                                        <Button.Content>
                                            <TextBlock Text="{Binding Path=Castelletto, StringFormat={}{0:N2}}" />
                                        </Button.Content>
                                    </Button>
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="140"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding DisponibilitaPortafoglio}"
                                                    Header="Disp. portafoglio"
                                                    HeaderTextAlignment="Right"
                                                    IsReadOnly="True"
                                                    TextAlignment="Right" />
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding Items}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>
</UserControl>
