<UserControl x:Class="VulpesX.Modules.Default.Treasury.CommitmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Treasury"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="IMPEGNI FISCALI" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />
            </StackPanel>
        </Grid>


        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="1"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <telerik:RadTabControl Grid.Row="0"
                                       VerticalAlignment="Stretch"
                                       BorderThickness="0"
                                       DisplayMemberPath="Content"
                                       DropDownDisplayMode="Visible"
                                       ScrollMode="Viewport">
                    <telerik:RadTabItem DropDownContent="GESTIONE IMPEGNI" Header="GESTIONE IMPEGNI">
                        <telerik:RadTabItem.Content>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="35" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" HorizontalAlignment="Stretch">
                                    <telerik:RadWatermarkTextBox Name="txtSearch"
                                                                 Margin="5"
                                                                 TextChanged="txtSearch_TextChanged"
                                                                 WatermarkContent="Cerca..." />
                                </Grid>

                                <telerik:RadGridView x:Name="GridView"
                                                     Grid.Row="1"
                                                     AutoGenerateColumns="False"
                                                     CanUserFreezeColumns="False"
                                                     CanUserResizeColumns="False"
                                                     GroupRenderMode="Flat"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                                     RowDetailsVisibilityMode="VisibleWhenSelected"
                                                     RowIndicatorVisibility="Collapsed"
                                                     ShowGroupPanel="True">
                                    <telerik:RadContextMenu.ContextMenu>
                                        <telerik:RadContextMenu x:Name="cmGrid" Opening="cmGrid_Opening">
                                            <telerik:RadMenuItem x:Name="rmiAccounting"
                                                                 Click="rmiAccounting_Click"
                                                                 Header="Contabilizzazione"
                                                                 Typography.Capitals="AllSmallCaps">
                                                <telerik:RadMenuItem.Icon>
                                                    <Image Width="16"
                                                           Height="16"
                                                           Source="{telerik:RadGlyph Glyph={StaticResource GlyphLinkHorizontal}}"
                                                           Stretch="Uniform" />
                                                </telerik:RadMenuItem.Icon>
                                            </telerik:RadMenuItem>
                                        </telerik:RadContextMenu>
                                    </telerik:RadContextMenu.ContextMenu>
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewColumn Width="110">
                                            <telerik:GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <telerik:RadButton x:Name="cmdDelete"
                                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                                       Click="cmdDelete_Click"
                                                                       Content="Elimina"
                                                                       Style="{StaticResource VulpesXButton}" />
                                                </DataTemplate>
                                            </telerik:GridViewColumn.CellTemplate>
                                        </telerik:GridViewColumn>
                                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding Group.FullDescriptionSearchable}" Header="Gruppo">
                                            <telerik:GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button x:Name="cmdEdit"
                                                            Margin="3"
                                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                                            Click="cmdEdit_Click"
                                                            Content="{Binding Path=Group.FullDescriptionSearchable}"
                                                            Cursor="Hand"
                                                            Foreground="{DynamicResource VulpesXBrush}"
                                                            ToolTip="Clicca per modificare i dettagli" />
                                                </DataTemplate>
                                            </telerik:GridViewColumn.CellTemplate>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding Account.FullDescriptionSearchable}" Header="Conto" />
                                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding Subaccount.FullDescriptionSearchable}" Header="Sottoconto" />
                                        <telerik:GridViewDataColumn Width="120"
                                                                    DataFormatString="dd/MM/yyyy"
                                                                    DataMemberBinding="{Binding ifdata}"
                                                                    Header="Data"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="120"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding ifimpo}"
                                                                    Header="Importo"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewColumn.AggregateFunctions>
                                                <telerik:SumFunction Caption="TOTALE: " ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="120" DataMemberBinding="{Binding ifrife}" Header="Riferimento" />
                                        <telerik:GridViewDataColumn Width="140"
                                                                    DataFormatString="dd/MM/yyyy"
                                                                    DataMemberBinding="{Binding ifdaca}"
                                                                    Header="Data chiusura"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="70"
                                                                    DataMemberBinding="{Binding Year}"
                                                                    Header="Anno"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="70"
                                                                    DataMemberBinding="{Binding Month}"
                                                                    Header="Mese"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding ifnote}"
                                                                    Header="Note"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Left" />
                                    </telerik:RadGridView.Columns>
                                    <telerik:RadGridView.RowDetailsTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="10" Orientation="Horizontal">
                                                <TextBlock FontWeight="Bold" Text="Note: " />
                                                <TextBlock Text="{Binding ifnote}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </telerik:RadGridView.RowDetailsTemplate>
                                </telerik:RadGridView>
                                <telerik:RadDataPager x:Name="rdpGrid"
                                                      Grid.Row="2"
                                                      Margin="0,-1,0,0"
                                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                                      FontSize="12"
                                                      IsTotalItemCountFixed="True"
                                                      PageSize="20"
                                                      Source="{Binding Items}" />
                            </Grid>
                        </telerik:RadTabItem.Content>
                    </telerik:RadTabItem>
                    <telerik:RadTabItem DropDownContent="PROSSIMI IMPEGNI" Header="PROSSIMI IMPEGNI">
                        <telerik:RadTabItem.Content>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="35" />
                                </Grid.RowDefinitions>
                                <Grid.Resources>
                                    <selectors:TreasuryCommitmentDateCellSelector x:Key="IMFIDateCellSelector">
                                        <selectors:TreasuryCommitmentDateCellSelector.DefaultCell>
                                            <DataTemplate>
                                                <TextBlock Foreground="{DynamicResource VulpesXSecondBrush}" Text="{Binding ifdata, StringFormat={}{0:dd/MM/yyyy}}" TextAlignment="Center" />
                                            </DataTemplate>
                                        </selectors:TreasuryCommitmentDateCellSelector.DefaultCell>
                                        <selectors:TreasuryCommitmentDateCellSelector.ExpiringCell>
                                            <DataTemplate>
                                                <TextBlock Background="{DynamicResource VulpesXYellowBrush}"
                                                           Foreground="Black"
                                                           Text="{Binding ifdata, StringFormat={}{0:dd/MM/yyyy}}"
                                                           TextAlignment="Center" />
                                            </DataTemplate>
                                        </selectors:TreasuryCommitmentDateCellSelector.ExpiringCell>
                                        <selectors:TreasuryCommitmentDateCellSelector.ExpiredCell>
                                            <DataTemplate>
                                                <TextBlock Background="{DynamicResource VulpesXRedBrush}"
                                                           Foreground="{DynamicResource VulpesXSecondBrush}"
                                                           Text="{Binding ifdata, StringFormat={}{0:dd/MM/yyyy}}"
                                                           TextAlignment="Center" />
                                            </DataTemplate>
                                        </selectors:TreasuryCommitmentDateCellSelector.ExpiredCell>
                                    </selectors:TreasuryCommitmentDateCellSelector>
                                </Grid.Resources>
                                <Grid Grid.Row="0" HorizontalAlignment="Stretch">
                                    <telerik:RadWatermarkTextBox Name="txtSearchNext"
                                                                 Margin="5"
                                                                 TextChanged="txtSearchNext_TextChanged"
                                                                 WatermarkContent="Cerca..." />
                                </Grid>
                                <telerik:RadGridView x:Name="GridViewNear"
                                                     Grid.Row="1"
                                                     AutoGenerateColumns="False"
                                                     CanUserFreezeColumns="False"
                                                     CanUserResizeColumns="False"
                                                     GroupRenderMode="Flat"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding PagedSource, ElementName=rdpGridNear}"
                                                     RowDetailsVisibilityMode="VisibleWhenSelected"
                                                     RowIndicatorVisibility="Collapsed"
                                                     ShowGroupPanel="True">
                                    <telerik:RadContextMenu.ContextMenu>
                                        <telerik:RadContextMenu x:Name="cmGridNext" Background="#2C2D33" Opening="cmGridNext_Opening">
                                            <telerik:RadMenuItem x:Name="rmiAccountingNext"
                                                                 Background="{DynamicResource VulpesXBrush}"
                                                                 Click="rmiAccountingNext_Click"
                                                                 Foreground="Black"
                                                                 Header="Contabilizzazione"
                                                                 Typography.Capitals="AllSmallCaps">
                                                <telerik:RadMenuItem.Icon>
                                                    <Image Width="16"
                                                           Height="16"
                                                           Source="{telerik:RadGlyph Glyph={StaticResource GlyphLinkHorizontal}}"
                                                           Stretch="Uniform" />
                                                </telerik:RadMenuItem.Icon>
                                            </telerik:RadMenuItem>
                                        </telerik:RadContextMenu>
                                    </telerik:RadContextMenu.ContextMenu>
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewColumn Width="110">
                                            <telerik:GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <telerik:RadButton x:Name="cmdDelete"
                                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                                       Click="cmdDelete_Click"
                                                                       Content="Elimina"
                                                                       Style="{StaticResource VulpesXButton}" />
                                                </DataTemplate>
                                            </telerik:GridViewColumn.CellTemplate>
                                        </telerik:GridViewColumn>
                                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding Group.FullDescriptionSearchable}" Header="Gruppo">
                                            <telerik:GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button x:Name="cmdEdit"
                                                            Margin="3"
                                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                                            Click="cmdEdit_Click"
                                                            Content="{Binding Path=Group.FullDescriptionSearchable}"
                                                            Cursor="Hand"
                                                            Foreground="{DynamicResource VulpesXBrush}"
                                                            ToolTip="Clicca per modificare i dettagli" />
                                                </DataTemplate>
                                            </telerik:GridViewColumn.CellTemplate>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding Account.FullDescriptionSearchable}" Header="Conto" />
                                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding Subaccount.FullDescriptionSearchable}" Header="Sottoconto" />
                                        <telerik:GridViewDataColumn Width="120"
                                                                    CellTemplateSelector="{StaticResource IMFIDateCellSelector}"
                                                                    DataFormatString="dd/MM/yyyy"
                                                                    DataMemberBinding="{Binding ifdata}"
                                                                    Header="Data"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="120"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding ifimpo}"
                                                                    Header="Importo"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewColumn.AggregateFunctions>
                                                <telerik:SumFunction Caption="TOTALE: " ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="120" DataMemberBinding="{Binding ifrife}" Header="Riferimento" />
                                        <telerik:GridViewDataColumn Width="140"
                                                                    DataFormatString="dd/MM/yyyy"
                                                                    DataMemberBinding="{Binding ifdaca}"
                                                                    Header="Data chiusura"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="70"
                                                                    DataMemberBinding="{Binding Year}"
                                                                    Header="Anno"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="70"
                                                                    DataMemberBinding="{Binding Month}"
                                                                    Header="Mese"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding ifnote}"
                                                                    Header="Note"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Left" />
                                    </telerik:RadGridView.Columns>
                                    <telerik:RadGridView.RowDetailsTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="10" Orientation="Horizontal">
                                                <TextBlock FontWeight="Bold" Text="Note: " />
                                                <TextBlock Text="{Binding ifnote}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </telerik:RadGridView.RowDetailsTemplate>
                                </telerik:RadGridView>
                                <telerik:RadDataPager x:Name="rdpGridNear"
                                                      Grid.Row="2"
                                                      Margin="0,-1,0,0"
                                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                                      FontSize="12"
                                                      IsTotalItemCountFixed="True"
                                                      PageSize="20"
                                                      Source="{Binding ItemsNear}" />
                            </Grid>
                        </telerik:RadTabItem.Content>
                    </telerik:RadTabItem>
                </telerik:RadTabControl>
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>

</UserControl>
