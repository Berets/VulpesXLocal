<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Treasury.CommitmentWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Treasury"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli impegno fiscale"
                        Width="600"
                        Height="500"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="5" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="70" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="7*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Gruppo" />
                <telerik:RadAutoCompleteBox Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            IsEnabled="{Binding IsInsert}"
                                            ItemsSource="{Binding Data.GroupsList}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun gruppo trovato"
                                            SelectedItem="{Binding Data.SelectedGroup, Mode=TwoWay}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Conto" />
                <telerik:RadAutoCompleteBox Grid.Row="2"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            IsEnabled="{Binding IsInsert}"
                                            ItemsSource="{Binding Data.AccountsList}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun conto trovato"
                                            SelectedItem="{Binding Data.SelectedAccount, Mode=TwoWay}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Sottoconto" />
                <telerik:RadAutoCompleteBox Grid.Row="3"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            IsEnabled="{Binding IsInsert}"
                                            ItemsSource="{Binding Data.SubaccountsList}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun sottoconto trovato"
                                            SelectedItem="{Binding Data.SelectedSubaccount, Mode=TwoWay}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Data" />
                <telerik:RadDateTimePicker x:Name="dtpDate"
                                           Grid.Row="4"
                                           Grid.Column="1"
                                           Margin="5,0,15,0"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent="Scegliere la data"
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           IsEnabled="{Binding IsInsert}"
                                           SelectedValue="{Binding Data.ifdata, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Importo" />
                <telerik:RadNumericUpDown Grid.Row="5"
                                          Grid.Column="3"
                                          Margin="5,0,15,3"
                                          VerticalAlignment="Bottom"
                                          Minimum="0"
                                          NumberDecimalDigits="2"
                                          Value="{Binding Data.ifimpo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Riferimento" />
                <TextBox Grid.Row="6"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         Text="{Binding Data.ifrife, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="7"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Data chiusura" />
                <telerik:RadDateTimePicker Grid.Row="7"
                                           Grid.Column="1"
                                           Margin="5,0,15,0"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent="Scegliere la data di chiusura"
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           SelectedValue="{Binding Data.ifdaca}" />

                <TextBlock Grid.Row="8"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Note" />
                <TextBox Grid.Row="8"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         VerticalContentAlignment="Top"
                         AcceptsReturn="True"
                         MinLines="3"
                         SpellCheck.IsEnabled="True"
                         Text="{Binding Data.ifnote}"
                         TextWrapping="WrapWithOverflow" />

            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
