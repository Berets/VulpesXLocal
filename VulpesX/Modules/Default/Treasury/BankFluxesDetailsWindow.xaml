<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Treasury.BankFluxesDetailsWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:aggregators="clr-namespace:VulpesX.Shared.Controls.Aggregators;assembly=VulpesX.Shared.Controls"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Treasury"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Flussi per banca"
                        Width="1024"
                        Height="768"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Margin="15,0,0,0"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Center"
                       FontSize="20"
                       Foreground="{DynamicResource VulpesXBrush}"
                       Text="TESORERIA - FLUSSI BANCARI - DETTAGLIO MOVIMENTI TEMPORANEI" />

            <StackPanel Grid.Row="1" Margin="25,0,0,0" Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Banca" />
                <TextBlock Margin="15,0,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{DynamicResource VulpesXBrush}"
                           Text="{Binding BankFullText}" />
            </StackPanel>

            <telerik:RadBusyIndicator x:Name="bsyGrid"
                                      Grid.Row="2"
                                      BusyContent="Caricamento dati in corso..."
                                      Foreground="{DynamicResource VulpesXBrush}"
                                      IsBusy="{Binding IsBusy}"
                                      OverlayStyle="{StaticResource WaitOverlayStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="35" />
                    </Grid.RowDefinitions>
                    <telerik:RadGridView x:Name="grdData"
                                         Grid.Row="0"
                                         AutoGenerateColumns="False"
                                         CanUserFreezeColumns="False"
                                         CanUserResizeColumns="False"
                                         CellEditEnded="grdData_CellEditEnded"
                                         GroupRenderMode="Flat"
                                         ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                         RowIndicatorVisibility="Collapsed"
                                         SelectionMode="Single"
                                         ShowColumnFooters="True"
                                         ShowGroupPanel="True">
                        <telerik:RadGridView.Columns>
                            <telerik:GridViewColumn Width="120">
                                <telerik:GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <telerik:RadButton x:Name="cmdSflag"
                                                           telerik:TouchManager.TouchMode="HitTestHidden"
                                                           BorderBrush="{DynamicResource VulpesXBrush}"
                                                           Click="cmdSflag_Click"
                                                           Content="RENDI DEFINITIVA"
                                                           Style="{StaticResource VulpesXButton}"
                                                           ToolTip="Clicca per rendere definitiva questa riga di registrazione" />
                                    </DataTemplate>
                                </telerik:GridViewColumn.CellTemplate>
                            </telerik:GridViewColumn>
                            <telerik:GridViewCheckBoxColumn DataMemberBinding="{Binding N1FLTE}" Header="Banca" />
                            <telerik:GridViewDataColumn Width="70"
                                                        DataMemberBinding="{Binding N1REGI}"
                                                        Header="Nr. reg."
                                                        HeaderTextAlignment="Right"
                                                        IsReadOnly="True"
                                                        TextAlignment="Right">
                                <telerik:GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button x:Name="cmdEdit"
                                                Margin="3"
                                                HorizontalContentAlignment="Right"
                                                BorderBrush="{DynamicResource VulpesXBrush}"
                                                Click="cmdEditHead_Click"
                                                Content="{Binding Path=N1REGI}"
                                                Cursor="Hand"
                                                Foreground="{DynamicResource VulpesXBrush}" />
                                    </DataTemplate>
                                </telerik:GridViewColumn.CellTemplate>
                            </telerik:GridViewDataColumn>
                            <telerik:GridViewDataColumn Width="90"
                                                        DataFormatString="dd/MM/yyyy"
                                                        DataMemberBinding="{Binding Testata.N1DARE}"
                                                        Header="Data reg."
                                                        HeaderTextAlignment="Center"
                                                        IsReadOnly="True"
                                                        TextAlignment="Center">
                                <telerik:GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button x:Name="cmdEdit"
                                                Margin="3"
                                                HorizontalContentAlignment="Center"
                                                BorderBrush="{DynamicResource VulpesXBrush}"
                                                Click="cmdEditDetails_Click"
                                                Content="{Binding Path=Testata.N1DARE}"
                                                Cursor="Hand"
                                                Foreground="{DynamicResource VulpesXBrush}" />
                                    </DataTemplate>
                                </telerik:GridViewColumn.CellTemplate>
                            </telerik:GridViewDataColumn>
                            <telerik:GridViewDataColumn Width="200"
                                                        DataMemberBinding="{Binding Testata.BasicRegistry.FullDescriptionSearchable}"
                                                        Header="Ragione sociale"
                                                        IsReadOnly="True" />
                            <telerik:GridViewDataColumn Width="75"
                                                        DataMemberBinding="{Binding Testata.pncaus}"
                                                        Header="Causale"
                                                        IsReadOnly="True"
                                                        TextAlignment="Right" />
                            <telerik:GridViewDataColumn Width="180"
                                                        DataMemberBinding="{Binding Testata.AccountingCausal.caudes}"
                                                        Header="Descrizione causale"
                                                        IsReadOnly="True" />
                            <telerik:GridViewDataColumn Width="50"
                                                        DataMemberBinding="{Binding Testata.pnvdiv}"
                                                        Header="Val."
                                                        IsReadOnly="True"
                                                        TextAlignment="Center" />
                            <telerik:GridViewDataColumn Width="150"
                                                        DataFormatString="N2"
                                                        DataMemberBinding="{Binding N1IMEU}"
                                                        FooterTextAlignment="Right"
                                                        Header="Importo"
                                                        HeaderTextAlignment="Right"
                                                        IsReadOnly="True"
                                                        TextAlignment="Right">
                                <telerik:GridViewColumn.AggregateFunctions>
                                    <aggregators:PNRigheCustomSum ResultFormatString="{}{0:N2}" />
                                </telerik:GridViewColumn.AggregateFunctions>
                            </telerik:GridViewDataColumn>
                            <telerik:GridViewDataColumn Width="60"
                                                        DataMemberBinding="{Binding N1SEGN}"
                                                        Header="D/A"
                                                        IsReadOnly="True"
                                                        TextAlignment="Center" />
                            <telerik:GridViewDataColumn Width="150"
                                                        DataFormatString="N2"
                                                        DataMemberBinding="{Binding TreasuryProgressive}"
                                                        FooterTextAlignment="Right"
                                                        Header="Progressivo"
                                                        HeaderTextAlignment="Right"
                                                        IsReadOnly="True"
                                                        TextAlignment="Right" />
                            <telerik:GridViewDataColumn Width="60"
                                                        DataMemberBinding="{Binding TreasuryProgressiveSign}"
                                                        Header="D/A"
                                                        IsReadOnly="True"
                                                        TextAlignment="Center" />
                            <telerik:GridViewDataColumn Width="120"
                                                        DataMemberBinding="{Binding Testata.N1docn}"
                                                        Header="Documento"
                                                        HeaderTextAlignment="Right"
                                                        IsReadOnly="True"
                                                        TextAlignment="Right" />
                            <telerik:GridViewDataColumn Width="120"
                                                        DataMemberBinding="{Binding Testata.N1rifn}"
                                                        Header="Riferimento"
                                                        HeaderTextAlignment="Right"
                                                        IsReadOnly="True"
                                                        TextAlignment="Right" />
                        </telerik:RadGridView.Columns>
                    </telerik:RadGridView>
                    <telerik:RadDataPager x:Name="rdpGrid"
                                          Grid.Row="1"
                                          Margin="0,-1,0,0"
                                          DisplayMode="FirstLastPreviousNextNumeric, Text"
                                          FontSize="12"
                                          IsTotalItemCountFixed="True"
                                          PageSize="20"
                                          Source="{Binding Items}" />
                </Grid>
            </telerik:RadBusyIndicator>
        </Grid>
    </Grid>
</sc:FluentDefaultWindow>
