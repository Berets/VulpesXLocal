<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Treasury.BankFluxesWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Treasury"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Flussi per banca"
                        Width="950"
                        Height="700"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="5" />
                <RowDefinition Height="35" />
                <RowDefinition Height="5" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Margin="15,0,0,0"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Center"
                       FontSize="20"
                       Foreground="{DynamicResource VulpesXBrush}"
                       Text="TESORERIA - FLUSSI BANCARI" />

            <StackPanel Grid.Row="2" Margin="25,0,0,0" Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Banca" />
                <TextBlock Margin="15,0,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="DeepSkyBlue"
                           Text="{Binding BankFullText}" />
            </StackPanel>

            <telerik:RadBusyIndicator x:Name="bsyGrid"
                                      Grid.Row="4"
                                      BusyContent="Caricamento dati in corso..."
                                      FontSize="40"
                                      Foreground="{DynamicResource VulpesXBrush}"
                                      IsBusy="False"
                                      OverlayStyle="{StaticResource WaitOverlayStyle}">
                <telerik:RadTabControl Grid.Row="1"
                                       VerticalAlignment="Stretch"
                                       BorderThickness="0"
                                       DisplayMemberPath="Content"
                                       DropDownDisplayMode="Visible"
                                       ScrollMode="Viewport">
                    <telerik:RadTabItem DropDownContent="PER CAUSALE" Header="PER CAUSALE">
                        <telerik:RadTabItem.Content>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="35" />
                                </Grid.RowDefinitions>
                                <telerik:RadGridView x:Name="GridView"
                                                     Grid.Row="0"
                                                     AutoGenerateColumns="False"
                                                     CanUserFreezeColumns="False"
                                                     CanUserResizeColumns="False"
                                                     GroupRenderMode="Flat"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                                     RowIndicatorVisibility="Collapsed"
                                                     ShowColumnFooters="True"
                                                     ShowGroupFooters="True"
                                                     ShowGroupPanel="False">
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewDataColumn Width="80"
                                                                    DataMemberBinding="{Binding CausalID}"
                                                                    Header="Causale"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="180" DataMemberBinding="{Binding CausalDescription}" Header="Descrizione causale" />
                                        <telerik:GridViewDataColumn Width="110"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Total}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Totale causale"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="100"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Amounts[0]}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Gennaio"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="100"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Amounts[1]}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Febbraio"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="100"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Amounts[2]}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Marzo"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="100"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Amounts[3]}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Aprile"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="100"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Amounts[4]}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Maggio"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="100"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Amounts[5]}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Giugno"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="100"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Amounts[6]}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Luglio"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="100"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Amounts[7]}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Agosto"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="100"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Amounts[8]}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Settembre"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="100"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Amounts[9]}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Ottobre"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="100"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Amounts[10]}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Novembre"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="100"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Amounts[11]}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Dicembre"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                    </telerik:RadGridView.Columns>
                                </telerik:RadGridView>
                                <telerik:RadDataPager x:Name="rdpGrid"
                                                      Grid.Row="1"
                                                      Margin="0,-1,0,0"
                                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                                      FontSize="12"
                                                      IsTotalItemCountFixed="True"
                                                      PageSize="20"
                                                      Source="{Binding Items}" />
                            </Grid>
                        </telerik:RadTabItem.Content>
                    </telerik:RadTabItem>
                    <telerik:RadTabItem DropDownContent="PER PERIODO" Header="PER PERIODO">
                        <telerik:RadTabItem.Content>
                            <Grid>
                                <Grid.Resources>
                                    <selectors:TreasuryBankFluxSelector x:Key="TreasuryBankFluxSelector">
                                        <selectors:TreasuryBankFluxSelector.DefaultRowStyle>
                                            <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                                                <Setter Property="Background" Value="Transparent" />
                                            </Style>
                                        </selectors:TreasuryBankFluxSelector.DefaultRowStyle>
                                        <selectors:TreasuryBankFluxSelector.TemporaryRowStyle>
                                            <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                                                <Setter Property="Foreground" Value="OrangeRed" />
                                                <Setter Property="ToolTip" Value="Importi da registrazioni temporanee" />
                                            </Style>
                                        </selectors:TreasuryBankFluxSelector.TemporaryRowStyle>
                                    </selectors:TreasuryBankFluxSelector>
                                    <selectors:TreasuryBankFlowCellSelector x:Key="BankFlowTemporaryDetailsCellSelector">
                                        <selectors:TreasuryBankFlowCellSelector.DefaultCell10>
                                            <DataTemplate>
                                                <TextBlock Foreground="{DynamicResource VulpesXSecondBrush}" Text="{Binding Amounts[0], StringFormat=N2}" TextAlignment="Right" />
                                            </DataTemplate>
                                        </selectors:TreasuryBankFlowCellSelector.DefaultCell10>
                                        <selectors:TreasuryBankFlowCellSelector.DefaultCell20>
                                            <DataTemplate>
                                                <TextBlock Foreground="{DynamicResource VulpesXSecondBrush}" Text="{Binding Amounts[1], StringFormat=N2}" TextAlignment="Right" />
                                            </DataTemplate>
                                        </selectors:TreasuryBankFlowCellSelector.DefaultCell20>
                                        <selectors:TreasuryBankFlowCellSelector.DefaultCell30>
                                            <DataTemplate>
                                                <TextBlock Foreground="{DynamicResource VulpesXSecondBrush}" Text="{Binding Amounts[2], StringFormat=N2}" TextAlignment="Right" />
                                            </DataTemplate>
                                        </selectors:TreasuryBankFlowCellSelector.DefaultCell30>
                                        <selectors:TreasuryBankFlowCellSelector.TemporaryDetailsCell10>
                                            <DataTemplate>
                                                <Button x:Name="cmdDetailsFirst"
                                                        Margin="3"
                                                        HorizontalContentAlignment="Right"
                                                        BorderBrush="OrangeRed"
                                                        Click="cmdDetailsFirst_Click"
                                                        Content="{Binding Path=Amounts[0]}"
                                                        ContentStringFormat="N2"
                                                        Cursor="Hand"
                                                        Foreground="OrangeRed"
                                                        ToolTip="Cliccare per visualizzare le registrazioni in dettaglio" />
                                            </DataTemplate>
                                        </selectors:TreasuryBankFlowCellSelector.TemporaryDetailsCell10>
                                        <selectors:TreasuryBankFlowCellSelector.TemporaryDetailsCell20>
                                            <DataTemplate>
                                                <Button x:Name="cmdDetailsSecond"
                                                        Margin="3"
                                                        HorizontalContentAlignment="Right"
                                                        BorderBrush="OrangeRed"
                                                        Click="cmdDetailsSecond_Click"
                                                        Content="{Binding Path=Amounts[1]}"
                                                        ContentStringFormat="N2"
                                                        Cursor="Hand"
                                                        Foreground="OrangeRed"
                                                        ToolTip="Cliccare per visualizzare le registrazioni in dettaglio" />
                                            </DataTemplate>
                                        </selectors:TreasuryBankFlowCellSelector.TemporaryDetailsCell20>
                                        <selectors:TreasuryBankFlowCellSelector.TemporaryDetailsCell30>
                                            <DataTemplate>
                                                <Button x:Name="cmdDetailsThird"
                                                        Margin="3"
                                                        HorizontalContentAlignment="Right"
                                                        BorderBrush="OrangeRed"
                                                        Click="cmdDetailsThird_Click"
                                                        Content="{Binding Path=Amounts[2]}"
                                                        ContentStringFormat="N2"
                                                        Cursor="Hand"
                                                        Foreground="OrangeRed"
                                                        ToolTip="Cliccare per visualizzare le registrazioni in dettaglio" />
                                            </DataTemplate>
                                        </selectors:TreasuryBankFlowCellSelector.TemporaryDetailsCell30>
                                    </selectors:TreasuryBankFlowCellSelector>
                                </Grid.Resources>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="35" />
                                </Grid.RowDefinitions>
                                <telerik:RadGridView x:Name="GridViewPeriod"
                                                     Grid.Row="0"
                                                     AutoGenerateColumns="False"
                                                     CanUserFreezeColumns="False"
                                                     CanUserResizeColumns="False"
                                                     GroupRenderMode="Flat"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding PagedSource, ElementName=rdpGridPeriod}"
                                                     MergedCellsDirection="Vertical"
                                                     RowIndicatorVisibility="Collapsed"
                                                     RowStyleSelector="{StaticResource TreasuryBankFluxSelector}"
                                                     ShowColumnFooters="True"
                                                     ShowGroupFooters="True"
                                                     ShowGroupPanel="False">
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewDataColumn Width="80"
                                                                    DataMemberBinding="{Binding Month}"
                                                                    Header="Mese"
                                                                    HeaderTextAlignment="Center"
                                                                    IsCellMergingEnabled="True"
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="150"
                                                                    DataMemberBinding="{Binding MonthDescription}"
                                                                    Header="Descrizione mese"
                                                                    IsCellMergingEnabled="True" />
                                        <telerik:GridViewDataColumn Width="120"
                                                                    CellTemplateSelector="{StaticResource BankFlowTemporaryDetailsCellSelector}"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Amounts[0]}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Fino al 10"
                                                                    HeaderTextAlignment="Right"
                                                                    IsCellMergingEnabled="False"
                                                                    Tag="10"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="120"
                                                                    CellTemplateSelector="{StaticResource BankFlowTemporaryDetailsCellSelector}"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Amounts[1]}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Fino al 20"
                                                                    HeaderTextAlignment="Right"
                                                                    IsCellMergingEnabled="False"
                                                                    Tag="20"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="130"
                                                                    CellTemplateSelector="{StaticResource BankFlowTemporaryDetailsCellSelector}"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Amounts[2]}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Fino a fine mese"
                                                                    HeaderTextAlignment="Right"
                                                                    IsCellMergingEnabled="False"
                                                                    Tag="30"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn Width="140"
                                                                    DataFormatString="N2"
                                                                    DataMemberBinding="{Binding Total}"
                                                                    FooterTextAlignment="Right"
                                                                    Header="Totale mese"
                                                                    HeaderTextAlignment="Right"
                                                                    IsCellMergingEnabled="False"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction ResultFormatString="{}{0:N2}" />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                    </telerik:RadGridView.Columns>
                                </telerik:RadGridView>
                                <telerik:RadDataPager x:Name="rdpGridPeriod"
                                                      Grid.Row="1"
                                                      Margin="0,-1,0,0"
                                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                                      FontSize="12"
                                                      IsTotalItemCountFixed="True"
                                                      PageSize="24"
                                                      Source="{Binding ItemsMonths}" />
                            </Grid>
                        </telerik:RadTabItem.Content>
                    </telerik:RadTabItem>
                </telerik:RadTabControl>
            </telerik:RadBusyIndicator>
        </Grid>
    </Grid>
</sc:FluentDefaultWindow>
