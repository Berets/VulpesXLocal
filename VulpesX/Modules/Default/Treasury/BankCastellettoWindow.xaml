<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Treasury.BankCastellettoWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Treasury"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli del castelletto"
                        Width="1000"
                        Height="700"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="5" />
                <RowDefinition Height="35" />
                <RowDefinition Height="5" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Margin="15,0,0,0"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Center"
                       FontSize="20"
                       Foreground="{DynamicResource VulpesXBrush}"
                       Text="TESORERIA - DETTAGLI CASTELLETTO" />

            <StackPanel Grid.Row="2" Margin="25,0,0,0" Orientation="Horizontal">
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Banca" />
                <TextBlock Margin="15,0,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="DeepSkyBlue"
                           Text="{Binding BankFullText}" />
            </StackPanel>

            <telerik:RadBusyIndicator x:Name="bsyGrid"
                                      Grid.Row="4"
                                      BusyContent="Caricamento dati in corso..."
                                      FontSize="40"
                                      Foreground="{DynamicResource VulpesXBrush}"
                                      IsBusy="False"
                                      OverlayStyle="{StaticResource WaitOverlayStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="35" />
                    </Grid.RowDefinitions>
                    <telerik:RadGridView x:Name="GridView"
                                         Grid.Row="0"
                                         AutoExpandGroups="True"
                                         AutoGenerateColumns="False"
                                         CanUserFreezeColumns="False"
                                         CanUserResizeColumns="False"
                                         GroupRenderMode="Flat"
                                         IsReadOnly="True"
                                         ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                         MergedCellsDirection="Vertical"
                                         RowIndicatorVisibility="Collapsed"
                                         ShowColumnFooters="True"
                                         ShowGroupFooters="True"
                                         ShowGroupPanel="True">
                        <telerik:RadGridView.GroupDescriptors>
                            <telerik:GroupDescriptor DisplayContent="Data scadenza" Member="N6SCAD" SortDirection="Ascending" />
                        </telerik:RadGridView.GroupDescriptors>
                        <telerik:RadGridView.Columns>
                            <telerik:GridViewDataColumn Width="90"
                                                        DataFormatString="dd/MM/yyyy"
                                                        DataMemberBinding="{Binding N6SCAD}"
                                                        Header="Scadenza"
                                                        IsCellMergingEnabled="True"
                                                        TextAlignment="Center" />
                            <telerik:GridViewDataColumn Width="200"
                                                        DataMemberBinding="{Binding CustomerDescription}"
                                                        Header="Ragione sociale"
                                                        IsCellMergingEnabled="True" />
                            <telerik:GridViewDataColumn Width="40"
                                                        DataMemberBinding="{Binding N6COVA}"
                                                        Header="Val."
                                                        HeaderTextAlignment="Center"
                                                        IsCellMergingEnabled="False"
                                                        TextAlignment="Center" />
                            <telerik:GridViewDataColumn Width="160"
                                                        DataFormatString="N2"
                                                        DataMemberBinding="{Binding N6IMEU}"
                                                        FooterTextAlignment="Right"
                                                        Header="Importo"
                                                        HeaderTextAlignment="Right"
                                                        IsCellMergingEnabled="False"
                                                        TextAlignment="Right">
                                <telerik:GridViewColumn.AggregateFunctions>
                                    <telerik:SumFunction Caption="TOTALE GIORNO: " ResultFormatString="{}{0:N2}" />
                                </telerik:GridViewColumn.AggregateFunctions>
                            </telerik:GridViewDataColumn>
                            <telerik:GridViewDataColumn Width="160"
                                                        DataFormatString="N2"
                                                        DataMemberBinding="{Binding N6IMPANT}"
                                                        FooterTextAlignment="Right"
                                                        Header="Anticipo"
                                                        HeaderTextAlignment="Right"
                                                        IsCellMergingEnabled="False"
                                                        TextAlignment="Right">
                                <telerik:GridViewColumn.AggregateFunctions>
                                    <telerik:SumFunction Caption="TOTALE ANTICIPI: " ResultFormatString="{}{0:N2}" />
                                </telerik:GridViewColumn.AggregateFunctions>
                            </telerik:GridViewDataColumn>
                            <telerik:GridViewDataColumn Width="120"
                                                        DataMemberBinding="{Binding N6REGI}"
                                                        Header="Registrazione n."
                                                        HeaderTextAlignment="Right"
                                                        IsCellMergingEnabled="False"
                                                        TextAlignment="Right" />
                            <telerik:GridViewDataColumn Width="130"
                                                        DataFormatString="dd/MM/yyyy"
                                                        DataMemberBinding="{Binding N6DARI}"
                                                        Header="Data riferimento"
                                                        IsCellMergingEnabled="False"
                                                        TextAlignment="Center" />
                            <telerik:GridViewDataColumn Width="120"
                                                        DataMemberBinding="{Binding N6RIFE}"
                                                        Header="Riferimento n."
                                                        HeaderTextAlignment="Right"
                                                        IsCellMergingEnabled="False"
                                                        TextAlignment="Right" />
                        </telerik:RadGridView.Columns>
                    </telerik:RadGridView>
                    <telerik:RadDataPager x:Name="rdpGrid"
                                          Grid.Row="1"
                                          Margin="0,-1,0,0"
                                          DisplayMode="FirstLastPreviousNextNumeric, Text"
                                          FontSize="12"
                                          IsTotalItemCountFixed="True"
                                          PageSize="20"
                                          Source="{Binding Items}" />
                </Grid>
            </telerik:RadBusyIndicator>
        </Grid>
    </Grid>
</sc:FluentDefaultWindow>
