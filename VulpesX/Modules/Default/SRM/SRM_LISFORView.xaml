<UserControl x:Class="VulpesX.Modules.Default.SRM.SRM_LISFORView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.SRM"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="LISTINI FORNITORE" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <telerik:RadComboBox x:Name="cmbStatus"
                                     Margin="5"
                                     HorizontalAlignment="Stretch"
                                     DisplayMemberPath="Description"
                                     DockPanel.Dock="Right"
                                     SelectedValuePath="ID"
                                     SelectionChanged="cmbStatus_SelectionChanged" />

                <telerik:RadAutoCompleteBox x:Name="acSupplier"
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Width="400"
                                            Margin="5"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Stretch"
                                            VerticalContentAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            DockPanel.Dock="Right"
                                            GotFocus="ac_GotFocus"
                                            ItemsSource="{Binding Suppliers}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun codice trovato"
                                            SelectedItem="{Binding SelectedSupplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionChanged="acSupplier_SelectionChanged"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Digitare il codice o la descrizione del fornitore per cercare..." />
                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />
                <Button Name="cmdCopyFrom"
                        Width="150"
                        Margin="5"
                        BorderBrush="{DynamicResource VulpesXVioletBrush}"
                        Click="cmdCopyFrom_Click"
                        Content="COPIA DA FORNITORE"
                        Style="{StaticResource VulpesXButton}"
                        ToolTip="Copia l'intero listino da un altro fornitore. Attenzione, eventuali voci già presenti vengono mantenute" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Margin="5"
                                         TextChanged="txtSearch_TextChanged"
                                         WatermarkContent="Cerca..." />
        </Grid>

        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     RowIndicatorVisibility="Collapsed"
                                     ShowGroupPanel="True">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewColumn Width="110">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadButton x:Name="cmdDelete"
                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                       Click="cmdDelete_Click"
                                                       Content="Elimina"
                                                       Style="{StaticResource VulpesXButton}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewDataColumn Width="280" DataMemberBinding="{Binding Supplier.FullDescriptionSearchable}" Header="Fornitore" />
                        <telerik:GridViewDataColumn Width="380" DataMemberBinding="{Binding ProductDescription}" Header="Prodotto">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Left"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEdit_Click"
                                            Content="{Binding Path=ProductDescription}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="180" DataMemberBinding="{Binding supplierProductID}" Header="Codifica fornitore" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding fromDate}"
                                                    Header="Dal"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding toDate}"
                                                    Header="Al"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="N6"
                                                    DataMemberBinding="{Binding fromQuantity}"
                                                    Header="Da"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90" DataMemberBinding="{Binding unit_id}" Header="" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="N6"
                                                    DataMemberBinding="{Binding toQuantity}"
                                                    Header="A"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90" DataMemberBinding="{Binding unit_id}" Header="" />
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="N6"
                                                    DataMemberBinding="{Binding price}"
                                                    Header="Prezzo"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding description}" Header="Nota" />
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding Items}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>

</UserControl>
