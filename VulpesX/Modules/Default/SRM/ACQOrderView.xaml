<UserControl x:Class="VulpesX.Modules.Default.SRM.ACQOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.SRM"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">

    <UserControl.Resources>
        <selectors:RDACanceledListSelector x:Key="CanceledListSelector">
            <selectors:RDACanceledListSelector.DefaultRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="ToolTip" Value="{Binding OFTOGG, StringFormat={}Oggetto: {0}}" />
                </Style>
            </selectors:RDACanceledListSelector.DefaultRowStyle>
            <selectors:RDACanceledListSelector.CanceledRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="{StaticResource VulpesXRedBrush}" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="ToolTip" Value="Elemento annullato" />
                </Style>
            </selectors:RDACanceledListSelector.CanceledRowStyle>
        </selectors:RDACanceledListSelector>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="GESTIONE ORDINI DI ACQUISTO" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <telerik:RadComboBox x:Name="cmbStatus"
                                     Margin="5"
                                     HorizontalAlignment="Stretch"
                                     DisplayMemberPath="Description"
                                     SelectedValuePath="ID"
                                     SelectionChanged="cmbStatus_SelectionChanged" />
                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />

            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">

            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Margin="5"
                                         TextChanged="txtSearch_TextChanged"
                                         WatermarkContent="Cerca..." />
        </Grid>

        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     RowIndicatorVisibility="Collapsed"
                                     RowStyleSelector="{StaticResource CanceledListSelector}"
                                     ShowGroupPanel="True">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewColumn Width="110">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadButton x:Name="cmdDelete"
                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                       Click="cmdDelete_Click"
                                                       Content="Elimina"
                                                       Style="{StaticResource VulpesXButton}"
                                                       Visibility="{Binding CanDeleteVisibility, Converter={StaticResource boolToVisibilityConverter}}" />

                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn Width="110">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadButton x:Name="cmdClose"
                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                       BorderBrush="{DynamicResource VulpesXOrangeBrush}"
                                                       Click="cmdClose_Click"
                                                       Content="Chiudi"
                                                       Style="{StaticResource VulpesXButton}"
                                                       Visibility="{Binding CanCloseVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn Width="30">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgPrint"
                                                      Cursor="Hand"
                                                      FontSize="14"
                                                      Foreground="{Binding CanPrintColor, Converter={StaticResource stringToColorConverter}}"
                                                      Glyph="&#xe90e;"
                                                      MouseDown="rgPrint_MouseDown"
                                                      ToolTip="{Binding PrintToolTip}"
                                                      Visibility="{Binding CanTasksVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn Width="30">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgSendEmail"
                                                      Cursor="Hand"
                                                      FontSize="14"
                                                      Foreground="{Binding CanSendColor, Converter={StaticResource stringToColorConverter}}"
                                                      Glyph="&#xe809;"
                                                      MouseDown="rgSendEmail_MouseDown"
                                                      ToolTip="{Binding SendToolTip}"
                                                      Visibility="{Binding CanTasksVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn Width="30">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgSign"
                                                      Cursor="Hand"
                                                      FontSize="14"
                                                      Foreground="{Binding SignColor, Converter={StaticResource stringToColorConverter}}"
                                                      Glyph="&#xe157;"
                                                      MouseDown="rgSign_MouseDown"
                                                      ToolTip="{Binding SignToolTip}"
                                                      Visibility="{Binding CanTasksVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewDataColumn Width="120"
                                                    DataMemberBinding="{Binding id}"
                                                    Header="ID"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Center"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEdit_Click"
                                            Content="{Binding Path=id}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding order_date}"
                                                    Header="Data ordine"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding SupplierGrid.FullDescriptionSearchable}" Header="Fornitore" />
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding TotalAmount}"
                                                    Header="Importo"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEditRows"
                                            Margin="3"
                                            HorizontalContentAlignment="Right"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEditRows_Click"
                                            Content="{Binding Path=TotalAmount}"
                                            ContentStringFormat="N2"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding PaymentGrid.FullDescriptionSearchable}" Header="Pagamento" />
                        <telerik:GridViewDataColumn Width="140"
                                                    DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                    DataMemberBinding="{Binding sent}"
                                                    Header="Inviato"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding send_user}" Header="Da" />
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                    DataMemberBinding="{Binding closed}"
                                                    Header="Chiuso"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding Items}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>

</UserControl>
