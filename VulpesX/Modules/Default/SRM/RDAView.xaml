<UserControl x:Class="VulpesX.Modules.Default.SRM.RDAView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.SRM"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:selectors="clr-namespace:VulpesX.Shared.Controls.Selectors;assembly=VulpesX.Shared.Controls"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">

    <UserControl.Resources>
        <selectors:RDACanceledListSelector x:Key="CanceledListSelector">
            <selectors:RDACanceledListSelector.DefaultRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="ToolTip" Value="{Binding OFTOGG, StringFormat={}Oggetto: {0}}" />
                </Style>
            </selectors:RDACanceledListSelector.DefaultRowStyle>
            <selectors:RDACanceledListSelector.CanceledRowStyle>
                <Style BasedOn="{StaticResource GridViewRowStyle}" TargetType="telerik:GridViewRow">
                    <Setter Property="Background" Value="{StaticResource VulpesXRedBrush}" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="ToolTip" Value="Elemento annullato" />
                </Style>
            </selectors:RDACanceledListSelector.CanceledRowStyle>
        </selectors:RDACanceledListSelector>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="GESTIONE RICHIESTE D'ACQUISTO" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <telerik:RadComboBox x:Name="cmbStatus"
                                     Margin="5"
                                     HorizontalAlignment="Stretch"
                                     DisplayMemberPath="Description"
                                     SelectedValuePath="ID"
                                     SelectionChanged="cmbStatus_SelectionChanged" />
                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />
                <Button x:Name="cmdTransform"
                        Width="200"
                        Margin="5"
                        BorderBrush="{DynamicResource VulpesXVioletBrush}"
                        Click="cmdTransform_Click"
                        Content="TRASFORMA IN ORDINE"
                        Style="{StaticResource VulpesXButton}"
                        ToolTip="Trasforma tutte le RDA selezionate in un ordine di acquisto" />
            </StackPanel>
        </Grid>


        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Margin="5"
                                         TextChanged="txtSearch_TextChanged"
                                         WatermarkContent="Cerca..." />
        </Grid>

        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     RowIndicatorVisibility="Hidden"
                                     RowStyleSelector="{StaticResource CanceledListSelector}"
                                     SelectionChanged="GridView_SelectionChanged"
                                     SelectionMode="Extended"
                                     ShowGroupPanel="True">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewColumn Width="110">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadButton x:Name="cmdDelete"
                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                       Click="cmdDelete_Click"
                                                       Content="Elimina"
                                                       Style="{StaticResource VulpesXButton}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewColumn Width="30">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadGlyph x:Name="rgApprove"
                                                      Cursor="Hand"
                                                      FontSize="14"
                                                      Foreground="{Binding ApproveColor, Converter={StaticResource stringToColorConverter}}"
                                                      Glyph="&#xe157;"
                                                      MouseDown="rgApprove_MouseDown"
                                                      ToolTip="{Binding ApproveToolTip}"
                                                      Visibility="{Binding CanApproveVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewDataColumn Width="120"
                                                    DataMemberBinding="{Binding id}"
                                                    Header="Codice"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Center"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEdit_Click"
                                            Content="{Binding Path=id}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding Product.FullDescriptionSearchable}" Header="Articolo" />
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding original_needed}"
                                                    Header="Q.ta' originale"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="70" DataMemberBinding="{Binding UM}" Header="UM" />
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="N2"
                                                    DataMemberBinding="{Binding quantity}"
                                                    Header="Quantita'"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="70" DataMemberBinding="{Binding UM}" Header="UM" />
                        <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding Supplier.FullDescriptionSearchable}" Header="Fornitore" />
                        <telerik:GridViewDataColumn Width="140"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding requested_delivery}"
                                                    Header="Consegna richiesta"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="140"
                                                    DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                    DataMemberBinding="{Binding approval_date}"
                                                    Header="Approvata"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="180" DataMemberBinding="{Binding approval_user}" Header="Da" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding FullCustomerOrderID}"
                                                    Header="Ordine cliente origine"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding production_order_id}" Header="Ordine prod. origine" />
                        <telerik:GridViewDataColumn Width="140"
                                                    DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                    DataMemberBinding="{Binding transformed}"
                                                    Header="Trasformata"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="180" DataMemberBinding="{Binding transform_user}" Header="Da" />
                        <telerik:GridViewDataColumn Width="150"
                                                    DataMemberBinding="{Binding purchase_order_id}"
                                                    Header="Ordine di acquisto"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="140"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding added}"
                                                    Header="Inserita"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="180" DataMemberBinding="{Binding addedUserID}" Header="Da" />
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding Items}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>
</UserControl>
