<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.SRM.GoodsReceiptReceiveWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:global="clr-namespace:System.Globalization;assembly=mscorlib"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.SRM"
                        xmlns:maskedInput="clr-namespace:Telerik.Windows.Controls.MaskedInput;assembly=Telerik.Windows.Controls.Input"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli entrata merce fornitori"
                        Width="1000"
                        Height="800"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="35" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal">
            <TextBlock Width="90"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Fornitore"
                       TextAlignment="Right" />
            <TextBlock Margin="5,2,15,2"
                       HorizontalAlignment="Left"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding OrderHeadData.SupplierGrid.FullDescriptionSearchable}" />
        </StackPanel>
        <StackPanel Grid.Row="1"
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal">
            <TextBlock Width="90"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Articolo"
                       TextAlignment="Right" />
            <TextBlock Margin="5,2,15,2"
                       HorizontalAlignment="Left"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding OrderRowData.Product.FullDescriptionSearchable}" />
            <TextBlock Style="{StaticResource VulpesXLabel}" Text="Q.ta' ordinata" />
            <TextBlock Margin="5,2,15,2"
                       HorizontalAlignment="Left"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding OrderRowData.quantity, StringFormat=N6}" />
            <TextBlock Margin="5,2,15,2"
                       HorizontalAlignment="Left"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding OrderRowData.Product.UnitaID}" />
            <TextBlock Style="{StaticResource VulpesXLabel}" Text="Q.ta' gia' ricevuta" />
            <TextBlock Margin="5,2,15,2"
                       HorizontalAlignment="Left"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding OrderRowData.quantity_received, StringFormat=N6}" />
            <TextBlock Margin="5,2,15,2"
                       HorizontalAlignment="Left"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding OrderRowData.Product.UnitaID}" />
        </StackPanel>

        <telerik:RadTabControl Grid.Row="2"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="DATI GENERALI" Header="DATI GENERALI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="2"
                                       Style="{StaticResource VulpesXSubtitle}"
                                       Text="Dati del documento di trasporto" />

                            <StackPanel Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Orientation="Horizontal">
                                <TextBlock Margin="30,0,0,0" Style="{StaticResource VulpesXLabel}" Text="Data" />
                                <telerik:RadDateTimePicker Width="100"
                                                           Margin="5,0,15,0"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           IsEnabled="{Binding IsReadonly}"
                                                           SelectedValue="{Binding Data.document_date, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Numero" />
                                <TextBox Width="120"
                                         Margin="5,2,15,2"
                                         MaxLength="50"
                                         Text="{Binding Data.document_number}" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Riga" />
                                <telerik:RadMaskedNumericInput Width="100"
                                                               Margin="5,2,15,2"
                                                               HorizontalAlignment="Left"
                                                               maskedInput:MaskedInputExtensions.AllowNull="True"
                                                               maskedInput:MaskedInputExtensions.MaxTextLength="5"
                                                               maskedInput:MaskedInputExtensions.Maximum="99999"
                                                               AllowSkipPlaceholders="True"
                                                               AutoFillNumberGroupSeparators="False"
                                                               AutoFillZeros="False"
                                                               FormatString="00000"
                                                               InputBehavior="Insert"
                                                               Mask="#####"
                                                               SelectionOnFocus="SelectAll"
                                                               SpinMode="Position"
                                                               TextMode="MaskedText"
                                                               Value="{Binding Data.document_row, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Q.ta' ricevuta" />
                                <telerik:RadNumericUpDown Width="200"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          Minimum="0.000001"
                                                          NumberDecimalDigits="6"
                                                          Value="{Binding Data.quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="2"
                                       Style="{StaticResource VulpesXSubtitle}"
                                       Text="Dati del magazzino" />

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Magazzino" />
                            <telerik:RadAutoCompleteBox x:Name="acStore"
                                                        Grid.Row="3"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        IsEnabled="{Binding IsReadonly}"
                                                        ItemsSource="{Binding Data.Stores}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding Data.Store, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Causale" />
                            <telerik:RadAutoCompleteBox x:Name="acCausal"
                                                        Grid.Row="4"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        IsEnabled="{Binding IsReadonly}"
                                                        ItemsSource="{Binding Data.Causals}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding Data.Causal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Lotto" />
                            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="txtLot"
                                         Width="265"
                                         Margin="5,2,15,2"
                                         HorizontalAlignment="Left"
                                         GotFocus="txtLot_GotFocus"
                                         IsReadOnly="{Binding IsLotLocked}"
                                         MaxLength="50"
                                         Text="{Binding Data.lot}"
                                         Visibility="{Binding LotVisibility}" />
                                <TextBlock Width="100"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Lotto fornitore"
                                           TextAlignment="Right"
                                           Visibility="{Binding LotVisibility}" />
                                <TextBox Width="270"
                                         Margin="5,2,15,2"
                                         HorizontalAlignment="Left"
                                         GotFocus="txtLot_GotFocus"
                                         MaxLength="50"
                                         Text="{Binding Data.supplier_lot}"
                                         Visibility="{Binding LotVisibility}" />
                            </StackPanel>

                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Data di scadenza" />
                            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadDateTimePicker Width="140"
                                                           Margin="5,0,15,0"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           IsEnabled="{Binding IsReadonly}"
                                                           SelectedValue="{Binding Data.expire, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ubicazione" />
                            <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="400"
                                         Margin="5,2,15,2"
                                         HorizontalAlignment="Left"
                                         MaxLength="255"
                                         Text="{Binding Data.goods_location}" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="Stampa etichetta" Visibility="{Binding LotVisibility}" />
                                <telerik:RadToggleSwitchButton IsChecked="{Binding LotLabelPrint}" Visibility="{Binding LotVisibility}" />
                            </StackPanel>

                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       VerticalAlignment="Top"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Note" />
                            <TextBox Grid.Row="8"
                                     Grid.RowSpan="2"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     VerticalContentAlignment="Top"
                                     AcceptsReturn="True"
                                     IsEnabled="{Binding IsReadonly}"
                                     Text="{Binding Data.note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <telerik:RadGridView Name="rgvCustomerOrders"
                                                 Grid.Row="10"
                                                 Grid.Column="0"
                                                 Grid.ColumnSpan="2"
                                                 Margin="10"
                                                 AutoGenerateColumns="False"
                                                 CanUserFreezeColumns="False"
                                                 CanUserGroupColumns="False"
                                                 IsSearchingDeferred="True"
                                                 ItemsSource="{Binding OrderRowData.CustomerOrders}"
                                                 RowIndicatorVisibility="Collapsed"
                                                 RowValidating="rgvCustomerOrders_RowValidating"
                                                 ShowGroupPanel="False"
                                                 ShowSearchPanel="False"
                                                 ValidatesOnDataErrors="InEditMode">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewDataColumn Width="200"
                                                                DataMemberBinding="{Binding order_id}"
                                                                Header="Ordine d'acquisto"
                                                                HeaderTextAlignment="Center"
                                                                IsReadOnly="True"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="200"
                                                                DataMemberBinding="{Binding FullID}"
                                                                Header="Ordine cliente"
                                                                HeaderTextAlignment="Right"
                                                                IsReadOnly="True"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="150"
                                                                DataFormatString="N6"
                                                                DataMemberBinding="{Binding quantity_needed}"
                                                                Header="Q.tà necessaria"
                                                                HeaderTextAlignment="Right"
                                                                IsReadOnly="True"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="150"
                                                                DataFormatString="N6"
                                                                DataMemberBinding="{Binding quantity_received}"
                                                                Header="Q.tà già ricevuta"
                                                                HeaderTextAlignment="Right"
                                                                IsReadOnly="True"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="150"
                                                                DataFormatString="N6"
                                                                DataMemberBinding="{Binding QuantityAssigned}"
                                                                Header="Q.tà assegnata"
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right">
                                        <telerik:GridViewDataColumn.CellEditTemplate>
                                            <DataTemplate>
                                                <telerik:RadNumericUpDown Minimum="0.000001" NumberDecimalDigits="6" Value="{Binding QuantityAssigned}">
                                                    <telerik:RadNumericUpDown.NumberFormatInfo>
                                                        <global:NumberFormatInfo NumberDecimalSeparator="," />
                                                    </telerik:RadNumericUpDown.NumberFormatInfo>
                                                </telerik:RadNumericUpDown>
                                            </DataTemplate>
                                        </telerik:GridViewDataColumn.CellEditTemplate>
                                    </telerik:GridViewDataColumn>
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>

                            <telerik:RadGridView Name="rgvJobs"
                                                 Grid.Row="11"
                                                 Grid.Column="0"
                                                 Grid.ColumnSpan="2"
                                                 Margin="10"
                                                 AutoGenerateColumns="False"
                                                 CanUserFreezeColumns="False"
                                                 CanUserGroupColumns="False"
                                                 IsSearchingDeferred="True"
                                                 ItemsSource="{Binding OrderRowData.Jobs}"
                                                 RowIndicatorVisibility="Collapsed"
                                                 RowValidating="rgvJobs_RowValidating"
                                                 ShowGroupPanel="False"
                                                 ShowSearchPanel="False"
                                                 ValidatesOnDataErrors="InEditMode">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewDataColumn Width="200"
                                                                DataMemberBinding="{Binding order_id}"
                                                                Header="Ordine d'acquisto"
                                                                HeaderTextAlignment="Center"
                                                                IsReadOnly="True"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="200"
                                                                DataMemberBinding="{Binding job_id}"
                                                                Header="Ordine di produzione"
                                                                HeaderTextAlignment="Right"
                                                                IsReadOnly="True"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="150"
                                                                DataFormatString="N6"
                                                                DataMemberBinding="{Binding quantity_needed}"
                                                                Header="Q.tà necessaria"
                                                                HeaderTextAlignment="Right"
                                                                IsReadOnly="True"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="150"
                                                                DataFormatString="N6"
                                                                DataMemberBinding="{Binding quantity_received}"
                                                                Header="Q.tà già ricevuta"
                                                                HeaderTextAlignment="Right"
                                                                IsReadOnly="True"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="150"
                                                                DataFormatString="N6"
                                                                DataMemberBinding="{Binding QuantityAssigned}"
                                                                Header="Q.tà assegnata"
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right">
                                        <telerik:GridViewDataColumn.CellEditTemplate>
                                            <DataTemplate>
                                                <telerik:RadNumericUpDown Minimum="0.000001" NumberDecimalDigits="6" Value="{Binding QuantityAssigned}">
                                                    <telerik:RadNumericUpDown.NumberFormatInfo>
                                                        <global:NumberFormatInfo NumberDecimalSeparator="," />
                                                    </telerik:RadNumericUpDown.NumberFormatInfo>
                                                </telerik:RadNumericUpDown>
                                            </DataTemplate>
                                        </telerik:GridViewDataColumn.CellEditTemplate>
                                    </telerik:GridViewDataColumn>
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Inserito il" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultimo aggiornamento il" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Annullato il" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Motivo annullamento" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Margin="5,2,2,2"
                                       Style="{StaticResource VulpesXData}"
                                       Text="{Binding Data.canceledNote}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>

        <StackPanel Grid.Row="3"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
