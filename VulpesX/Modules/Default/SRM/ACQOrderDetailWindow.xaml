<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.SRM.ACQOrderDetailWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.SRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli ordine di acquisto"
                        Width="1024"
                        Height="768"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Left" Orientation="Horizontal">
            <TextBlock Margin="5"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Fornitore"
                       TextAlignment="Left" />
            <TextBlock Margin="5"
                       Style="{StaticResource VulpesXData}"
                       Text="{Binding Head.Supplier.FullDescriptionSearchable, Mode=OneWay}"
                       TextAlignment="Right" />
        </StackPanel>

        <Grid Grid.Row="1"
              Grid.Column="0"
              Margin="5"
              VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="{DynamicResource VulpesXBrush}" BorderThickness="1">
                <TextBlock Padding="0"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXBrush}"
                           Opacity=".8"
                           Text="RIGHE"
                           TextAlignment="Center"
                           Typography.Capitals="AllSmallCaps">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="270" />
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Border>

            <telerik:RadGridView Name="rgvRows"
                                 Grid.Column="1"
                                 AddingNewDataItem="rgvRows_AddingNewDataItem"
                                 AreRowDetailsFrozen="True"
                                 AutoGenerateColumns="False"
                                 CanUserFreezeColumns="False"
                                 CanUserInsertRows="True"
                                 Deleted="rgvRows_Deleted"
                                 GroupRenderMode="Flat"
                                 IsReadOnly="{Binding IsReadonly}"
                                 IsSearchingDeferred="True"
                                 ItemsSource="{Binding Rows}"
                                 LeftFrozenColumnCount="3"
                                 NewRowPosition="Top"
                                 RowEditEnded="rgvRows_RowEditEnded"
                                 RowIndicatorVisibility="Collapsed"
                                 RowValidating="rgvRows_RowValidating"
                                 SearchMode="MatchAnyTerm"
                                 ShowGroupPanel="False"
                                 ShowSearchPanel="False"
                                 ToolTipService.ShowOnDisabled="True"
                                 ValidatesOnDataErrors="InEditMode">
                <telerik:RadGridView.Columns>
                    <telerik:GridViewToggleRowDetailsColumn ToolTip="Mostra i dettagli della riga" />
                    <telerik:GridViewColumn Width="30">
                        <telerik:GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <telerik:RadGlyph x:Name="rgMagnifier"
                                                  Cursor="Hand"
                                                  FontSize="18"
                                                  Foreground="{DynamicResource VulpesXBrush}"
                                                  Glyph="&#xe137;"
                                                  MouseDown="rgMagnifier_MouseDown"
                                                  ToolTip="Visualizza la riga in formato esteso" />
                            </DataTemplate>
                        </telerik:GridViewColumn.CellTemplate>
                    </telerik:GridViewColumn>
                    <telerik:GridViewDataColumn Width="60"
                                                DataMemberBinding="{Binding sequence}"
                                                Header="Riga"
                                                HeaderTextAlignment="Right"
                                                IsReadOnly="True"
                                                IsVisible="False"
                                                TextAlignment="Right" />
                    <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding Product.FullDescriptionSearchable}" Header="Articolo">
                        <telerik:GridViewDataColumn.CellEditTemplate>
                            <DataTemplate>
                                <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Products}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun articolo trovato"
                                                            SelectedItem="{Binding Product, Mode=TwoWay}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable" />
                            </DataTemplate>
                        </telerik:GridViewDataColumn.CellEditTemplate>
                    </telerik:GridViewDataColumn>
                    <telerik:GridViewDataColumn Width="100"
                                                DataMemberBinding="{Binding QuantityValue, StringFormat=N6}"
                                                Header="Quantita'"
                                                HeaderTextAlignment="Right"
                                                TextAlignment="Right">
                        <telerik:GridViewDataColumn.CellEditTemplate>
                            <DataTemplate>
                                <telerik:RadNumericUpDown Minimum="0" NumberDecimalDigits="6" Value="{Binding QuantityValue}" />
                            </DataTemplate>
                        </telerik:GridViewDataColumn.CellEditTemplate>
                    </telerik:GridViewDataColumn>
                    <telerik:GridViewComboBoxColumn Width="100"
                                                    DataMemberBinding="{Binding unit_id}"
                                                    DisplayMemberPath="Description"
                                                    Header="U.M."
                                                    IsLightweightModeEnabled="True"
                                                    ItemsSourceBinding="{Binding UMs}"
                                                    SelectedValueMemberPath="ID" />
                    <telerik:GridViewDataColumn Width="100"
                                                DataMemberBinding="{Binding price, StringFormat=N6}"
                                                Header="Prezzo"
                                                HeaderTextAlignment="Right"
                                                TextAlignment="Right">
                        <telerik:GridViewDataColumn.CellEditTemplate>
                            <DataTemplate>
                                <telerik:RadNumericUpDown Minimum="0" NumberDecimalDigits="6" Value="{Binding price}" />
                            </DataTemplate>
                        </telerik:GridViewDataColumn.CellEditTemplate>
                    </telerik:GridViewDataColumn>
                    <telerik:GridViewComboBoxColumn Width="120"
                                                    DataMemberBinding="{Binding price_type}"
                                                    DisplayMemberPath="Description"
                                                    Header="Tipo prezzo"
                                                    IsLightweightModeEnabled="True"
                                                    ItemsSourceBinding="{Binding PriceTypes}"
                                                    SelectedValueMemberPath="ID" />
                    <telerik:GridViewDataColumn Width="90"
                                                DataMemberBinding="{Binding discount, StringFormat=N2}"
                                                Header="Sconto"
                                                HeaderTextAlignment="Right"
                                                TextAlignment="Right">
                        <telerik:GridViewDataColumn.CellEditTemplate>
                            <DataTemplate>
                                <telerik:RadNumericUpDown Minimum="0" NumberDecimalDigits="2" Value="{Binding discount}" />
                            </DataTemplate>
                        </telerik:GridViewDataColumn.CellEditTemplate>
                    </telerik:GridViewDataColumn>
                    <telerik:GridViewComboBoxColumn Width="120"
                                                    DataMemberBinding="{Binding discount_type}"
                                                    DisplayMemberPath="Description"
                                                    Header="Tipo sconto"
                                                    IsLightweightModeEnabled="True"
                                                    ItemsSourceBinding="{Binding DiscountTypes}"
                                                    SelectedValueMemberPath="ID" />
                    <telerik:GridViewDataColumn Width="120"
                                                DataFormatString="N6"
                                                DataMemberBinding="{Binding NetAmount}"
                                                Header="Prezzo netto"
                                                HeaderTextAlignment="Right"
                                                IsReadOnly="True"
                                                TextAlignment="Right" />
                    <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding Store.FullDescriptionSearchable}" Header="Magazzino">
                        <telerik:GridViewDataColumn.CellEditTemplate>
                            <DataTemplate>
                                <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Stores}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun magazzino trovato"
                                                            SelectedItem="{Binding Store, Mode=TwoWay}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable" />
                            </DataTemplate>
                        </telerik:GridViewDataColumn.CellEditTemplate>
                    </telerik:GridViewDataColumn>
                    <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding Rate.FullDescriptionSearchable}" Header="Aliquota">
                        <telerik:GridViewDataColumn.CellEditTemplate>
                            <DataTemplate>
                                <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Rates}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessuna aliquota trovata"
                                                            SelectedItem="{Binding Rate, Mode=TwoWay}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable" />
                            </DataTemplate>
                        </telerik:GridViewDataColumn.CellEditTemplate>
                    </telerik:GridViewDataColumn>
                    <telerik:GridViewDataColumn Width="150"
                                                DataFormatString="dd/MM/yyyy"
                                                DataMemberBinding="{Binding delivery_requested}"
                                                Header="Consegna richiesta" />
                    <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding note}" Header="Note" />
                </telerik:RadGridView.Columns>
                <telerik:RadGridView.RowDetailsTemplate>
                    <DataTemplate>
                        <Grid Margin="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="10" />
                                <RowDefinition Height="300" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="795" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="5*" />
                                    <RowDefinition Height="5*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="550" />
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="200" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="{DynamicResource VulpesXBrush}" BorderThickness="1">
                                    <TextBlock Padding="0"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               Background="Black"
                                               FontSize="16"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Opacity=".8"
                                               Text="ORDINI CLIENTI"
                                               TextAlignment="Center"
                                               Typography.Capitals="AllSmallCaps">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="270" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </Border>
                                <telerik:RadGridView Name="rgvCustomerOrders"
                                                     Grid.Column="1"
                                                     AutoGenerateColumns="False"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding CustomerOrders}"
                                                     RowIndicatorVisibility="Collapsed"
                                                     ShowGroupPanel="False"
                                                     ShowSearchPanel="False">
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding order_id}" Header="Ordine" IsVisible="False" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding order_row_id}" Header="Riga ordine" IsVisible="False" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding FullID}"
                                                                    Header="Ordine cliente"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="120"
                                                                    DataFormatString="N6"
                                                                    DataMemberBinding="{Binding quantity_needed}"
                                                                    Header="Quantità"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right" />
                                        <telerik:GridViewDataColumn Width="120"
                                                                    DataFormatString="N6"
                                                                    DataMemberBinding="{Binding quantity_original}"
                                                                    Header="Q.tà fabbisogno"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right" />
                                        <telerik:GridViewDataColumn Width="120"
                                                                    DataFormatString="N6"
                                                                    DataMemberBinding="{Binding quantity_received}"
                                                                    Header="Q.tà ricevuta"
                                                                    HeaderTextAlignment="Right"
                                                                    IsReadOnly="True"
                                                                    TextAlignment="Right" />
                                    </telerik:RadGridView.Columns>
                                </telerik:RadGridView>
                                <Border Grid.Row="1"
                                        Grid.Column="0"
                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                        BorderThickness="1">
                                    <TextBlock Padding="0"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               Background="Black"
                                               FontSize="16"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Opacity=".8"
                                               Text="ORDINI PRODUZIONE"
                                               TextAlignment="Center"
                                               Typography.Capitals="AllSmallCaps">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="270" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </Border>
                                <telerik:RadGridView Name="rgvJobs"
                                                     Grid.Row="1"
                                                     Grid.Column="1"
                                                     AutoGenerateColumns="False"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding Jobs}"
                                                     RowIndicatorVisibility="Collapsed"
                                                     ShowGroupPanel="False"
                                                     ShowSearchPanel="False">
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding order_id}" Header="Ordine" IsVisible="False" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding order_row_id}" Header="Riga ordine" IsVisible="False" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding job_id}"
                                                                    Header="Ordine produzione"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="120"
                                                                    DataFormatString="N6"
                                                                    DataMemberBinding="{Binding quantity_needed}"
                                                                    Header="Quantità"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right" />
                                        <telerik:GridViewDataColumn Width="120"
                                                                    DataFormatString="N6"
                                                                    DataMemberBinding="{Binding quantity_original}"
                                                                    Header="Q.tà fabbisogno"
                                                                    HeaderTextAlignment="Right"
                                                                    TextAlignment="Right" />
                                        <telerik:GridViewDataColumn Width="120"
                                                                    DataFormatString="N6"
                                                                    DataMemberBinding="{Binding quantity_received}"
                                                                    Header="Q.tà ricevuta"
                                                                    HeaderTextAlignment="Right"
                                                                    IsReadOnly="True"
                                                                    TextAlignment="Right" />
                                    </telerik:RadGridView.Columns>
                                </telerik:RadGridView>
                                <Border Grid.Column="2" BorderBrush="{DynamicResource VulpesXBrush}" BorderThickness="1">
                                    <TextBlock Padding="0"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               Background="Black"
                                               FontSize="16"
                                               Foreground="{DynamicResource VulpesXBrush}"
                                               Opacity=".8"
                                               Text="RDA"
                                               TextAlignment="Center"
                                               Typography.Capitals="AllSmallCaps">
                                        <TextBlock.LayoutTransform>
                                            <RotateTransform Angle="270" />
                                        </TextBlock.LayoutTransform>
                                    </TextBlock>
                                </Border>
                                <telerik:RadGridView Name="rgvRDAs"
                                                     Grid.Column="3"
                                                     AutoGenerateColumns="False"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding RDAs}"
                                                     RowIndicatorVisibility="Collapsed"
                                                     ShowGroupPanel="False"
                                                     ShowSearchPanel="False"
                                                     ValidatesOnDataErrors="InEditMode">
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding order_id}" Header="Ordine" IsVisible="False" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding order_row_id}" Header="Riga ordine" IsVisible="False" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding rda_id}"
                                                                    Header="Codice RDA"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Center" />
                                    </telerik:RadGridView.Columns>
                                </telerik:RadGridView>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </telerik:RadGridView.RowDetailsTemplate>
            </telerik:RadGridView>
        </Grid>


        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
