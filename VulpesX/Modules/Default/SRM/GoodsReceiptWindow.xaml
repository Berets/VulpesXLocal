<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.SRM.GoodsReceiptWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.SRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli entrata merce"
                        Width="700"
                        Height="600"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="DATI GENERALI" Header="DATI GENERALI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="5" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="5" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="ID" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Width="200"
                                       Margin="5,2,2,2"
                                       HorizontalAlignment="Left"
                                       Style="{DynamicResource VulpesXData}"
                                       Text="{Binding Data.id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Fornitore" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Margin="5,2,2,2"
                                       HorizontalAlignment="Stretch"
                                       Style="{DynamicResource VulpesXInfoData}"
                                       Text="{Binding Data.SupplierDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Prodotto" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="1"
                                       Margin="5,2,2,2"
                                       HorizontalAlignment="Stretch"
                                       Style="{DynamicResource VulpesXInfoData}"
                                       Text="{Binding Data.ProductDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Magazzino" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Margin="5,2,2,2"
                                       HorizontalAlignment="Stretch"
                                       Style="{DynamicResource VulpesXInfoData}"
                                       Text="{Binding Data.StoreDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Causale" />
                            <TextBlock Grid.Row="5"
                                       Grid.Column="1"
                                       Margin="5,2,2,2"
                                       HorizontalAlignment="Stretch"
                                       Style="{DynamicResource VulpesXInfoData}"
                                       Text="{Binding Data.CausalDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Lotto" />
                            <TextBlock Grid.Row="6"
                                       Grid.Column="1"
                                       Margin="5,2,2,2"
                                       HorizontalAlignment="Stretch"
                                       Style="{DynamicResource VulpesXInfoData}"
                                       Text="{Binding Data.lot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Data di scadenza" />
                            <TextBlock Grid.Row="7"
                                       Grid.Column="1"
                                       Margin="5,2,2,2"
                                       HorizontalAlignment="Stretch"
                                       Style="{DynamicResource VulpesXInfoData}"
                                       Text="{Binding Data.expire, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=dd/MM/yyyy}" />
                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Quantita'" />
                            <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Stretch"
                                           Style="{DynamicResource VulpesXInfoData}"
                                           Text="{Binding Data.quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N6}" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Stretch"
                                           Style="{DynamicResource VulpesXData}"
                                           Text="{Binding Data.unit_id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Grid.Row="9"
                                       Grid.Column="1"
                                       Style="{StaticResource VulpesXSubtitle}"
                                       Text="Dati del DDT" />
                            <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Width="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Data"
                                           TextAlignment="Right" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Stretch"
                                           Style="{DynamicResource VulpesXInfoData}"
                                           Text="{Binding Data.document_date, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=dd/MM/yyyy}" />
                                <TextBlock Width="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Numero"
                                           TextAlignment="Right" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Stretch"
                                           Style="{DynamicResource VulpesXInfoData}"
                                           Text="{Binding Data.document_number, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" />
                                <TextBlock Width="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Riga"
                                           TextAlignment="Right" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Stretch"
                                           Style="{DynamicResource VulpesXInfoData}"
                                           Text="{Binding Data.document_row, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N0}" />
                            </StackPanel>
                            <TextBlock Grid.Row="11"
                                       Grid.Column="1"
                                       Style="{StaticResource VulpesXSubtitle}"
                                       Text="Dati dell'ordine di acquisto" />
                            <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Width="90"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Numero"
                                           TextAlignment="Right" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Stretch"
                                           Style="{DynamicResource VulpesXInfoData}"
                                           Text="{Binding Data.order_id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Width="80"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Riga"
                                           TextAlignment="Right" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Stretch"
                                           Style="{DynamicResource VulpesXInfoData}"
                                           Text="{Binding Data.order_row_id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Grid.Row="14"
                                       Grid.Column="0"
                                       VerticalAlignment="Top"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Note" />
                            <TextBox Grid.Row="14"
                                     Grid.RowSpan="3"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     IsReadOnly="True"
                                     Text="{Binding Data.note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Inserito il" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultimo aggiornamento il" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Annullato il" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Motivo annullamento" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Margin="5,2,2,2"
                                       Style="{StaticResource VulpesXData}"
                                       Text="{Binding Data.canceledNote}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
