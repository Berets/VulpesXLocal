<UserControl x:Class="VulpesX.Modules.Default.SRM.CostMaterialsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.SRM"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="GESTIONE COSTI MATERIALI" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />

            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Grid.Column="1"
                                         Margin="5"
                                         TextChanged="txtSearch_TextChanged"
                                         WatermarkContent="Cerca..." />
        </Grid>

        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="5*" />
                    <RowDefinition Height="5*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="35" />
                    </Grid.RowDefinitions>

                    <telerik:RadGridView x:Name="GridViewMaster"
                                         Grid.Row="0"
                                         AutoGenerateColumns="False"
                                         CanUserFreezeColumns="False"
                                         CanUserResizeColumns="False"
                                         GroupRenderMode="Flat"
                                         IsReadOnly="True"
                                         IsSynchronizedWithCurrentItem="True"
                                         ItemsSource="{Binding PagedSource, ElementName=rdpGridMaster}"
                                         RowIndicatorVisibility="Hidden"
                                         ShowGroupPanel="True">
                        <telerik:RadGridView.Columns>
                            <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding ID}" Header="Articolo" />
                            <telerik:GridViewDataColumn Width="450" DataMemberBinding="{Binding Description}" Header="" />
                            <telerik:GridViewDataColumn Width="200"
                                                        DataFormatString="N6"
                                                        DataMemberBinding="{Binding GloballyLoad}"
                                                        Header="Quantità globale"
                                                        HeaderTextAlignment="Right"
                                                        TextAlignment="Right" />
                            <telerik:GridViewDataColumn Width="50"
                                                        DataMemberBinding="{Binding UM}"
                                                        Header=""
                                                        HeaderTextAlignment="Center"
                                                        TextAlignment="Center" />
                            <telerik:GridViewDataColumn Width="250"
                                                        DataFormatString="N6"
                                                        DataMemberBinding="{Binding GloballyValue}"
                                                        Header="Valore globale totale"
                                                        HeaderTextAlignment="Right"
                                                        TextAlignment="Right" />
                            <telerik:GridViewDataColumn Width="250"
                                                        DataFormatString="N6"
                                                        DataMemberBinding="{Binding GloballyAverageCost}"
                                                        Header="Costo medio globale unitario"
                                                        HeaderTextAlignment="Right"
                                                        TextAlignment="Right" />
                        </telerik:RadGridView.Columns>
                    </telerik:RadGridView>
                    <telerik:RadDataPager x:Name="rdpGridMaster"
                                          Grid.Row="1"
                                          Margin="0,-1,0,0"
                                          DisplayMode="FirstLastPreviousNextNumeric, Text"
                                          FontSize="12"
                                          IsTotalItemCountFixed="True"
                                          PageSize="20"
                                          Source="{Binding Items}" />
                </Grid>
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="35" />
                    </Grid.RowDefinitions>

                    <telerik:RadGridView x:Name="GridViewDetails"
                                         Grid.Row="0"
                                         AutoGenerateColumns="False"
                                         CanUserFreezeColumns="False"
                                         CanUserResizeColumns="False"
                                         GroupRenderMode="Flat"
                                         IsReadOnly="True"
                                         ItemsSource="{Binding PagedSource, ElementName=rdpGridDetails}"
                                         RowIndicatorVisibility="Collapsed"
                                         ShowGroupPanel="True">
                        <telerik:RadGridView.Columns>
                            <telerik:GridViewColumn Width="110">
                                <telerik:GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <telerik:RadButton x:Name="cmdDelete"
                                                           telerik:TouchManager.TouchMode="HitTestHidden"
                                                           BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                           Click="cmdDelete_Click"
                                                           Content="Elimina"
                                                           Style="{StaticResource VulpesXButton}"
                                                           Visibility="{Binding CanDeleteVisibility, Converter={StaticResource boolToVisibilityConverter}}" />
                                    </DataTemplate>
                                </telerik:GridViewColumn.CellTemplate>
                            </telerik:GridViewColumn>
                            <telerik:GridViewDataColumn Width="100"
                                                        DataMemberBinding="{Binding year}"
                                                        Header="Anno"
                                                        HeaderTextAlignment="Center"
                                                        TextAlignment="Center" />
                            <telerik:GridViewDataColumn Width="100"
                                                        DataMemberBinding="{Binding month}"
                                                        Header="Mese"
                                                        HeaderTextAlignment="Right"
                                                        TextAlignment="Right">
                                <telerik:GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button x:Name="cmdEdit"
                                                Margin="3"
                                                HorizontalContentAlignment="Right"
                                                BorderBrush="{DynamicResource VulpesXBrush}"
                                                Click="cmdEdit_Click"
                                                Content="{Binding Path=month}"
                                                Cursor="Hand"
                                                Foreground="{DynamicResource VulpesXBrush}" />
                                    </DataTemplate>
                                </telerik:GridViewColumn.CellTemplate>
                            </telerik:GridViewDataColumn>
                            <telerik:GridViewDataColumn Width="200"
                                                        DataFormatString="N6"
                                                        DataMemberBinding="{Binding total_load}"
                                                        Header="Quantità totale"
                                                        HeaderTextAlignment="Right"
                                                        TextAlignment="Right" />
                            <telerik:GridViewDataColumn Width="50"
                                                        DataMemberBinding="{Binding Product.UnitaID}"
                                                        Header=""
                                                        HeaderTextAlignment="Center"
                                                        TextAlignment="Center" />
                            <telerik:GridViewDataColumn Width="200"
                                                        DataFormatString="N6"
                                                        DataMemberBinding="{Binding total_value}"
                                                        Header="Valore totale"
                                                        HeaderTextAlignment="Right"
                                                        TextAlignment="Right" />
                            <telerik:GridViewDataColumn Width="250"
                                                        DataFormatString="N6"
                                                        DataMemberBinding="{Binding last_cost}"
                                                        Header="Ultimo costo unitario"
                                                        HeaderTextAlignment="Right"
                                                        TextAlignment="Right" />
                            <telerik:GridViewDataColumn Width="250"
                                                        DataFormatString="N6"
                                                        DataMemberBinding="{Binding AverageCost}"
                                                        Header="Costo medio unitario"
                                                        HeaderTextAlignment="Right"
                                                        TextAlignment="Right" />
                        </telerik:RadGridView.Columns>
                    </telerik:RadGridView>
                    <telerik:RadDataPager x:Name="rdpGridDetails"
                                          Grid.Row="1"
                                          Margin="0,-1,0,0"
                                          DisplayMode="FirstLastPreviousNextNumeric, Text"
                                          FontSize="12"
                                          IsTotalItemCountFixed="True"
                                          PageSize="20"
                                          Source="{Binding DetailsItems}" />
                </Grid>
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>

</UserControl>
