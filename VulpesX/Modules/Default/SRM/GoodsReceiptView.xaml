<UserControl x:Class="VulpesX.Modules.Default.SRM.GoodsReceiptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.SRM"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Style="{StaticResource VulpesXTitle}" Text="ENTRATA MERCE" />

        <telerik:RadTabControl Grid.Row="2"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="GESTIONE" Header="GESTIONE">
                <telerik:RadTabItem.Content>
                    <telerik:RadBusyIndicator x:Name="bsyGrid"
                                              Grid.Row="4"
                                              BusyContent="Caricamento dati in corso..."
                                              Foreground="{DynamicResource VulpesXBrush}"
                                              IsBusy="{Binding IsBusy}"
                                              OverlayStyle="{StaticResource WaitOverlayStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="35" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5*" />
                                    <ColumnDefinition Width="5*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" HorizontalAlignment="Left" Orientation="Horizontal">
                                    <telerik:RadWatermarkTextBox Name="txtSearch"
                                                                 Width="450"
                                                                 Margin="5,5,0,5"
                                                                 TextChanged="txtSearch_TextChanged"
                                                                 WatermarkContent="Cerca..." />
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                                    <TextBlock DockPanel.Dock="Right"
                                               Style="{DynamicResource VulpesXLabel}"
                                               Text="Fornitore selezionato"
                                               TextAlignment="Right" />
                                    <telerik:RadAutoCompleteBox x:Name="acSupplier"
                                                                Grid.Row="0"
                                                                Grid.Column="0"
                                                                Width="450"
                                                                Margin="5,0,0,0"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Center"
                                                                DisplayMemberPath="FullDescriptionSearchable"
                                                                DockPanel.Dock="Right"
                                                                GotFocus="ac_GotFocus"
                                                                ItemsSource="{Binding Suppliers}"
                                                                LostFocus="ac_LostFocus"
                                                                NoResultsContent="Nessun codice trovato"
                                                                SelectedItem="{Binding SelectedSupplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                SelectionChanged="acSupplier_SelectionChanged"
                                                                SelectionMode="Single"
                                                                TextSearchMode="Contains"
                                                                TextSearchPath="FullDescriptionSearchable"
                                                                WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                </StackPanel>

                            </Grid>
                            <telerik:RadGridView x:Name="GridView"
                                                 Grid.Row="1"
                                                 AutoGenerateColumns="False"
                                                 CanUserFreezeColumns="False"
                                                 CanUserResizeColumns="False"
                                                 GroupRenderMode="Flat"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                                 RowIndicatorVisibility="Collapsed"
                                                 ShowGroupPanel="True">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewColumn Width="110">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadButton x:Name="cmdClose"
                                                                   telerik:TouchManager.TouchMode="HitTestHidden"
                                                                   BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                                   Click="cmdClose_Click"
                                                                   Content="Chiudi"
                                                                   Style="{StaticResource VulpesXButton}"
                                                                   ToolTip="Chiudi questa riga di ordine d'acquisto come se il materiale fosse completamente ricevuto" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewColumn Width="110">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadButton x:Name="cmdReceipt"
                                                                   telerik:TouchManager.TouchMode="HitTestHidden"
                                                                   BorderBrush="{DynamicResource VulpesXGreenBrush}"
                                                                   Click="cmdReceipt_Click"
                                                                   Content="Ricevi"
                                                                   Style="{StaticResource VulpesXButton}"
                                                                   ToolTip="Ricevi questo materiale" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewDataColumn Width="130"
                                                                DataMemberBinding="{Binding id}"
                                                                Header="Ordine"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="60"
                                                                DataFormatString="N0"
                                                                DataMemberBinding="{Binding sequence}"
                                                                Header="Riga"
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding Product.FullDescriptionSearchable}" Header="Articolo" />
                                    <telerik:GridViewDataColumn Width="130"
                                                                DataFormatString="N6"
                                                                DataMemberBinding="{Binding quantity}"
                                                                Header="Q.tà ordinata"
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="90" DataMemberBinding="{Binding unit_id}" Header="" />
                                    <telerik:GridViewDataColumn Width="130"
                                                                DataFormatString="N6"
                                                                DataMemberBinding="{Binding quantity_received}"
                                                                Header="Q.tà già ricevuta"
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="90" DataMemberBinding="{Binding unit_id}" Header="" />
                                    <telerik:GridViewDataColumn Width="500" DataMemberBinding="{Binding note}" Header="Nota" />
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>
                            <telerik:RadDataPager x:Name="rdpGrid"
                                                  Grid.Row="2"
                                                  Margin="0,-1,0,0"
                                                  DisplayMode="FirstLastPreviousNextNumeric, Text"
                                                  FontSize="12"
                                                  IsTotalItemCountFixed="True"
                                                  PageSize="20"
                                                  Source="{Binding Items}" />
                        </Grid>
                    </telerik:RadBusyIndicator>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>

            <telerik:RadTabItem DropDownContent="STORICO" Header="STORICO">
                <telerik:RadTabItem.Content>
                    <telerik:RadBusyIndicator x:Name="bsyGridHistory"
                                              Grid.Row="4"
                                              BusyContent="Caricamento dati in corso..."
                                              Foreground="{DynamicResource VulpesXBrush}"
                                              IsBusy="{Binding IsBusy}"
                                              OverlayStyle="{StaticResource WaitOverlayStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="35" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5*" />
                                    <ColumnDefinition Width="5*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" HorizontalAlignment="Left" Orientation="Horizontal">
                                    <telerik:RadWatermarkTextBox Name="txtSearchHistory"
                                                                 Width="450"
                                                                 Margin="5,5,0,5"
                                                                 TextChanged="txtSearchHistory_TextChanged"
                                                                 WatermarkContent="Cerca..." />
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXSecondBrush}"
                                               Text="Entrate merci dal" />
                                    <telerik:RadDateTimePicker x:Name="rdtFromDate"
                                                               Width="130"
                                                               Margin="5,0,5,0"
                                                               VerticalAlignment="Center"
                                                               DateSelectionMode="Day"
                                                               DateTimeWatermarkContent="Scegliere la data"
                                                               DisplayFormat="Short"
                                                               InputMode="DatePicker"
                                                               ParseExact="False"
                                                               SelectedValue="{Binding FromDate}"
                                                               SelectionChanged="rdtFromDate_SelectionChanged" />
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource VulpesXSecondBrush}"
                                               Text="al" />
                                    <telerik:RadDateTimePicker x:Name="rdtToDate"
                                                               Width="130"
                                                               Margin="5,0,5,0"
                                                               VerticalAlignment="Center"
                                                               DateSelectionMode="Day"
                                                               DateTimeWatermarkContent="Scegliere la data"
                                                               DisplayFormat="Short"
                                                               InputMode="DatePicker"
                                                               ParseExact="False"
                                                               SelectedValue="{Binding ToDate}"
                                                               SelectionChanged="rdtToDate_SelectionChanged" />
                                </StackPanel>
                            </Grid>
                            <telerik:RadGridView x:Name="GridViewHistory"
                                                 Grid.Row="1"
                                                 AutoGenerateColumns="False"
                                                 CanUserFreezeColumns="False"
                                                 CanUserResizeColumns="False"
                                                 GroupRenderMode="Flat"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding PagedSource, ElementName=rdpGridHistory}"
                                                 RowIndicatorVisibility="Collapsed"
                                                 ShowGroupPanel="True">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewDataColumn Width="130"
                                                                DataMemberBinding="{Binding id}"
                                                                Header="ID"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button x:Name="cmdEditHistory"
                                                        Margin="3"
                                                        HorizontalContentAlignment="Center"
                                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                                        Click="cmdEditHistory_Click"
                                                        Content="{Binding Path=id}"
                                                        Cursor="Hand"
                                                        Foreground="{DynamicResource VulpesXBrush}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewDataColumn>
                                    <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding ProductDescription}" Header="Articolo" />
                                    <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding lot}" Header="Lotto" />
                                    <telerik:GridViewDataColumn Width="300" DataMemberBinding="{Binding SupplierDescription}" Header="Fornitore" />
                                    <telerik:GridViewDataColumn Width="130"
                                                                DataFormatString="N6"
                                                                DataMemberBinding="{Binding OrderedQuantity}"
                                                                Header="Q.tà ordinata"
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="30" DataMemberBinding="{Binding unit_id}" Header="" />
                                    <telerik:GridViewDataColumn Width="130"
                                                                DataFormatString="N6"
                                                                DataMemberBinding="{Binding quantity}"
                                                                Header="Q.tà entrata"
                                                                HeaderTextAlignment="Right"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="30" DataMemberBinding="{Binding unit_id}" Header="" />
                                    <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding CausalDescription}" Header="Causale" />
                                    <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding StoreDescription}" Header="Magazzino" />
                                    <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding goods_location}" Header="Ubicazione" />
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>
                            <telerik:RadDataPager x:Name="rdpGridHistory"
                                                  Grid.Row="2"
                                                  Margin="0,-1,0,0"
                                                  DisplayMode="FirstLastPreviousNextNumeric, Text"
                                                  FontSize="12"
                                                  IsTotalItemCountFixed="True"
                                                  PageSize="20"
                                                  Source="{Binding ItemsHistory}" />
                        </Grid>
                    </telerik:RadBusyIndicator>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>
    </Grid>

</UserControl>
