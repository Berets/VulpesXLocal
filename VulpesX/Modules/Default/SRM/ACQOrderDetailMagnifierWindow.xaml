<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.SRM.ACQOrderDetailMagnifierWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.SRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="{Binding Title}"
                        Width="850"
                        Height="330"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterOwner"
                        WindowStyle="None"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="10" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="90" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="8*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,3,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Articolo"
                           TextAlignment="Right" />
                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            Orientation="Horizontal">
                    <telerik:RadAutoCompleteBox Width="350"
                                                Margin="2"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Stretch"
                                                DisplayMemberPath="FullDescriptionSearchable"
                                                GotFocus="ac_GotFocus"
                                                IsEnabled="{Binding IsEnabled}"
                                                ItemsSource="{Binding Row.Products}"
                                                LostFocus="ac_LostFocus"
                                                NoResultsContent="Nessun articolo trovato"
                                                SelectedItem="{Binding Row.Product, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                TextSearchMode="Contains"
                                                TextSearchPath="FullDescriptionSearchable" />
                    <TextBlock Width="70"
                               Margin="0,0,5,0"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Style="{DynamicResource VulpesXLabel}"
                               Text="Quantità"
                               TextAlignment="Right" />
                    <telerik:RadNumericUpDown Width="100"
                                              Margin="2"
                                              FontSize="10"
                                              IsEnabled="{Binding IsEnabled}"
                                              Minimum="0"
                                              NumberDecimalDigits="6"
                                              ShowButtons="False"
                                              Value="{Binding Row.QuantityValue}" />
                    <Button x:Name="cmdAvailability"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="cmdAvailability_Click"
                            Cursor="Hand"
                            Style="{DynamicResource CalloutButtonStyle}"
                            ToolTip="Mostra le giacenze per l'articolo selezionato">
                        <telerik:RadGlyph Margin="3,0,3,0"
                                          FontSize="14"
                                          Foreground="{DynamicResource VulpesXGreenBrush}"
                                          Glyph="&#xe134;" />
                    </Button>
                    <telerik:RadComboBox Width="100"
                                         Margin="2,1,5,1"
                                         HorizontalAlignment="Left"
                                         HorizontalContentAlignment="Left"
                                         DisplayMemberPath="Description"
                                         FontSize="10"
                                         IsEditable="True"
                                         IsEnabled="{Binding IsEnabled}"
                                         ItemsSource="{Binding Row.UMs}"
                                         SelectedValue="{Binding Row.unit_id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         SelectedValuePath="ID" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,0,3,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Prezzo"
                           TextAlignment="Right" />
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                    <telerik:RadNumericUpDown Width="100"
                                              Margin="2"
                                              FontSize="10"
                                              IsEnabled="{Binding IsEnabled}"
                                              Minimum="0"
                                              NumberDecimalDigits="6"
                                              ShowButtons="False"
                                              Value="{Binding Row.price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button x:Name="cmdPrices"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="cmdPrices_Click"
                            Cursor="Hand"
                            IsEnabled="{Binding Model.IsEnabled}"
                            Style="{DynamicResource CalloutButtonStyle}"
                            ToolTip="Mostra i listini per l'articolo selezionato">
                        <telerik:RadGlyph Margin="3,0,5,0"
                                          FontSize="14"
                                          Foreground="{DynamicResource VulpesXGreenBrush}"
                                          Glyph="&#xe134;" />
                    </Button>
                    <telerik:RadComboBox Width="100"
                                         Margin="2"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Stretch"
                                         HorizontalContentAlignment="Left"
                                         DisplayMemberPath="Description"
                                         FontSize="10"
                                         IsEditable="True"
                                         IsEnabled="{Binding IsEnabled}"
                                         IsReadOnly="True"
                                         ItemsSource="{Binding Row.PriceTypes}"
                                         SelectedValue="{Binding Row.price_type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         SelectedValuePath="ID" />
                    <TextBlock Width="60"
                               Margin="0,0,3,0"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Style="{DynamicResource VulpesXLabel}"
                               Text="Sconto"
                               TextAlignment="Right" />
                    <telerik:RadNumericUpDown Width="50"
                                              Margin="2"
                                              FontSize="10"
                                              IsEnabled="{Binding IsEnabled}"
                                              Minimum="0"
                                              NumberDecimalDigits="2"
                                              ShowButtons="False"
                                              Value="{Binding Row.discount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <telerik:RadComboBox Width="100"
                                         Margin="2"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Stretch"
                                         HorizontalContentAlignment="Left"
                                         DisplayMemberPath="Description"
                                         FontSize="10"
                                         IsEditable="True"
                                         IsEnabled="{Binding IsEnabled}"
                                         IsReadOnly="True"
                                         ItemsSource="{Binding Row.DiscountTypes}"
                                         SelectedValue="{Binding Row.discount_type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         SelectedValuePath="ID" />
                    <Button x:Name="cmdAddToPriceList"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="cmdAddToPriceList_Click"
                            Cursor="Hand"
                            Style="{DynamicResource CalloutButtonStyle}"
                            ToolTip="Crea una nuova voce nel listino fornitore con i dati attuali">
                        <telerik:RadGlyph Margin="3,0,5,0"
                                          FontSize="14"
                                          Foreground="{DynamicResource VulpesXGreenBrush}"
                                          Glyph="&#xe11f;" />
                    </Button>
                </StackPanel>

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Width="90"
                           Margin="0,0,5,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Consegna ric."
                           TextAlignment="Right" />
                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                    <telerik:RadDateTimePicker Width="140"
                                               Margin="2"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               DateSelectionMode="Day"
                                               DateTimeWatermarkContent=""
                                               DisplayFormat="Short"
                                               InputMode="DatePicker"
                                               IsEnabled="{Binding IsEnabled}"
                                               SelectedValue="{Binding Row.delivery_requested, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Width="320"
                               Margin="0,0,5,0"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Style="{DynamicResource VulpesXLabel}"
                               Text="Prezzo netto"
                               TextAlignment="Right" />
                    <TextBlock Margin="5,0,5,0"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Style="{DynamicResource VulpesXData}"
                               Text="{Binding Row.NetAmount, StringFormat=N6}"
                               TextAlignment="Left" />
                </StackPanel>

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Margin="0,0,3,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Magazzino"
                           TextAlignment="Right" />
                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                    <telerik:RadAutoCompleteBox Width="300"
                                                Margin="2"
                                                HorizontalAlignment="Left"
                                                DisplayMemberPath="FullDescriptionSearchable"
                                                GotFocus="ac_GotFocus"
                                                IsEnabled="{Binding IsEnabled}"
                                                ItemsSource="{Binding Row.Stores}"
                                                LostFocus="ac_LostFocus"
                                                NoResultsContent="Nessun magazzino trovato"
                                                SelectedItem="{Binding Row.Store, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                TextSearchMode="Contains"
                                                TextSearchPath="FullDescriptionSearchable" />
                    <TextBlock Width="67"
                               Margin="0,0,3,0"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Style="{DynamicResource VulpesXLabel}"
                               Text="Aliquota"
                               TextAlignment="Right" />
                    <telerik:RadAutoCompleteBox Width="300"
                                                Margin="2"
                                                HorizontalAlignment="Left"
                                                DisplayMemberPath="FullDescriptionSearchable"
                                                GotFocus="ac_GotFocus"
                                                IsEnabled="{Binding IsEnabled}"
                                                ItemsSource="{Binding Row.Rates}"
                                                LostFocus="ac_LostFocus"
                                                NoResultsContent="Nessuna aliquota trovata"
                                                SelectedItem="{Binding Row.Rate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                TextSearchMode="Contains"
                                                TextSearchPath="FullDescriptionSearchable" />
                </StackPanel>

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Margin="0,0,5,0"
                           VerticalAlignment="Top"
                           FontWeight="Bold"
                           Style="{DynamicResource VulpesXLabel}"
                           Text="Nota"
                           TextAlignment="Right" />
                <TextBox Grid.Row="5"
                         Grid.Column="1"
                         Margin="2,2,5,2"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         VerticalContentAlignment="Top"
                         AcceptsReturn="True"
                         FontSize="10"
                         IsEnabled="{Binding IsEnabled}"
                         IsReadOnly="{Binding IsReadOnly}"
                         PreviewMouseRightButtonDown="txtNote_PreviewMouseRightButtonDown"
                         PreviewMouseRightButtonUp="TextBox_PreviewMouseRightButtonUp"
                         Text="{Binding Row.note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </ScrollViewer>
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
