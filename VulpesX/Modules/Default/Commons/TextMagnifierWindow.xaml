<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Commons.TextMagnifierWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Commons"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Specificare il motivo dell'annullamento"
                        Width="1000"
                        Height="700"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="20" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <TextBox x:Name="txtText"
                 Grid.Row="1"
                 Margin="2"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch"
                 VerticalContentAlignment="Top"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 FontSize="14"
                 TextAlignment="Left"
                 TextChanged="txtText_TextChanged"
                 TextWrapping="Wrap" />
        <TextBlock Grid.Row="2"
                   Grid.Column="1"
                   Padding="0,0,5,0"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Top"
                   FontSize="12"
                   Foreground="{Binding CurrentSizeColor, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True}"
                   Text="{Binding CurrentSizeText, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True}"
                   TextAlignment="Right" />

        <StackPanel Grid.Row="3"
                    Margin="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Width="200"
                    Margin="2"
                    BorderBrush="Gold"
                    BorderThickness="5,0,0,0"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    FontSize="10"
                    IsCancel="True" />
            <Button Name="cmdSave"
                    Width="200"
                    Margin="2"
                    BorderBrush="ForestGreen"
                    BorderThickness="5,0,0,0"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    FontSize="10"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
