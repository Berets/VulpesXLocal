<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Commons.YearWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Commons"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Seleziona l'anno da utilizzare per l'operazione"
                        Width="500"
                        Height="180"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="6*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Anno"
                   TextAlignment="Right"
                   TextWrapping="Wrap" />
        <telerik:RadDatePicker x:Name="rdpDate"
                               Grid.Row="2"
                               Grid.Column="1"
                               Width="130"
                               Margin="2"
                               HorizontalAlignment="Left"
                               HorizontalContentAlignment="Right"
                               DateSelectionMode="Year"
                               DateTimeWatermarkContent="Scegliere un anno"
                               DisplayFormat="Short" />
        <StackPanel Grid.Row="4"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Width="200"
                    Margin="2"
                    BorderBrush="Gold"
                    BorderThickness="5,0,0,0"
                    Content="USCIRE"
                    FontSize="10"
                    IsCancel="True" />
            <Button Name="cmdSave"
                    Width="200"
                    Margin="2"
                    BorderBrush="ForestGreen"
                    BorderThickness="5,0,0,0"
                    Click="cmdSave_Click"
                    Content="CONFERMA"
                    FontSize="10"
                    Foreground="White"
                    IsDefault="True" />
        </StackPanel>
    </Grid>

</sc:FluentDefaultWindow>
