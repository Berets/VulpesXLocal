<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Commons.SendMailWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Commons"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Invio email"
                        Width="1024"
                        Height="768"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="None"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="5" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="25" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="8*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="A*"
                           TextAlignment="Right" />
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsInsert}"
                         Text="{Binding To, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Cc*"
                           TextAlignment="Right" />
                <TextBox Grid.Row="3"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsInsert}"
                         Text="{Binding Cc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           Margin="5,0,0,0"
                           HorizontalAlignment="Stretch"
                           FontStyle="Italic"
                           FontWeight="Normal"
                           Style="{StaticResource VulpesXLabel}"
                           Text="* indirizzi multipli separati da ,"
                           TextAlignment="Left" />

                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Oggetto" />
                <TextBox Grid.Row="6"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsInsert}"
                         MaxLength="255"
                         Text="{Binding Subject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="7"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Testo email" />
                <TextBox Grid.Row="7"
                         Grid.RowSpan="7"
                         Grid.Column="1"
                         Margin="5,5,15,5"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         VerticalContentAlignment="Stretch"
                         AcceptsReturn="True"
                         HorizontalScrollBarVisibility="Auto"
                         Text="{Binding Body, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         VerticalScrollBarVisibility="Auto" />

                <TextBlock Grid.Row="14"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Allegati" />
                <telerik:RadListBox x:Name="lbAttachments"
                                    Grid.Row="14"
                                    Grid.RowSpan="5"
                                    Grid.Column="1"
                                    Margin="5,5,15,5"
                                    ItemsSource="{Binding Attachments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    PreviewKeyDown="lbAttachments_PreviewKeyDown" />

                <TextBlock Grid.Row="19"
                           Grid.Column="1"
                           Margin="5,0,0,0"
                           HorizontalAlignment="Left"
                           FontStyle="Italic"
                           FontWeight="Normal"
                           Style="{StaticResource VulpesXLabel}"
                           Text="utilizzare il tasto Canc per eliminare allegati"
                           TextAlignment="Left" />
                <Button Name="cmdAddAttachment"
                        Grid.Row="19"
                        Grid.Column="1"
                        Width="150"
                        Margin="5,5,15,5"
                        HorizontalAlignment="Right"
                        BorderBrush="{DynamicResource VulpesXBlueBrush}"
                        Click="cmdAddAttachment_Click"
                        Content="Aggiungi allegato"
                        Style="{StaticResource VulpesXButton}" />
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="INVIA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
