<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Tables.Store.STORE_CAUSALSWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Store"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli causale di magazzino"
                        Width="750"
                        Height="600"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="DATI GENERALI" Header="DATI GENERALI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="15" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="15" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*" />
                                <ColumnDefinition Width="6*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Codice" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Width="80"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     IsEnabled="{Binding IsInsert}"
                                     MaxLength="50"
                                     Text="{Binding Data.id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Descrizione" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="50"
                                     Text="{Binding Data.description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Tipo" />
                            <telerik:RadComboBox Grid.Row="3"
                                                 Grid.Column="1"
                                                 Width="200"
                                                 Margin="5,2,15,2"
                                                 HorizontalAlignment="Left"
                                                 HorizontalContentAlignment="Left"
                                                 DisplayMemberPath="Description"
                                                 IsEditable="True"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding Data.CausalTypes}"
                                                 SelectedValue="{Binding Data.sign, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 SelectedValuePath="ID" />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Centro di costo" />
                            <telerik:RadAutoCompleteBox x:Name="acCostCenter"
                                                        Grid.Row="5"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Data.CostCentersList}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding Data.SelectedCostCenter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <Border Grid.Row="7"
                                    Grid.RowSpan="2"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Margin="5,0,5,0"
                                    Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                                    BorderBrush="{DynamicResource VulpesXBrush}"
                                    BorderThickness="1">
                                <TextBlock Padding="0"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource VulpesXBrush}"
                                           Opacity=".8"
                                           Text="LINK"
                                           TextAlignment="Center"
                                           Typography.Capitals="AllSmallCaps">
                                    <TextBlock.LayoutTransform>
                                        <RotateTransform Angle="270" />
                                    </TextBlock.LayoutTransform>
                                </TextBlock>
                            </Border>
                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Causale collegamento" />
                            <telerik:RadAutoCompleteBox x:Name="acLinkedCausal"
                                                        Grid.Row="7"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Data.CausalsList}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding Data.SelectedLinkedCausal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Magazzino collegato" />
                            <telerik:RadAutoCompleteBox x:Name="acLinkedStore"
                                                        Grid.Row="8"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Data.StoresList}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding Data.SelectedLinkedStore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="PREDEFINITI" Header="PREDEFINITI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5*" />
                                <ColumnDefinition Width="5*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Predefinita carico materie prime" />
                            <telerik:RadToggleSwitchButton Grid.Row="0"
                                                           Grid.Column="1"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.is_default_raw_load, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           IsChecked="{Binding Data.is_default_raw_load}"
                                                           UncheckedContent="No" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Predefinita scarico materie prime" />
                            <telerik:RadToggleSwitchButton Grid.Row="1"
                                                           Grid.Column="1"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.is_default_raw_unload, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           IsChecked="{Binding Data.is_default_raw_unload}"
                                                           UncheckedContent="No" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Predefinita carico prodotto finito" />
                            <telerik:RadToggleSwitchButton Grid.Row="2"
                                                           Grid.Column="1"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.is_default_final_load, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           IsChecked="{Binding Data.is_default_final_load}"
                                                           UncheckedContent="No" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Predefinita scarico prodotto finito" />
                            <telerik:RadToggleSwitchButton Grid.Row="3"
                                                           Grid.Column="1"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.is_default_final_unload, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           IsChecked="{Binding Data.is_default_final_unload}"
                                                           UncheckedContent="No" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Predefinita carico semilavorato" />
                            <telerik:RadToggleSwitchButton Grid.Row="4"
                                                           Grid.Column="1"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.is_default_half_load, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           IsChecked="{Binding Data.is_default_half_load}"
                                                           UncheckedContent="No" />
                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Predefinita scarico semilavorato" />
                            <telerik:RadToggleSwitchButton Grid.Row="5"
                                                           Grid.Column="1"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.is_default_half_unload, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           IsChecked="{Binding Data.is_default_half_unload}"
                                                           UncheckedContent="No" />
                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Predefinita carico conto lavoro" />
                            <telerik:RadToggleSwitchButton Grid.Row="6"
                                                           Grid.Column="1"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.is_default_external_charge, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           IsChecked="{Binding Data.is_default_external_charge}"
                                                           UncheckedContent="No" />
                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Predefinita scarico conto lavoro" />
                            <telerik:RadToggleSwitchButton Grid.Row="7"
                                                           Grid.Column="1"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.is_default_external_discharge, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           IsChecked="{Binding Data.is_default_external_discharge}"
                                                           UncheckedContent="No" />
                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Predefinita scarico sempre disponibili" />
                            <telerik:RadToggleSwitchButton Grid.Row="8"
                                                           Grid.Column="1"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.is_default_infinite_unload, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           IsChecked="{Binding Data.is_default_infinite_unload}"
                                                           UncheckedContent="No" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>

    </Grid>
</sc:FluentDefaultWindow>
