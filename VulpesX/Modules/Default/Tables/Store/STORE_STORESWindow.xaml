<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Tables.Store.STORE_STORESWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Store"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli magazzino"
                        Width="750"
                        Height="500"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabControl.Items>
                <telerik:RadTabItem DropDownContent="DATI" Header="DATI">
                    <telerik:RadTabItem.Content>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <Grid Margin="0,15,15,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="15" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="15" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4*" />
                                    <ColumnDefinition Width="6*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Codice" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Width="80"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         IsEnabled="{Binding IsInsert}"
                                         MaxLength="3"
                                         Text="{Binding Data.id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Descrizione" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         MaxLength="255"
                                         Text="{Binding Data.description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Tipo" />
                                <telerik:RadComboBox Grid.Row="3"
                                                     Grid.Column="1"
                                                     Width="200"
                                                     Margin="5,2,15,2"
                                                     HorizontalAlignment="Left"
                                                     HorizontalContentAlignment="Left"
                                                     DisplayMemberPath="Description"
                                                     IsEditable="True"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding StoreTypes}"
                                                     SelectedValue="{Binding Data.type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     SelectedValuePath="ID" />

                                <TextBlock Grid.Row="5"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Predefinito carico prodotto finito" />
                                <telerik:RadToggleSwitchButton Grid.Row="5"
                                                               Grid.Column="1"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Data.is_default_final_load, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               IsChecked="{Binding Data.is_default_final_load}"
                                                               UncheckedContent="No" />
                                <TextBlock Grid.Row="6"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Predefinito carico semilavorati" />
                                <telerik:RadToggleSwitchButton Grid.Row="6"
                                                               Grid.Column="1"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Data.is_default_half, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               IsChecked="{Binding Data.is_default_half}"
                                                               UncheckedContent="No" />
                                <TextBlock Grid.Row="7"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Predefinito carico materie prime" />
                                <telerik:RadToggleSwitchButton Grid.Row="7"
                                                               Grid.Column="1"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Data.is_default_raw, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               IsChecked="{Binding Data.is_default_raw}"
                                                               UncheckedContent="No" />
                                <TextBlock Grid.Row="8"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Predefinito prodotti sempre disponibili" />
                                <telerik:RadToggleSwitchButton Grid.Row="8"
                                                               Grid.Column="1"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Data.is_default_infinite, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               IsChecked="{Binding Data.is_default_infinite}"
                                                               UncheckedContent="No" />
                            </Grid>
                        </ScrollViewer>
                    </telerik:RadTabItem.Content>
                </telerik:RadTabItem>
                <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                    <telerik:RadTabItem.Content>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <Grid Margin="0,10,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="7*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Inserito il" />
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.AddedText}" />
                                    <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.AddedUserText}" />
                                </StackPanel>

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Ultimo aggiornamento il" />
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.UpdatedText}" />
                                    <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.UpdatedUserText}" />
                                </StackPanel>

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Annullato il" />
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.CanceledText}" />
                                    <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                    <TextBlock Margin="5,2,2,2"
                                               HorizontalAlignment="Left"
                                               Style="{StaticResource VulpesXData}"
                                               Text="{Binding Data.CanceledUserText}" />
                                </StackPanel>

                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Motivo annullamento" />
                                <TextBlock Grid.Row="4"
                                           Grid.Column="1"
                                           Margin="5,2,2,2"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledReason}" />
                            </Grid>
                        </ScrollViewer>
                    </telerik:RadTabItem.Content>
                </telerik:RadTabItem>
            </telerik:RadTabControl.Items>
        </telerik:RadTabControl>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
