<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Tables.CRM.CAUFAT00FWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.CRM"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli causale fatture"
                        Width="700"
                        Height="500"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,15,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="7*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Codice" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Width="100"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsInsert}"
                         MaxLength="2"
                         Text="{Binding Data.fatcod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Descrizione" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         MaxLength="50"
                         Text="{Binding Data.fatdes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Scrittura contabilita'" />
                <telerik:RadToggleSwitchButton Grid.Row="2"
                                               Grid.Column="1"
                                               Margin="5,0,0,0"
                                               CheckedContent="Sì"
                                               Content="{Binding Data.flgcon}"
                                               IsChecked="{Binding Data.flgconBool}"
                                               UncheckedContent="No" />
                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Causale contabile" />
                <telerik:RadAutoCompleteBox x:Name="acCausal"
                                            Grid.Row="3"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            ItemsSource="{Binding Causals}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun codice trovato"
                                            SelectedItem="{Binding SelectedCausal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionChanged="acCausal_SelectionChanged"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Autofattura" />
                <telerik:RadToggleSwitchButton Grid.Row="4"
                                               Grid.Column="1"
                                               Margin="5,0,0,0"
                                               CheckedContent="Sì"
                                               Content="{Binding Data.fataut}"
                                               IsChecked="{Binding Data.fatautBool}"
                                               UncheckedContent="No" />
                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Causale contabile giroconto" />
                <telerik:RadAutoCompleteBox x:Name="acSelfInvoiceCausal"
                                            Grid.Row="5"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            ItemsSource="{Binding Causals}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun codice trovato"
                                            SelectedItem="{Binding SelectedSelfInvoiceCausal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionChanged="acSelfInvoiceCausal_SelectionChanged"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Tipo documento" />
                <telerik:RadComboBox Grid.Row="6"
                                     Grid.Column="1"
                                     Width="200"
                                     Margin="5,2,15,2"
                                     HorizontalAlignment="Left"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     IsEditable="True"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Data.DocumentTypes}"
                                     SelectedValue="{Binding Data.fattif, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
                <TextBlock Grid.Row="7"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Numeratore" />
                <telerik:RadAutoCompleteBox x:Name="acNumerator"
                                            Grid.Row="7"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            ItemsSource="{Binding Numerators}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun codice trovato"
                                            SelectedItem="{Binding SelectedNumerator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionChanged="acNumerator_SelectionChanged"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                <TextBlock Grid.Row="8"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Tipo documento" />
                <telerik:RadAutoCompleteBox x:Name="acFEDocType"
                                            Grid.Row="8"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            ItemsSource="{Binding FEDocTypes}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun codice trovato"
                                            SelectedItem="{Binding SelectedFEDocType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionChanged="acFEDocType_SelectionChanged"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                <TextBlock Grid.Row="9"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Prefisso fatture" />
                <TextBox Grid.Row="9"
                         Grid.Column="1"
                         Width="50"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         MaxLength="2"
                         Text="{Binding Data.fatpre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />


            </Grid>
        </ScrollViewer>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
