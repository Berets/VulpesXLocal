<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Tables.Accounting.RITENUTEWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli ritenuta"
                        Width="850"
                        Height="650"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,15,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="7*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Codice" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Width="120"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsInsert}"
                         MaxLength="4"
                         Text="{Binding Data.ritcod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Descrizione" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         MaxLength="50"
                         Text="{Binding Data.ritdes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Sezione" />
                <telerik:RadComboBox Grid.Row="2"
                                     Grid.Column="1"
                                     Margin="5,2,15,2"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     IsEditable="True"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Data.Sections}"
                                     SelectedValue="{Binding Data.rtsez, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Tipo" />
                <telerik:RadComboBox Grid.Row="3"
                                     Grid.Column="1"
                                     Margin="5,2,15,2"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     IsEditable="True"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Data.ElementTypes}"
                                     SelectedValue="{Binding Data.rttipo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Mese per IVA" />
                <telerik:RadComboBox Grid.Row="4"
                                     Grid.Column="1"
                                     Margin="5,2,15,2"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     IsEditable="True"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Data.Months}"
                                     SelectedValue="{Binding Data.rtmese, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Tipologia reddituale" />
                <telerik:RadComboBox Grid.Row="5"
                                     Grid.Column="1"
                                     Margin="5,2,15,2"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     IsEditable="True"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Data.RedditTypes}"
                                     SelectedValue="{Binding Data.rtTipRed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />
                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Style="{StaticResource VulpesXSubtitle}"
                           Text="Dati contabili" />
                <TextBlock Grid.Row="7"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Causale pagamento fatture" />
                <telerik:RadAutoCompleteBox x:Name="acCausal"
                                            Grid.Row="7"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            ItemsSource="{Binding Causals}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun codice trovato"
                                            SelectedItem="{Binding SelectedCausal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionChanged="acCausal_SelectionChanged"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                <TextBlock Grid.Row="8"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Conto accertamento" />
                <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                    <telerik:RadAutoCompleteBox x:Name="acAssessmentGroup"
                                                Width="250"
                                                Margin="5,2,5,2"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Center"
                                                DisplayMemberPath="FullDescriptionSearchable"
                                                GotFocus="ac_GotFocus"
                                                ItemsSource="{Binding Data.GroupsList}"
                                                LostFocus="ac_LostFocus"
                                                NoResultsContent="Nessun gruppo trovato"
                                                SelectedItem="{Binding Data.SelectedAssessmentGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                TextSearchMode="Contains"
                                                TextSearchPath="FullDescriptionSearchable"
                                                WatermarkContent="Cerca gruppo..." />
                    <telerik:RadAutoCompleteBox x:Name="acAssessmentAccount"
                                                Width="250"
                                                Margin="5,2,5,2"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Center"
                                                DisplayMemberPath="FullDescriptionSearchable"
                                                GotFocus="ac_GotFocus"
                                                ItemsSource="{Binding Data.AssessmentAccountsList}"
                                                LostFocus="ac_LostFocus"
                                                NoResultsContent="Nessun conto trovato"
                                                SelectedItem="{Binding Data.SelectedAssessmentAccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                TextSearchMode="Contains"
                                                TextSearchPath="FullDescriptionSearchable"
                                                WatermarkContent="Cerca conto..." />
                </StackPanel>
                <TextBlock Grid.Row="9"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Sottoconto" />
                <telerik:RadAutoCompleteBox x:Name="acAssessmentSubaccount"
                                            Grid.Row="9"
                                            Grid.Column="1"
                                            Margin="5,2,5,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            ItemsSource="{Binding Data.AssessmentSubaccountsList}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun sottoconto trovato"
                                            SelectedItem="{Binding Data.SelectedAssessmentSubaccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Cerca sottoconto..." />
                <TextBlock Grid.Row="10"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Causale accertamento" />
                <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal">
                    <telerik:RadAutoCompleteBox x:Name="acAssessmentCausal"
                                                Width="300"
                                                Margin="5,2,15,2"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                DisplayMemberPath="FullDescriptionSearchable"
                                                ItemsSource="{Binding Causals}"
                                                LostFocus="ac_LostFocus"
                                                NoResultsContent="Nessun codice trovato"
                                                SelectedItem="{Binding SelectedAssessmentCausal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionChanged="acAssessmentCausal_SelectionChanged"
                                                SelectionMode="Single"
                                                TextSearchMode="Contains"
                                                TextSearchPath="FullDescriptionSearchable"
                                                WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                    <TextBlock Style="{StaticResource VulpesXLabel}" Text="Attivazione giroconto" />
                    <telerik:RadToggleSwitchButton Margin="5,0,0,0"
                                                   CheckedContent="Sì"
                                                   Content="{Binding Data.ritfl1}"
                                                   IsChecked="{Binding Data.ritfl1Bool}"
                                                   UncheckedContent="No" />
                </StackPanel>
                <TextBlock Grid.Row="11"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Conto pagamento" />
                <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal">
                    <telerik:RadAutoCompleteBox x:Name="acPaymentGroup"
                                                Width="250"
                                                Margin="5,2,5,2"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Center"
                                                DisplayMemberPath="FullDescriptionSearchable"
                                                GotFocus="ac_GotFocus"
                                                ItemsSource="{Binding Data.GroupsList}"
                                                LostFocus="ac_LostFocus"
                                                NoResultsContent="Nessun gruppo trovato"
                                                SelectedItem="{Binding Data.SelectedPaymentGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                TextSearchMode="Contains"
                                                TextSearchPath="FullDescriptionSearchable"
                                                WatermarkContent="Cerca gruppo..." />
                    <telerik:RadAutoCompleteBox x:Name="acPaymentAccount"
                                                Width="250"
                                                Margin="5,2,5,2"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Center"
                                                DisplayMemberPath="FullDescriptionSearchable"
                                                GotFocus="ac_GotFocus"
                                                ItemsSource="{Binding Data.PaymentAccountsList}"
                                                LostFocus="ac_LostFocus"
                                                NoResultsContent="Nessun conto trovato"
                                                SelectedItem="{Binding Data.SelectedPaymentAccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionMode="Single"
                                                TextSearchMode="Contains"
                                                TextSearchPath="FullDescriptionSearchable"
                                                WatermarkContent="Cerca conto..." />
                </StackPanel>
                <TextBlock Grid.Row="12"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Sottoconto" />
                <telerik:RadAutoCompleteBox x:Name="acPaymentSubaccount"
                                            Grid.Row="12"
                                            Grid.Column="1"
                                            Margin="5,2,5,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            GotFocus="ac_GotFocus"
                                            ItemsSource="{Binding Data.PaymentSubaccountsList}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun sottoconto trovato"
                                            SelectedItem="{Binding Data.SelectedPaymentSubaccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Cerca sottoconto..." />
                <TextBlock Grid.Row="13"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Causale pagamento" />
                <StackPanel Grid.Row="13" Grid.Column="1" Orientation="Horizontal">
                    <telerik:RadAutoCompleteBox x:Name="acPaymentCausal"
                                                Width="300"
                                                Margin="5,2,15,2"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                DisplayMemberPath="FullDescriptionSearchable"
                                                ItemsSource="{Binding Causals}"
                                                LostFocus="ac_LostFocus"
                                                NoResultsContent="Nessun codice trovato"
                                                SelectedItem="{Binding SelectedPaymentCausal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionChanged="acPaymentCausal_SelectionChanged"
                                                SelectionMode="Single"
                                                TextSearchMode="Contains"
                                                TextSearchPath="FullDescriptionSearchable"
                                                WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                    <TextBlock Style="{StaticResource VulpesXLabel}" Text="Attivazione giroconto" />
                    <telerik:RadToggleSwitchButton Margin="5,0,0,0"
                                                   CheckedContent="Sì"
                                                   Content="{Binding Data.ritfl2}"
                                                   IsChecked="{Binding Data.ritfl2Bool}"
                                                   UncheckedContent="No" />
                </StackPanel>




            </Grid>
        </ScrollViewer>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
