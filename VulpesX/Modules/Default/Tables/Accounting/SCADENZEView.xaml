<UserControl x:Class="VulpesX.Modules.Default.Tables.Accounting.SCADENZEView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Accounting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="TABELLA SPOSTAMENTO SCADENZE" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Margin="5"
                                         TextChanged="txtSearch_TextChanged"
                                         WatermarkContent="Cerca..." />
        </Grid>

        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     RowIndicatorVisibility="Hidden"
                                     ShowGroupPanel="True">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewColumn Width="110">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadButton x:Name="cmdDelete"
                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                       Click="cmdDelete_Click"
                                                       Content="Elimina"
                                                       Style="{StaticResource VulpesXButton}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewDataColumn Width="100"
                                                    DataMemberBinding="{Binding scacod}"
                                                    Header="Codice"
                                                    HeaderTextAlignment="Center">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Center"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEdit_Click"
                                            Content="{Binding Path=scacod}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scam01}"
                                                    Header="Mese"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scas01}"
                                                    Header="Sposta a"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scam02}"
                                                    Header="Mese"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scas02}"
                                                    Header="Sposta a"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scam03}"
                                                    Header="Mese"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scas03}"
                                                    Header="Sposta a"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scam04}"
                                                    Header="Mese"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scas04}"
                                                    Header="Sposta a"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scam05}"
                                                    Header="Mese"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scas05}"
                                                    Header="Sposta a"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scam06}"
                                                    Header="Mese"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scas06}"
                                                    Header="Sposta a"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scam07}"
                                                    Header="Mese"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scas07}"
                                                    Header="Sposta a"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scam08}"
                                                    Header="Mese"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scas08}"
                                                    Header="Sposta a"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scam09}"
                                                    Header="Mese"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scas09}"
                                                    Header="Sposta a"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scam10}"
                                                    Header="Mese"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scas10}"
                                                    Header="Sposta a"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scam11}"
                                                    Header="Mese"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scas11}"
                                                    Header="Sposta a"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scam12}"
                                                    Header="Mese"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding scas12}"
                                                    Header="Sposta a"
                                                    HeaderTextAlignment="Right"
                                                    TextAlignment="Right" />

                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding Items}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>

</UserControl>
