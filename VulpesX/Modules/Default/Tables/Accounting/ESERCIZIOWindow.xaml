<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Tables.Accounting.ESERCIZIOWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli esercizio contabile"
                        Width="800"
                        Height="650"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="DATI GENERALI" Header="DATI GENERALI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,5,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Anno" />
                            <telerik:RadNumericUpDown Grid.Row="0"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      IsEnabled="{Binding IsInsert}"
                                                      Maximum="9999"
                                                      Minimum="1"
                                                      NumberDecimalDigits="0"
                                                      Value="{Binding Data.eseann, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Primo mese esercizio" />
                            <telerik:RadComboBox Grid.Row="1"
                                                 Grid.Column="1"
                                                 Width="200"
                                                 Margin="5,2,15,2"
                                                 HorizontalAlignment="Left"
                                                 HorizontalContentAlignment="Left"
                                                 DisplayMemberPath="Description"
                                                 IsEditable="True"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding Months}"
                                                 SelectedValue="{Binding Data.eseini}"
                                                 SelectedValuePath="ID" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultima pagina/riga giornale" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadNumericUpDown Width="100"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          NumberDecimalDigits="0"
                                                          ShowButtons="False"
                                                          Value="{Binding Data.esepag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Width="20"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="/"
                                           TextAlignment="Center" />
                                <telerik:RadNumericUpDown Width="100"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          NumberDecimalDigits="0"
                                                          ShowButtons="False"
                                                          Value="{Binding Data.eseulr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock MinWidth="180"
                                           Margin="15,0,5,0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Numerazione pagine"
                                           TextAlignment="Right" />
                                <telerik:RadToggleSwitchButton Margin="5,0,0,0"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Data.eseagg}"
                                                               IsChecked="{Binding Data.eseaggBool}"
                                                               UncheckedContent="No" />
                            </StackPanel>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Stato esercizio IVA" />
                            <telerik:RadComboBox Grid.Row="3"
                                                 Grid.Column="1"
                                                 Width="200"
                                                 Margin="5,2,15,2"
                                                 HorizontalAlignment="Left"
                                                 HorizontalContentAlignment="Left"
                                                 DisplayMemberPath="Description"
                                                 IsEditable="True"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding OCStatuses}"
                                                 SelectedValue="{Binding Data.eseist}"
                                                 SelectedValuePath="ID" />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       MinWidth="180"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Stato esercizio contabile"
                                       TextAlignment="Right" />
                            <telerik:RadComboBox Grid.Row="4"
                                                 Grid.Column="1"
                                                 Width="200"
                                                 Margin="5,2,15,2"
                                                 HorizontalAlignment="Left"
                                                 HorizontalContentAlignment="Left"
                                                 DisplayMemberPath="Description"
                                                 IsEditable="True"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding OCStatuses}"
                                                 SelectedValue="{Binding Data.eseest}"
                                                 SelectedValuePath="ID" />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultima chiusura mensile" />
                            <telerik:RadDateTimePicker Grid.Row="5"
                                                       Grid.Column="1"
                                                       Width="150"
                                                       Margin="5,0,15,0"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       DateSelectionMode="Day"
                                                       DateTimeWatermarkContent="Scegliere la data"
                                                       DisplayFormat="Short"
                                                       InputMode="DatePicker"
                                                       SelectedValue="{Binding Data.eseuch}" />

                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Liquidazione IVA" />
                            <telerik:RadComboBox Grid.Row="6"
                                                 Grid.Column="1"
                                                 Width="200"
                                                 Margin="5,2,15,2"
                                                 HorizontalAlignment="Left"
                                                 HorizontalContentAlignment="Left"
                                                 DisplayMemberPath="Description"
                                                 IsEditable="True"
                                                 IsReadOnly="True"
                                                 ItemsSource="{Binding Liquidations}"
                                                 SelectedValue="{Binding Data.eseliq}"
                                                 SelectedValuePath="ID" />

                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Gestione commesse" />
                            <telerik:RadToggleSwitchButton Grid.Row="7"
                                                           Grid.Column="1"
                                                           Margin="5,0,0,0"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.esecom}"
                                                           IsChecked="{Binding Data.esecomBool}"
                                                           UncheckedContent="No" />

                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="IVA per cassa" />
                            <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadToggleSwitchButton Margin="5,0,0,0"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Data.eseivaven}"
                                                               IsChecked="{Binding Data.eseivavenBool}"
                                                               UncheckedContent="No" />
                                <TextBlock MinWidth="160"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Data inizio IVA per cassa"
                                           TextAlignment="Right" />
                                <telerik:RadDateTimePicker Width="150"
                                                           Margin="5,0,15,0"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           SelectedValue="{Binding Data.esedtiniva}" />
                            </StackPanel>

                            <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock MinWidth="254"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Data fine IVA per cassa"
                                           TextAlignment="Right" />
                                <telerik:RadDateTimePicker Width="150"
                                                           Margin="5,0,15,0"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           SelectedValue="{Binding Data.esedtfniva}" />
                            </StackPanel>

                            <TextBlock Grid.Row="10"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="2"
                                       Style="{StaticResource VulpesXSubtitle}"
                                       Text="Gestione plafond" />

                            <TextBlock Grid.Row="11"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Plafond iniziale" />
                            <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadNumericUpDown Width="150"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          NumberDecimalDigits="0"
                                                          ShowButtons="False"
                                                          Value="{Binding Data.esepli, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock MinWidth="180"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Plafond residuo"
                                           TextAlignment="Right" />
                                <telerik:RadNumericUpDown Width="150"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          NumberDecimalDigits="0"
                                                          ShowButtons="False"
                                                          Value="{Binding Data.esepre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <TextBlock Grid.Row="12"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultimo calcolo" />
                            <telerik:RadDateTimePicker Grid.Row="12"
                                                       Grid.Column="1"
                                                       Width="150"
                                                       Margin="5,0,15,0"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       DateSelectionMode="Day"
                                                       DateTimeWatermarkContent="Scegliere la data"
                                                       DisplayFormat="Short"
                                                       InputMode="DatePicker"
                                                       SelectedValue="{Binding Data.esedap}" />

                            <TextBlock Grid.Row="13"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Progressivo DARE" />
                            <StackPanel Grid.Row="13" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadNumericUpDown Width="150"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          NumberDecimalDigits="0"
                                                          ShowButtons="False"
                                                          Value="{Binding Data.esedar, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock MinWidth="180"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Progressivo AVERE"
                                           TextAlignment="Right" />
                                <telerik:RadNumericUpDown Width="150"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          NumberDecimalDigits="0"
                                                          ShowButtons="False"
                                                          Value="{Binding Data.eseave, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="DATE ULTIME STAMPE" Header="DATE ULTIME STAMPE">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,5,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Giornale" />
                            <telerik:RadDateTimePicker Grid.Row="0"
                                                       Grid.Column="1"
                                                       Width="150"
                                                       Margin="5,0,15,0"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       DateSelectionMode="Day"
                                                       DateTimeWatermarkContent="Scegliere la data"
                                                       DisplayFormat="Short"
                                                       InputMode="DatePicker"
                                                       SelectedValue="{Binding Data.eseusg}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Mastrini" />
                            <telerik:RadDateTimePicker Grid.Row="1"
                                                       Grid.Column="1"
                                                       Width="150"
                                                       Margin="5,0,15,0"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       DateSelectionMode="Day"
                                                       DateTimeWatermarkContent="Scegliere la data"
                                                       DisplayFormat="Short"
                                                       InputMode="DatePicker"
                                                       SelectedValue="{Binding Data.eseusm}" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Libro vendite Italia" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadDateTimePicker Width="150"
                                                           Margin="5,0,15,0"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           SelectedValue="{Binding Data.eselvi}" />
                                <TextBlock MinWidth="160"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Libro acquisti Italia"
                                           TextAlignment="Right" />
                                <telerik:RadDateTimePicker Width="150"
                                                           Margin="5,0,15,0"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           SelectedValue="{Binding Data.eselai}" />
                            </StackPanel>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Libro vendite estero" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadDateTimePicker Width="150"
                                                           Margin="5,0,15,0"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           SelectedValue="{Binding Data.eselve}" />
                                <TextBlock MinWidth="160"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Libro acquisti estero"
                                           TextAlignment="Right" />
                                <telerik:RadDateTimePicker Width="150"
                                                           Margin="5,0,15,0"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data"
                                                           DisplayFormat="Short"
                                                           InputMode="DatePicker"
                                                           SelectedValue="{Binding Data.eselae}" />
                            </StackPanel>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Libro sospensione" />
                            <telerik:RadDateTimePicker Grid.Row="4"
                                                       Grid.Column="1"
                                                       Width="150"
                                                       Margin="5,0,15,0"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       DateSelectionMode="Day"
                                                       DateTimeWatermarkContent="Scegliere la data"
                                                       DisplayFormat="Short"
                                                       InputMode="DatePicker"
                                                       SelectedValue="{Binding Data.eselso}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Inserito il" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultimo aggiornamento il" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Annullato il" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Motivo annullamento" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Margin="5,2,2,2"
                                       Style="{StaticResource VulpesXData}"
                                       Text="{Binding Data.canceledNote}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
