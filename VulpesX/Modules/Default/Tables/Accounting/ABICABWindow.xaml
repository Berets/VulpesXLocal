<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Tables.Accounting.ABICABWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:culture="clr-namespace:System.Globalization;assembly=mscorlib"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Accounting"
                        xmlns:maskedInput="clr-namespace:Telerik.Windows.Controls.MaskedInput;assembly=Telerik.Windows.Controls.Input"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli ABI/CAB"
                        Width="700"
                        Height="500"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        ResizeMode="CanResize"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="None"
                        mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,15,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="7*" />
                </Grid.ColumnDefinitions>


                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="ABI/CAB" />
                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Visibility="{Binding IsUpdateVisibility, Converter={StaticResource boolToVisibilityConverter}}">
                    <TextBlock Margin="5,2,2,2" Style="{DynamicResource VulpesXData}" Text="{Binding Data.abiabi}" />
                    <TextBlock Margin="5,2,2,2" Style="{DynamicResource VulpesXData}" Text="/" />
                    <TextBlock Margin="5,2,2,2" Style="{DynamicResource VulpesXData}" Text="{Binding Data.abicab}" />
                </StackPanel>
                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Visibility="{Binding IsInsertVisibility, Converter={StaticResource boolToVisibilityConverter}}">
                    <telerik:RadNumericUpDown Width="150"
                                              Margin="5,2,2,2"
                                              HorizontalAlignment="Left"
                                              Maximum="99999"
                                              Minimum="1"
                                              NumberDecimalDigits="0"
                                              Value="{Binding Data.abiabi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <telerik:RadNumericUpDown.NumberFormatInfo>
                            <culture:NumberFormatInfo NumberGroupSeparator="" />
                        </telerik:RadNumericUpDown.NumberFormatInfo>
                    </telerik:RadNumericUpDown>
                    <telerik:RadNumericUpDown Width="150"
                                              Margin="5,2,2,2"
                                              HorizontalAlignment="Left"
                                              Maximum="99999"
                                              Minimum="1"
                                              NumberDecimalDigits="0"
                                              Value="{Binding Data.abicab, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <telerik:RadNumericUpDown.NumberFormatInfo>
                            <culture:NumberFormatInfo NumberGroupSeparator="" />
                        </telerik:RadNumericUpDown.NumberFormatInfo>
                    </telerik:RadNumericUpDown>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Istituto" />
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         MaxLength="80"
                         Text="{Binding Data.abiban, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Agenzia" />
                <TextBox Grid.Row="3"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         MaxLength="50"
                         Text="{Binding Data.abiage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Città" />
                <telerik:RadAutoCompleteBox x:Name="acCity"
                                            Grid.Row="4"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            ItemsSource="{Binding Cities}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun comune trovato"
                                            SelectedItem="{Binding SelectedCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionChanged="acCity_SelectionChanged"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Indirizzo" />
                <TextBox Grid.Row="5"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         MaxLength="50"
                         Text="{Binding Data.abiind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Provincia" />
                <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                    <telerik:RadAutoCompleteBox x:Name="acState"
                                                Width="200"
                                                Margin="5,2,15,2"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Center"
                                                DisplayMemberPath="FullDescriptionSearchable"
                                                ItemsSource="{Binding States}"
                                                LostFocus="ac_LostFocus"
                                                NoResultsContent="Nessuna provincia trovata"
                                                SelectedItem="{Binding SelectedState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SelectionChanged="acState_SelectionChanged"
                                                SelectionMode="Single"
                                                TextSearchMode="Contains"
                                                TextSearchPath="FullDescriptionSearchable"
                                                WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                    <TextBlock Width="75"
                               Style="{StaticResource VulpesXLabel}"
                               Text="C.a.p."
                               TextAlignment="Right" />
                    <telerik:RadMaskedNumericInput Width="150"
                                                   Margin="5,2,15,2"
                                                   HorizontalAlignment="Left"
                                                   maskedInput:MaskedInputExtensions.AllowNull="True"
                                                   maskedInput:MaskedInputExtensions.MaxTextLength="5"
                                                   maskedInput:MaskedInputExtensions.Maximum="99999"
                                                   AllowSkipPlaceholders="True"
                                                   AutoFillNumberGroupSeparators="False"
                                                   AutoFillZeros="False"
                                                   FormatString="00000"
                                                   InputBehavior="Insert"
                                                   Mask="#####"
                                                   SelectionOnFocus="SelectAll"
                                                   SpinMode="Position"
                                                   TextMode="MaskedText"
                                                   Value="{Binding Data.abicap, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>

</sc:FluentDefaultWindow>
