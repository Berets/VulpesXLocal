<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Tables.Accounting.PAGCLIWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:converters="clr-namespace:VulpesX.Shared.Controls.Converters;assembly=VulpesX.Shared.Controls"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli incasso clienti"
                        Width="800"
                        Height="700"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">
    <sc:FluentDefaultWindow.Resources>
        <converters:StringToBoolConverter x:Key="StringToBoolConverter" />
    </sc:FluentDefaultWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Left" Orientation="Horizontal">
            <TextBlock Margin="10,0,0,0" Style="{StaticResource VulpesXLabel}" Text="Codice" />
            <TextBox x:Name="txtID"
                     Width="100"
                     Margin="5,0,15,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Center"
                     IsEnabled="{Binding IsInsert}"
                     MaxLength="3"
                     Text="{Binding Data.pclcod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
        <StackPanel Grid.Row="0" HorizontalAlignment="Right" Orientation="Horizontal">
            <TextBlock Style="{StaticResource VulpesXLabel}" Text="Escluso da gestione IVA per cassa" />
            <telerik:RadToggleSwitchButton Margin="5,0,0,0"
                                           CheckedContent="Sì"
                                           Content="{Binding Data.pcivacas}"
                                           IsChecked="{Binding Data.pcivacasBool}"
                                           UncheckedContent="No" />
        </StackPanel>

        <telerik:RadTabControl Grid.Row="1"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="GENERALI" Header="GENERALI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Descrizione" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="50"
                                     Text="{Binding Data.pcldes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Tipo pagamento" />
                            <telerik:RadAutoCompleteBox x:Name="acPaymentTpe"
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding PaymentTypes}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding SelectedPaymentType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acPaymentTpe_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="1a scadenza" />
                            <telerik:RadNumericUpDown Grid.Row="2"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      Minimum="0"
                                                      NumberDecimalDigits="0"
                                                      Value="{Binding Data.pclgs1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="2a scadenza" />
                            <telerik:RadNumericUpDown Grid.Row="3"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      Minimum="0"
                                                      NumberDecimalDigits="0"
                                                      Value="{Binding Data.pclgs2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="3a scadenza" />
                            <telerik:RadNumericUpDown Grid.Row="4"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      Minimum="0"
                                                      NumberDecimalDigits="0"
                                                      Value="{Binding Data.pclgs3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="4a scadenza" />
                            <telerik:RadNumericUpDown Grid.Row="5"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      Minimum="0"
                                                      NumberDecimalDigits="0"
                                                      Value="{Binding Data.pclgs4, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="5a scadenza" />
                            <telerik:RadNumericUpDown Grid.Row="6"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      Minimum="0"
                                                      NumberDecimalDigits="0"
                                                      Value="{Binding Data.pclgs5, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="6a scadenza" />
                            <telerik:RadNumericUpDown Grid.Row="7"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      Minimum="0"
                                                      NumberDecimalDigits="0"
                                                      Value="{Binding Data.pclgs6, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="7a scadenza" />
                            <telerik:RadNumericUpDown Grid.Row="8"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      Minimum="0"
                                                      NumberDecimalDigits="0"
                                                      Value="{Binding Data.pclgs7, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="9"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="8a scadenza" />
                            <telerik:RadNumericUpDown Grid.Row="9"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      Minimum="0"
                                                      NumberDecimalDigits="0"
                                                      Value="{Binding Data.pclgs8, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="10"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="9a scadenza" />
                            <telerik:RadNumericUpDown Grid.Row="10"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      Minimum="0"
                                                      NumberDecimalDigits="0"
                                                      Value="{Binding Data.pclgs9, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="11"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Scadenza fissa" />
                            <telerik:RadNumericUpDown Grid.Row="11"
                                                      Grid.Column="1"
                                                      Width="200"
                                                      Margin="5,2,2,2"
                                                      HorizontalAlignment="Left"
                                                      Minimum="0"
                                                      NumberDecimalDigits="0"
                                                      Value="{Binding Data.pclmed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="12"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Partenza pagamento" />
                            <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadComboBox Width="200"
                                                     Margin="5,2,15,2"
                                                     HorizontalAlignment="Left"
                                                     HorizontalContentAlignment="Left"
                                                     DisplayMemberPath="Description"
                                                     IsEditable="True"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding Data.StartingTypes}"
                                                     SelectedValue="{Binding Data.pclppa, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     SelectedValuePath="ID" />
                                <telerik:RadNumericUpDown Width="120"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          Minimum="0"
                                                          NumberDecimalDigits="0"
                                                          Value="{Binding Data.pclgio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="10,0,0,0" Style="{StaticResource VulpesXLabel}" Text="giorni" />
                            </StackPanel>
                            <TextBlock Grid.Row="13"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Sconto (%)" />
                            <StackPanel Grid.Row="13" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadNumericUpDown Width="150"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          Minimum="0"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.pclsco, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock MinWidth="150"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Maggiorazione (%)"
                                           TextAlignment="Right" />
                                <telerik:RadNumericUpDown Width="150"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          Minimum="0"
                                                          NumberDecimalDigits="2"
                                                          Value="{Binding Data.pclmag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Grid.Row="14"
                                       Grid.Column="0"
                                       MinWidth="150"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Vecchio codice"
                                       TextAlignment="Right" />
                            <TextBox Grid.Row="14"
                                     Grid.Column="1"
                                     Width="150"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     MaxLength="50"
                                     Text="{Binding Data.pclold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="LINGUA" Header="LINGUA" IsEnabled="{Binding Text, ElementName=txtID, Converter={StaticResource StringToBoolConverter}}">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Lingua" />
                            <telerik:RadComboBox Name="cmbLingua"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Margin="5,0,15,0"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Center"
                                                 DisplayMemberPath="lindes"
                                                 ItemsSource="{Binding Lingue}"
                                                 SelectedItem="{Binding SelectedLingua}"
                                                 SelectionChanged="cmbLingua_SelectionChanged"
                                                 TextSearch.TextPath="lindes" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Descrizione" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="5,5,15,5"
                                     MaxLength="255"
                                     Text="{Binding SelectedTraduzione.pcldes, Mode=TwoWay, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>

            <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Inserito il" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultimo aggiornamento il" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Annullato il" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Motivo annullamento" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Margin="5,2,2,2"
                                       Style="{StaticResource VulpesXData}"
                                       Text="{Binding Data.canceledNote}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>

        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
