<UserControl x:Class="VulpesX.Modules.Default.Tables.Accounting.ABICABView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Accounting"
             xmlns:maskedInput="clr-namespace:Telerik.Windows.Controls.MaskedInput;assembly=Telerik.Windows.Controls.Input"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Margin="5"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Center"
                       FontSize="20"
                       Foreground="{DynamicResource VulpesXBrush}"
                       Text="TABELLA ABI/CAB" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Margin="5,0,0,0" Orientation="Horizontal">
            <TextBlock Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="ABI"
                       TextAlignment="Right" />
            <telerik:RadMaskedNumericInput x:Name="rmniABI"
                                           Width="100"
                                           Margin="6"
                                           HorizontalAlignment="Left"
                                           maskedInput:MaskedInputExtensions.AllowNull="True"
                                           maskedInput:MaskedInputExtensions.MaxTextLength="5"
                                           maskedInput:MaskedInputExtensions.Maximum="99999"
                                           AllowSkipPlaceholders="True"
                                           AutoFillNumberGroupSeparators="False"
                                           AutoFillZeros="False"
                                           FormatString="00000"
                                           InputBehavior="Insert"
                                           Mask="#####"
                                           SelectionOnFocus="SelectAll"
                                           SpinMode="Position"
                                           TextMode="MaskedText"
                                           ValueChanged="rmniABI_ValueChanged"
                                           Value="{Binding AbiFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="CAB"
                       TextAlignment="Right" />
            <telerik:RadMaskedNumericInput x:Name="rmniCAB"
                                           Width="100"
                                           Margin="6"
                                           HorizontalAlignment="Left"
                                           maskedInput:MaskedInputExtensions.AllowNull="True"
                                           maskedInput:MaskedInputExtensions.MaxTextLength="5"
                                           maskedInput:MaskedInputExtensions.Maximum="99999"
                                           AllowSkipPlaceholders="True"
                                           AutoFillNumberGroupSeparators="False"
                                           AutoFillZeros="False"
                                           FormatString="00000"
                                           InputBehavior="Insert"
                                           Mask="#####"
                                           SelectionOnFocus="SelectAll"
                                           SpinMode="Position"
                                           TextMode="MaskedText"
                                           ValueChanged="rmniCAB_ValueChanged"
                                           Value="{Binding CabFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Column="0"
                       Style="{StaticResource VulpesXLabel}"
                       Text="Nome banca"
                       TextAlignment="Right" />
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Width="400"
                                         Margin="5,5,0,5"
                                         LostFocus="txtSearch_LostFocus"
                                         Text="{Binding TextFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         WatermarkContent="Cerca banca/filiale..." />
        </StackPanel>

        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Items}"
                                     RowIndicatorVisibility="Hidden"
                                     ShowGroupPanel="True">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewColumn Width="110">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadButton x:Name="cmdDelete"
                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                       Click="cmdDelete_Click"
                                                       Content="Elimina"
                                                       Style="{StaticResource VulpesXButton}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewDataColumn Width="80"
                                                    DataMemberBinding="{Binding abiabi}"
                                                    Header="ABI"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="80"
                                                    DataMemberBinding="{Binding abicab}"
                                                    Header="CAB"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="350" DataMemberBinding="{Binding abiban}" Header="Istituto" />
                        <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding abiage}" Header="Agenzia">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Left"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEdit_Click"
                                            Content="{Binding Path=abiage}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding abicit}" Header="Città" />
                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding abiind}" Header="Indirizzo" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataMemberBinding="{Binding abipro}"
                                                    Header="Provincia"
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="100"
                                                    DataFormatString="D5"
                                                    DataMemberBinding="{Binding abicap}"
                                                    Header="C.a.p." />

                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      ItemCount="{Binding TotalCount}"
                                      PageIndexChanged="rdpGrid_PageIndexChanged"
                                      PageSize="{Binding PageSize}"
                                      PageIndex="{Binding PageRequested, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>

</UserControl>
