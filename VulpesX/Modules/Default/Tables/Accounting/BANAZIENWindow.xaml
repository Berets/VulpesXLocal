<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Tables.Accounting.BANAZIENWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli banca aziendale"
                        Width="1000"
                        Height="700"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="DATI BANCA" Header="DATI BANCA">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="8*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Attiva"
                                       TextAlignment="Right" />
                            <telerik:RadToggleSwitchButton Grid.Row="0"
                                                           Grid.Column="1"
                                                           Margin="5,0,0,0"
                                                           CheckedContent="Sì"
                                                           Content="{Binding Data.abiatt}"
                                                           IsChecked="{Binding Data.abiatt}"
                                                           UncheckedContent="No" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="ABI/CAB" />
                            <telerik:RadAutoCompleteBox x:Name="acACs"
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        IsEnabled="{Binding IsInsert}"
                                                        ItemsSource="{Binding ABICABs}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessuna banca trovata"
                                                        SelectedItem="{Binding SelectedABICAB, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acACs_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="C/C nr." />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="150"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         MaxLength="15"
                                         Text="{Binding Data.abicon}" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="CIN" />
                                <TextBox Width="50"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         MaxLength="1"
                                         Text="{Binding Data.abicin}" />
                            </StackPanel>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Codice ISO" />
                            <telerik:RadAutoCompleteBox x:Name="acISO"
                                                        Grid.Row="3"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding ISOs}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun codice trovato"
                                                        SelectedItem="{Binding SelectedISO, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acISO_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="BBAN" />
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="200"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         MaxLength="23"
                                         Text="{Binding Data.abibba}" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="IBAN" />
                                <TextBox Width="200"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         MaxLength="34"
                                         Text="{Binding Data.abibiba}" />
                            </StackPanel>

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="BIC" />
                            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="130"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         MaxLength="11"
                                         Text="{Binding Data.abibic}" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="SIA" />
                                <TextBox Width="80"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         MaxLength="5"
                                         Text="{Binding Data.abisia}" />
                                <TextBlock Style="{StaticResource VulpesXLabel}" Text="CUC (SEPA)" />
                                <TextBox Width="100"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Center"
                                         MaxLength="8"
                                         Text="{Binding Data.abicuc}" />
                            </StackPanel>

                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Conto banca" />
                            <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadAutoCompleteBox x:Name="acGroupBank"
                                                            Width="200"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.GroupsList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun gruppo trovato"
                                                            SelectedItem="{Binding Data.SelectedGroupBank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                <telerik:RadAutoCompleteBox x:Name="acAccountBank"
                                                            Width="270"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.AccountsBankList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun conto trovato"
                                                            SelectedItem="{Binding Data.SelectedAccountBank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                <telerik:RadAutoCompleteBox x:Name="acSubaccountBank"
                                                            Width="270"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.SubaccountsBankList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun sottoconto trovato"
                                                            SelectedItem="{Binding Data.SelectedSubaccountBank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            </StackPanel>
                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Conto portafoglio/anticipi" />
                            <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadAutoCompleteBox x:Name="acGroupAnticipation"
                                                            Width="200"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.GroupsList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun gruppo trovato"
                                                            SelectedItem="{Binding Data.SelectedGroupAnticipation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                <telerik:RadAutoCompleteBox x:Name="acAccountAnticipation"
                                                            Width="270"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.AccountsAnticipationList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun conto trovato"
                                                            SelectedItem="{Binding Data.SelectedAccountAnticipation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                <telerik:RadAutoCompleteBox x:Name="acSubaccountAnticipation"
                                                            Width="270"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.SubaccountsAnticipationList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun sottoconto trovato"
                                                            SelectedItem="{Binding Data.SelectedSubaccountAnticipation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            </StackPanel>
                            <TextBlock Grid.Row="9"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Conto spese bancarie" />
                            <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadAutoCompleteBox x:Name="acGroupCosts"
                                                            Width="200"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.GroupsList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun gruppo trovato"
                                                            SelectedItem="{Binding Data.SelectedGroupCosts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                <telerik:RadAutoCompleteBox x:Name="acAccountCosts"
                                                            Width="270"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.AccountsCostsList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun conto trovato"
                                                            SelectedItem="{Binding Data.SelectedAccountCosts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                <telerik:RadAutoCompleteBox x:Name="acSubaccountCosts"
                                                            Width="270"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.SubaccountsCostsList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun sottoconto trovato"
                                                            SelectedItem="{Binding Data.SelectedSubaccountCosts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            </StackPanel>

                            <TextBlock Grid.Row="11"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Fido anticipazioni" />
                            <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadNumericUpDown Width="170"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          NumberDecimalDigits="2"
                                                          ShowButtons="False"
                                                          Value="{Binding Data.abifidant, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock MinWidth="120"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Fido portafoglio"
                                           TextAlignment="Right" />
                                <telerik:RadNumericUpDown Width="170"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          NumberDecimalDigits="2"
                                                          ShowButtons="False"
                                                          Value="{Binding Data.abivalport, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <TextBlock Grid.Row="12"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Fido di cassa" />
                            <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadNumericUpDown Width="170"
                                                          Margin="5,2,2,2"
                                                          HorizontalAlignment="Left"
                                                          NumberDecimalDigits="2"
                                                          ShowButtons="False"
                                                          Value="{Binding Data.abifidcas, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock MinWidth="120"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Sigla banca"
                                           TextAlignment="Right" />
                                <TextBox Grid.Row="14"
                                         Grid.Column="1"
                                         Width="100"
                                         Margin="5,0,15,0"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         MaxLength="3"
                                         Text="{Binding Data.abisigla}" />
                            </StackPanel>

                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="DATI GIROCONTI" Header="DATI GIROCONTI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="15" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="8*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Conto portafoglio" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadAutoCompleteBox x:Name="acGroupWallet"
                                                            Width="200"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.GroupsList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun gruppo trovato"
                                                            SelectedItem="{Binding Data.SelectedGroupWallet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                <telerik:RadAutoCompleteBox x:Name="acAccountWallet"
                                                            Width="270"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.AccountsWalletList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun conto trovato"
                                                            SelectedItem="{Binding Data.SelectedAccountWallet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                <telerik:RadAutoCompleteBox x:Name="acSubaccountWallet"
                                                            Width="270"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.SubaccountsWalletList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun sottoconto trovato"
                                                            SelectedItem="{Binding Data.SelectedSubaccountWallet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            </StackPanel>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Conto banca c/effetti" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadAutoCompleteBox x:Name="acGroupEffects"
                                                            Width="200"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.GroupsList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun gruppo trovato"
                                                            SelectedItem="{Binding Data.SelectedGroupEffects, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                <telerik:RadAutoCompleteBox x:Name="acAccountEffects"
                                                            Width="270"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.AccountsEffectsList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun conto trovato"
                                                            SelectedItem="{Binding Data.SelectedAccountEffects, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                <telerik:RadAutoCompleteBox x:Name="acSubaccountEffects"
                                                            Width="270"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.SubaccountsEffectsList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun sottoconto trovato"
                                                            SelectedItem="{Binding Data.SelectedSubaccountEffects, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Causale da conto effetti"
                                       TextAlignment="Right" />
                            <telerik:RadAutoCompleteBox x:Name="acFromEffectsCausal"
                                                        Grid.Row="2"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Causals}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessuna causale trovata"
                                                        SelectedItem="{Binding SelectedFromEffectsCausal, Mode=TwoWay}"
                                                        SelectionChanged="acFromEffectsCausal_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Causale a conto effetti"
                                       TextAlignment="Right" />
                            <telerik:RadAutoCompleteBox x:Name="acToEffectsCausal"
                                                        Grid.Row="3"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Causals}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessuna causale trovata"
                                                        SelectedItem="{Binding SelectedToEffectsCausal, Mode=TwoWay}"
                                                        SelectionChanged="acToEffectsCausal_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Conto anticipazioni" />
                            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadAutoCompleteBox x:Name="acGroupBankAnticipation"
                                                            Width="200"
                                                            Margin="5,2,5,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding Data.GroupsList}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun gruppo trovato"
                                                            SelectedItem="{Binding Data.SelectedGroupBankAnticipation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
