<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Tables.Accounting.CAUCONTWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli causale contabile"
                        Width="900"
                        Height="700"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="DATI COMUNI" Header="DATI COMUNI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Codice" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     IsEnabled="{Binding IsInsert}"
                                     MaxLength="2"
                                     Text="{Binding Data.caucod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Descrizione" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     MaxLength="255"
                                     Text="{Binding Data.caudes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Generale" />
                            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadToggleSwitchButton Margin="5,0,0,0"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Data.caugen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               IsChecked="{Binding Data.caugenBool}"
                                                               UncheckedContent="No" />
                                <TextBlock MinWidth="120"
                                           Margin="50,0,5,0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="IVA"
                                           TextAlignment="Right" />
                                <telerik:RadToggleSwitchButton Margin="5,0,0,0"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Data.cauiva, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               IsChecked="{Binding Data.cauivaBool}"
                                                               UncheckedContent="No" />
                            </StackPanel>

                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Clienti" />
                            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadToggleSwitchButton Margin="5,0,0,0"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Data.caucli, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               IsChecked="{Binding Data.caucliBool}"
                                                               UncheckedContent="No" />
                                <TextBlock MinWidth="120"
                                           Margin="50,0,5,0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Fornitori"
                                           TextAlignment="Right" />
                                <telerik:RadToggleSwitchButton Margin="5,0,0,0"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Data.caufor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               IsChecked="{Binding Data.cauforBool}"
                                                               UncheckedContent="No" />
                            </StackPanel>

                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Solo IVA" />
                            <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadToggleSwitchButton Margin="5,0,0,0"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Data.causol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               IsChecked="{Binding Data.causolBool}"
                                                               UncheckedContent="No" />
                                <TextBlock MinWidth="120"
                                           Margin="50,0,5,0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Fatture a 0"
                                           TextAlignment="Right" />
                                <telerik:RadToggleSwitchButton Margin="5,0,0,0"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Data.cauzer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               IsChecked="{Binding Data.cauzer}"
                                                               UncheckedContent="No" />
                            </StackPanel>

                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Check" />
                            <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadToggleSwitchButton Margin="5,0,0,0"
                                                               CheckedContent="Sì"
                                                               Content="{Binding Data.cauceco, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               IsChecked="{Binding Data.caucecoBool}"
                                                               UncheckedContent="No" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="DATI CONTABILI" Header="DATI CONTABILI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Aliquota" />
                            <telerik:RadAutoCompleteBox x:Name="acRate"
                                                        Grid.Row="0"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding Rates}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessuna aliquota trovata"
                                                        SelectedItem="{Binding SelectedRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acRate_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Libro IVA" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <telerik:RadAutoCompleteBox x:Name="acIVABook"
                                                            Width="250"
                                                            Margin="5,2,15,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            ItemsSource="{Binding IVABooks}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun libro IVA trovato"
                                                            SelectedItem="{Binding SelectedIVABook, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionChanged="acIVABook_SelectionChanged"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                                <TextBlock Margin="5,0,5,0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Segno"
                                           TextAlignment="Right" />
                                <telerik:RadComboBox Width="100"
                                                     Margin="5,2,15,2"
                                                     HorizontalAlignment="Left"
                                                     HorizontalContentAlignment="Left"
                                                     DisplayMemberPath="Description"
                                                     IsEditable="True"
                                                     IsReadOnly="True"
                                                     ItemsSource="{Binding IVASigns}"
                                                     SelectedValue="{Binding Data.causeg}"
                                                     SelectedValuePath="ID" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Margin="0,0,15,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="Centro di costo" />
                            <telerik:RadAutoCompleteBox x:Name="acCostCenter"
                                                        Grid.Row="2"
                                                        Grid.Column="1"
                                                        Margin="5,2,15,2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        DisplayMemberPath="FullDescriptionSearchable"
                                                        GotFocus="ac_GotFocus"
                                                        ItemsSource="{Binding CostCenters}"
                                                        LostFocus="ac_LostFocus"
                                                        NoResultsContent="Nessun centro di costo trovato"
                                                        SelectedItem="{Binding SelectedCostCenter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        SelectionChanged="acCostCenter_SelectionChanged"
                                                        SelectionMode="Single"
                                                        TextSearchMode="Contains"
                                                        TextSearchPath="FullDescriptionSearchable"
                                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="CONTROPARTITE" Header="CONTROPARTITE">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="35" />
                            </Grid.RowDefinitions>

                            <telerik:RadGridView Name="rgvCounterpartsRows"
                                                 Grid.Row="0"
                                                 Margin="0"
                                                 AddingNewDataItem="rgvCounterpartsRows_AddingNewDataItem"
                                                 AutoGenerateColumns="False"
                                                 CanUserFreezeColumns="False"
                                                 CanUserInsertRows="True"
                                                 IsSearchingDeferred="True"
                                                 ItemsSource="{Binding CounterpartsRows}"
                                                 NewRowPosition="Top"
                                                 RowDetailsVisibilityMode="VisibleWhenSelected"
                                                 RowEditEnded="rgvCounterpartsRows_RowEditEnded"
                                                 RowIndicatorVisibility="Collapsed"
                                                 RowValidated="rgvCounterpartsRows_RowValidated"
                                                 RowValidating="rgvCounterpartsRows_RowValidating"
                                                 SearchMode="MatchAnyTerm"
                                                 ShowGroupPanel="False"
                                                 ShowSearchPanel="False"
                                                 ValidatesOnDataErrors="InEditMode">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding GroupDescription}" Header="Gruppo">
                                        <telerik:GridViewDataColumn.CellEditTemplate>
                                            <DataTemplate>
                                                <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                            GotFocus="ac_GotFocus"
                                                                            ItemsSource="{Binding GroupsList}"
                                                                            LostFocus="ac_LostFocus"
                                                                            NoResultsContent="Nessun gruppo trovato"
                                                                            SelectedItem="{Binding SelectedGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                            SelectionMode="Single"
                                                                            TextSearchMode="Contains"
                                                                            TextSearchPath="FullDescriptionSearchable" />
                                            </DataTemplate>
                                        </telerik:GridViewDataColumn.CellEditTemplate>
                                    </telerik:GridViewDataColumn>
                                    <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding AccountDescription}" Header="Conto">
                                        <telerik:GridViewDataColumn.CellEditTemplate>
                                            <DataTemplate>
                                                <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                            GotFocus="ac_GotFocus"
                                                                            ItemsSource="{Binding AccountsList}"
                                                                            LostFocus="ac_LostFocus"
                                                                            NoResultsContent="Nessun conto trovato"
                                                                            SelectedItem="{Binding SelectedAccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                            SelectionMode="Single"
                                                                            TextSearchMode="Contains"
                                                                            TextSearchPath="FullDescriptionSearchable" />
                                            </DataTemplate>
                                        </telerik:GridViewDataColumn.CellEditTemplate>
                                    </telerik:GridViewDataColumn>
                                    <telerik:GridViewDataColumn Width="320" DataMemberBinding="{Binding SubaccountDescription}" Header="Sottoconto">
                                        <telerik:GridViewDataColumn.CellEditTemplate>
                                            <DataTemplate>
                                                <telerik:RadAutoCompleteBox DisplayMemberPath="FullDescriptionSearchable"
                                                                            GotFocus="ac_GotFocus"
                                                                            ItemsSource="{Binding SubaccountsList}"
                                                                            LostFocus="ac_LostFocus"
                                                                            NoResultsContent="Nessun sottoconto trovato"
                                                                            SelectedItem="{Binding SelectedSubaccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                            SelectionMode="Single"
                                                                            TextSearchMode="Contains"
                                                                            TextSearchPath="FullDescriptionSearchable" />
                                            </DataTemplate>
                                        </telerik:GridViewDataColumn.CellEditTemplate>
                                    </telerik:GridViewDataColumn>
                                    <telerik:GridViewComboBoxColumn Width="70"
                                                                    DataMemberBinding="{Binding grpseg}"
                                                                    DisplayMemberPath="Description"
                                                                    Header="Segno"
                                                                    IsLightweightModeEnabled="True"
                                                                    ItemsSource="{Binding Signs}"
                                                                    SelectedValueMemberPath="ID" />
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Inserito il" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultimo aggiornamento il" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Annullato il" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Motivo annullamento" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Margin="5,2,2,2"
                                       Style="{StaticResource VulpesXData}"
                                       Text="{Binding Data.canceledNote}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
