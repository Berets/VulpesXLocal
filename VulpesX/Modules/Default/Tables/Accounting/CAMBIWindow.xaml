<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Tables.Accounting.CAMBIWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli sul cambio"
                        Width="600"
                        Height="500"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="7*" />
                </Grid.ColumnDefinitions>


                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="UIC" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Width="100"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsInsert}"
                         MaxLength="3"
                         Text="{Binding Data.CAMLIS}" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="SWIFT" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Width="100"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsInsert}"
                         MaxLength="3"
                         Text="{Binding Data.CAMSWI}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Data ed ora cambio" />
                <telerik:RadDateTimePicker Grid.Row="2"
                                           Grid.Column="1"
                                           Width="200"
                                           Margin="5,0,15,0"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent="Scegliere la data e l'ora del cambio"
                                           DisplayFormat="Short"
                                           InputMode="DateTimePicker"
                                           SelectedValue="{Binding Data.CAMDAT}"
                                           TodayButtonVisibility="Visible" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Divisa" />
                <TextBox Grid.Row="3"
                         Grid.Column="1"
                         Width="120"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         MaxLength="4"
                         Text="{Binding Data.CAMDIV}" />

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Scadenza" />
                <telerik:RadDateTimePicker Grid.Row="4"
                                           Grid.Column="1"
                                           Width="200"
                                           Margin="5,0,15,0"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent="Scegliere la data "
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           SelectedValue="{Binding Data.CAMSCA}" />

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Cambio acquisto" />
                <telerik:RadNumericUpDown Grid.Row="5"
                                          Grid.Column="1"
                                          Width="200"
                                          Margin="5,2,2,2"
                                          HorizontalAlignment="Left"
                                          NumberDecimalDigits="6"
                                          Value="{Binding Data.CAMACQ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Cambio vendita" />
                <telerik:RadNumericUpDown Grid.Row="6"
                                          Grid.Column="1"
                                          Width="200"
                                          Margin="5,2,2,2"
                                          HorizontalAlignment="Left"
                                          NumberDecimalDigits="6"
                                          Value="{Binding Data.CAMVEN, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="7"
                           Grid.Column="0"
                           VerticalAlignment="Top"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Note" />
                <TextBox Grid.Row="7"
                         Grid.Column="1"
                         Height="100"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Top"
                         VerticalContentAlignment="Top"
                         AcceptsReturn="True"
                         MaxLength="255"
                         MaxLines="3"
                         MinLines="3"
                         Text="{Binding Data.CAMDES}"
                         TextWrapping="Wrap" />
            </Grid>
        </ScrollViewer>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
