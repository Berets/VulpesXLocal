<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Tables.Accounting.ISOWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli codice ISO"
                        Width="800"
                        Height="500"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">

            <Grid Margin="0,15,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3.5*" />
                    <ColumnDefinition Width="6.5*" />
                </Grid.ColumnDefinitions>


                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Codice" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Width="100"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         MaxLength="3"
                         Text="{Binding Data.isocod}" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Descrizione" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         MaxLength="255"
                         Text="{Binding Data.isodes}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Lunghezza partita IVA" />
                <telerik:RadNumericUpDown Grid.Row="2"
                                          Grid.Column="1"
                                          Width="100"
                                          Margin="5,2,2,2"
                                          HorizontalAlignment="Left"
                                          Maximum="99"
                                          Minimum="1"
                                          NumberDecimalDigits="0"
                                          Value="{Binding Data.isopiv, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Lingua" />
                <telerik:RadAutoCompleteBox x:Name="acLanguage"
                                            Grid.Row="3"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            ItemsSource="{Binding Languages}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun codice lingua trovato"
                                            SelectedItem="{Binding SelectedLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionChanged="acLanguage_SelectionChanged"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Naz. sogg. a trasferimento INTRA" />
                <telerik:RadToggleSwitchButton Grid.Row="4"
                                               Grid.Column="1"
                                               Margin="5,0,0,0"
                                               CheckedContent="Sì"
                                               Content="{Binding Data.isointr}"
                                               IsChecked="{Binding Data.isointrBool}"
                                               UncheckedContent="No" />

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Codice ISO 3166-1 alpha-2" />
                <TextBox Grid.Row="5"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         MaxLength="2"
                         Text="{Binding Data.isocod3166}" />

            </Grid>
        </ScrollViewer>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
