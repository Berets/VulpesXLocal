<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Tables.Accounting.VALUTEWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli categoria cliente"
                        Width="600"
                        Height="500"
                        Background="{DynamicResource VulpesXFirstBrush}"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,15,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="7*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Codice" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Width="100"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsInsert}"
                         MaxLength="3"
                         Text="{Binding Data.VALCOD, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />


                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Sigla" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Width="100"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsInsert}"
                         MaxLength="3"
                         Text="{Binding Data.VALDIV, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Descrizione" />
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         MaxLength="35"
                         Text="{Binding Data.VALDES, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Tipo" />
                <telerik:RadComboBox Grid.Row="3"
                                     Grid.Column="1"
                                     Width="200"
                                     Margin="5,2,15,2"
                                     HorizontalAlignment="Left"
                                     HorizontalContentAlignment="Left"
                                     DisplayMemberPath="Description"
                                     IsEditable="True"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Data.Types}"
                                     SelectedValue="{Binding Data.VALTIP, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SelectedValuePath="ID" />

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Valore cambio" />
                <telerik:RadNumericUpDown Grid.Row="4"
                                          Grid.Column="1"
                                          Margin="5,0,0,0"
                                          Minimum="0"
                                          NumberDecimalDigits="4"
                                          Value="{Binding Data.VALCAM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </ScrollViewer>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>