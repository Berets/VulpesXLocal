<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Tables.Accounting.FE_TIPODOCWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Accounting"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli tipo documento fatturazione elettronica"
                        Width="700"
                        Height="500"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,15,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />

                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="7*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Codice" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Width="100"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         IsEnabled="{Binding IsInsert}"
                         MaxLength="4"
                         Text="{Binding Data.FETDCod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Descrizione" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="5,0,15,0"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         MaxLength="150"
                         Text="{Binding Data.FETDDes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Causale contabile" />
                <telerik:RadAutoCompleteBox x:Name="acCausal"
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            Margin="5,2,15,2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            DisplayMemberPath="FullDescriptionSearchable"
                                            ItemsSource="{Binding Causals}"
                                            LostFocus="ac_LostFocus"
                                            NoResultsContent="Nessun codice trovato"
                                            SelectedItem="{Binding SelectedCausal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            SelectionChanged="acCausal_SelectionChanged"
                                            SelectionMode="Single"
                                            TextSearchMode="Contains"
                                            TextSearchPath="FullDescriptionSearchable"
                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Style="{StaticResource VulpesXLabel}"
                           Text="Data annullamento" />
                <telerik:RadDateTimePicker Grid.Row="3"
                                           Grid.Column="1"
                                           Width="200"
                                           Margin="5,0,15,0"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           DateSelectionMode="Day"
                                           DateTimeWatermarkContent="Scegliere la data"
                                           DisplayFormat="Short"
                                           InputMode="DatePicker"
                                           SelectedValue="{Binding Data.FETDDat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />


            </Grid>
        </ScrollViewer>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
