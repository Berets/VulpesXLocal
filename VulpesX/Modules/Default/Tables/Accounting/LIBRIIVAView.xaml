<UserControl x:Class="VulpesX.Modules.Default.Tables.Accounting.LIBRIIVAView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Accounting"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="TABELLA LIBRI IVA" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Margin="5"
                                         TextChanged="txtSearch_TextChanged"
                                         WatermarkContent="Cerca..." />
        </Grid>

        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding PagedSource, ElementName=rdpGrid}"
                                     RowIndicatorVisibility="Hidden"
                                     ShowGroupPanel="True">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewColumn Width="110">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <telerik:RadButton x:Name="cmdDelete"
                                                       telerik:TouchManager.TouchMode="HitTestHidden"
                                                       BorderBrush="{DynamicResource VulpesXRedBrush}"
                                                       Click="cmdDelete_Click"
                                                       Content="Elimina"
                                                       Style="{StaticResource VulpesXButton}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewColumn>
                        <telerik:GridViewDataColumn Width="120" DataMemberBinding="{Binding livcod}" Header="Codice" />
                        <telerik:GridViewDataColumn Width="250" DataMemberBinding="{Binding livdes}" Header="Descrizione">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Left"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEdit_Click"
                                            Content="{Binding Path=livdes}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding BookTypeFullDescription}" Header="Tipo" />
                        <telerik:GridViewCheckBoxColumn Width="150" DataMemberBinding="{Binding livili}" Header="Includi liquidazione" />
                        <telerik:GridViewCheckBoxColumn Width="150" DataMemberBinding="{Binding livliq}" Header="Num. liquidazione" />
                        <telerik:GridViewDataColumn Width="160"
                                                    DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                    DataMemberBinding="{Binding livulst}"
                                                    Header="Ultima stampa def."
                                                    HeaderTextAlignment="Center"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding SelectedIVAGroup.FullDescriptionSearchable}" Header="Gruppo IVA" />
                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding SelectedIVAAccount.FullDescriptionSearchable}" Header="Conto IVA" />
                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding SelectedIVASubaccount.FullDescriptionSearchable}" Header="Sottoconto IVA" />
                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding SelectedErarioGroup.FullDescriptionSearchable}" Header="Gruppo erario" />
                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding SelectedErarioAccount.FullDescriptionSearchable}" Header="Conto erario" />
                        <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding SelectedErarioSubaccount.FullDescriptionSearchable}" Header="Sottoconto erario" />
                        <telerik:GridViewCheckBoxColumn Width="150" DataMemberBinding="{Binding livautBool}" Header="Prot. automatico" />
                        <telerik:GridViewDataColumn Width="120" DataMemberBinding="{Binding livsezio}" Header="Sezionale" />

                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageSize="20"
                                      Source="{Binding Items}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>
</UserControl>
