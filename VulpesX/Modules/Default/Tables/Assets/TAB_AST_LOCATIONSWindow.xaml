<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Tables.Assets.TAB_AST_LOCATIONSWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Tables.Assets"
                        xmlns:maskedInput="clr-namespace:Telerik.Windows.Controls.MaskedInput;assembly=Telerik.Windows.Controls.Input"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli ubicazione"
                        Width="600"
                        Height="500"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="DATI GENERALI" Header="DATI GENERALI">
                <telerik:RadTabItem.Content>
                    <Grid Margin="0,15,15,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35" />
                            <RowDefinition Height="35" />
                            <RowDefinition Height="35" />
                            <RowDefinition Height="35" />
                            <RowDefinition Height="35" />
                            <RowDefinition Height="35" />
                            <RowDefinition Height="35" />
                            <RowDefinition Height="35" />
                            <RowDefinition Height="35" />
                            <RowDefinition Height="35" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="7*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Style="{StaticResource VulpesXLabel}"
                                   Text="Codice" />
                        <TextBox Grid.Row="0"
                                 Grid.Column="1"
                                 Width="150"
                                 Margin="5,0,15,0"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"
                                 IsEnabled="{Binding IsInsert}"
                                 MaxLength="10"
                                 Text="{Binding Data.id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Style="{StaticResource VulpesXLabel}"
                                   Text="Descrizione" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Margin="5,0,15,0"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"
                                 MaxLength="255"
                                 Text="{Binding Data.description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="0"
                                   Style="{StaticResource VulpesXLabel}"
                                   Text="Indirizzo" />
                        <TextBox Grid.Row="3"
                                 Grid.Column="1"
                                 Margin="5,0,15,0"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"
                                 MaxLength="255"
                                 Text="{Binding Data.address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="4"
                                   Grid.Column="0"
                                   Style="{StaticResource VulpesXLabel}"
                                   Text="Città" />
                        <telerik:RadAutoCompleteBox x:Name="acCity"
                                                    Grid.Row="4"
                                                    Grid.Column="1"
                                                    Margin="5,2,15,2"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Center"
                                                    DisplayMemberPath="FullDescriptionSearchable"
                                                    GotFocus="ac_GotFocus"
                                                    ItemsSource="{Binding Data.Cities}"
                                                    LostFocus="ac_LostFocus"
                                                    NoResultsContent="Nessun codice trovato"
                                                    SelectedItem="{Binding Data.City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    SelectionMode="Single"
                                                    TextSearchMode="Contains"
                                                    TextSearchPath="FullDescriptionSearchable"
                                                    WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                        <TextBlock Grid.Row="5"
                                   Grid.Column="0"
                                   Style="{StaticResource VulpesXLabel}"
                                   Text="Provincia" />
                        <telerik:RadAutoCompleteBox x:Name="acState"
                                                    Grid.Row="5"
                                                    Grid.Column="1"
                                                    Margin="5,2,15,2"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Center"
                                                    DisplayMemberPath="FullDescriptionSearchable"
                                                    GotFocus="ac_GotFocus"
                                                    ItemsSource="{Binding Data.States}"
                                                    LostFocus="ac_LostFocus"
                                                    NoResultsContent="Nessun codice trovato"
                                                    SelectedItem="{Binding Data.State, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    SelectionMode="Single"
                                                    TextSearchMode="Contains"
                                                    TextSearchPath="FullDescriptionSearchable"
                                                    WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                        <TextBlock Grid.Row="6"
                                   Grid.Column="0"
                                   Style="{StaticResource VulpesXLabel}"
                                   Text="C.a.p." />
                        <telerik:RadMaskedNumericInput Grid.Row="6"
                                                       Grid.Column="1"
                                                       Width="100"
                                                       Margin="5,2,15,2"
                                                       HorizontalAlignment="Left"
                                                       maskedInput:MaskedInputExtensions.AllowNull="True"
                                                       maskedInput:MaskedInputExtensions.MaxTextLength="5"
                                                       maskedInput:MaskedInputExtensions.Maximum="99999"
                                                       AllowSkipPlaceholders="True"
                                                       AutoFillNumberGroupSeparators="False"
                                                       AutoFillZeros="False"
                                                       FormatString="00000"
                                                       InputBehavior="Insert"
                                                       Mask="#####"
                                                       SelectionOnFocus="SelectAll"
                                                       SpinMode="Position"
                                                       TextMode="MaskedText"
                                                       Value="{Binding Data.zip, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="7"
                                   Grid.Column="0"
                                   VerticalAlignment="Top"
                                   Style="{StaticResource VulpesXLabel}"
                                   Text="Note" />
                        <TextBox Grid.Row="7"
                                 Grid.RowSpan="3"
                                 Grid.Column="1"
                                 Margin="5,0,15,0"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch"
                                 VerticalContentAlignment="Top"
                                 AcceptsReturn="True"
                                 Text="{Binding Data.note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Inserito il" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultimo aggiornamento il" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Annullato il" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Motivo annullamento" />
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       Margin="5,2,2,2"
                                       Style="{StaticResource VulpesXData}"
                                       Text="{Binding Data.CanceledReason}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
