<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Stores.StoreMovementsCheckWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Stores"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Controllo giacenze"
                        Width="1024"
                        Height="768"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <telerik:RadWatermarkTextBox Name="txtSearchExistance"
                                             Grid.Row="0"
                                             Margin="5,5,5,5"
                                             HorizontalAlignment="Stretch"
                                             TextChanged="txtSearchExistance_TextChanged"
                                             WatermarkContent="Cerca..." />

                <Grid Grid.Row="1" Background="{DynamicResource VulpesXFirstAlternativeBrush}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXBrush}"
                               Text="ARTICOLI SENZA LOTTO"
                               TextAlignment="Center" />
                </Grid>

                <Grid Grid.Row="2">
                    <telerik:RadBusyIndicator Name="bsyGridNoLots"
                                              BusyContent="Caricamento dati in corso..."
                                              Foreground="{DynamicResource VulpesXBrush}"
                                              IsBusy="{Binding IsBusy}"
                                              OverlayStyle="{StaticResource WaitOverlayStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="35" />
                            </Grid.RowDefinitions>

                            <telerik:RadGridView Name="rgvExistanceNoLots"
                                                 Grid.Row="0"
                                                 AutoGenerateColumns="False"
                                                 CanUserFreezeColumns="False"
                                                 ColumnAggregatesAlignment="NextToGroupKey"
                                                 GroupRenderMode="Nested"
                                                 IsReadOnly="True"
                                                 IsSearchingDeferred="True"
                                                 IsSynchronizedWithCurrentItem="False"
                                                 ItemsSource="{Binding PagedSource, ElementName=rdpExistanceNoLots}"
                                                 RowIndicatorVisibility="Collapsed"
                                                 SelectionChanged="rgvExistanceNoLots_SelectionChanged"
                                                 ShowGroupFooters="True"
                                                 ShowSearchPanel="False">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewColumn Width="30">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadGlyph x:Name="rgAlign"
                                                                  Cursor="Hand"
                                                                  FontSize="14"
                                                                  Foreground="LawnGreen"
                                                                  Glyph="&#xe021;"
                                                                  MouseDown="rgAlign_MouseDown"
                                                                  ToolTip="Allinea giacenza con i movimenti" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding StoreDescription}" Header="Magazzino" />
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding ProductID}" Header="Articolo">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button x:Name="btnArticleSelect"
                                                        Width="100"
                                                        HorizontalContentAlignment="Center"
                                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                                        Click="btnArticleSelect_Click"
                                                        Content="{Binding Path=ProductID}"
                                                        Foreground="{DynamicResource VulpesXBrush}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewDataColumn>

                                    <telerik:GridViewDataColumn DataFormatString="N6"
                                                                DataMemberBinding="{Binding Quantity}"
                                                                Header="Qtà lotto"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn DataFormatString="N6"
                                                                DataMemberBinding="{Binding QuantityMovements}"
                                                                Header="Qtà movimenti"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Background="Sienna"
                                                                DataFormatString="N6"
                                                                DataMemberBinding="{Binding QuantityGap}"
                                                                Header="Diff."
                                                                TextAlignment="Right" />
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>
                            <telerik:RadDataPager Name="rdpExistanceNoLots"
                                                  Grid.Row="1"
                                                  DisplayMode="All"
                                                  PageSize="25"
                                                  Source="{Binding NoLots}" />
                        </Grid>
                    </telerik:RadBusyIndicator>
                </Grid>

                <Grid Grid.Row="3" Background="{DynamicResource VulpesXFirstAlternativeBrush}">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXBrush}"
                               Text="ARTICOLI CON LOTTO"
                               TextAlignment="Center" />
                </Grid>

                <Grid Grid.Row="4">
                    <telerik:RadBusyIndicator Name="bsyGridLots"
                                              Grid.Column="1"
                                              BusyContent="Caricamento dati in corso..."
                                              FontSize="40"
                                              Foreground="{DynamicResource VulpesXBrush}"
                                              IsBusy="False"
                                              OverlayStyle="{StaticResource WaitOverlayStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="35" />
                            </Grid.RowDefinitions>

                            <telerik:RadGridView Name="rgvExistanceLots"
                                                 Grid.Row="0"
                                                 AutoGenerateColumns="False"
                                                 CanUserFreezeColumns="False"
                                                 ColumnAggregatesAlignment="NextToGroupKey"
                                                 GroupRenderMode="Nested"
                                                 IsReadOnly="True"
                                                 IsSearchingDeferred="True"
                                                 IsSynchronizedWithCurrentItem="False"
                                                 ItemsSource="{Binding PagedSource, ElementName=rdpExistanceLots}"
                                                 RowIndicatorVisibility="Collapsed"
                                                 SelectionChanged="rgvExistanceLots_SelectionChanged"
                                                 ShowGroupFooters="True"
                                                 ShowSearchPanel="False">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewColumn Width="30">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <telerik:RadGlyph x:Name="rgAlignLots"
                                                                  Cursor="Hand"
                                                                  FontSize="14"
                                                                  Foreground="LawnGreen"
                                                                  Glyph="&#xe022;"
                                                                  MouseDown="rgAlignLots_MouseDown"
                                                                  ToolTip="Allinea giacenza con i movimenti" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewColumn>
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding StoreDescription}" Header="Magazzino" />
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding Lot}" Header="Lotto" />
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding ProductID}" Header="Articolo">
                                        <telerik:GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button x:Name="btnArticleSelect"
                                                        Width="100"
                                                        HorizontalContentAlignment="Center"
                                                        BorderBrush="{DynamicResource VulpesXBrush}"
                                                        Click="btnArticleSelect_Click"
                                                        Content="{Binding Path=ProductID}"
                                                        Foreground="{DynamicResource VulpesXBrush}" />
                                            </DataTemplate>
                                        </telerik:GridViewColumn.CellTemplate>
                                    </telerik:GridViewDataColumn>

                                    <telerik:GridViewDataColumn DataFormatString="N6"
                                                                DataMemberBinding="{Binding QuantityLot}"
                                                                Header="Qtà lotto"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn DataFormatString="N6"
                                                                DataMemberBinding="{Binding QuantityMovementsLot}"
                                                                Header="Mov lotto"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Background="Sienna"
                                                                DataFormatString="N6"
                                                                DataMemberBinding="{Binding GapLot}"
                                                                Header="Dif lotto"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn DataFormatString="N6"
                                                                DataMemberBinding="{Binding QuantityStore}"
                                                                Header="Qtà giacenza"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn DataFormatString="N6"
                                                                DataMemberBinding="{Binding QuantityMovementsStore}"
                                                                Header="Mov giacenza"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Background="Teal"
                                                                DataFormatString="N6"
                                                                DataMemberBinding="{Binding GapStore}"
                                                                Header="Dif giacenza"
                                                                TextAlignment="Right" />
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>
                            <telerik:RadDataPager Name="rdpExistanceLots"
                                                  Grid.Row="1"
                                                  DisplayMode="All"
                                                  PageSize="25"
                                                  Source="{Binding Lots}" />
                        </Grid>
                    </telerik:RadBusyIndicator>

                </Grid>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50*" />
                    <RowDefinition Height="50*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"
                               Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXBrush}"
                               Text="MOVIMENTI ARTICOLO"
                               TextAlignment="Center">
                        <TextBlock.LayoutTransform>
                            <RotateTransform Angle="270" />
                        </TextBlock.LayoutTransform>
                    </TextBlock>

                    <telerik:RadBusyIndicator Name="bsyMovsNoLot"
                                              Grid.Column="1"
                                              BusyContent="Caricamento dati in corso..."
                                              FontSize="40"
                                              Foreground="{DynamicResource VulpesXBrush}"
                                              IsBusy="False"
                                              OverlayStyle="{StaticResource WaitOverlayStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="40" />
                            </Grid.RowDefinitions>
                            <telerik:RadGridView Name="rgvMovementsNoLot"
                                                 Grid.Row="0"
                                                 AutoGenerateColumns="False"
                                                 CanUserFreezeColumns="False"
                                                 IsReadOnly="True"
                                                 IsSearchingDeferred="True"
                                                 ItemsSource="{Binding PagedSource, ElementName=rdpMovementsNoLot}"
                                                 RowIndicatorVisibility="Collapsed"
                                                 ShowSearchPanel="False">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewDataColumn Width="120"
                                                                DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                                DataMemberBinding="{Binding date}"
                                                                Header="Data" />
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding StoreFullDescription}" Header="Magazzino" />
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding lot}" Header="Lotto" />

                                    <telerik:GridViewDataColumn Width="120" DataMemberBinding="{Binding Causal.FullDescriptionSearchable}" Header="Causale" />
                                    <telerik:GridViewDataColumn Width="30"
                                                                DataMemberBinding="{Binding Causal.sign}"
                                                                Header=""
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="100"
                                                                DataFormatString="N6"
                                                                DataMemberBinding="{Binding quantity}"
                                                                Header="Quantità"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="80"
                                                                DataMemberBinding="{Binding UM}"
                                                                Header="U.M."
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="120" DataMemberBinding="{Binding document_id}" Header="Documento" />
                                    <telerik:GridViewDataColumn Width="150"
                                                                DataMemberBinding="{Binding order_id}"
                                                                Header="Commessa"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="150"
                                                                DataMemberBinding="{Binding engage_id}"
                                                                Header="ID impegno"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>
                            <telerik:RadDataPager Name="rdpMovementsNoLot"
                                                  Grid.Row="1"
                                                  DisplayMode="All"
                                                  PageSize="25"
                                                  Source="{Binding MovementsNoLot, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True}" />
                        </Grid>
                    </telerik:RadBusyIndicator>
                </Grid>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"
                               Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource VulpesXBrush}"
                               Text="MOVIMENTI LOTTO"
                               TextAlignment="Center">
                        <TextBlock.LayoutTransform>
                            <RotateTransform Angle="270" />
                        </TextBlock.LayoutTransform>
                    </TextBlock>

                    <telerik:RadBusyIndicator Name="bsyMovsLot"
                                              Grid.Column="1"
                                              BusyContent="Caricamento dati in corso..."
                                              FontSize="40"
                                              Foreground="{DynamicResource VulpesXBrush}"
                                              IsBusy="False"
                                              OverlayStyle="{StaticResource WaitOverlayStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="40" />
                            </Grid.RowDefinitions>
                            <telerik:RadGridView Name="rgvMovementsLot"
                                                 Grid.Row="0"
                                                 AutoGenerateColumns="False"
                                                 CanUserFreezeColumns="False"
                                                 IsReadOnly="True"
                                                 IsSearchingDeferred="True"
                                                 ItemsSource="{Binding PagedSource, ElementName=rdpMovementsLot}"
                                                 RowIndicatorVisibility="Collapsed"
                                                 ShowSearchPanel="False">
                                <telerik:RadGridView.Columns>
                                    <telerik:GridViewDataColumn Width="120"
                                                                DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                                DataMemberBinding="{Binding date}"
                                                                Header="Data" />
                                    <telerik:GridViewDataColumn DataMemberBinding="{Binding StoreFullDescription}" Header="Magazzino" />
                                    <telerik:GridViewDataColumn Width="120" DataMemberBinding="{Binding Causal.FullDescriptionSearchable}" Header="Causale" />
                                    <telerik:GridViewDataColumn Width="30"
                                                                DataMemberBinding="{Binding Causal.sign}"
                                                                Header=""
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="100"
                                                                DataFormatString="N6"
                                                                DataMemberBinding="{Binding quantity}"
                                                                Header="Quantità"
                                                                TextAlignment="Right" />
                                    <telerik:GridViewDataColumn Width="80"
                                                                DataMemberBinding="{Binding UM}"
                                                                Header="U.M."
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="120" DataMemberBinding="{Binding document_id}" Header="Documento" />
                                    <telerik:GridViewDataColumn Width="150"
                                                                DataMemberBinding="{Binding order_id}"
                                                                Header="Commessa"
                                                                TextAlignment="Center" />
                                    <telerik:GridViewDataColumn Width="150"
                                                                DataMemberBinding="{Binding engage_id}"
                                                                Header="ID impegno"
                                                                HeaderTextAlignment="Center"
                                                                TextAlignment="Center" />
                                </telerik:RadGridView.Columns>
                            </telerik:RadGridView>
                            <telerik:RadDataPager Name="rdpMovementsLot"
                                                  Grid.Row="1"
                                                  DisplayMode="All"
                                                  PageSize="25"
                                                  Source="{Binding MovementsLot, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True}" />
                        </Grid>
                    </telerik:RadBusyIndicator>
                </Grid>
            </Grid>

        </Grid>


        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />

        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
