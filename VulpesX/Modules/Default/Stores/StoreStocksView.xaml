<UserControl x:Class="VulpesX.Modules.Default.Stores.StoreStocksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:aggregates="clr-namespace:VulpesX.Shared.Controls.Aggregators;assembly=VulpesX.Shared.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Stores"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Style="{StaticResource VulpesXTitle}" Text="GESTIONE GIACENZE" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.Resources>
                    <Style x:Key="GridViewImpactCellStyle" BasedOn="{StaticResource GridViewCellStyle}" TargetType="telerik:GridViewCell">
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="Background" Value="{DynamicResource VulpesXBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource VulpesXDarkBrush}" />
                    </Style>
                </Grid.Resources>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <telerik:RadAutoCompleteBox x:Name="acStores"
                                                    Width="400"
                                                    Margin="5"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalContentAlignment="Center"
                                                    DisplayMemberPath="FullDescriptionSearchable"
                                                    ItemsSource="{Binding Stores}"
                                                    LostFocus="ac_LostFocus"
                                                    NoResultsContent="Nessun magazzino trovato"
                                                    SelectedItem="{Binding SelectedStore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    SelectionChanged="acStores_SelectionChanged"
                                                    SelectionMode="Single"
                                                    TextSearchMode="Contains"
                                                    TextSearchPath="FullDescriptionSearchable"
                                                    WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />
                        <TextBlock Margin="15,0,0,0"
                                   Style="{StaticResource VulpesXLabel}"
                                   Text="Mostra sempre disponibili"
                                   TextAlignment="Right" />
                        <telerik:RadToggleSwitchButton x:Name="togShowInfinite"
                                                       Margin="15,0,0,0"
                                                       Checked="togShowInfinite_Changed"
                                                       CheckedContent="Sì"
                                                       Content="{Binding ShowInfinite}"
                                                       IsChecked="{Binding ShowInfinite}"
                                                       Unchecked="togShowInfinite_Changed"
                                                       UncheckedContent="No" />
                    </StackPanel>


                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <telerik:RadWatermarkTextBox Name="txtSearchStocks"
                                                     Width="400"
                                                     Margin="5"
                                                     HorizontalAlignment="Left"
                                                     TextChanged="txtSearchStocks_TextChanged"
                                                     WatermarkContent="Cerca..." />
                        <TextBlock Margin="15,0,0,0"
                                   Style="{StaticResource VulpesXLabel}"
                                   Text="Mostra i lotti a giacenza 0"
                                   TextAlignment="Right" />
                        <telerik:RadToggleSwitchButton x:Name="togShowZeroLots"
                                                       Margin="15,0,0,0"
                                                       Checked="togShowInfinite_Changed"
                                                       CheckedContent="Sì"
                                                       Content="{Binding ShowZeroLots}"
                                                       IsChecked="{Binding ShowZeroLots}"
                                                       Unchecked="togShowInfinite_Changed"
                                                       UncheckedContent="No" />
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <telerik:RadBusyIndicator Name="bsyGrid"
                                                  Grid.Column="1"
                                                  BusyContent="Caricamento dati in corso..."
                                                  FontSize="40"
                                                  Foreground="{DynamicResource VulpesXBrush}"
                                                  IsBusy="False"
                                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="35" />
                                </Grid.RowDefinitions>

                                <telerik:RadGridView Name="rgvStocks"
                                                     Grid.Row="0"
                                                     AutoGenerateColumns="False"
                                                     CanUserFreezeColumns="False"
                                                     ColumnAggregatesAlignment="NextToGroupKey"
                                                     GroupRenderMode="Nested"
                                                     IsReadOnly="True"
                                                     IsSearchingDeferred="True"
                                                     IsSynchronizedWithCurrentItem="False"
                                                     ItemsSource="{Binding PagedSource, ElementName=rdpStocks}"
                                                     RowIndicatorVisibility="Collapsed"
                                                     RowIsExpandedChanged="rgvStocks_RowIsExpandedChanged"
                                                     SelectionChanged="rgvStocks_SelectionChanged"
                                                     ShowGroupFooters="True"
                                                     ShowSearchPanel="False">
                                    <telerik:RadGridView.ChildTableDefinitions>
                                        <telerik:GridViewTableDefinition>
                                            <telerik:GridViewTableDefinition.Relation>
                                                <telerik:PropertyRelation />
                                            </telerik:GridViewTableDefinition.Relation>
                                        </telerik:GridViewTableDefinition>
                                    </telerik:RadGridView.ChildTableDefinitions>
                                    <telerik:RadGridView.HierarchyChildTemplate>
                                        <DataTemplate>
                                            <telerik:RadGridView AutoGenerateColumns="False"
                                                                 IsReadOnly="True"
                                                                 ItemsSource="{Binding Lots}"
                                                                 RowIndicatorVisibility="Collapsed"
                                                                 ShowGroupPanel="False">
                                                <telerik:RadGridView.Columns>
                                                    <telerik:GridViewColumn Width="30">
                                                        <telerik:GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <telerik:RadGlyph x:Name="rgPrintLotLabel"
                                                                                  Cursor="Hand"
                                                                                  FontSize="14"
                                                                                  Foreground="LawnGreen"
                                                                                  Glyph="&#xe90e;"
                                                                                  MouseDown="rgPrintLotLabel_MouseDown"
                                                                                  ToolTip="Stampa cartellino" />
                                                            </DataTemplate>
                                                        </telerik:GridViewColumn.CellTemplate>
                                                    </telerik:GridViewColumn>
                                                    <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding lot}" Header="Lotto" />
                                                    <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding supplier_lot}" Header="Lotto fornitore" />
                                                    <telerik:GridViewDataColumn Width="200" DataMemberBinding="{Binding goods_location}" Header="Ubicazione" />
                                                    <telerik:GridViewDataColumn Width="140"
                                                                                DataFormatString="dd/MM/yyyy"
                                                                                DataMemberBinding="{Binding expire}"
                                                                                Header="Data scadenza"
                                                                                HeaderTextAlignment="Center"
                                                                                TextAlignment="Center" />
                                                    <telerik:GridViewDataColumn Width="160"
                                                                                CellStyle="{StaticResource GridViewImpactCellStyle}"
                                                                                DataFormatString="N6"
                                                                                DataMemberBinding="{Binding AvailableQuantity}"
                                                                                FooterTextAlignment="Right"
                                                                                Header="Quantità disponibile"
                                                                                HeaderTextAlignment="Right"
                                                                                TextAlignment="Right" />
                                                    <telerik:GridViewDataColumn Width="160"
                                                                                DataFormatString="N6"
                                                                                DataMemberBinding="{Binding quantity_stock}"
                                                                                FooterTextAlignment="Right"
                                                                                Header="Quantità presente"
                                                                                HeaderTextAlignment="Right"
                                                                                TextAlignment="Right" />
                                                    <telerik:GridViewDataColumn Width="160"
                                                                                DataFormatString="N6"
                                                                                DataMemberBinding="{Binding EngagedQuantity}"
                                                                                FooterTextAlignment="Right"
                                                                                Header="Quantità impegnata"
                                                                                HeaderTextAlignment="Right"
                                                                                TextAlignment="Right" />
                                                    <telerik:GridViewDataColumn Width="160"
                                                                                DataFormatString="N6"
                                                                                DataMemberBinding="{Binding quantity_production}"
                                                                                FooterTextAlignment="Right"
                                                                                Header="Quantità in produzione"
                                                                                HeaderTextAlignment="Right"
                                                                                TextAlignment="Right" />
                                                </telerik:RadGridView.Columns>
                                            </telerik:RadGridView>
                                        </DataTemplate>
                                    </telerik:RadGridView.HierarchyChildTemplate>
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding StoreDescription}" Header="Magazzino" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding goods_location}" Header="Ubicazione" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding product_id}" Header="Articolo">
                                            <telerik:GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button x:Name="btnArticleSelect"
                                                            Width="100"
                                                            HorizontalContentAlignment="Center"
                                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                                            Click="btnArticleSelect_Click"
                                                            Content="{Binding Path=product_id}"
                                                            Foreground="{DynamicResource VulpesXBrush}" />
                                                </DataTemplate>
                                            </telerik:GridViewColumn.CellTemplate>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding ProductDescription}" Header="" />
                                        <telerik:GridViewDataColumn CellStyle="{StaticResource GridViewImpactCellStyle}"
                                                                    DataFormatString="N6"
                                                                    DataMemberBinding="{Binding QuantityDisplay}"
                                                                    Header="Disponibile"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewColumn.AggregateFunctions>
                                                <aggregates:StoreStocksCustomSumAvailability />
                                            </telerik:GridViewColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding UM}" Header="UM" />
                                        <telerik:GridViewDataColumn DataFormatString="N6"
                                                                    DataMemberBinding="{Binding QuantityStockDisplay}"
                                                                    Header="Giacenza"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewColumn.AggregateFunctions>
                                                <aggregates:StoreStocksCustomSumStock />
                                            </telerik:GridViewColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn DataFormatString="N6"
                                                                    DataMemberBinding="{Binding Info.QuantityEngaged}"
                                                                    Header="Impegnato"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction Caption="Totale impegnato: " />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn DataFormatString="N6"
                                                                    DataMemberBinding="{Binding Info.QuantityProduction}"
                                                                    Header="In produzione"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction Caption="Totale in produzione: " />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                        <telerik:GridViewDataColumn DataFormatString="N6"
                                                                    DataMemberBinding="{Binding Info.QuantityOrdered}"
                                                                    Header="Ordinato"
                                                                    TextAlignment="Right">
                                            <telerik:GridViewDataColumn.AggregateFunctions>
                                                <telerik:SumFunction Caption="Totale ordinato: " />
                                            </telerik:GridViewDataColumn.AggregateFunctions>
                                        </telerik:GridViewDataColumn>
                                    </telerik:RadGridView.Columns>
                                </telerik:RadGridView>
                                <telerik:RadDataPager Name="rdpStocks"
                                                      Grid.Row="1"
                                                      DisplayMode="All"
                                                      PageSize="25"
                                                      Source="{Binding Items}" />
                            </Grid>
                        </telerik:RadBusyIndicator>
                    </Grid>
                </Grid>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="5*" />
                    <RowDefinition Height="5*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="2"
                        BorderBrush="{DynamicResource VulpesXBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Padding="0"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource VulpesXBrush}"
                                   Opacity=".8"
                                   Text="MOVIMENTI DI MAGAZZINO"
                                   TextAlignment="Center"
                                   Typography.Capitals="AllSmallCaps">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="270" />
                            </TextBlock.LayoutTransform>
                        </TextBlock>

                        <telerik:RadBusyIndicator Name="bsMovs"
                                                  Grid.Column="1"
                                                  BusyContent="Caricamento dati in corso..."
                                                  FontSize="40"
                                                  Foreground="{DynamicResource VulpesXBrush}"
                                                  IsBusy="False"
                                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="40" />
                                </Grid.RowDefinitions>
                                <Button Name="rmiInsertMovement"
                                        Grid.Row="0"
                                        Margin="5"
                                        HorizontalAlignment="Right"
                                        Click="rmiInsertMovement_Click"
                                        Content="INSERISCI"
                                        Style="{StaticResource VulpesXInsertButton}" />

                                <telerik:RadWatermarkTextBox Name="txtSearchMovements"
                                                             Grid.Row="1"
                                                             Margin="5"
                                                             TextChanged="txtSearchMovements_TextChanged"
                                                             WatermarkContent="Cerca..." />

                                <telerik:RadGridView Name="rgvMovements"
                                                     Grid.Row="2"
                                                     Margin="5"
                                                     AutoGenerateColumns="False"
                                                     CanUserFreezeColumns="False"
                                                     IsReadOnly="True"
                                                     IsSearchingDeferred="True"
                                                     ItemsSource="{Binding PagedSource, ElementName=rdpMovements}"
                                                     RowIndicatorVisibility="Collapsed"
                                                     ShowSearchPanel="False">
                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewDataColumn Width="120"
                                                                    DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                                    DataMemberBinding="{Binding date}"
                                                                    Header="Data" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding StoreFullDescription}" Header="Magazzino" />
                                        <telerik:GridViewDataColumn Width="120" DataMemberBinding="{Binding Causal.FullDescriptionSearchable}" Header="Causale" />
                                        <telerik:GridViewDataColumn Width="30"
                                                                    DataMemberBinding="{Binding Causal.sign}"
                                                                    Header=""
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="100"
                                                                    DataFormatString="N6"
                                                                    DataMemberBinding="{Binding quantity}"
                                                                    Header="Quantità"
                                                                    TextAlignment="Right" />
                                        <telerik:GridViewDataColumn Width="80"
                                                                    DataMemberBinding="{Binding UM}"
                                                                    Header="U.M."
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding lot}" Header="Lotto" TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="120" DataMemberBinding="{Binding document_id}" Header="Documento" />
                                        <telerik:GridViewDataColumn Width="150"
                                                                    DataMemberBinding="{Binding order_id}"
                                                                    Header="Commessa"
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="150"
                                                                    DataMemberBinding="{Binding engage_id}"
                                                                    Header="ID impegno"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Center" />
                                    </telerik:RadGridView.Columns>
                                </telerik:RadGridView>
                                <telerik:RadDataPager Name="rdpMovements"
                                                      Grid.Row="3"
                                                      DisplayMode="All"
                                                      PageSize="25"
                                                      Source="{Binding Movements, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True}" />
                            </Grid>
                        </telerik:RadBusyIndicator>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="2"
                        Padding="5"
                        BorderBrush="{DynamicResource VulpesXBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Padding="0"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource VulpesXBrush}"
                                   Opacity=".8"
                                   Text="IMPEGNI DI MATERIALE"
                                   TextAlignment="Center"
                                   Typography.Capitals="AllSmallCaps">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="270" />
                            </TextBlock.LayoutTransform>
                        </TextBlock>

                        <telerik:RadBusyIndicator Name="bsEngage"
                                                  Grid.Column="1"
                                                  BusyContent="Caricamento dati in corso..."
                                                  FontSize="40"
                                                  Foreground="{DynamicResource VulpesXBrush}"
                                                  IsBusy="False"
                                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="40" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" HorizontalAlignment="Right" Orientation="Horizontal">
                                    <Button Name="rmiInsertEngage"
                                            Width="90"
                                            Margin="5"
                                            Click="rmiInsertEngage_Click"
                                            Content="INSERISCI"
                                            Style="{StaticResource VulpesXInsertButton}" />
                                    <Button Name="rmiUpdateEngage"
                                            Width="90"
                                            Margin="5"
                                            BorderBrush="{DynamicResource VulpesXYellowBrush}"
                                            Click="rmiUpdateEngage_Click"
                                            Content="MODIFICA"
                                            Style="{StaticResource VulpesXButton}" />
                                    <Button Name="rmiDeleteEngage"
                                            Width="90"
                                            Margin="5"
                                            BorderBrush="{DynamicResource VulpesXRedBrush}"
                                            Click="rmiDeleteEngage_Click"
                                            Content="ELIMINA"
                                            Style="{StaticResource VulpesXButton}" />
                                    <Button Name="rmiUnloadEngage"
                                            Width="90"
                                            Margin="5"
                                            BorderBrush="{DynamicResource VulpesXVioletBrush}"
                                            Click="rmiUnloadEngage_Click"
                                            Content="SCARICA"
                                            Style="{StaticResource VulpesXButton}" />
                                </StackPanel>

                                <telerik:RadWatermarkTextBox Name="txtSearchEngage"
                                                             Grid.Row="1"
                                                             Margin="5"
                                                             TextChanged="txtSearchEngage_TextChanged"
                                                             WatermarkContent="Cerca..." />

                                <telerik:RadGridView Name="rgvEngages"
                                                     Grid.Row="2"
                                                     Margin="5"
                                                     AutoGenerateColumns="False"
                                                     CanUserFreezeColumns="False"
                                                     IsReadOnly="True"
                                                     IsSearchingDeferred="True"
                                                     ItemsSource="{Binding PagedSource, ElementName=rdpEngages}"
                                                     RowIndicatorVisibility="Collapsed"
                                                     SelectionChanged="rgvEngages_SelectionChanged"
                                                     ShowSearchPanel="False">

                                    <telerik:RadGridView.Columns>
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding StoreFullDescription}" Header="Magazzino" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding lot}" Header="Lotto" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding order_id}" Header="Ordine" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding FullCustomerOrderID}" Header="Ordine cliente" />
                                        <telerik:GridViewDataColumn DataMemberBinding="{Binding FullDDTID}" Header="DDT" />
                                        <telerik:GridViewDataColumn Width="100"
                                                                    DataFormatString="N6"
                                                                    DataMemberBinding="{Binding quantity}"
                                                                    Header="Quantità"
                                                                    TextAlignment="Right" />
                                        <telerik:GridViewDataColumn Width="80"
                                                                    DataMemberBinding="{Binding UM}"
                                                                    Header="U.M."
                                                                    TextAlignment="Center" />
                                        <telerik:GridViewDataColumn Width="150" DataMemberBinding="{Binding document_id}" Header="Documento" />
                                        <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy HH:mm:ss" DataMemberBinding="{Binding date_engaged}" Header="Data impegno" />
                                        <telerik:GridViewDataColumn DataFormatString="dd/MM/yyyy HH:mm:ss" DataMemberBinding="{Binding date_unloaded}" Header="Data scarico" />
                                        <telerik:GridViewDataColumn Width="150"
                                                                    DataMemberBinding="{Binding id}"
                                                                    Header="ID"
                                                                    HeaderTextAlignment="Center"
                                                                    TextAlignment="Center" />
                                    </telerik:RadGridView.Columns>
                                </telerik:RadGridView>
                                <telerik:RadDataPager Name="rdpEngages"
                                                      Grid.Row="3"
                                                      DisplayMode="All"
                                                      PageSize="25"
                                                      Source="{Binding Engages, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </telerik:RadBusyIndicator>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>

</UserControl>
