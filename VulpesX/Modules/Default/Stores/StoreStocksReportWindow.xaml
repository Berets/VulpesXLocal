<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Stores.StoreStocksReportWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Stores"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Stampa giacenze di magazzino"
                        Width="800"
                        Height="500"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        WindowStyle="ToolWindow"
                        mc:Ignorable="d">

    <telerik:RadBusyIndicator x:Name="bsyGrid"
                              Grid.Row="2"
                              BusyContent="Estrazione dati in corso..."
                              Foreground="{DynamicResource VulpesXBrush}"
                              IsBusy="{Binding IsBusy}"
                              OverlayStyle="{StaticResource WaitOverlayStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="10" />
                <RowDefinition Height="40" />
                <RowDefinition Height="40" />
                <RowDefinition Height="40" />
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="8*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Margin="0,0,15,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{DynamicResource VulpesXSecondBrush}"
                       Text="Magazzino" />
            <telerik:RadAutoCompleteBox x:Name="acStore"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="5,2,15,2"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        DisplayMemberPath="FullDescriptionSearchable"
                                        GotFocus="ac_GotFocus"
                                        ItemsSource="{Binding Stores}"
                                        LostFocus="ac_LostFocus"
                                        NoResultsContent="Nessun codice trovato"
                                        SelectedItem="{Binding SelectedStore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectionMode="Single"
                                        TextSearchMode="Contains"
                                        TextSearchPath="FullDescriptionSearchable"
                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Margin="0,0,15,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{DynamicResource VulpesXSecondBrush}"
                       Text="Articolo" />
            <telerik:RadAutoCompleteBox x:Name="acProduct"
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="5,2,15,2"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        DisplayMemberPath="FullDescriptionSearchable"
                                        GotFocus="ac_GotFocus"
                                        ItemsSource="{Binding Products}"
                                        LostFocus="ac_LostFocus"
                                        NoResultsContent="Nessun codice trovato"
                                        SelectedItem="{Binding SelectedProduct, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectionMode="Single"
                                        TextSearchMode="Contains"
                                        TextSearchPath="FullDescriptionSearchable"
                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Margin="0,0,15,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{DynamicResource VulpesXSecondBrush}"
                       Text="Tipo articolo" />
            <telerik:RadAutoCompleteBox x:Name="acProductType"
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Margin="5,2,15,2"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        DisplayMemberPath="FullDescriptionSearchable"
                                        GotFocus="ac_GotFocus"
                                        ItemsSource="{Binding ProductTypes}"
                                        LostFocus="ac_LostFocus"
                                        NoResultsContent="Nessun codice trovato"
                                        SelectedItem="{Binding SelectedProductType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectionMode="Single"
                                        TextSearchMode="Contains"
                                        TextSearchPath="FullDescriptionSearchable"
                                        WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Margin="0,0,15,0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{DynamicResource VulpesXSecondBrush}"
                       Text="Fino alla data" />
            <telerik:RadDateTimePicker Grid.Row="4"
                                       Grid.Column="1"
                                       Width="200"
                                       Margin="5,0,15,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       DateSelectionMode="Day"
                                       DateTimeWatermarkContent="Scegliere la data"
                                       DisplayFormat="Short"
                                       InputMode="DatePicker"
                                       SelectedValue="{Binding PrintUntil}" />

            <Grid Grid.Row="5" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Stampa giacenze a 0" />
                <telerik:RadToggleSwitchButton Grid.Row="0"
                                               Grid.Column="1"
                                               Margin="5,0,0,0"
                                               CheckedContent="Sì"
                                               Content="{Binding ShowZeroStocks}"
                                               IsChecked="{Binding ShowZeroStocks}"
                                               UncheckedContent="No" />
                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Stampa dettaglio lotti" />
                <telerik:RadToggleSwitchButton Grid.Row="0"
                                               Grid.Column="3"
                                               Margin="5,0,0,0"
                                               CheckedContent="Sì"
                                               Content="{Binding ShowLots}"
                                               IsChecked="{Binding ShowLots}"
                                               UncheckedContent="No" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Stampa movimenti" />
                <telerik:RadToggleSwitchButton x:Name="togShowMovements"
                                               Grid.Row="1"
                                               Grid.Column="1"
                                               Margin="5,0,0,0"
                                               Checked="togShowMovements_Checked"
                                               CheckedContent="Sì"
                                               Content="{Binding ShowMovements}"
                                               IsChecked="{Binding ShowMovements}"
                                               UncheckedContent="No" />
                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Anche annullati" />
                <telerik:RadToggleSwitchButton Grid.Row="1"
                                               Grid.Column="3"
                                               Margin="5,0,0,0"
                                               CheckedContent="Sì"
                                               Content="{Binding ShowMovementsCanceled}"
                                               IsChecked="{Binding ShowMovementsCanceled}"
                                               IsEnabled="{Binding ElementName=togShowMovements, Path=IsChecked}"
                                               UncheckedContent="No" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Stampa impegni" />
                <telerik:RadToggleSwitchButton x:Name="togShowEngages"
                                               Grid.Row="2"
                                               Grid.Column="1"
                                               Margin="5,0,0,0"
                                               Checked="togShowEngages_Checked"
                                               CheckedContent="Sì"
                                               Content="{Binding ShowEngages}"
                                               IsChecked="{Binding ShowEngages}"
                                               UncheckedContent="No" />
                <TextBlock Grid.Row="2"
                           Grid.Column="2"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Anche scaricati/annullati" />
                <telerik:RadToggleSwitchButton Grid.Row="2"
                                               Grid.Column="3"
                                               Margin="5,0,0,0"
                                               CheckedContent="Sì"
                                               Content="{Binding ShowEngagesUnloaded}"
                                               IsChecked="{Binding ShowEngagesUnloaded}"
                                               IsEnabled="{Binding ElementName=togShowEngages, Path=IsChecked}"
                                               UncheckedContent="No" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,0,15,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource VulpesXSecondBrush}"
                           Text="Stampa sempre disponibili" />
                <telerik:RadToggleSwitchButton Grid.Row="3"
                                               Grid.Column="1"
                                               Margin="5,0,0,0"
                                               CheckedContent="Sì"
                                               Content="{Binding ShowInfinite}"
                                               IsChecked="{Binding ShowInfinite}"
                                               UncheckedContent="No" />

            </Grid>

            <StackPanel Grid.Row="6"
                        Grid.ColumnSpan="3"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
                <Button Name="cmdSave"
                        Click="cmdSave_Click"
                        Content="STAMPA"
                        Style="{StaticResource VulpesXConfirmButton}" />
            </StackPanel>
        </Grid>
    </telerik:RadBusyIndicator>
</sc:FluentDefaultWindow>
