<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Stores.StoreMovementsWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Stores"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Dettagli movimento di magazzino"
                        Width="850"
                        Height="660"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <telerik:RadTabControl Grid.Row="0"
                               VerticalAlignment="Stretch"
                               BorderThickness="0"
                               DisplayMemberPath="Content"
                               DropDownDisplayMode="Visible"
                               ScrollMode="Viewport">
            <telerik:RadTabItem DropDownContent="DATI GENERALI" Header="DATI GENERALI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,15,15,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="8*" />
                            </Grid.ColumnDefinitions>

                            <Grid x:Name="gMain" Grid.Row="0" Grid.ColumnSpan="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="70" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                    <RowDefinition Height="35" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="8*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Codice" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Margin="5,0,0,0"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.id}" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Data movimento" />
                                <telerik:RadDateTimePicker x:Name="dtpMoved"
                                                           Grid.Row="1"
                                                           Grid.Column="1"
                                                           Width="200"
                                                           Margin="5,0,15,0"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           DateSelectionMode="Day"
                                                           DateTimeWatermarkContent="Scegliere la data"
                                                           DisplayFormat="Short"
                                                           InputMode="DateTimePicker"
                                                           IsEnabled="{Binding IsInsert}"
                                                           SelectedValue="{Binding Data.date, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Articolo" />
                                <telerik:RadAutoCompleteBox x:Name="acProduct"
                                                            Grid.Row="2"
                                                            Grid.Column="1"
                                                            Margin="5,2,15,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            IsEnabled="{Binding IsProductEnabled}"
                                                            ItemsSource="{Binding Products}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun codice trovato"
                                                            SelectedItem="{Binding Data.Product, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionChanged="acProduct_SelectionChanged"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Fornitore" />
                                <telerik:RadAutoCompleteBox x:Name="acSupplier"
                                                            Grid.Row="3"
                                                            Grid.Column="1"
                                                            Margin="5,2,15,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            IsEnabled="{Binding IsReadonly}"
                                                            ItemsSource="{Binding Suppliers}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun codice trovato"
                                                            SelectedItem="{Binding Data.Supplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionChanged="acSupplier_SelectionChanged"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Magazzino" />
                                <telerik:RadAutoCompleteBox x:Name="acStore"
                                                            Grid.Row="4"
                                                            Grid.Column="1"
                                                            Margin="5,2,15,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            IsEnabled="{Binding IsInsert}"
                                                            ItemsSource="{Binding Stores}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun codice trovato"
                                                            SelectedItem="{Binding SelectedStore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionChanged="acStore_SelectionChanged"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                                <Grid x:Name="grdLot"
                                      Grid.Row="5"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="2"
                                      Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="8*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Style="{StaticResource VulpesXLabel}"
                                               Text="Lotto" />
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                        <TextBox x:Name="txtLot"
                                                 Width="255"
                                                 Margin="5,0,15,0"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 GotFocus="txtLot_GotFocus"
                                                 IsEnabled="{Binding IsInsert}"
                                                 IsReadOnly="{Binding IsLotLocked}"
                                                 MaxLength="50"
                                                 Text="{Binding Data.lot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Style="{StaticResource VulpesXLabel}" Text="Lotto fornitore" />
                                        <TextBox Width="260"
                                                 Margin="5,0,15,0"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 MaxLength="50"
                                                 Text="{Binding Data.supplier_lot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Style="{StaticResource VulpesXLabel}"
                                               Text="Data scadenza lotto" />
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                        <telerik:RadDateTimePicker Width="140"
                                                                   Margin="5,0,15,0"
                                                                   HorizontalAlignment="Left"
                                                                   VerticalAlignment="Center"
                                                                   DateSelectionMode="Day"
                                                                   DateTimeWatermarkContent="Scegliere la data"
                                                                   DisplayFormat="Short"
                                                                   InputMode="DatePicker"
                                                                   SelectedValue="{Binding Data.expire, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Grid.Row="6"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Causale" />
                                <telerik:RadAutoCompleteBox x:Name="acCausal"
                                                            Grid.Row="6"
                                                            Grid.Column="1"
                                                            Margin="5,2,15,2"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Center"
                                                            DisplayMemberPath="FullDescriptionSearchable"
                                                            GotFocus="ac_GotFocus"
                                                            IsEnabled="{Binding IsInsert}"
                                                            ItemsSource="{Binding Causals}"
                                                            LostFocus="ac_LostFocus"
                                                            NoResultsContent="Nessun codice trovato"
                                                            SelectedItem="{Binding Data.Causal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectionChanged="acCausal_SelectionChanged"
                                                            SelectionMode="Single"
                                                            TextSearchMode="Contains"
                                                            TextSearchPath="FullDescriptionSearchable"
                                                            WatermarkContent="Inizia a digitare il codice o la descrizione per cercare..." />

                                <TextBlock Grid.Row="7"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Quantita'" />
                                <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
                                    <telerik:RadNumericUpDown Width="200"
                                                              Margin="5,2,2,2"
                                                              HorizontalAlignment="Left"
                                                              NumberDecimalDigits="6"
                                                              Value="{Binding Data.quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="5,0,0,0" Style="{StaticResource VulpesXData}" Text="{Binding Data.Product.UnitaID, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Width="200"
                                               Style="{StaticResource VulpesXLabel}"
                                               Text="Prezzo"
                                               TextAlignment="Right" />
                                    <telerik:RadNumericUpDown Width="200"
                                                              Margin="5,2,2,2"
                                                              HorizontalAlignment="Left"
                                                              NumberDecimalDigits="6"
                                                              Value="{Binding Data.price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <TextBlock Grid.Row="8"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Numero DDT" />
                                <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                                    <TextBox Width="200"
                                             Margin="5,0,15,0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"
                                             MaxLength="50"
                                             Text="{Binding Data.document_id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource VulpesXLabel}" Text="Data DDT" />
                                    <telerik:RadDateTimePicker Width="120"
                                                               Margin="5,0,15,0"
                                                               HorizontalAlignment="Left"
                                                               VerticalAlignment="Center"
                                                               DateSelectionMode="Day"
                                                               DateTimeWatermarkContent="Scegliere la data"
                                                               DisplayFormat="Short"
                                                               InputMode="DatePicker"
                                                               SelectedValue="{Binding Data.document_date, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Style="{StaticResource VulpesXLabel}" Text="Riga DDT" />
                                    <telerik:RadNumericUpDown Width="100"
                                                              Margin="5,2,2,2"
                                                              HorizontalAlignment="Left"
                                                              Minimum="1"
                                                              NumberDecimalDigits="0"
                                                              Value="{Binding Data.document_row, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <TextBlock Grid.Row="9"
                                           Grid.Column="0"
                                           Style="{StaticResource VulpesXLabel}"
                                           Text="Ordine di produzione" />
                                <TextBlock Grid.Row="9"
                                           Grid.Column="1"
                                           Margin="5,0,15,0"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.order_id}" />
                            </Grid>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ubicazione" />
                            <telerik:RadAutoSuggestBox Grid.Row="1"
                                                       Grid.Column="1"
                                                       Margin="5,2,15,2"
                                                       HorizontalAlignment="Stretch"
                                                       IsEnabled="True"
                                                       ItemsSource="{Binding GoodsLocations}"
                                                       Text="{Binding Data.goods_location, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       VerticalAlignment="Top"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Note" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     Margin="5,0,15,0"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Top"
                                     VerticalContentAlignment="Top"
                                     AcceptsReturn="True"
                                     MinLines="5"
                                     Text="{Binding Data.note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
            <telerik:RadTabItem DropDownContent="INFORMAZIONI" Header="INFORMAZIONI">
                <telerik:RadTabItem.Content>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,10,10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="7*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Inserito il" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.AddedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Ultimo aggiornamento il" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.UpdatedUserText}" />
                            </StackPanel>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Style="{StaticResource VulpesXLabel}"
                                       Text="Annullato il" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledText}" />
                                <TextBlock Margin="10,0,10,0" Style="{StaticResource VulpesXLabel}" Text="da" />
                                <TextBlock Margin="5,2,2,2"
                                           HorizontalAlignment="Left"
                                           Style="{StaticResource VulpesXData}"
                                           Text="{Binding Data.CanceledUserText}" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </telerik:RadTabItem.Content>
            </telerik:RadTabItem>
        </telerik:RadTabControl>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel" Content="USCIRE" Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
