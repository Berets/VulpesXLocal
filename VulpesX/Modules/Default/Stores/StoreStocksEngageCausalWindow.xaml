<sc:FluentDefaultWindow x:Class="VulpesX.Modules.Default.Stores.StoreStocksEngageCausalWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:local="clr-namespace:VulpesX.Modules.Default.Stores"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:sc="clr-namespace:VulpesX.Shared.Controls.CustomWindows;assembly=VulpesX.Shared.Controls"
                        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                        Title="Specificare una causale di magazzino per lo scarico del materiale"
                        Width="700"
                        Height="200"
                        Style="{StaticResource VulpesXDefaultWindow}"
                        WindowStartupLocation="CenterScreen"
                        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="7*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   Style="{StaticResource VulpesXSubtitle}"
                   Text="Selezionare la causale di magazzino da utilizzare per il movimento di scarico del materiale"
                   TextAlignment="Center"
                   TextWrapping="Wrap" />

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Style="{StaticResource VulpesXLabel}"
                   Text="Causale" />
        <telerik:RadComboBox x:Name="cmbCausal"
                             Grid.Row="1"
                             Grid.Column="1"
                             Margin="5,2,15,2"
                             HorizontalAlignment="Stretch"
                             HorizontalContentAlignment="Left"
                             DisplayMemberPath="description"
                             IsEditable="True"
                             IsReadOnly="True"
                             ItemsSource="{Binding Causals}"
                             SelectedValuePath="id" />

        <StackPanel Grid.Row="2"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Name="cmdCancel"
                    Click="cmdCancel_Click"
                    Content="USCIRE"
                    Style="{StaticResource VulpesXCancelButton}" />
            <Button Name="cmdSave"
                    Click="cmdSave_Click"
                    Content="SALVA"
                    Style="{StaticResource VulpesXConfirmButton}" />
        </StackPanel>
    </Grid>
</sc:FluentDefaultWindow>
