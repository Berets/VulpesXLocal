<UserControl x:Class="VulpesX.Modules.Default.Stores.StoreMovementsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:aggregates="clr-namespace:VulpesX.Shared.Controls.Aggregators;assembly=VulpesX.Shared.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Modules.Default.Stores"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource VulpesXTitle}" Text="GESTIONE MOVIMENTI DI MAGAZZINO" />

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <telerik:RadDatePicker x:Name="dtpYear"
                                       Margin="5,5,0,5"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Right"
                                       DateSelectionMode="Year"
                                       DisplayFormat="Short"
                                       SelectedValue="{Binding Year, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       SelectionChanged="dtpYear_SelectionChanged" />
                <Button Name="cmdInsert"
                        Margin="5"
                        Click="cmdInsert_Click"
                        Content="INSERISCI"
                        Style="{StaticResource VulpesXInsertButton}" />
                <Button Name="cmdCheckExistance"
                        Width="200"
                        Margin="5"
                        BorderBrush="{DynamicResource VulpesXOrangeBrush}"
                        Click="cmdCheckExistance_Click"
                        Content="CONTROLLO ESISTENZE"
                        Style="{StaticResource VulpesXButton}" />

            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <telerik:RadWatermarkTextBox Name="txtSearch"
                                         Margin="5"
                                         LostFocus="txtSearch_LostFocus"
                                         WatermarkContent="Cerca..." />
        </Grid>

        <telerik:RadBusyIndicator x:Name="bsyGrid"
                                  Grid.Row="2"
                                  BusyContent="Caricamento dati in corso..."
                                  Foreground="{DynamicResource VulpesXBrush}"
                                  IsBusy="{Binding IsBusy}"
                                  OverlayStyle="{StaticResource WaitOverlayStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <telerik:RadGridView x:Name="GridView"
                                     Grid.Row="0"
                                     AutoGenerateColumns="False"
                                     CanUserFreezeColumns="False"
                                     CanUserResizeColumns="False"
                                     FieldFilterEditorCreated="GridView_FieldFilterEditorCreated"
                                     FilterOperatorsLoading="OnRadGridViewFilterOperatorsLoading"
                                     Filtering="GridView_Filtering"
                                     FilteringMode="FilterRow"
                                     GroupRenderMode="Flat"
                                     IsReadOnly="True"
                                     ItemsSource="{Binding Items}"
                                     RowIndicatorVisibility="Collapsed"
                                     ShowColumnSortIndexes="True"
                                     ShowGroupPanel="False"
                                     Sorting="GridView_Sorting">
                    <telerik:RadGridView.Columns>
                        <telerik:GridViewDataColumn Width="120"
                                                    DataMemberBinding="{Binding id}"
                                                    Header="Codice"
                                                    HeaderTextAlignment="Center"
                                                    IsCustomSortingEnabled="True"
                                                    TextAlignment="Center">
                            <telerik:GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button x:Name="cmdEdit"
                                            Margin="3"
                                            HorizontalContentAlignment="Center"
                                            BorderBrush="{DynamicResource VulpesXBrush}"
                                            Click="cmdEdit_Click"
                                            Content="{Binding Path=id}"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource VulpesXBrush}" />
                                </DataTemplate>
                            </telerik:GridViewColumn.CellTemplate>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding dateText}"
                                                    Header="Data ed ora"
                                                    HeaderTextAlignment="Center"
                                                    IsCustomSortingEnabled="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="120"
                                                    DataMemberBinding="{Binding product_id}"
                                                    Header="Articolo"
                                                    IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding ProductDescription}" Header="" IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="75"
                                                    DataMemberBinding="{Binding store_id}"
                                                    Header="Magazzino"
                                                    IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="180"
                                                    DataMemberBinding="{Binding StoreDescription}"
                                                    Header=""
                                                    IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="N6"
                                                    DataMemberBinding="{Binding quantity}"
                                                    Header="Quantita'"
                                                    HeaderTextAlignment="Right"
                                                    IsCustomSortingEnabled="True"
                                                    TextAlignment="Right">
                            <telerik:GridViewColumn.AggregateFunctions>
                                <telerik:CountFunction Caption="MOVIMENTI : " ResultFormatString="{}{0:N0}" />
                                <aggregates:StoreMovementsCustomSum />
                            </telerik:GridViewColumn.AggregateFunctions>
                        </telerik:GridViewDataColumn>
                        <telerik:GridViewDataColumn Width="50"
                                                    DataMemberBinding="{Binding Sign}"
                                                    Header=""
                                                    IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="60"
                                                    DataMemberBinding="{Binding UM}"
                                                    Header=""
                                                    HeaderTextAlignment="Center"
                                                    IsCustomSortingEnabled="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding lot}" Header="Lotto" IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="70"
                                                    DataMemberBinding="{Binding causal_id}"
                                                    Header="Causale"
                                                    IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="200"
                                                    DataMemberBinding="{Binding CausalDescription}"
                                                    Header=""
                                                    IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn x:Name="gcPrice"
                                                    Width="120"
                                                    DataFormatString="N6"
                                                    DataMemberBinding="{Binding price}"
                                                    Header="Prezzo"
                                                    HeaderTextAlignment="Right"
                                                    IsCustomSortingEnabled="True"
                                                    TextAlignment="Right" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding supplier_lot}" Header="Lotto fornitore" IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn DataMemberBinding="{Binding supplier_id}" Header="Fornitore" IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="250"
                                                    DataMemberBinding="{Binding SupplierDescription}"
                                                    Header=""
                                                    IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="200"
                                                    DataMemberBinding="{Binding goods_location}"
                                                    Header="Ubicazione"
                                                    IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="140"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding expireText}"
                                                    Header="Data scadenza"
                                                    HeaderTextAlignment="Center"
                                                    IsCustomSortingEnabled="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="180"
                                                    DataMemberBinding="{Binding order_id}"
                                                    Header="Ordine di produzione"
                                                    IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="120"
                                                    DataMemberBinding="{Binding document_id}"
                                                    Header="Numero DDT"
                                                    IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="120"
                                                    DataFormatString="dd/MM/yyyy"
                                                    DataMemberBinding="{Binding document_dateText}"
                                                    Header="Data DDT"
                                                    HeaderTextAlignment="Center"
                                                    IsCustomSortingEnabled="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="90"
                                                    DataMemberBinding="{Binding document_row}"
                                                    Header="Riga DDT"
                                                    IsCustomSortingEnabled="True" />
                        <telerik:GridViewDataColumn Width="180"
                                                    DataFormatString="dd/MM/yyyy HH:mm:ss"
                                                    DataMemberBinding="{Binding addedText}"
                                                    Header="Inserito il"
                                                    HeaderTextAlignment="Center"
                                                    IsCustomSortingEnabled="True"
                                                    TextAlignment="Center" />
                        <telerik:GridViewDataColumn Width="200"
                                                    DataMemberBinding="{Binding add_user}"
                                                    Header="Inserito da"
                                                    IsCustomSortingEnabled="True" />
                    </telerik:RadGridView.Columns>
                </telerik:RadGridView>
                <telerik:RadDataPager x:Name="rdpGrid"
                                      Grid.Row="1"
                                      Margin="0,-1,0,0"
                                      DisplayMode="FirstLastPreviousNextNumeric, Text"
                                      FontSize="12"
                                      IsTotalItemCountFixed="True"
                                      PageIndexChanged="rdpGrid_PageIndexChanged"
                                      PageSize="{Binding PageSize}" />
            </Grid>
        </telerik:RadBusyIndicator>
    </Grid>

</UserControl>
