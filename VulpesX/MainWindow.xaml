<Window x:Class="VulpesX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:VulpesX"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
        Title="VulpesX"
        MinWidth="1024"
        MinHeight="768"
        Background="{DynamicResource VulpesXFirstBrush}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        mc:Ignorable="d">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="True" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <HierarchicalDataTemplate x:Key="menuItem" ItemsSource="{Binding SubItems}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="5,0,5,0" FontSize="15" Text="{Binding Name}" />
                <telerik:RadContextMenu.ContextMenu>
                    <telerik:RadContextMenu x:Name="radContextMenu" Opening="radContextMenu_Opening">
                        <telerik:RadContextMenu.Items>
                            <telerik:RadMenuItem Name="ctxAddBookmark" Click="ctxAddBookmark_Click" Header="Aggiungi ai preferiti">
                                <telerik:RadMenuItem.Icon>
                                    <Path Margin="0,0,0,2" Data="{DynamicResource StarAdd}" Fill="{DynamicResource VulpesXGreenBrush}" />
                                </telerik:RadMenuItem.Icon>
                            </telerik:RadMenuItem>
                        </telerik:RadContextMenu.Items>
                    </telerik:RadContextMenu>
                </telerik:RadContextMenu.ContextMenu>
            </StackPanel>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate x:Key="bookmarkItem" ItemsSource="{Binding SubItems}">
            <StackPanel Orientation="Horizontal">
                <Path x:Name="NullDescriptionIcon"
                      Width="14"
                      Height="14"
                      Data="{DynamicResource StarPath}"
                      Fill="{DynamicResource VulpesXYellowBrush}"
                      Stretch="UniformToFill"
                      Visibility="Collapsed" />
                <TextBlock Margin="5,0,5,0" FontSize="15" Text="{Binding Name}" />
                <telerik:RadContextMenu.ContextMenu>
                    <telerik:RadContextMenu x:Name="radContextMenu" Opening="radContextMenu_Opening">
                        <telerik:RadContextMenu.Items>
                            <telerik:RadMenuItem Name="ctxRemoveBookmark" Click="ctxRemoveBookmark_Click" Header="Rimuovi dai preferiti">
                                <telerik:RadMenuItem.Icon>
                                    <Path Margin="0,0,0,2" Data="{DynamicResource StarRemove}" Fill="{DynamicResource VulpesXRedBrush}" />
                                </telerik:RadMenuItem.Icon>
                            </telerik:RadMenuItem>
                        </telerik:RadContextMenu.Items>
                    </telerik:RadContextMenu>
                </telerik:RadContextMenu.ContextMenu>
            </StackPanel>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding Uri}" Value="{x:Null}">
                    <Setter TargetName="NullDescriptionIcon" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>

    </Window.Resources>

    <Border>
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Padding" Value="0" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="Padding" Value="{x:Static SystemParameters.WindowResizeBorderThickness}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  TITLE BAR  -->
            <Border Grid.Row="0" Background="{DynamicResource VulpesXFirstBrush}" BorderThickness="0,0,0,0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  TITLE  -->
                    <Grid Name="grdMenu"
                          Grid.Column="0"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True"
                          Cursor="Hand"
                          MouseLeftButtonDown="grdMenu_MouseLeftButtonDown">
                        <TextBlock Name="tblVulpes"
                                   Margin="15,5,0,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   FontSize="30"
                                   Foreground="{DynamicResource VulpesXSecondBrush}"
                                   Text="VULPES" />
                        <TextBlock Name="tblX"
                                   Margin="115,5,0,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   FontSize="40"
                                   FontStyle="Italic"
                                   Foreground="{DynamicResource VulpesXBrush}"
                                   RenderTransformOrigin="0.5,0.5"
                                   Text="X">
                            <TextBlock.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform />
                                    <SkewTransform />
                                    <RotateTransform />
                                    <TranslateTransform />
                                </TransformGroup>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Grid>

                    <StackPanel Grid.Column="2"
                                Margin="0,0,10,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">

                        <!--  THEME  -->
                        <Grid Margin="5,0,5,0" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>


                            <Button x:Name="btnTheme"
                                    Grid.Column="0"
                                    VerticalContentAlignment="Center"
                                    Click="btnTheme_Click"
                                    Cursor="Hand"
                                    FontSize="16"
                                    Style="{StaticResource FluentWindowButton}"
                                    ToolTip="Modificare tema"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                                <Button.Content>
                                    <telerik:RadGlyph FontSize="18" Glyph="&#xe511;" />
                                </Button.Content>
                            </Button>
                        </Grid>

                        <!--  USER  -->
                        <Grid Margin="5,0,5,0" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Padding="0,5,5,5"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       Foreground="{DynamicResource VulpesXSecondBrush}"
                                       Text="{Binding UserContext.ACCESS.USRID}"
                                       Typography.Capitals="AllSmallCaps" />

                            <Button x:Name="btnUserSetting"
                                    Grid.Column="1"
                                    VerticalContentAlignment="Center"
                                    Click="btnUserSetting_Click"
                                    Cursor="Hand"
                                    FontSize="16"
                                    Style="{StaticResource FluentWindowButton}"
                                    ToolTip="Profilo utente"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                                <Button.Content>
                                    <telerik:RadGlyph FontSize="18" Glyph="&#xe801;" />
                                </Button.Content>
                            </Button>

                        </Grid>

                        <!--  COMPANY  -->
                        <Grid Margin="5,0,100,0" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <telerik:RadComboBox x:Name="cmbCompany"
                                                 Grid.Column="0"
                                                 Height="30"
                                                 Margin="5"
                                                 Padding="5"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Center"
                                                 HorizontalContentAlignment="Center"
                                                 DisplayMemberPath="Description"
                                                 Focusable="False"
                                                 IsEditable="False"
                                                 ItemsSource="{Binding UserContext.ACCESS.EnabledCompanies}"
                                                 SelectedItem="{Binding UserContext.ACCESS.SelectedCompany, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 SelectionChanged="cmbCompany_SelectionChanged">
                                <telerik:RadComboBox.SelectionBoxTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Text="{Binding SOMDES}"
                                                   Typography.Capitals="AllSmallCaps" />
                                    </DataTemplate>
                                </telerik:RadComboBox.SelectionBoxTemplate>
                            </telerik:RadComboBox>

                            <Button x:Name="btnCompanySettings"
                                    Grid.Column="1"
                                    VerticalContentAlignment="Center"
                                    Click="btnCompanySettings_Click"
                                    Cursor="Hand"
                                    FontSize="16"
                                    Style="{StaticResource FluentWindowButton}"
                                    ToolTip="Profilo della società"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                                <Button.Content>
                                    <telerik:RadGlyph FontSize="18" Glyph="&#xe13a;" />
                                </Button.Content>
                            </Button>

                        </Grid>


                        <!--  SYSTEM BUTTONS  -->
                        <Button x:Name="btnMinimize"
                                Click="btnMinimize_Click"
                                Style="{StaticResource FluentWindowButton}"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Content>
                                <telerik:RadGlyph FontSize="16" Glyph="&#xe139;" />
                            </Button.Content>
                        </Button>

                        <Button x:Name="btnMaximize"
                                Click="btnMaximize_Click"
                                Style="{StaticResource FluentWindowButton}"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Content>
                                <telerik:RadGlyph FontSize="16" Glyph="&#xe138;" />
                            </Button.Content>
                        </Button>

                        <Button x:Name="btnLogout"
                                VerticalContentAlignment="Center"
                                Click="btnLogout_Click"
                                Style="{StaticResource FluentWindowButton}"
                                ToolTip="Disconnettere la sessione corrente"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Content>
                                <telerik:RadGlyph FontSize="16" Glyph="&#xe131;" />
                            </Button.Content>
                        </Button>

                        <Button x:Name="btnClose"
                                VerticalContentAlignment="Center"
                                Click="btnClose_Click"
                                Style="{StaticResource FluentCloseButton}"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Content>
                                <telerik:RadGlyph FontSize="16" Glyph="&#xe11b;" />
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>


                <Grid Name="grdNavigation"
                      Grid.Row="1"
                      Grid.Column="0"
                      Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="7" />
                        <RowDefinition Height="35" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="1"
                            Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                            BorderBrush="{DynamicResource VulpesXBrush}"
                            BorderThickness="0,1,1,1">
                        <telerik:RadWatermarkTextBox x:Name="wtxtMenuSearch"
                                                     Margin="3"
                                                     HorizontalAlignment="Stretch"
                                                     Background="{DynamicResource VulpesXFirstAlternativeBrush}"
                                                     BorderBrush="{DynamicResource VulpesXBrush}"
                                                     BorderThickness="0"
                                                     Foreground="{DynamicResource VulpesXBrush}"
                                                     GotFocus="wtxtMenuSearch_GotFocus"
                                                     GotMouseCapture="wtxtMenuSearch_GotMouseCapture"
                                                     Style="{StaticResource RadWatermarkTextBoxMenuSearchStyle}"
                                                     TextChanged="wtxtMenuSearch_TextChanged"
                                                     WatermarkContent="Digitare una voce per cercarla nel menu'..." />
                    </Border>

                    <telerik:RadTreeView x:Name="twBookmark"
                                         Grid.Row="2"
                                         Margin="5"
                                         BorderThickness="0"
                                         Cursor="Hand"
                                         IsExpandOnSingleClickEnabled="True"
                                         IsVirtualizing="True"
                                         ItemClick="twMenu_ItemClick"
                                         ItemTemplate="{StaticResource bookmarkItem}"
                                         ItemsIndent="10"
                                         ItemsSource="{Binding BookmarkItems}">
                        <telerik:RadTreeView.ItemContainerStyle>
                            <Style BasedOn="{StaticResource RadTreeViewItemStyle}" TargetType="telerik:RadTreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            </Style>
                        </telerik:RadTreeView.ItemContainerStyle>
                    </telerik:RadTreeView>

                    <telerik:RadTreeView x:Name="twMenu"
                                         Grid.Row="3"
                                         Margin="5"
                                         BorderThickness="0"
                                         Cursor="Hand"
                                         IsExpandOnSingleClickEnabled="True"
                                         IsVirtualizing="True"
                                         ItemClick="twMenu_ItemClick"
                                         ItemTemplate="{StaticResource menuItem}"
                                         ItemsIndent="10"
                                         ItemsSource="{Binding MenuItems}">
                        <telerik:RadTreeView.ItemContainerStyle>
                            <Style BasedOn="{StaticResource RadTreeViewItemStyle}" TargetType="telerik:RadTreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                            </Style>
                        </telerik:RadTreeView.ItemContainerStyle>
                    </telerik:RadTreeView>
                </Grid>

                <Grid x:Name="mainGrid"
                      Grid.Row="1"
                      Grid.ColumnSpan="3"
                      MouseEnter="mainGrid_MouseEnter">
                    <Image Width="200"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity=".3"
                           Source="/Images/GX.png" />

                    <telerik:RadDocking x:Name="panelsHome"
                                        Margin="0"
                                        Panel.ZIndex="9999"
                                        Background="{DynamicResource VulpesXFirstBrush}"
                                        BorderBrush="{x:Null}"
                                        BorderThickness="0"
                                        CloseButtonPosition="InPane"
                                        PreviewClose="panelsHome_PreviewClose"
                                        RetainPaneSizeMode="DockingAndFloating"
                                        ScrollViewer.CanContentScroll="True"
                                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                        Style="{StaticResource RadDockingStyle}"
                                        Visibility="Collapsed">
                        <telerik:RadDocking.DockingPanesFactory>
                            <telerik:DockingPanesFactory />
                        </telerik:RadDocking.DockingPanesFactory>
                    </telerik:RadDocking>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
