<UserControl x:Class="VulpesX.Shared.Controls.GridCustomFilters.FromNumberToNumberFilterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VulpesX.Shared.Controls.GridCustomFilters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">

    <Border x:Name="LayoutRoot"
            Padding="5"
            Background="#FFDFE2E5"
            BorderBrush="#FF8A929E"
            BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Margin="2">Da:</TextBlock>
            <TextBlock Grid.Row="0" Grid.Column="1" Margin="2">A :</TextBlock>
            <telerik:RadNumericUpDown Name="numFrom"
                                      Grid.Row="1"
                                      Grid.Column="0"
                                      Margin="2" />
            <telerik:RadNumericUpDown Name="numTo"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      Margin="2" />
            <StackPanel Grid.Row="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                <telerik:RadButton Name="filterButton"
                                   Width="80"
                                   Margin="2"
                                   Click="OnFilter"
                                   Content="Filter" />
                <telerik:RadButton Name="clearButton"
                                   Width="80"
                                   Margin="2"
                                   Click="OnClear"
                                   Content="Clear" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
