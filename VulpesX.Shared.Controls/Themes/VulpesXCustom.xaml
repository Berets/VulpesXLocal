<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:VulpesX.Shared.Controls.Converters"
                    xmlns:customwindows="clr-namespace:VulpesX.Shared.Controls.CustomWindows"
                    xmlns:dock="clr-namespace:Telerik.Windows.Controls.Docking;assembly=Telerik.Windows.Controls.Docking"
                    xmlns:grid="clr-namespace:Telerik.Windows.Controls.GridView;assembly=Telerik.Windows.Controls.GridView"
                    xmlns:mat="clr-namespace:Telerik.Windows.Controls.MaterialControls;assembly=Telerik.Windows.Controls"
                    xmlns:shell="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                    xmlns:telerikAnimation="clr-namespace:Telerik.Windows.Controls.Animation;assembly=Telerik.Windows.Controls"
                    xmlns:telerikDocking="clr-namespace:Telerik.Windows.Controls;assembly=Telerik.Windows.Controls.Docking">

    <Style x:Key="VulpesXDefaultWindow" TargetType="{x:Type customwindows:FluentDefaultWindow}">
        <Setter Property="Background" Value="{DynamicResource VulpesXFirstBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type customwindows:FluentDefaultWindow}">
                    <Border Background="{TemplateBinding Background}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="48" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  REUSABLE TITLE BAR  -->
                            <customwindows:FluentDefaultTitleBar Grid.Row="0" />

                            <!--  WINDOW CONTENT  -->
                            <ContentPresenter Grid.Row="1" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FluentWindowButton" BasedOn="{StaticResource ButtonStyle}" TargetType="Button">
        <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="48" />
        <Setter Property="Foreground" Value="{DynamicResource VulpesXSecondBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource VulpesXFluentBlueBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#55FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FluentCloseButton" BasedOn="{StaticResource FluentWindowButton}" TargetType="Button">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource VulpesXRedBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource VulpesXSecondBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="VulpesXLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource VulpesXSecondBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,5,0" />
    </Style>


    <Style x:Key="VulpesXSubtitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource VulpesXBrush}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Typography.Capitals" Value="AllSmallCaps" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="15,0,0,0" />
    </Style>

    <Style x:Key="VulpesXSubtitleInfo" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource VulpesXDataBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontStyle" Value="Italic" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="5,0,0,0" />
    </Style>

    <Style x:Key="VulpesXData" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource VulpesXDataBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="15,0,0,0" />
    </Style>

    <Style x:Key="WaitOverlayStyle" TargetType="Rectangle">
        <Setter Property="Stroke" Value="{DynamicResource VulpesXBrush}" />
        <Setter Property="Fill">
            <Setter.Value>
                <SolidColorBrush Color="{DynamicResource VulpesXFirstAlternativeColor}" />
            </Setter.Value>
        </Setter>
        <Setter Property="Opacity" Value="0.9" />
    </Style>

    <Style x:Key="VulpesXTitle" TargetType="TextBlock">
        <Setter Property="Margin" Value="5" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="Foreground" Value="{DynamicResource VulpesXBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style x:Key="VulpesXInfoData" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource VulpesXDataBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="5,0,0,0" />
    </Style>

    <Style x:Key="VulpesXButton" BasedOn="{StaticResource ButtonStyle}" TargetType="Button">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="BorderThickness" Value="5,1,1,1" />
        <Setter Property="BorderBrush" Value="{DynamicResource VulpesXBrush}" />
    </Style>

    <Style x:Key="VulpesXInsertButton" BasedOn="{StaticResource VulpesXButton}" TargetType="Button">
        <Setter Property="Width" Value="200" />
        <Setter Property="BorderBrush" Value="{DynamicResource VulpesXBlueBrush}" />
    </Style>

    <Style x:Key="VulpesXCancelButton" BasedOn="{StaticResource VulpesXButton}" TargetType="Button">
        <Setter Property="IsCancel" Value="True" />
        <Setter Property="Width" Value="200" />
        <Setter Property="BorderBrush" Value="{DynamicResource VulpesXYellowBrush}" />
    </Style>

    <Style x:Key="VulpesXConfirmButton" BasedOn="{StaticResource VulpesXButton}" TargetType="Button">
        <Setter Property="IsDefault" Value="True" />
        <Setter Property="Width" Value="200" />
        <Setter Property="BorderBrush" Value="{DynamicResource VulpesXGreenBrush}" />
    </Style>


    <Style x:Key="VulpesXGridButton" BasedOn="{StaticResource RadButtonStyle}" TargetType="{x:Type telerik:RadButton}">
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="7" />
        <Setter Property="Margin" Value="5" />
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="BorderThickness" Value="0" />
    </Style>


    <converters:LongToTimeSpanConverter x:Key="longToTimeSpanConverter" />
    <converters:BoolToColorConverter x:Key="booleanColorConverter" FalseColor="{StaticResource GXSecondBrush}" TrueColor="{StaticResource GXYellowBrush}" />

    <DataTemplate x:Key="logTooltipTemplate">
        <Grid Width="600">
            <Border Background="{DynamicResource GXFirstBrush}"
                    BorderBrush="{DynamicResource GXOrangeBrush}"
                    BorderThickness="2"
                    UseLayoutRounding="True">
                <StackPanel Orientation="Vertical">
                    <DockPanel>
                        <TextBlock Width="100" Foreground="{DynamicResource GXSecondBrush}" Text="Inserito il" />
                        <TextBlock Foreground="{DynamicResource GXSecondBrush}" Text="{Binding LogAdded}" />
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Width="100" Foreground="{DynamicResource GXSecondBrush}" Text="Da" />
                        <TextBlock Foreground="{DynamicResource GXSecondBrush}" Text="{Binding LogAddedUserID}" />
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Width="100" Foreground="{DynamicResource GXSecondBrush}" Text="Modificato il" />
                        <TextBlock Foreground="{DynamicResource GXSecondBrush}" Text="{Binding LogUpdated}" />
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Width="100" Foreground="{DynamicResource GXSecondBrush}" Text="Da" />
                        <TextBlock Foreground="{DynamicResource GXSecondBrush}" Text="{Binding LogUpdatedUserID}" />
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Width="100" Foreground="{DynamicResource GXSecondBrush}" Text="Annullato il" />
                        <TextBlock Foreground="{DynamicResource GXSecondBrush}" Text="{Binding LogCanceled}" />
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Width="100" Foreground="{DynamicResource GXSecondBrush}" Text="Da" />
                        <TextBlock Foreground="{DynamicResource GXSecondBrush}" Text="{Binding LogCanceledUserID}" />
                    </DockPanel>
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="compositionTooltipTemplate">
        <Grid Width="600">
            <Border Background="{DynamicResource VulpesXFirstBrush}"
                    BorderBrush="{DynamicResource VulpesXOrangeBrush}"
                    BorderThickness="2"
                    UseLayoutRounding="True">
                <telerik:RadTreeView AllowDrop="False"
                                     ItemTemplateSelector="{DynamicResource compositionTemplateSelectorRead}"
                                     ItemsSource="{Binding}"
                                     SelectionMode="Extended">
                    <telerik:RadTreeView.ItemContainerStyle>
                        <Style BasedOn="{StaticResource RadTreeViewItemStyle}" TargetType="{x:Type telerik:RadTreeViewItem}">
                            <Setter Property="IsExpanded" Value="True" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </telerik:RadTreeView.ItemContainerStyle>
                </telerik:RadTreeView>
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="compositionTooltipTemplateRead">
        <Grid Width="600">
            <Border Margin="20"
                    Padding="10"
                    Background="{DynamicResource VulpesXFirstBrush}"
                    BorderBrush="{DynamicResource VulpesXOrangeBrush}"
                    BorderThickness="2"
                    UseLayoutRounding="True">
                <telerik:RadTreeView AllowDrop="False"
                                     ItemTemplateSelector="{DynamicResource compositionTemplateSelectorRead}"
                                     ItemsSource="{Binding}"
                                     SelectionMode="Extended">
                    <telerik:RadTreeView.ItemContainerStyle>
                        <Style BasedOn="{StaticResource RadTreeViewItemStyle}" TargetType="{x:Type telerik:RadTreeViewItem}">
                            <Setter Property="IsExpanded" Value="True" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="2" />
                        </Style>
                    </telerik:RadTreeView.ItemContainerStyle>
                </telerik:RadTreeView>
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="dependenciesTooltipTemplate">
        <Grid Width="600">
            <Border Margin="20"
                    Background="{DynamicResource VulpesXFirstBrush}"
                    BorderBrush="{DynamicResource VulpesXOrangeBrush}"
                    BorderThickness="2"
                    UseLayoutRounding="True">
                <telerik:RadListBox AllowDrop="False" ItemsSource="{Binding}" SelectionMode="Extended">
                    <telerik:RadListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="{Binding Descrizione}" />
                                    <TextBlock FontWeight="Bold" Text="{Binding ArticoloID}" />
                                </StackPanel>

                                <StackPanel Margin="10,0,0,0" Orientation="Vertical">
                                    <TextBlock Text="Revisione" />
                                    <TextBlock FontWeight="Bold" Text="{Binding RevisioneID}" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </telerik:RadListBox.ItemTemplate>
                </telerik:RadListBox>
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="attachTooltipTemplate">
        <Grid Width="600">
            <Border Background="{DynamicResource VulpesXFirstBrush}"
                    BorderBrush="{DynamicResource VulpesXOrangeBrush}"
                    BorderThickness="2"
                    UseLayoutRounding="True">
                <telerik:RadListBox AllowDrop="False" ItemsSource="{Binding}" SelectionMode="Extended">
                    <telerik:RadListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="{Binding Uri}" />
                                <TextBlock FontWeight="Bold" Text="{Binding File}" />
                            </StackPanel>
                        </DataTemplate>
                    </telerik:RadListBox.ItemTemplate>
                </telerik:RadListBox>
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="imageTooltipTemplate">
        <Grid Width="600">
            <Border Background="{DynamicResource VulpesXFirstBrush}"
                    BorderBrush="{DynamicResource VulpesXOrangeBrush}"
                    BorderThickness="2"
                    UseLayoutRounding="True">
                <telerik:RadListBox AllowDrop="False" ItemsSource="{Binding}" SelectionMode="Extended">
                    <telerik:RadListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="{Binding Url}" />
                                <TextBlock FontWeight="Bold" Text="{Binding File}" />
                            </StackPanel>
                        </DataTemplate>
                    </telerik:RadListBox.ItemTemplate>
                </telerik:RadListBox>
            </Border>
        </Grid>
    </DataTemplate>

    <Style x:Key="TreeViewItemNavigationTemplate" TargetType="telerik:RadTreeViewItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="telerik:RadTreeViewItem">
                    <Grid x:Name="RootElement" UseLayoutRounding="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid x:Name="HeaderRow"
                              MinHeight="{TemplateBinding MinHeight}"
                              Background="Transparent"
                              SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="2"
                                    Grid.ColumnSpan="6"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2" />
                            <Border x:Name="MouseOverVisual"
                                    Grid.Column="2"
                                    Grid.ColumnSpan="6"
                                    Background="{telerik:VisualStudio2013Resource ResourceKey=MouseOverBrush}"
                                    Opacity="0" />
                            <Border x:Name="SelectionUnfocusedVisual"
                                    Grid.Column="2"
                                    Grid.ColumnSpan="6"
                                    Background="{telerik:VisualStudio2013Resource ResourceKey=BasicBrush}"
                                    Visibility="Collapsed" />
                            <Border x:Name="SelectionVisual"
                                    Grid.Column="2"
                                    Grid.ColumnSpan="6"
                                    Background="{telerik:VisualStudio2013Resource ResourceKey=AccentMainBrush}"
                                    Visibility="Collapsed" />
                            <StackPanel x:Name="IndentContainer" Orientation="Horizontal">
                                <Rectangle x:Name="IndentFirstVerticalLine"
                                           Width="1"
                                           VerticalAlignment="Top"
                                           Stroke="{telerik:VisualStudio2013Resource ResourceKey=BasicBrush}"
                                           Visibility="Collapsed" />
                            </StackPanel>
                            <Grid x:Name="ListRootContainer"
                                  Grid.Column="1"
                                  MinWidth="21"
                                  HorizontalAlignment="Center">
                                <Rectangle x:Name="HorizontalLine"
                                           Height="1"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Stroke="{telerik:VisualStudio2013Resource ResourceKey=BasicBrush}" />
                                <Rectangle x:Name="VerticalLine"
                                           Width="1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Stroke="{telerik:VisualStudio2013Resource ResourceKey=BasicBrush}" />
                                <ToggleButton x:Name="Expander" Background="{TemplateBinding Background}" IsTabStop="False" />
                                <Grid x:Name="LoadingVisual"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      RenderTransformOrigin="0.5,0.5"
                                      Visibility="Collapsed">
                                    <Grid.RenderTransform>
                                        <TransformGroup>
                                            <RotateTransform x:Name="LoadingVisualAngleTransform" Angle="0" CenterX="0.5" CenterY="0.5" />
                                        </TransformGroup>
                                    </Grid.RenderTransform>
                                    <Path Width="10"
                                          Height="10"
                                          Data="M1,0 A1,1,90,1,1,0,-1"
                                          Stretch="Fill"
                                          Stroke="{TemplateBinding Foreground}"
                                          StrokeStartLineCap="Round"
                                          StrokeThickness="1" />
                                    <Path Width="4"
                                          Height="4"
                                          Margin="5,-1.5,0,0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Top"
                                          Data="M0,-1.1 L0.1,-1 L0,-0.9"
                                          Fill="{TemplateBinding Foreground}"
                                          Stretch="Fill"
                                          StrokeThickness="1" />
                                </Grid>
                            </Grid>
                            <Image x:Name="Image"
                                   Grid.Column="3"
                                   MaxWidth="16"
                                   MaxHeight="16"
                                   Margin="2"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                            <Rectangle x:Name="FocusVisual"
                                       Grid.Column="2"
                                       Grid.ColumnSpan="6"
                                       IsHitTestVisible="False"
                                       Stroke="{telerik:VisualStudio2013Resource ResourceKey=AccentMainBrush}"
                                       StrokeThickness="1"
                                       Visibility="Collapsed" />

                            <Grid x:Name="HeaderContentPanel"
                                  Grid.Column="4"
                                  Grid.ColumnSpan="2"
                                  Background="Transparent">
                                <ContentControl x:Name="Header"
                                                Margin="{TemplateBinding Padding}"
                                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                Content="{TemplateBinding Header}"
                                                ContentStringFormat="{TemplateBinding HeaderStringFormat}"
                                                ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                ContentTemplateSelector="{TemplateBinding HeaderTemplateSelector}"
                                                Foreground="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Foreground, Mode=OneWay}"
                                                IsTabStop="False" />
                                <ContentPresenter x:Name="EditHeaderElement"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  ContentTemplate="{TemplateBinding HeaderEditTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding HeaderEditTemplateSelector}"
                                                  Visibility="Collapsed" />
                            </Grid>

                            <CheckBox x:Name="CheckBoxElement"
                                      Grid.Column="2"
                                      Margin="5,0,0,0"
                                      VerticalAlignment="Center"
                                      IsTabStop="False"
                                      Visibility="Collapsed" />
                            <RadioButton x:Name="RadioButtonElement"
                                         Grid.Column="2"
                                         Margin="5,0,0,0"
                                         VerticalAlignment="Center"
                                         IsTabStop="False"
                                         Visibility="Collapsed" />
                        </Grid>
                        <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Visibility="Collapsed" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Header"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.2"
                                                         Duration="0" />
                                        <DoubleAnimation Storyboard.TargetName="Image"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.2"
                                                         Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="ExpandStates">
                                <VisualState x:Name="Expanded">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ItemsHost" Storyboard.TargetProperty="Visibility" Duration="0">
                                            <DiscreteObjectKeyFrame KeyTime="0">
                                                <DiscreteObjectKeyFrame.Value>
                                                    <Visibility>Visible</Visibility>
                                                </DiscreteObjectKeyFrame.Value>
                                            </DiscreteObjectKeyFrame>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Collapsed" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CalloutButtonStyle" TargetType="Button">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Margin="0,0,5,0" VerticalAlignment="Stretch" Background="{TemplateBinding Background}">
                        <ContentPresenter />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate x:Key="PricesCalloutContentTemplate">
        <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=telerik:RadCallout}, Path=ActualWidth}" Height="{Binding RelativeSource={RelativeSource AncestorType=telerik:RadCallout}, Path=Height}">
            <Grid.RowDefinitions>
                <RowDefinition Height="20" />
                <RowDefinition Height="5" />
                <RowDefinition Height="20" />
                <RowDefinition Height="20" />
                <RowDefinition Height="20" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Grid.ColumnSpan="4"
                       Margin="0"
                       Padding="5,0,0,0"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"
                       Background="MediumVioletRed"
                       FontFamily="SegoeUI"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="Black"
                       Text="SUGGERIMENTI PREZZO"
                       TextAlignment="Left"
                       Typography.Capitals="AllSmallCaps" />

            <!--  prices info  -->
            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Margin="0,0,5,0"
                       VerticalAlignment="Center"
                       FontFamily="SegoeUI"
                       FontSize="12"
                       Foreground="MediumVioletRed"
                       Text="LISTINO GENERALE&gt;"
                       TextAlignment="Right"
                       Typography.Capitals="AllSmallCaps" />
            <Button Grid.Row="2"
                    Grid.Column="1"
                    Margin="0"
                    Padding="0,0,5,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding SelectLastListGeneralPrice}"
                    Content="{Binding LastListGeneralPrice.Price, StringFormat=N6}"
                    ContentStringFormat="N6"
                    Cursor="Hand"
                    FontFamily="SegoeUI"
                    FontSize="12"
                    Foreground="{DynamicResource VulpesXDataBrush}"
                    Style="{StaticResource CalloutButtonStyle}"
                    TextBlock.TextAlignment="Right"
                    ToolTip="{Binding LastListGeneralPrice.Note}"
                    Typography.Capitals="AllSmallCaps" />

            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Margin="0,0,5,0"
                       VerticalAlignment="Center"
                       FontFamily="SegoeUI"
                       FontSize="12"
                       Foreground="MediumVioletRed"
                       Text="LISTINO CLIENTE&gt;"
                       TextAlignment="Right"
                       Typography.Capitals="AllSmallCaps" />
            <Button Grid.Row="3"
                    Grid.Column="1"
                    Margin="0"
                    Padding="0,0,5,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding SelectLastListEntityPrice}"
                    Content="{Binding LastListEntityPrice.Price, StringFormat=N6}"
                    ContentStringFormat="N6"
                    Cursor="Hand"
                    FontFamily="SegoeUI"
                    FontSize="12"
                    Foreground="{DynamicResource VulpesXDataBrush}"
                    Style="{StaticResource CalloutButtonStyle}"
                    TextBlock.TextAlignment="Right"
                    ToolTip="{Binding LastListGeneralPrice.Note}"
                    Typography.Capitals="AllSmallCaps" />

            <TextBlock Grid.Row="4"
                       Grid.Column="0"
                       Margin="0,0,5,0"
                       VerticalAlignment="Center"
                       FontFamily="SegoeUI"
                       FontSize="12"
                       Foreground="MediumVioletRed"
                       Text="ULTIMO PREZZO GENERALE&gt;"
                       TextAlignment="Right"
                       Typography.Capitals="AllSmallCaps" />
            <Button Grid.Row="4"
                    Grid.Column="1"
                    Margin="0"
                    Padding="0,0,5,0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding SelectLastOrderPrice}"
                    Content="{Binding LastOrderPrice.Price, StringFormat=N6}"
                    ContentStringFormat="N6"
                    Cursor="Hand"
                    FontFamily="SegoeUI"
                    FontSize="12"
                    Foreground="{DynamicResource VulpesXDataBrush}"
                    Style="{StaticResource CalloutButtonStyle}"
                    TextBlock.TextAlignment="Right"
                    ToolTip="{Binding LastOrderPrice.Note}"
                    Typography.Capitals="AllSmallCaps" />

            <TextBlock Grid.Row="5"
                       Grid.Column="0"
                       Margin="0,0,5,0"
                       VerticalAlignment="Center"
                       FontFamily="SegoeUI"
                       FontSize="12"
                       Foreground="MediumVioletRed"
                       Text="ULTIMO PREZZO CLIENTE&gt;"
                       TextAlignment="Right"
                       Typography.Capitals="AllSmallCaps" />
            <Button Grid.Row="5"
                    Grid.Column="1"
